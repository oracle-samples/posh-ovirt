		foreach($PropertyName in $this.psobject.Properties.Name){
			#IF(($Props.Name -NotContains $PropertyName) -AND ($this.oVirtProperties -Contains $PropertyName)){$this.$PropertyName = $Null}
			IF(($Props.Name -NotContains $PropertyName) -AND ([oVM]::oVirtProperties -Contains $PropertyName)){$this.$PropertyName = $Null}
		}
		$this.GetRelated()
	}
