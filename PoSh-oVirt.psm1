		#$VMType rules
		IF($PSBoundParameters['VMType'] -eq "high_performance"){
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_type/values/high_performance
				#The following configuration changes are set automatically:
					#Enable headless mode.
					#Enable serial console.
					#Enable pass-through host CPU.
					#Enable I/O threads.
					#Enable I/O threads pinning and set the pinning topology.
					#Enable the paravirtualized random number generator PCI (virtio-rng) device.
					#Disable all USB devices.
					#Disable the soundcard device.
					#Disable the smartcard device.
					#Disable the memory balloon device.
					#Disable the watchdog device.
					#Disable migration.
					#Disable high availability.
			$PSBoundParameters['HeadlessMode'] = $True #Enable headless mode.						#$oVM1.display empty ()
			$PSBoundParameters['VirtIOSerialConsoleEnabled'] = $True #Enable serial console.		#$oVM.console.enabled
			$PSBoundParameters['PassThroughHostCPU'] = $True #Enable pass-through host CPU.			#This option can only be enabled when VM live migration is disabled. $oVM.cpu.mode = "host_passthrough"
			$PSBoundParameters['IOThreadsEnabled'] = $True #Enable I/O threads.
			$PSBoundParameters['NumberIOThreads'] = [INT16]1 #Enable I/O threads pinning and set the pinning topology.
			$PSBoundParameters['RandomGeneratorEnabled'] = $True #Enable the paravirtualized random number generator PCI (virtio-rng) device.
			#$PSBoundParameters['xxxxx'] = $True #Migrate only to hosts with the same TSC frequency.
			$PSBoundParameters['UsbEnabled'] = $False #Disable all USB devices.
			$PSBoundParameters['SoundCardEnabled'] = $False #Disable the soundcard device.
			$PSBoundParameters['SmartCardEnabled'] = $False #Disable the smartcard device.
			$PSBoundParameters['MemoryBallooning'] = $False #Disable the memory balloon device.
			$PSBoundParameters['WatchDogModel'] = 'no_watchdog' #Disable the watchdog device.
			#$PSBoundParameters['MigrationMode'] = 'pinned' #Disable migration.
			$PSBoundParameters['MigrationMode'] = 'user_migratable}' #Allow manual migration only.
			$PSBoundParameters['HAEnabled'] = $False #Disable high availability.
			#$PSBoundParameters['hugepages'] = [INT16]1
			#https://www.ovirt.org/develop/release-management/features/virt/high-performance-vm.html (oVirt 4.2)
				#Enable host_passthrough, set cpu_pinning, disable soundcard, disable migration, disable balloon, enable serial console, enable huge pages, enable high availability, set io threads number to 1.
				#configuration changed by the Instance Type may override the VM High Performance configuration
				#List of automatic configuration settings for High Performance VM
					#Enable Headless Mode and enable Serial console
					#Disable all USB devices
					#Disable the Sound Card device
					#Disable the Smart Card device
					#Enable Pass-Through Host CPU
					#Disable VM migration		The VM cannot be migrated, either automatically or manually for oVirt 4.2. Support migration is planned for oVirt 4.3
					#Enable IO Threads, Num Of IO Threads = 1
					#Disable the Memory Balloon Device
					#Enable High availability only for pinned hosts		Currently (oVirt 4.2) High availability is not supported when migration is disabled. High Performance VMs will be treated differently and will support High availability, but only for the VM’s pinned host(s). The High availability support will be expanded to all cluster hosts as part of the solution for supporting migration in oVirt 4.3.
					#Disable the Watchdog device
					#Enable paravirtualized Random Number Generator PCI (virtio-rng) device
					#Enable Multi Queues per Virtual Interface
			$PSBoundParameters['VirtIOSCSIMultiQueues'] = 'automatic' #Enable Multi Queues per Virtual Interface (Multi Queues Enabled).
		}ElseIF($PSBoundParameters['VMType'] -eq "desktop"){
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_type/values/desktop
			#The virtual machine is intended to be used as a desktop.
			#Currently, its implication is that a sound device will automatically be added to the virtual machine.
			$PSBoundParameters['SoundCardEnabled'] = $True #Enable the soundcard device.
			IF(!$PSBoundParameters.ContainsKey('HeadlessMode')){$PSBoundParameters['HeadlessMode'] = $False}
			IF(!$PSBoundParameters.ContainsKey('VideoType')){$PSBoundParameters['VideoType'] = "vga"}
			IF(!$PSBoundParameters.ContainsKey('GraphicsProtocol')){$PSBoundParameters['GraphicsProtocol'] = "vnc"}
			IF(!$PSBoundParameters.ContainsKey('VNCKeyboardLayout')){$PSBoundParameters['VNCKeyboardLayout'] = "en-us"}
			IF(!$PSBoundParameters.ContainsKey('ConsoleDisconnectAction')){$PSBoundParameters['ConsoleDisconnectAction'] = "LOCK_SCREEN"}
			IF(!$PSBoundParameters.ContainsKey('DisconnectActionDelayinMinutes')){$PSBoundParameters['DisconnectActionDelayinMinutes'] = [INT32]0}
			IF(!$PSBoundParameters.ContainsKey('Monitors')){$PSBoundParameters['Monitors'] = [INT32]1}
			IF(!$PSBoundParameters.ContainsKey('SmartCardEnabled')){$PSBoundParameters['SmartCardEnabled'] = $False}
			IF(!$PSBoundParameters.ContainsKey('DisplayAllowOverRide')){$PSBoundParameters['DisplayAllowOverRide'] = $False}
			IF(!$PSBoundParameters.ContainsKey('DisplayCopyPasteEnabled')){$PSBoundParameters['DisplayCopyPasteEnabled'] = $True}
			IF(!$PSBoundParameters.ContainsKey('DisplayFileTransferEnabled')){$PSBoundParameters['DisplayFileTransferEnabled'] = $True}
		}ElseIF($PSBoundParameters['VMType'] -eq "server"){
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_type/values/server
			#The virtual machine is intended to be used as a server.
			#Currently, its implication is that a sound device will not automatically be added to the virtual machine.
			$PSBoundParameters['SoundCardEnabled'] = $False #Disable the soundcard device.
			IF(!$PSBoundParameters.ContainsKey('HeadlessMode')){$PSBoundParameters['HeadlessMode'] = $False}
			IF(!$PSBoundParameters.ContainsKey('VideoType')){$PSBoundParameters['VideoType'] = "vga"}
			IF(!$PSBoundParameters.ContainsKey('GraphicsProtocol')){$PSBoundParameters['GraphicsProtocol'] = "vnc"}
			IF(!$PSBoundParameters.ContainsKey('VNCKeyboardLayout')){$PSBoundParameters['VNCKeyboardLayout'] = "en-us"}
			IF(!$PSBoundParameters.ContainsKey('ConsoleDisconnectAction')){$PSBoundParameters['ConsoleDisconnectAction'] = "LOCK_SCREEN"}
			IF(!$PSBoundParameters.ContainsKey('DisconnectActionDelayinMinutes')){$PSBoundParameters['DisconnectActionDelayinMinutes'] = [INT32]0}
			IF(!$PSBoundParameters.ContainsKey('Monitors')){$PSBoundParameters['Monitors'] = [INT32]1}
			IF(!$PSBoundParameters.ContainsKey('SmartCardEnabled')){$PSBoundParameters['SmartCardEnabled'] = $False}
			IF(!$PSBoundParameters.ContainsKey('DisplayAllowOverRide')){$PSBoundParameters['DisplayAllowOverRide'] = $False}
			IF(!$PSBoundParameters.ContainsKey('DisplayCopyPasteEnabled')){$PSBoundParameters['DisplayCopyPasteEnabled'] = $True}
			IF(!$PSBoundParameters.ContainsKey('DisplayFileTransferEnabled')){$PSBoundParameters['DisplayFileTransferEnabled'] = $True}
		}
		
		IF($PSBoundParameters.ContainsKey('hugepages') -OR $PSBoundParameters.ContainsKey('sndbuf') -OR $PSBoundParameters.ContainsKey('vhost') -OR $PSBoundParameters.ContainsKey('sap_agent') -OR $PSBoundParameters.ContainsKey('nvram_template') -OR $PSBoundParameters.ContainsKey('viodiskcache') -OR $PSBoundParameters.ContainsKey('extra_cpu_flags') -OR $PSBoundParameters.ContainsKey('qemu_cmdline') -OR $PSBoundParameters.ContainsKey('scsi_hostdev')){
			$VMSpecsCustomProperties = [PSCustomObject]@{}
			$VMSpecsCustomPropertyArray = @()
			IF($PSBoundParameters.ContainsKey('hugepages')){
				IF($PSBoundParameters['hugepages'] -lt 1){
					$VMSpecsCustomPropertyArray += @{"name"="hugepages"; "value"=$null}
				}Else{
					$VMSpecsCustomPropertyArray += @{"name"="hugepages"; "value"=$PSBoundParameters['hugepages']}
				}
			}
			IF($PSBoundParameters.ContainsKey('sndbuf')){$VMSpecsCustomPropertyArray += @{"name"="sndbuf"; "value"=$PSBoundParameters['sndbuf']}}
			IF($PSBoundParameters.ContainsKey('vhost')){$VMSpecsCustomPropertyArray += @{"name"="vhost"; "value"=$PSBoundParameters['vhost']}}
			IF($PSBoundParameters.ContainsKey('sap_agent')){$VMSpecsCustomPropertyArray += @{"name"="sap_agent"; "value"=$PSBoundParameters['sap_agent']}}
			IF($PSBoundParameters.ContainsKey('nvram_template')){$VMSpecsCustomPropertyArray += @{"name"="nvram_template"; "value"=$PSBoundParameters['nvram_template']}}
			IF($PSBoundParameters.ContainsKey('viodiskcache')){$VMSpecsCustomPropertyArray += @{"name"="viodiskcache"; "value"=$PSBoundParameters['viodiskcache']}}
			IF($PSBoundParameters.ContainsKey('extra_cpu_flags')){$VMSpecsCustomPropertyArray += @{"name"="extra_cpu_flags"; "value"=$PSBoundParameters['extra_cpu_flags']}}
			IF($PSBoundParameters.ContainsKey('qemu_cmdline')){$VMSpecsCustomPropertyArray += @{"name"="qemu_cmdline"; "value"=$PSBoundParameters['qemu_cmdline']}}
			IF($PSBoundParameters.ContainsKey('scsi_hostdev')){$VMSpecsCustomPropertyArray += @{"name"="scsi_hostdev"; "value"=$PSBoundParameters['scsi_hostdev']}}
			Add-Member -NotePropertyName "custom_property" -NotePropertyValue $VMSpecsCustomPropertyArray -inputObject $VMSpecsCustomProperties
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oTemplateOBjects Names: $($oTemplateOBjects.Name)"
		ForEach($TargetoTemplate in $oTemplateOBjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoTemplate [$($TargetoTemplate.Name)]"
			$oVirtServerName = $TargetoTemplate.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$UpdatedTemplate = $Null
			IF($TargetoTemplate.status -eq "ok"){
				#region SetoTemplateContainer
				$TemplateSpecs = $Null; $TemplateSpecsInstanceType = $Null; $TemplateSpecsLeaseStorageDomainId = $Null; $TemplateSpecsLeaseStorageDomain = $Null; $TemplateSpecsVirtioScsi = $Null; 
				$TemplateSpecsRandomGeneratorDevice = $Null; 
				$TemplateSpecsRandomGeneratorDeviceRate = $Null; $TemplateSpecsIO = $Null; $TemplateSpecsDisplay = $Null; $TemplateSpecsTimeZone = $Null; $TemplateSpecsUsb = $Null; $TemplateSpecsMigration = $Null; 
				$TemplateSpecsMemoryPolicy = $Null; $TemplateSpecsHA = $Null; $TemplateSpecsCpuProfile = $Null; $TemplateSpecsBiosBoot_menu = $Null; $TemplateSpecsBios = $Null; $TemplateSpecsOSBootDevices = $Null; 
				$TemplateSpecsOSBoot = $Null; $TemplateSpecsOS = $Null;	$TemplateSpecsPlacementPolicy = $Null; $HostsArray = $Null
				IF($oHost){
					$HostArray = [System.Collections.ArrayList]@()
					ForEach($Item in ($PSBoundParameters['oHost']|Sort)){
