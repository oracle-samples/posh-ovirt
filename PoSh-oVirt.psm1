				#$oClusterObjects = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oClusterObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oCluster" -oVirtServerName $oVirtServerName})
