			[oHostLabel]
			[oVM]
			[oVMLabel]
			[INT32]
			[BOOLEAN]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oAffinityGroup]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		11/19/2024
		.LINK
