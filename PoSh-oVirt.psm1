Function Set-oClusterNetwork{
	<#
		.SYNOPSIS
			This function assigns the provided oNetwork to the provided oCluster, on an oVirt Server system.
		.DESCRIPTION
			This function assigns the provided oNetwork to the provided oCluster, on an oVirt Server system.
		.PARAMETER oCluster
			The Name(s) or oCluster Object of oCluster(s)
			Can use Wildcard '*'
		.PARAMETER oClusterId
			The Id(s) of oCluster(s)
		.PARAMETER oClusterUid
			The Uid(s) of oCluster(s)
		.PARAMETER oNetwork
			The Name(s) of oNetwork(s)
			Can use Wildcard '*'
		.PARAMETER oNetworkId
			The Id(s) of oNetwork(s)
		.PARAMETER oNetworkUid
			The Uid(s) of oNetwork(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oClusterNetwork -oVirtServerName $oVirtServerName -oCluster "ClusterName" -oNetwork "NetworkName"
				Assigns the oNetwork to the oCluster(s)
		.EXAMPLE
			PS> Set-oClusterNetwork -oVirtServerName $oVirtServerName -oCluster "ClusterName" -oNetworkUid $oNetwork.Uid
				Assigns the oNetwork to the oCluster(s)
		.INPUTS
			[System.String]
			[oCluster]
			[oNetwork]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetwork]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		10/14/2024
			Version 1.1		3/10/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster_network
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster_networks/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster
			New-oNetwork
			Set-oNetwork
			Remove-oClusterNetwork
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oCluster'})]$oCluster,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oClusterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oClusterUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oNetwork|String'})]$oNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkUid,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($PSBoundParameters['oVirtServerName']){
			$BaseURL = "https://$($PSBoundParameters['oVirtServerName'])"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): PSBoundParameters: [$($PSBoundParameters | Out-String)]"
		Write-Verbose "$($MyInvocation.MyCommand): Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#Write-Verbose "$($MyInvocation.MyCommand): Is [oCluster]: [$($PSBoundParameters['oCluster'] -IS [oCluster])]"
		Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oCluster'] Type: [$(($PSBoundParameters['oCluster']).GetType().Name)]"
		$oClusterObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH(($PSBoundParameters['oCluster'])){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -EA SilentlyContinue
					}
					IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oCluster]) -OR ($_.GetType().Name -eq "oCluster")}{
					Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oCluster'] is [oCluster]"
					$oClusterObjects = $PSBoundParameters['oCluster']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oClusterId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['oClusterId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['oClusterId'] -EA SilentlyContinue
				}
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oClusterUId']){
				$UidUrl = [Uri]$oClusterUid
				$oClusterObjects = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObjects Names: $($oClusterObjects.Name)"
		
		$oNetworkObjects = $Null
		IF($PSBoundParameters['oNetworkUid']){
			$UidUrl = [Uri]$oNetworkUid
			$oNetworkObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oNetwork" -oVirtServerName $oVirtServerName}
		}ElseIF($PSBoundParameters['oNetworkId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}Else{
				$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}
		}ElseIF($PSBoundParameters['oNetwork']){
			SWITCH($PSBoundParameters['oNetwork']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}Else{
						$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}
				}
				{($_ -IS [oNetwork]) -OR ($_.GetType().Name -eq "oNetwork")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is [oNetwork]"
					$oNetworkObjects = $PSBoundParameters['oNetwork']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		IF($oNetworkObjects){
			$oClusterNetworkSpec = [PSCustomObject]@{}
			ForEach($oNetworkObject in $oNetworkObjects){
				#<network id="123" />
				#$oClusterNetworkSpec | Add-Member -MemberType NoteProperty -Name 'network' -Value $([PSCustomObject]@{'id'=$oNetworkObject.Id})
				$oClusterNetworkSpec | Add-Member -MemberType NoteProperty -Name 'id' -Value $oNetworkObject.Id
			}
		}Else{
			Write-Warning "No oNetwork Objects found matching provided criteria, quitting..."; BREAK
		}
		
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oClusterObject in $oClusterObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObject [$($oClusterObject | Out-String)]"
			$oVirtServerName = $oClusterObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#POST /ovirt-engine/api/clusters/123/networks
			$Uri = $BaseURL + "/ovirt-engine/api/clusters/$($oClusterObject.ID)/networks"
			$Method = "POST"
			$JsonBody = $oClusterNetworkSpec | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oClusterNetworkSpec | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oNetwork to oCluster"
			Write-Verbose "$($JsonBody | Out-String)"
			Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
			$UpdatedoNetwork = $Null
			TRY{$UpdatedoNetwork = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoNetwork){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoNetwork -ObjectType "oNetwork" -oVirtServerName $oVirtServerName)) | Out-Null}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oFenceAgent{
	<#
		.SYNOPSIS
			This function creates a new oFenceAgent, on an oHost, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oFenceAgent, on an oHost, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oFenceAgent
			Can use Wildcard '*'
		.PARAMETER oHost
			The Name of the parent oHost for the new oFenceAgent(s)
		.PARAMETER oHostId
			The Id of the parent oHost for the new oFenceAgent(s)
		.PARAMETER oHostUid
			The Uid of the parent oHost for the new oFenceAgent(s)
		.PARAMETER Address
			The FQDN or IP Address of the oFenceAgent
		.PARAMETER Comment
			The Text for the Comment field to set on the oFenceAgent
		.PARAMETER Concurrent
			Boolean
			Allows the oFenceAgent priority to be grouped
		.PARAMETER Description
			The Text for the Description field to set on the oFenceAgent
		.PARAMETER EncryptOptions
			Secure Checkbox
			Boolean
		.PARAMETER Options
			Hashtable(s) of options
		.PARAMETER Order
			The Priority Number of the oFenceAgent
		.PARAMETER Password
			The Password of the oFenceAgent
		.PARAMETER Port
			The Port Number of the oFenceAgent
		.PARAMETER Type
			The Type of the oFenceAgent
				Valid options "apc","apc_snmp","bladecenter","cisco_ucs", "drac5", "drac7", "eps", "hpblade", "ilo", "ilo2", "ilo3", "ilo4", "ilo_ssh", "ipmilan", "redfish", "rsa", "rsb", "wti"
		.PARAMETER UserName
			The UserName of the oFenceAgent
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oFenceAgent -oVirtServerName $oVirtServerName -oHost "oHostName" -Type 'ilo4' -UserName "UserName" -Password "Password" -Options @{"lanplus"="1"}
				Creates a new oFenceAgent with the provided Type on the specified oHost
		.EXAMPLE
			PS> Get-oHost "oHostName" | New-oFenceAgent -oVirtServerName $oVirtServerName -Type 'ilo4' -UserName "UserName" -Password "Password" -Options @{"lanplus"="1"}
				Creates a new oFenceAgent with the provided Type on the specified oHost
		.INPUTS
			[System.String]
			[oHost]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oFenceAgent]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/10/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/fence_agent
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/fence_agents/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/agent
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Address,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$Concurrent,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$EncryptOptions,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Collections.Hashtable]$Options,
			#[System.String]$Options,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Int32]$Order,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Password,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Int32]$Port,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$ServiceProfile,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Slot,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("apc","apc_snmp","bladecenter","cisco_ucs", "drac5", "drac7", "eps", "hpblade", "ilo", "ilo2", "ilo3", "ilo4", "ilo_ssh", "ipmilan", "redfish", "rsa", "rsb", "wti")]
			[System.String]$Type,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$UserName,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oHost'] Type: [$(($PSBoundParameters['oHost']).GetType().Name)]"
		$oHostObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oHost']){
				SWITCH($PSBoundParameters['oHost']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
						}
						IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
						}
						IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oHost]}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is [oHost]"
						$oHostObjects = $PSBoundParameters['oHost']
					}
					{$_.GetType().Name -eq "oHost"}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals [oHost]"
						$oHostObjects = $PSBoundParameters['oHost']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oHostId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oHostObjects = Get-oHost -Id $PSBoundParameters['oHostId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oHostObjects = Get-oHost -Id $PSBoundParameters['oHostId'] -EA SilentlyContinue
				}
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oHostUid']){
				$UidUrl = [Uri]$oHostUid
				$oHostObjects = Get-oHost -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$oHostObjects Names: $($oHostObjects.Name)"
		
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oHostObject in $oHostObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostObject [$($oHostObject | Out-String)]"
			$oVirtServerName = $oHostObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostObject Status [$($oHostObject.Status)]"
			$oFenceAgentSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Address')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $PSBoundParameters['Address'] }
			#IF($PSBoundParameters.ContainsKey('Comment')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'Comment' -Value $PSBoundParameters['Comment'] }
			#IF($PSBoundParameters.ContainsKey('Description')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $PSBoundParameters['Description'] }
			IF($PSBoundParameters.ContainsKey('UserName')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'username' -Value $PSBoundParameters['UserName'] }
			IF($PSBoundParameters.ContainsKey('Password')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'password' -Value $PSBoundParameters['Password'] }
			IF($PSBoundParameters.ContainsKey('Type')){ $oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $PSBoundParameters['Type'] }
			IF(($PSBoundParameters.ContainsKey('Options')) -OR ($PSBoundParameters.ContainsKey('Port')) -OR ($PSBoundParameters.ContainsKey('Slot'))){ 
				$oFenceAgentOptionSpecs = [PSCustomObject]@{}
				$OptionsArray = [System.Collections.ArrayList]@()
				IF($PSBoundParameters.ContainsKey('Options')){
					ForEach($Key in (($PSBoundParameters['Options']).Keys)){$OptionsArray.Add(([PSCustomObject]@{name=$Key;value=$PSBoundParameters['Options'][$Key]}))| Out-Null}
					$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'option' -Value $OptionsArray	
				}
				#"apc","apc_snmp","bladecenter","cisco_ucs", "drac5", "drac7", "eps", "hpblade", "ilo", "ilo2", "ilo3", "ilo4", "ilo_ssh", "ipmilan", "redfish", "rsa", "rsb", "wti"
				IF(@("drac5", "eps") -Contains $PSBoundParameters['Type']){
					#Not Documented or tested
					IF($PSBoundParameters.ContainsKey('Slot')){$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'slot' -Value $PSBoundParameters['Slot']}
				}
				IF(@("apc","apc_snmp","bladecenter","cisco_ucs", "drac5", "ilo", "ilo2", "redfish", "rsa", "wti") -Contains $PSBoundParameters['Type']){
					IF($PSBoundParameters.ContainsKey('EncryptOptions')){$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'secure' -Value $PSBoundParameters['EncryptOptions']}
				}
				IF(@("apc", "bladecenter", "wti") -Contains $PSBoundParameters['Type']){
					IF($PSBoundParameters.ContainsKey('Port')){$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'port' -Value $PSBoundParameters['Port']}
					IF($PSBoundParameters.ContainsKey('Slot')){$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'slot' -Value $PSBoundParameters['Slot']}
				}
				IF(@("cisco_ucs") -Contains $PSBoundParameters['Type']){
					#Not Documented or tested
					IF($PSBoundParameters.ContainsKey('ServiceProfile')){$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'slot' -Value $PSBoundParameters['ServiceProfile']}
				}
				IF(@("apc_snmp", "hpblade", "ilo", "ilo2", "ilo_ssh", "ipmilan", "redfish", "rsa") -Contains $PSBoundParameters['Type']){
					IF($PSBoundParameters.ContainsKey('Port')){	$oFenceAgentOptionSpecs | Add-Member -MemberType NoteProperty -Name 'port' -Value $PSBoundParameters['Port']}
				}
				
				Write-Verbose "$($MyInvocation.MyCommand): 5 `$Value [$(($oFenceAgentOptionSpecs) | Out-String)]"
				$oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $oFenceAgentOptionSpecs
			}
			$ExistingFenceAgents = $Null
			$ExistingFenceAgents = (Get-oUri -Uri "$($oHostObject.Uid)/fenceagents").agent
			IF($PSBoundParameters.ContainsKey('Order')){
				IF(($ExistingFenceAgents.order -Contains $PSBoundParameters['Order']) -AND ($PSBoundParameters['Concurrent'] -eq $True)){
					$oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'order' -Value $PSBoundParameters['Order']
				}ElseIF($ExistingFenceAgents.order -Contains $PSBoundParameters['Order']){
					#Change Roder Number to next available
					$Counter = 0
					Do{$Counter +=1}Until($ExistingFenceAgents.order -NotContains $Counter)
					$oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'order' -Value $Counter
				}Else{
					$oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'order' -Value @($PSBoundParameters['Order'])
				}
			}Else{
				$Counter = 0
				Do{$Counter +=1}Until($ExistingFenceAgents.order -NotContains $Counter)
				$oFenceAgentSpecs | Add-Member -MemberType NoteProperty -Name 'order' -Value $Counter
			}
			
			#Send to Server
			$JsonBody = $oFenceAgentSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oFenceAgentSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "$(($oHostObject.link | ?{$_.rel -eq 'fenceagents'}).href)"
			$Method = "POST"
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oFenceAgent"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoFenceAgent = $Null
			#TRY{$NewoFenceAgent = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
			TRY{$NewoFenceAgent = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoFenceAgent){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoFenceAgent -ObjectType "oFenceAgent" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oHostBond{
	<#
		.SYNOPSIS
			This function creates a new oHostBond across physical oHostNic(s), on an oHost , on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oHostBond across physical oHostNic(s), on an oHost , on an oVirt Server system.
			Returns the  oHostNic representing the bond
			An oHostBond is a logical bond between two (or more) physical Nics (oHostNic)
			
			Note: Objects oHost, oHostNic, oNetwork, oNetworkLabel must reside in the same Datacenter in oVirt or you might See
				(500) Internal Server Error.; StatusCode=500
				[General command validation failure.]
				[Logical Network (id 'c763d486-831f-4115-b5db-34dde4c6437c') doesn't exist.]
				
		.PARAMETER Name
			The Name(s) of the new oHostBond
		.PARAMETER oHostNic
			The Name(s) of the oHostNic(s) to set as slaves(s) for the new oHostBond(s)
		.PARAMETER oHostNicId
			The Id of the oHostNic(s) to set as slaves(s) for the new oHostBond(s)
		.PARAMETER oHostNicUid
			The Uid of the oHostNic(s) to set as slave(s) for the new oHostBond(s)
		.PARAMETER oHost
			The Name of the parent oHost for the new oHostBond
		.PARAMETER oHostId
			The Id of the parent oHost for the new oHostBond
		.PARAMETER oHostUid
			The Uid of the parent oHost for the new oHostBond
		.PARAMETER BondingMode
			Sets the Bonding Mode from defined sets, or enables Custom Bonding paramaters
			Valid options (IntelliSense Tabbing) "(Mode 0) Round-robin","(Mode 1) Active-Backup","(Mode 2) Load balance (balance-xor)","(Mode 3) Broadcast","(Mode 4) Dynamic link aggregation (802.3ad)","(Mode 5) Adaptive transmit load balancing (balance-tlb)","(Mode 6) Adaptive load balancing (balance-alb)","Custom"
		.PARAMETER CustomMode
			If BondingMode set to "Custom" enabled to accept an array of hashtable (name/value pairs) based on custom settings
				I.e. @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"}
		.PARAMETER oNetwork
			The Name of the oNetwork (vLAN) for the new oHostBond oNetworkAttachment
		.PARAMETER oNetworkId
			The Id of the oNetwork (vLAN) for the new oHostBond oNetworkAttachment
		.PARAMETER oNetworkUid
			The Uid of the oNetwork (vLAN) for the new oHostBond oNetworkAttachment
		.PARAMETER AssignmentMethod
			Valid options "autoconf", "dhcp", "none", "poly_dhcp_autoconf", "static"
		.PARAMETER IPAddress
			The IP Address to assign the oNetworkAttachment
		.PARAMETER Netmask
			The Subnet mask of the IPAddress in Octet format
			Intellisense available
			Valid options "255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248","255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128","255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0","255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0","255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0","255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0","255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0","240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0"
		.PARAMETER Gateway
			The IP Address of the gateway for the oNetworkAttachment
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER IPVersion version
			Valid options "v4","v6"
			Only "v4" is valid in this version of function
		.PARAMETER ip_address_assignments	
			Potential future feature accepting an array of hashtables to allocate to the IP settings of the oNetworkAttachment
				See https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
		.PARAMETER DNSServers
			This accepts an array of IPAddresses and/or FQDNs of Domain Name Servers (DNS)
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER Properties
			This accepts an array of hashtable (name/value pairs) based on custom settings found in 
				https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
		.PARAMETER oNetworkLabel
			The Name (Or oNetworkLabel object) of the oNetworkLabel for the new oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER oNetworkLabelId
			The Id of the oNetworkLabel for the new oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER oNetworkLabelUid
			The Uid of the oNetworkLabel for the new oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER ConnectivityTimeout
			A 32 bit integer from 0 - 2147483647
		.PARAMETER CheckConnectivity
		.PARAMETER CommitOnSuccess
			Specifies whether to automatically save the configuration in the oVirt Node upon completing the setup and re-establishing connectivity between the oVirt Node and oVirt Engine, and without waiting for a separate commitnetconfig request.
			To make sure that the network configuration has been saved in the host, and that it will be applied when the host is rebooted
			The default value is false, which means that the configuration will not be saved automatically.
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oHostBond -oVirtServerName $oVirtServerName -Name "Name" -oHost "oHostName" -oHostNic 'ens1f0np0', 'ens1f1np1' -BondingMode "custom" -CustomMode  @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"} -CommitOnSuccess -oNetwork "VLAN NAME"
				Creates a new oHostBond with the provided Name
		.EXAMPLE
			PS> New-oHostBond -oVirtServerName $oVirtServerName -Name "Name" -oHost "oHostName" -oHostNic 'ens1f0np0', 'ens1f1np1' -BondingMode "custom" -CustomMode  @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"} -CommitOnSuccess -oNetwork "VLAN NAME"
				Creates a new oHostBond with the provided Name
		.EXAMPLE
			PS> $oHostBond = New-oHostBond -oVirtServerName $oVirtServerName -Name "bond1" -oHostUid $oHost.Uid -oHostNicUid $bond1set3.Uid -BondingMode '(Mode 4) Dynamic link aggregation (802.3ad)' -CommitOnSuccess
		.EXAMPLE
			PS> $oHostBond = New-oHostBond -oVirtServerName $oVirtServerName -Name "bond1" -oHostUid $oHost.Uid -oHostNicUid $bond1set3.Uid -BondingMode "custom" -CustomMode @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"} -CommitOnSuccess

		.INPUTS
			[System.String]
			[oHost]
			[oHostNic]
			[oNetwork]
			[oNetworkLabel]
			[oNetworkAttachment]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oHostNic]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/6/2024
			Version 2.0		5/9/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://www.ovirt.org/develop/api/networkingapi.html
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_nic
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host_nic
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host_nics
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/bonding
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/setup_networks
		.LINK
			Get-oHostNic
			Set-oHostBond
			Remove-oHostBond
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({$_ | %{($_).GetType().Name -match 'oHostNic|String'}})]$oHostNic,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oHostNicId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}})]
			[System.String[]]$oHostNicUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oHostUid,
		
