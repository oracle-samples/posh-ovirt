				$oDiskAttachmentObjects = Get-oDiskAttachment -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskAttachmentObjects){$oDiskAttachmentObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		ForEach($TargetoDiskAttachment in $oDiskAttachmentObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoDiskAttachment [$($TargetoDiskAttachment.Name)]"
			$oVirtServerName = $TargetoDiskAttachment.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			IF($PSBoundParameters.ContainsKey('DeleteDisk')){$DeleteMessage = "Delete oDiskAttachment AND Delete oDisk from oStorageDomain"}Else{$DeleteMessage = "Delete oDiskAttachment, Leave oDisk on oStorageDomain"}
			IF($PSCmdlet.ShouldProcess($TargetoDiskAttachment.Name , $DeleteMessage)) {
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections |?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#DELETE /ovirt-engine/api/vms/123/diskattachments/456?detach_only=true
				#Indicates if the disk should only be detached from the virtual machine, but not removed from the system. 
				#The default value is true, which won’t remove the disk from the system.
				IF($PSBoundParameters.ContainsKey('DeleteDisk')){
					$oUri = $BaseURL + $TargetoDiskAttachment.href + "?detach_only=false"
				}Else{
					$oUri = $BaseURL + $TargetoDiskAttachment.href + "?detach_only=true"
				}
				$Method = "DELETE"
				#$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -ContentType "application/json" -EA Continue
