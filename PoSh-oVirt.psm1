			IF($ObjType.FullName -eq "System.Boolean"){
				$CurrentValue = $Null; $CurrentValue = $this."$($Property.Name)"
				#This verifies it's a boolean value
				IF($(Try{[System.Boolean]::Parse("$($Property.Value)")}Catch{Write-Verbose "Step FAILED 050"}) -ne $Null){
					IF("$($Property.Value)" -eq $True){
						$this."$($Property.Name)" = [System.Boolean]$True
					}Else{
						$this."$($Property.Name)" = [System.Boolean]$False
					}
				}
			}Else{
				$TmpValue = $Null; $TmpValue = (Invoke-Expression "[$($ObjType.Name)]`$Property.Value")
				IF($TmpValue -ne $Null){
					IF($Property.TypeNameOfValue -eq $ObjType.FullName){
						$this."$($Property.Name)" = $TmpValue
					}ElseIF($TmpValue -Is $ObjType.FullName){
						$this."$($Property.Name)" = $TmpValue
