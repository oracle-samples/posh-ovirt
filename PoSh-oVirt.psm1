				}
				Write-Verbose "$($MyInvocation.MyCommand): `$TempVMSpecs: [$($TempVMSpecs | Out-String)]"
				IF($PSBoundParameters.ContainsKey('Stateless')){IF($TargetoVM.stateless -ne $PSBoundParameters['stateless']){Add-Member -MemberType NoteProperty -Name stateless -Value $Stateless -InputObject $TempVMSpecs}}
