							{$_ -Is [Array]}{
								ForEach($ArrayItem in $oVxName){
									SWITCH(($ArrayItem)){
										{$_ -Is [String]}{Process-oVxName -oName $_ | %{$OutPutItems.Add($_) | Out-Null}}
										{$_ -Is [PSObject]}{Process-oVxName -oName $_.name | %{$OutPutItems.Add($_) | Out-Null}}
