		[Parameter(Mandatory=$True, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet('oAffinityGroup','oAffinityLabel', 'xxx')]
			[System.String]$oVxObjectName,
		[Parameter(ValueFromPipelineByPropertyName=$True)]
			[ValidateSet('json', 'xml')][System.String]$SendDataType = 'json',
		[Parameter(ValueFromPipelineByPropertyName=$True)]
			[ValidateSet('json', 'xml')][System.String]$ReturnDataType = 'json'
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{		
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) : Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) : PSBoundParameters: [$($PSBoundParameters | Out-String)]"
		IF($PSBoundParameters['Name']){$oVxName = $PSBoundParameters['Name']}Else{$oVxName = $Null}
		IF($PSBoundParameters['Id']){$oVxId = $PSBoundParameters['Id']}Else{$oVxId = $Null}
		IF($PSBoundParameters['oVxObjectName']){$oVxObjectName = $PSBoundParameters['oVxObjectName']}Else{$oVxObjectName = $Null}
		#Not Used for a GET request
		IF($PSBoundParameters['SendDataType']){$SendDataType = $PSBoundParameters['SendDataType']}Else{$SendDataType = 'json'}
		IF($PSBoundParameters['ReturnDataType']){$ReturnDataType = $PSBoundParameters['ReturnDataType']}Else{$ReturnDataType = 'json'}
		IF($oVxObjectName){
			$WebObjectPluralName = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).WebObjectPluralName
			$WebObjectSingularName = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).WebObjectSingularName
			$TypeName = $oVxObjectName
			$PipedObjectTypesAccepted = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).ParentObjectTypesAllowed
		}

		IF($PSBoundParameters['Uid']){
			$URI = "$(($PSBoundParameters['Uid']).OriginalString)"
			$Port = "$(($PSBoundParameters['Uid']).Port)"
			$oVirtServerName = "$(($PSBoundParameters['Uid']).Host)"
