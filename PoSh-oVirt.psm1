						IF($oVxObjects){
							Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
							#$oVxOutPutObjects = $Null;
							#$oVxOutPutObjects = [System.Collections.ArrayList]@()
							ForEach($oVxObject in $oVxObjects){
