#Open (and Store) a connection to an oVirt Server. Also can used saved connection data to renew when needed. REQUIRES DisConnect-oVirtServer to destroy the saved connection(S)
Function Connect-oVirtServer{
	<#
		.SYNOPSIS
			This function connects to the REST API Interface on an oVirt Server system.
		.DESCRIPTION
			This function connects to the REST API Interface on an oVirt Server system.
			If a connection is made the connection data is saved to the $global:oVirtConnections Collection
			to reference for subsequent access attempts
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtCredential
			The PSCredential to be used to connect to the -oVirtServerName
			
			This trys to build a proper OLVM UserName based on the local admin where KeyCloak is NOT used
			$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
			
			This trys to build a proper OLVM UserName based on the local admin where KeyCloak IS used
			$oVirtCredential = (Get-Credential -UserName 'admin@ovirt' -Message "Enter Password for $($oVirtServerName)")
			
			When using AD ldap the user name needs to be submitted in the format: SamAccountName@ADForrest@ADDomain
			
			This trys to build a proper LDAP UserName based on the logged in user and Active Directory Domain
			$oVirtCredential = (Get-Credential -UserName "$(([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.userprincipalname)@$(((((([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.distinguishedname).split(',') | ?{$_ -Match 'DC='}) -Join ',').Split('DC=').Trim(',')|?{$_}) -Join '.')" -Message "Enter Password for $($oVirtServerName)")
		.PARAMETER oVirtToken
			The OAuth Token to be used to connect to the -oVirtServerName
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER CloneoVirtCredentialForSSH
			If the oVirtCredential connection uses the default 'admin@internal' account, and the password for the web UI is the same as the root account, this switch will 
			copy the password provided to oVirtCredential into the oVirtSSHCredential with a user name of 'root' for convenience
		.PARAMETER PromptLDAPCredential
			This switch will attempt to look up the domain account for the logged in user to initially populate the UserName field for the Get-Credential pop-up for convenience
			If ADSI is unable to find a user account for $Env:UserName, it will populate the UserName field with the default admin@internal and allow password entry
		.PARAMETER RenewConnection
			Switch to Renew the Connection Token if expired or disconnected
		.PARAMETER NoOutPutObject
			Suppress returing the connection to avoid duplicate connections in Resolve-oVirtConnection
		.EXAMPLE
			PS> $oVirtConnect = Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential
		.EXAMPLE
			PS> $oVirtConnect = Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -RenewConnection
		.EXAMPLE
			PS> $oVirtConnect = Connect-oVirtServer -oVirtServerName $oVirtServerName -RenewConnection
		.EXAMPLE
			PS> $oVirtConnect = Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -oVirtSSHCredential $oVirtSSHCredential
		.EXAMPLE
			PS> $oVirtConnect = Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -CloneoVirtCredentialForSSH
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCredential]
			[oVirtToken]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVirtConnection]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/23/2024
			Version 1.0b	8/28/2024 Changed Token expiration from 30 minutes after created, to 30 minutes after last used, after testing time outs
			Version 1.0c	9/26/2024 Added inspecttion of oVirtCredential for LDAP formating in case user forgets, attempts alternate login automatically
			Version 1.0d	8/14/2025 Updated TokenTypicalTimeOutMinutes handling
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#_oauth_authentication
		.LINK
			DisConnect-oVirtServer
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0, HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
		#Credentials for oVirt Server (admin@internal is the default user on non KeyCloak authentication servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[System.Management.Automation.PSCredential]$oVirtCredential,
		
		#Token for oVirt Server
        [Parameter(Mandatory=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[Alias('TK')]
			[oVirtToken]$oVirtToken,
		
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,
		
		#Copy $oVirtCredential Password to SSH Credentials for oVirt Server
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$CloneoVirtCredentialForSSH,
		
		#Prompt Get-Credential with formated LDAP Credential
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('PLC')]
			[SWITCH]$PromptLDAPCredential,
		
		#RenewConnection
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,DontShow)]
			[Alias('RC')]
			[SWITCH]$RenewConnection,
		
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,DontShow)]
			[INT32]$TokenTimeOutMinutes,
			
		#NoOutPutObject
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,DontShow)]
			[Alias('NO')]
			[SWITCH]$NoOutPutObject
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		$URI = "https://$($oVirtServerName)/ovirt-engine/api"
	}
	Process{
		Write-Verbose "PSBoundParameters: [$($PSBoundParameters | Out-String)]"
		#Adding some handling for Credentials, as noted; When using AD ldap the user name needs to be submitted in the format: SamAccountName@ADForrest@ADDomain
		IF($PSBoundParameters['oVirtCredential']){
			Write-Verbose "$($MyInvocation.MyCommand): oVirtCredential Provided"
			$oVirtCredential = $PSBoundParameters['oVirtCredential']
			#Check if Not using internal domain and using LDAP style UserName SamAccountName@ADForrest@ADDomain
			IF(($oVirtCredential.UserName -ne 'admin@internal') -AND ($oVirtCredential.UserName -Match '@') -AND (([regex]::Matches($oVirtCredential.UserName, '@' )).count -lt 2)){
				$UserName = $oVirtCredential.GetNetworkCredential().UserName
					Write-Verbose "User Name: $UserName"
				$UserPassword = $oVirtCredential.GetNetworkCredential().Password
				$UserDomain = $oVirtCredential.GetNetworkCredential().Domain
			
				IF($UserDomain.Length -eq 0){
					#Check if using LDAP style UserName SamAccountName@ADDomain
					IF($UserName -Match "^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$"){
						$UserName = ($oVirtCredential.GetNetworkCredential().UserName)
						$UserDomain = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[1]
						$AlternateoVirtCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList "$($UserName)@$($UserDomain)", (ConvertTo-SecureString -String ($oVirtCredential.GetNetworkCredential().Password) -AsPlainText -Force)
					}Else{
						Write-Warning "User Credential REQUIRES a domain configured on the oVirt server, quitting connection..."; BREAK
					}
				}
			}
		}
		
		#So far in testing I have run over 20 hours, with regular repeat connections every few minutes, NOT using "Prefer" = "persistent-auth", and up to 30 minutes tested in between checks
		#Typical time out with no activity is 30 minutes
		#Activity keeps the Token valid up to the Token "exp" time (or the calculated for display time   (Show-oVirtConnection | Where{$_.Name -eq $PSBoundParameters['oVirtServerName']}).Expires  )
		#$TokenTypicalTimeOutMinutes is set by default to 30 Minutes below, but can be overridden by input parameter -TokenTimeOutMinutes
		#Discovered this is saved in /etc/ovirt-engine/engine-config	UserSessionTimeOutInterval
			# engine-config -g UserSessionTimeOutInterval
				# Picked up JAVA_TOOL_OPTIONS: -Dcom.redhat.fips=false
				# UserSessionTimeOutInterval: 30 version: general
			# engine-config -s UserSessionTimeOutInterval=30 ; systemctl restart ovirt-engine; systemctl restart httpd.service
			# so probably saved in the DB
			# probably a balance of performance impact by too many idle sessions vs too many new token requests
			# 
			# cat /etc/ovirt-engine/engine-config/engine-config.properties | grep -i UserSessionTimeOutInterval
				# UserSessionTimeOutInterval.type=Integer
				# UserSessionTimeOutInterval.validValues=-1,1..100000
				# UserSessionTimeOutInterval.description=Timeout interval in minutes, after which inactive user sessions expire. A negative value indicates that sessions never expire.
		$TokenTypicalTimeOutMinutes = 30
		IF($PSBoundParameters['TokenTimeOutMinutes']){$TokenTypicalTimeOutMinutes = $PSBoundParameters['TokenTimeOutMinutes']; Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes Provided"}Else{Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes NOT Provided"}
		
		IF($PSBoundParameters['oVirtServerName']){$oVirtServerName = $PSBoundParameters['oVirtServerName']; Write-Verbose "$($MyInvocation.MyCommand): oVirtServerName Provided"}Else{$oVirtServerName = $Null; Write-Verbose "$($MyInvocation.MyCommand): oVirtServerName NOT Provided"}
		IF($PSBoundParameters['oVirtToken']){$oVirtToken = $PSBoundParameters['oVirtToken']; Write-Verbose "$($MyInvocation.MyCommand): oVirtToken Provided"}Else{$oVirtToken = $Null; Write-Verbose "$($MyInvocation.MyCommand): oVirtToken NOT Provided"}
		
		#Check if oVirt Server Certificate is Installed/Trusted, and get if not
		Write-Verbose "$($MyInvocation.MyCommand): Running 'Get-ChildItem -Path cert:\ -Recurse' to check if oVirt Server Certificate is Installed/Trusted."
		IF(!($(Try{Get-ChildItem -Path cert:\ -Recurse -ErrorAction SilentlyContinue | ?{$_.Issuer -match $oVirtServerName}}Catch{Write-Verbose "$($MyInvocation.MyCommand): 'Get-ChildItem -Path cert:\ -Recurse' had an error: [$Error[0].Exception.Message | Out-String)]"}))){Write-Verbose "$($MyInvocation.MyCommand): No Certificate Found Installed/Trusted locally for [$($oVirtServerName)]" ; $CertResults = Import-oVirtCertificate -oVirtServerName $oVirtServerName}
		
		#Check if a oVirtConnections Collection already exists
		IF(!$global:oVirtConnections){$global:oVirtConnections = [System.Collections.ArrayList]@()}
		#Check if a connection already exists
		$ExistingConnections = $Null
		$ExistingConnection = $Null
		IF($PSBoundParameters['oVirtServerName']){
			$ExistingConnections = $global:oVirtConnections | ?{$_.oVirtServerName -eq $oVirtServerName}
		}Else{
			$ExistingConnections = $global:oVirtConnections | ?{$_}
		}
		
		IF($ExistingConnections){
			Write-Verbose "$($MyInvocation.MyCommand): Found Existing Connection(s)"
			ForEach($ExistingConnection in $ExistingConnections){
				#Check for active Statuses
				#Check Token
				$ConnectionStatus = $False
				IF($ExistingConnection.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $ExistingConnection.TokenTypicalTimeOutMinutes}
				#Next Line checks the Token is less than the ConnectionTime plus 30 Minutes, or less than 10 seconds from Expires Time as provided by oVirt
					#$ConnectionStatus = ( ($ExistingConnection.Expires -lt (Get-Date).AddSeconds(-10))  -OR ((Get-Date $ExistingConnection.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -gt (Get-Date)) )
				#Next Line checks the Token is less than the LastUsedTime plus 30 Minutes, or less than 10 seconds from Expires Time as provided by oVirt
				$ConnectionStatus = ( ($ExistingConnection.Expires -lt (Get-Date).AddSeconds(-10))  -OR ((Get-Date $ExistingConnection.LastUsedTime).AddMinutes($TokenTypicalTimeOutMinutes) -gt (Get-Date)) )
				Write-Verbose "$($MyInvocation.MyCommand): `$ExistingConnection [$($ExistingConnection | Select * | Out-String)])"
				#$global:ExistingConnection = $ExistingConnection
				Write-Verbose "$($MyInvocation.MyCommand): `$ConnectionStatus [$ConnectionStatus])"
				IF($ConnectionStatus -ne $True){
					#Expired
					#Set Stored Connection to IsConnected = False
					($global:oVirtConnections | ?{$_.oVirtServerName -eq $oVirtServerName}).IsConnected = $False
					#Check Online
					$OnlineStatus = $Null
					Try{$OnlineStatus = [System.Net.Sockets.TcpClient]::new().ConnectAsync("$($oVirtServerName)", 80).Wait(3000)}Catch{}
					IF($OnlineStatus -ne $True){
						$OnlineStatus = $Null
						Try{$OnlineStatus = [System.Net.Sockets.TcpClient]::new().ConnectAsync("$($oVirtServerName)", 443).Wait(3000)}Catch{}
					}
					IF($OnlineStatus -ne $True){
						$OnlineStatus = $Null
						IF(Get-Command -Name Test-Connection -EA SilentlyContinue){
							$OnlineStatus = (Test-Connection -ComputerName $oVirtServerName -Quiet -EA SilentlyContinue)
						}
					}
					IF($OnlineStatus -ne $True){
						$OnlineStatus = $Null
						#Normally I would pu this first, but reliability tests have shown this to hang under GUI use
						IF(Get-Command -Name Test-NetConnection -EA SilentlyContinue){
							$OnlineStatus = (Test-NetConnection -ComputerName $oVirtServerName -InformationLevel Quiet -EA SilentlyContinue)
						}
					}
					#$OnlineStatus = $True
					Write-Verbose "$($MyInvocation.MyCommand): `$OnlineStatus [$OnlineStatus])"
					IF($OnlineStatus -eq $True){
						IF(($PSBoundParameters['RenewConnection']).IsPresent -eq $True){
							$IsConnected = $False; $oVirtToken = $Null; $oVirt = $Null;
							Write-Warning "Idle Session Expired for [$($oVirtServerName)], Attempting to Renew Token"
							#Create PSCustomObject form class to hold new connection
							$oVirtConnection = [oVirtConnection]::new()
							
							$oVirtCredential = $ExistingConnection.oVirtCredential
							$oVirtSSHCredential = $ExistingConnection.oVirtSSHCredential
							#Retrieve oVirtToken
							IF($PSBoundParameters['oVirtCredential']){
								$oVirtCredential = $PSBoundParameters['oVirtCredential']
								$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $PSBoundParameters['oVirtCredential'] -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
							}Else{
								IF($oVirtCredential){
									$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
								}Else{
									$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
									$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
								}
							}
							#Retrieve oVirt Data
							IF($PSBoundParameters['oVirtToken']){
								$oVirtToken = $PSBoundParameters['oVirtToken']
							}Else{
								#IF(!(($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -lt (Get-Date)))){
								IF(!(($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($oVirtToken.TokenTypicalTimeOutMinutes) -lt (Get-Date)))){
									#Write-Host -Fore Cyan "`tReTrieved Valid oVirt OAuth Token"
									Write-Verbose "ReTrieved Valid oVirt OAuth Token"
								}
							}
							IF($oVirtToken){
								IF( ($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($oVirtToken.TokenTypicalTimeOutMinutes) -lt (Get-Date))  ){
									Write-Warning "Provided Token Expired for [$($oVirtToken.oVirtServerName)], Can't Use It"
								}Else{
									#$oVirtToken is not expired
									$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes
									$ReturnDataType = "xml"
									$ReturnDataType = "json"
									$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
									#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
									$oVirt = $Null
									
									$Output = @()
									$Response01 = $Null; $Response01 = Invoke-RestMethod -Uri $URI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction Continue
									
									IF(!($Response01)){
										#Errorinvalid_grant: The provided authorization grant for the auth code has expired.
										IF(($oVxError -Match "auth code has expired") -OR ($Error[0].ErrorDetails.Message -Match "auth code has expired")){
											#Token Expired, even though the expiration data not exceeded
											#$LastCommandExecuted = $Null; $LastCommandExecuted = $Error[0].ErrorRecord.InvocationInfo.Line
											$LastCommandExecuted = $Null; $LastCommandExecuted = $oVxError.ErrorRecord.InvocationInfo.Line
											Write-Warning "Idle Session Expired for [$($oVirtServerName)], Attempting to Renew Token"
											IF($PSBoundParameters['oVirtCredential']){
												$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
											}Else{
												IF($oVirtCredential){
													$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
												}Else{
													$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
													$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
												}
											}
											IF(!(($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -lt (Get-Date)))){
												Write-Host -Fore Green "`toVirt OAuth Token Renewed for [$($oVirtCredential.UserName)]"
											}
											$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
											#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
											IF($LastCommandExecuted){Invoke-Expression -Command $LastCommandExecuted}
										}
									}
									IF(!($Response01)){
										Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
									}Else{
										Write-Verbose "Raw oVirt Response: $Response01"
										IF($Response01.xml){
											$oVirt = ($Response01.api | %{Convert-XMLtoPSObject -XML $_})
										}Else{
											#$oVMs = ($Response01.vm | ConvertFrom-Json)
											$oVirt = $Response01
										}
									}
								}
							}
							
							IF($oVirtToken -OR $oVirt){$IsConnected = $True}
							IF($oVirtToken -AND $oVirt){
								$oVirtConnection.IsConnected = $IsConnected
								$oVirtConnection.AccessToken = $oVirtToken.AccessToken
								$oVirtConnection.Expires = $oVirtToken.Expires
								$oVirtConnection.ExpiresUTC = $oVirtToken.ExpiresUTC
								$oVirtConnection.oVirtServerName = $oVirtToken.oVirtServerName
								$oVirtConnection.ExtensionData = $oVirtToken.ExtensionData
								$oVirtConnection.oVirtCredential = $oVirtCredential
								$oVirtConnection.oVirtSSHCredential = $oVirtSSHCredential
								$oVirtConnection.ConnectionTime = $(Convert-FromEpochTime -EpochTimeMS $oVirt.time)
								$oVirtConnection.TokenTypicalTimeOutMinutes = $TokenTypicalTimeOutMinutes
								$LastUsedTime = $(Get-Date)
								$oVirtConnection.TokenConnectionExpires = (($LastUsedTime).AddMinutes($TokenTypicalTimeOutMinutes))
								$oVirtConnection.LastUsedTime = $LastUsedTime
								$oVirtConnection.InstanceId = $oVirt.product_info.instance_id
								$oVirtConnection.Name = $oVirtServerName
								$oVirtConnection.Authenticated_User_Id = $oVirt.authenticated_user.id
								$oVirtConnection.Authenticated_User_href = $oVirt.authenticated_user.href
								$oVirtConnection.User = $oVirtCredential.UserName
								$oVirtConnection.Product = $oVirt.product_info.name
								$oVirtConnection.FullVersion = $oVirt.product_info.version.full_version
								$oVirtConnection.Version = [Version]::new($oVirt.product_info.version.major,$oVirt.product_info.version.minor,$oVirt.product_info.version.build,$oVirt.product_info.version.revision)
								$oVirtConnection.Major = $oVirt.product_info.version.Major
								$oVirtConnection.Minor = $oVirt.product_info.version.Minor
								$oVirtConnection.Build = $oVirt.product_info.version.Build
								$oVirtConnection.Revision = $oVirt.product_info.version.Revision
								$oVirtConnection.Links = $oVirt.link
								Write-Verbose "$($MyInvocation.MyCommand): `$oVirtConnection [$($oVirtConnection | Select * | Out-String)])"
								IF($global:oVirtConnections.count -gt 1){
									Write-Verbose "$($MyInvocation.MyCommand): `$global:oVirtConnections count gt 1"
									$Tmp_oVirtConnections = [System.Collections.ArrayList]@()
									$global:oVirtConnections | ?{$_.oVirtServerName -ne $oVirtServerName} | Sort Name | %{$Tmp_oVirtConnections.Add($_) | Out-Null}
									$Tmp_oVirtConnections.Add($oVirtConnection) | Out-Null
									$global:oVirtConnections = $Tmp_oVirtConnections
								}Else{
									Write-Verbose "$($MyInvocation.MyCommand): `$global:oVirtConnections count le 1"
									$global:oVirtConnections = [System.Collections.ArrayList]@()
									$global:oVirtConnections.psbase.Add($oVirtConnection)| Out-Null
								}
								IF($global:oVirtConnections.psbase.Contains($oVirtConnection)){
									Write-Host -Fore Green "`toVirt OAuth Token Renewed"
								}ElseIF($global:oVirtConnections.psbase.Contains($ExistingConnection)){
									Write-Host -Fore Yellow "`toVirt OAuth Token FAILED to Renew"
								}
								Write-Verbose "$($MyInvocation.MyCommand): `$global:oVirtConnections for `$oVirtToken.oVirtServerName [$($global:oVirtConnections | ?{$_.oVirtServerName -eq $oVirtToken.oVirtServerName} | Select * | Out-String)])"
							}
						}Else{
							Write-Warning "Token Expired for [$($oVirtServerName)]"
							Write-Warning "Try again with '-RenewConnection' input parameter"
							#This Should be for future Disconnect-oVirtServer
							#Do you want to disconnect or reconnect?
							#$global:oVirtConnections.Remove($ExistingConnection)
						}
					}Else{
						IF(($PSBoundParameter['RenewConnection']).IsPresent -eq $True){
							Write-Host -Fore Yellow "Can NOT reach $($oVirtServerName) to renew connection"
						}
					}
				}Else{
					IF($global:oVirtConnections){$Host.UI.RawUI.WindowTitle = "Connected to oVirt Server(s): $(($global:oVirtConnections).Name -Join ', ')"}Else{$Host.UI.RawUI.WindowTitle = "No oVirt Server(s) Remain Connected."}
					IF(($PSBoundParameters['NoOutPutObject']).IsPresent -ne $True){$ExistingConnection}
				}
			}
		}Else{
			Write-Verbose "$($MyInvocation.MyCommand): NO Existing Connection(s) Found"
			$IsConnected = $False; $oVirtToken = $Null; $oVirt = $Null;
			#Determine LDAP username formatting in Windows from available Active Directory domain User is using
			IF($PSBoundParameters['PromptLDAPCredential'].IsPresent -eq $True){
				Write-Verbose "$($MyInvocation.MyCommand): PromptLDAPCredential TRUE"
				$CredentialDefaultUserName = "$(([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.userprincipalname)@$(((((([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.distinguishedname).split(',') | ?{$_ -Match 'DC='}) -Join ',').Split('DC=').Trim(',')|?{$_}) -Join '.')"
				IF($CredentialDefaultUserName -NotMatch "^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$"){$CredentialDefaultUserName = 'admin@internal'}
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): PromptLDAPCredential FALSE"
				$CredentialDefaultUserName = 'admin@internal'
			}
			Write-Verbose "$($MyInvocation.MyCommand): `$CredentialDefaultUserName: [$($CredentialDefaultUserName)]"
			
			#Create PSCustomObject form class to hold new connection
			$oVirtConnection = [oVirtConnection]::new()
			
			#Retrieve oVirtToken
			IF($PSBoundParameters['oVirtCredential']){
				$oVirtCredential = $PSBoundParameters['oVirtCredential']
				$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $PSBoundParameters['oVirtCredential'] -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
				IF((!($oVirtToken)) -AND $AlternateoVirtCredential){
					Write-Warning "UserName [$($oVirtCredential.UserName)] Failed, retrying using [$($AlternateoVirtCredential.UserName)]"
					$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $AlternateoVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
					IF($oVirtToken){
						Write-Host -Fore Green "Retry with Altername UserName succeeded, suggestion using UserName [$($AlternateoVirtCredential.UserName)] in the future"
						$oVirtCredential = $AlternateoVirtCredential
						IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
					}
				}Else{
					IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
				}
			}ElseIF($PSBoundParameters['oVirtToken']){
				$oVirtToken = $PSBoundParameters['oVirtToken']
				IF($oVirtToken){
					IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
					IF( ($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -lt (Get-Date))  ){
						Write-Warning "Provided Token Expired for [$($oVirtToken.oVirtServerName)], Can't Use It"
						$oVirtCredential = (Get-Credential -UserName $CredentialDefaultUserName -Message "Enter Password for $($oVirtServerName)")
						$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
					}Else{
						$oVirt = Get-oVirt -oVirtServerName $oVirtServerName -oVirtToken $oVirtToken -ErrorAction Continue
						$ReturnDataType = "xml"
						$ReturnDataType = "json"
						$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
						#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
						$oVirt = $Null
								
						$Output = @()
						$Response01 = $Null; $Response01 = Invoke-RestMethod -Uri $URI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction Continue
						
						IF(!($Response01)){
							#Errorinvalid_grant: The provided authorization grant for the auth code has expired.
							IF(($oVxError -Match "auth code has expired") -OR ($Error[0].ErrorDetails.Message -Match "auth code has expired")){
								#Token Expired, even though the expiration data not exceeded
								#$LastCommandExecuted = $Null; $LastCommandExecuted = $Error[0].ErrorRecord.InvocationInfo.Line
								$LastCommandExecuted = $Null; $LastCommandExecuted = $oVxError.ErrorRecord.InvocationInfo.Line
								Write-Warning "Idle Session Expired for [$($oVirtServerName)], Attempting to Renew Token"
								IF($PSBoundParameters['oVirtCredential']){
									$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
								}Else{
									$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential (Get-Credential -UserName $CredentialDefaultUserName -Message "Enter Password for $($oVirtServerName)") -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
								}
								IF(!(($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -lt (Get-Date)))){
									Write-Host -Fore Green "`toVirt OAuth Token Renewed"
								}
								$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
								#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
								IF($LastCommandExecuted){Invoke-Expression -Command $LastCommandExecuted}
								
							}
						}
						IF(!($Response01)){
							Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
						}Else{
							Write-Verbose "Raw oVirt Response: $Response01"
							IF($Response01.xml){
								$oVirt = ($Response01.api | %{Convert-XMLtoPSObject -XML $_})
							}Else{
								#$oVMs = ($Response01.vm | ConvertFrom-Json)
								$oVirt = $Response01
							}
						}
					}
				}
			}Else{
				$oVirtCredential = (Get-Credential -UserName $CredentialDefaultUserName -Message "Enter Password for $($oVirtServerName)")
				#Check if Not using internal domain and using LDAP style UserName SamAccountName@ADForrest@ADDomain
				IF(($oVirtCredential.UserName -ne 'admin@internal') -AND ($oVirtCredential.UserName -Match '@') -AND (([regex]::Matches($oVirtCredential.UserName, '@' )).count -lt 2)){
					$UserName = $oVirtCredential.GetNetworkCredential().UserName
						Write-Verbose "User Name: $UserName"
					$UserPassword = $oVirtCredential.GetNetworkCredential().Password
					$UserDomain = $oVirtCredential.GetNetworkCredential().Domain
				
					IF($UserDomain.Length -eq 0){
						#Check if using LDAP style UserName SamAccountName@ADDomain
						IF($UserName -Match "^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$"){
							$UserName = ($oVirtCredential.GetNetworkCredential().UserName)
							$UserDomain = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[1]
							$AlternateoVirtCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList "$($UserName)@$($UserDomain)", (ConvertTo-SecureString -String ($oVirtCredential.GetNetworkCredential().Password) -AsPlainText -Force)
						}Else{
							Write-Warning "User Credential REQUIRES a domain configured on the oVirt server, quitting connection..."; BREAK
						}
					}
				}

				$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
				IF((!($oVirtToken)) -AND $AlternateoVirtCredential){
					Write-Warning "UserName [$($oVirtCredential.UserName)] Failed, retrying using [$($AlternateoVirtCredential.UserName)]"
					$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $AlternateoVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
					IF($oVirtToken){
						Write-Host -Fore Green "Retry with Altername UserName succeeded, suggestion using UserName [$($AlternateoVirtCredential.UserName)] in the future"
						$oVirtCredential = $AlternateoVirtCredential
						IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
					}
				}
				IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
			}
			#Retrieve oVirtSSHCredential
			IF($PSBoundParameters['oVirtSSHCredential']){
				$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
			}ElseIF($PSBoundParameters['CloneoVirtCredentialForSSH'].IsPresent -eq $True){
				#See if Admin
				IF(($oVirtCredential.GetNetworkCredential().UserName -eq "admin") -AND ($oVirtCredential.GetNetworkCredential().Domain -eq "internal")){
					#IF($PSBoundParameters['CloneoVirtCredentialForSSH'].IsPresent -eq $True){
						$UserAnswer = 6
					#}Else{
						#Prompt to use Admin pwd for root access?
					#	$UserAnswer = Get-UserAnswerPopUp -Message "Use $($oVirtCredential.UserName) password for SSH 'root' account" -Title "Use admin passowrd for root SSH" -TimeOut 5 -ButtonSet YN -Icon Question
					#}
					IF($UserAnswer -eq 6){
						#Create root Credential using $oVirtCredential password
						$oVirtSSHCredential = New-Object System.Management.Automation.PSCredential 'root',$oVirtCredential.Password
					}Else{
						$oVirtSSHCredential = (Get-Credential -UserName 'root' -Message "Enter 'root' SSH Password for $($oVirtServerName)")
						IF($oVirtSSHCredential.GetNetworkCredential().password -eq ""){$oVirtSSHCredential = $Null}
					}
				}Else{
					IF($PSBoundParameters['CloneoVirtCredentialForSSH'].IsPresent -eq $True){Write-Warning "Cloning oVirtCredential password only works for 'admin@internal', otherwise you must provide the password."}
					#Prompt for oVirt Root to Allow SSH into oVirt and pass-thru to KVM oHosts
					$oVirtSSHCredential = (Get-Credential -UserName 'root' -Message "Enter 'root' SSH Password for $($oVirtServerName)")
					IF($oVirtSSHCredential.GetNetworkCredential().password -eq ""){$oVirtSSHCredential = $Null}
				}
			}
			#Retrieve oVirt Data
			IF($oVirtToken){
				#$oVirt = Get-oVirt -oVirtServerName $oVirtServerName -oVirtToken $oVirtToken
				IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
				$ReturnDataType = "xml"
				$ReturnDataType = "json"
				$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
				$oVirt = $Null
				
				$Output = @()
				$Response01 = $Null; $Response01 = Invoke-RestMethod -Uri $URI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction SilentlyContinue
				
				IF(!($Response01)){
					#Errorinvalid_grant: The provided authorization grant for the auth code has expired.
					IF(($oVxError -Match "auth code has expired") -OR ($Error[0].ErrorDetails.Message -Match "auth code has expired")){
						#Token Expired, even though the expiration data not exceeded
						#$LastCommandExecuted = $Null; $LastCommandExecuted = $Error[0].ErrorRecord.InvocationInfo.Line
						$LastCommandExecuted = $Null; $LastCommandExecuted = $oVxError.ErrorRecord.InvocationInfo.Line
						Write-Warning "Idle Session Expired for [$($oVirtServerName)], Attempting to Renew Token"
						IF($PSBoundParameters['oVirtCredential']){
							$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
						}Else{
							$oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential (Get-Credential -UserName $CredentialDefaultUserName -Message "Enter Password for $($oVirtServerName)") -TokenTimeOutMinutes $TokenTypicalTimeOutMinutes
						}
						IF($oVirtToken.TokenTypicalTimeOutMinutes){$TokenTypicalTimeOutMinutes = $oVirtToken.TokenTypicalTimeOutMinutes}
						IF(!(($oVirtToken.Expires -lt (Get-Date).AddSeconds(-30))  -OR ((Get-Date $oVirtToken.ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes) -lt (Get-Date)))){
							Write-Host -Fore Green "`toVirt OAuth Token Renewed"
						}
						$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
						#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
						IF($LastCommandExecuted){Invoke-Expression -Command $LastCommandExecuted}
					}
				}
				IF(!($Response01)){
					Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
				}Else{
					Write-Verbose "Raw oVirt Response: $Response01"
					IF($Response01.xml){
						$oVirt = ($Response01.api | %{Convert-XMLtoPSObject -XML $_})
					}Else{
						#$oVMs = ($Response01.vm | ConvertFrom-Json)
						$oVirt = $Response01
					}
				}
			}
			IF($oVirtToken -OR $oVirt){$IsConnected = $True}
			IF($oVirtToken -AND $oVirt){
				$oVirtConnection.IsConnected = $IsConnected
				$oVirtConnection.AccessToken = $oVirtToken.AccessToken
				$oVirtConnection.Expires = $oVirtToken.Expires
				$oVirtConnection.ExpiresUTC = $oVirtToken.ExpiresUTC
				$oVirtConnection.oVirtServerName = $oVirtToken.oVirtServerName
				$oVirtConnection.ExtensionData = $oVirtToken.ExtensionData
				$oVirtConnection.oVirtCredential = $oVirtCredential
				$oVirtConnection.oVirtSSHCredential = $oVirtSSHCredential
				$oVirtConnection.ConnectionTime = $(Convert-FromEpochTime -EpochTimeMS $oVirt.time)
				$oVirtConnection.TokenTypicalTimeOutMinutes = $TokenTypicalTimeOutMinutes
				$LastUsedTime = $(Get-Date)
				$oVirtConnection.TokenConnectionExpires = (($LastUsedTime).AddMinutes($TokenTypicalTimeOutMinutes))
				$oVirtConnection.LastUsedTime = $LastUsedTime
				$oVirtConnection.InstanceId = $oVirt.product_info.instance_id
				$oVirtConnection.Name = $oVirtServerName
				$oVirtConnection.Authenticated_User_Id = $oVirt.authenticated_user.id
				$oVirtConnection.Authenticated_User_href = $oVirt.authenticated_user.href
				$oVirtConnection.User = $oVirtCredential.UserName
				$oVirtConnection.Product = $oVirt.product_info.name
				$oVirtConnection.FullVersion = $oVirt.product_info.version.full_version
				$oVirtConnection.Version = [Version]::new($oVirt.product_info.version.major,$oVirt.product_info.version.minor,$oVirt.product_info.version.build,$oVirt.product_info.version.revision)
				$oVirtConnection.Major = $oVirt.product_info.version.Major
				$oVirtConnection.Minor = $oVirt.product_info.version.Minor
				$oVirtConnection.Build = $oVirt.product_info.version.Build
				$oVirtConnection.Revision = $oVirt.product_info.version.Revision
				$oVirtConnection.Links = $oVirt.link
				$global:oVirtConnections.Add($oVirtConnection) | Out-Null
				IF(($oVirt.product_info.version.major -lt 4) -OR (($oVirt.product_info.version.major -eq 4) -AND ($oVirt.product_info.version.minor -lt 5))){
					Write-Warning "oVirt Engine is Version [$($oVirt.product_info.version.full_version)], this PoSh-oVirt module was written for version [4.5] and above, some features may produce undesireable results."
				}
				IF($global:oVirtConnections){$Host.UI.RawUI.WindowTitle = "Connected to oVirt Server(s): $(($global:oVirtConnections).Name -Join ', ')"}Else{$Host.UI.RawUI.WindowTitle = "No oVirt Server(s) Remain Connected."}
				IF(($PSBoundParameters['NoOutPutObject']).IsPresent -ne $True){$oVirtConnection}
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function DisConnect-oVirtServer{
	<#
		.SYNOPSIS
			This function disconnects from the REST API Interface on an oVirt Server system.
		.DESCRIPTION
			This function disconnects from the REST API Interface on an oVirt Server system.
			If a connection is saved to the $global:oVirtConnections Collection, this function will remove it
		.PARAMETER oVirtServerName
			The oVirt Engine Server to disconnect
		.EXAMPLE
			PS> DisConnect-oVirtServer -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/26/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Connect-oVirtServer
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=2, HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String[]]$oVirtServerName
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		#Updated to Use *
		IF($PSBoundParameters['oVirtServerName']){
			IF($PSBoundParameters['oVirtServerName'] -eq '*'){
				Write-Verbose "$($MyInvocation.MyCommand): Removing ['*']"
				$global:oVirtConnections = $Null
				Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue | ?{$_} | Remove-Variable -Force -Confirm:0 -ErrorAction SilentlyContinue
			}Else{
				ForEach($ConnectionName in ($PSBoundParameters['oVirtServerName'])){
					Write-Verbose "$($MyInvocation.MyCommand): Attempting to Remove Connection for [$($ConnectionName)]"
					$ConnectionToRemove = $Null; $ConnectionToRemove = $global:oVirtConnections | ?{$_.oVirtServerName -eq $oVirtServerName}
					IF($ConnectionToRemove){
						#Write-Verbose "$($MyInvocation.MyCommand): Connection To Remove [$($ConnectionToRemove | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): Removing [$($ConnectionToRemove | Select * | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): Number of Connection in `$global:oVirtConnections [$($global:oVirtConnections.count)]"
						IF($global:oVirtConnections.count -ge 1){
							Write-Verbose "$($MyInvocation.MyCommand): Connection count greater than or equal to 1"
							$global:oVirtConnections.Remove($ConnectionToRemove)
							#$global:oVirtConnections = $global:oVirtConnections | ?{$_ -ne $ConnectionToRemove}
						}Else{
							Write-Verbose "$($MyInvocation.MyCommand): Connection count less than 1"
							#Exception calling "Remove" with "1" argument(s): "Collection was of a fixed size."
							IF(($global:oVirtConnections -Is [System.Collections.ArrayList]) -or (Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue)){
								IF($global:oVirtConnections -Is [System.Collections.ArrayList]){Write-Verbose "$($MyInvocation.MyCommand): `$global:oVirtConnections Is 'System.Collections.ArrayList'"}
								IF((Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue)){Write-Verbose "$($MyInvocation.MyCommand): Found Variable '`$global:oVirtConnections'"}
								$global:oVirtConnections = $Null
								Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue | ?{$_} | Clear-Variable -Force -Confirm:0 -PassThru -ErrorAction Continue | Remove-Variable -Force -Confirm:0 -ErrorAction Continue
							}
							IF(Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue | ?{$_}){Write-Verbose "$($MyInvocation.MyCommand): Variable '`$global:oVirtConnections' could not be removed."}
						}
					}
					#IF($global:oVirtConnections){IF(($global:oVirtConnections).count -lt 1){Get-Variable -Name oVirtConnections -Scope global -ErrorAction SilentlyContinue | ?{$_} | Remove-Variable -Force -Confirm:0 -ErrorAction SilentlyContinue}}
					#IF($global:oVirtConnections -Is [System.Collections.ArrayList]){IF(($global:oVirtConnections).count -lt 1){Get-Variable -Name oVirtConnections -Scope global -ErrorAction SilentlyContinue | ?{$_} | Remove-Variable -Force -Confirm:0}}
					IF(($global:oVirtConnections).count -lt 1){
						$global:oVirtConnections = $Null
						Get-Variable -Name oVirtConnections -Scope global -ErrorAction Continue | ?{$_} | Clear-Variable -Force -Confirm:0 -PassThru -ErrorAction Continue | Remove-Variable -Force -Confirm:0 -ErrorAction Continue
						IF(Get-Variable -Name oVirtConnections -Scope Global -EA SilentlyContinue | ?{$_}){Write-Verbose "$($MyInvocation.MyCommand): Cleanup: Variable '`$global:oVirtConnections' could not be removed."}
					}
				}
			}
			IF($global:oVirtConnections){$Host.UI.RawUI.WindowTitle = "Connected to oVirt Server(s): $(($global:oVirtConnections).Name -Join ', ')"}Else{$Host.UI.RawUI.WindowTitle = "No oVirt Server(s) Remain Connected."}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Show-oVirtConnection{[CmdletBinding()]$global:oVirtConnections}

Function Open-oVirtPutty{
	<#
		.SYNOPSIS
			This function Opens a Putty console to an oVirt Server system.
		.DESCRIPTION
			This function Opens a Putty console to an oVirt Server system using the SSH credentials found 
			in the $oVirtConnections matching the provided oVirt name.
			This assumes Putty is installed.
		.PARAMETER Name
			The Name(s) of oHost(s)
			Can use Wildcard '*'
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.EXAMPLE
			PS> Open-oVirtPutty -oVirtServerName $oVirtServerName -Name "oHostName"
				Opens a Putty console to the oVirt (OLVM) Server
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/5/2024
			Version 1.1		10/4/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://www.chiark.greenend.org.uk/~sgtatham/putty/
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	[Alias('OVP')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"; IF(!(Get-Command Putty.exe -ErrorAction SilentlyContinue)){Write-Warning "Putty.exe not installed. Download from 'https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html'";BREAK}}
	Process{
		$oVirtSSHCredential = $Null
		IF($PSBoundParameters['oVirtSSHCredential']){
			IF($($PSBoundParameters['oVirtSSHCredential']).GetNetworkCredential().password -ne ""){
				$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
				IF($PSBoundParameters['oVirtServerName']){
					($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
				}ElseIF(($oVirtConnections).count -eq 1){
					$oVirtConnections[0].oVirtSSHCredential = $oVirtSSHCredential
				}
			}Else{$oVirtSSHCredential = $Null}
		}
		
		IF(!($oVirtSSHCredential)){
			IF($PSBoundParameters['oVirtServerName']){
				$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential
				$oVirtServerName = $PSBoundParameters['oVirtServerName']
			}ElseIF(($oVirtConnections).count -eq 1){
				$oVirtConnection = ($oVirtConnections[0])
				$oVirtSSHCredential = $oVirtConnection.oVirtSSHCredential
				$oVirtServerName = $oVirtConnection.Name
			}Else{
				#$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).oVirtSSHCredential
			}
		}
		IF($oVirtSSHCredential){
			IF((Get-Command putty.exe -EA SilentlyContinue).Name -ne "putty.exe"){
				Write-Warning "Plink.exe NOT Installed. It is a part of the PuTTY suite, found here: https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html"
				BREAK
			}Else{
				#IF($PSCmdlet.ShouldProcess($oVirtServerName , "Open Putty SSH to oVirt")){
					putty.exe -ssh -t -l root -pw $($oVirtSSHCredential.GetNetworkCredential().Password) -2 -4 $oVirtServerName #BINGO
				#}
			}
		}Else{
			Write-Warning "No Valid or Matching oVirtConnection or oVirtSSHCredential found to make connection(s)"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Open-oHostPutty{
	<#
		.SYNOPSIS
			This function Opens a Putty console to the provided oHost(KVM), on an oVirt Server system.
		.DESCRIPTION
			This function Opens a Putty console to the provided oHost(KVM), by hooping through an oVirt Server system, 
			using the SSH credentials found in the $oVirtConnections matching the provided (or discovered)
			oVirt name.
			This assumes Putty is installed.
			VERY IMPORTANT: If the Host Key has not already been accepted into the Putty Key Store, the putty window for the oHost 
				will close immediately after attempting to open, without a prompt to accept the Host key. The fix is to make the first 
				connection and save the key.
				
				This can also happen if the KVM oHost has been rebuilt, but the SSH Keys file still has the former key saved, in which case the entry
				needs removed from the  ./root/.ssh/known_hosts file on the oVirt server
		.PARAMETER Name
			The Name(s) of oHost(s)
			Can use Wildcard '*'
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.EXAMPLE
			PS> Open-oHostPutty -oVirtServerName $oVirtServerName -Name "oHostName"
				Opens a Putty console to the oHost(s)
		.EXAMPLE
			PS> Open-oHostPutty -Name "oHostName"
				Opens a Putty console to the oHost(s) using the oVirt Server found connected
		.EXAMPLE
			PS> Open-oHostPutty $oHost
				Opens a Putty console to the oHost(s) using the oVirt Server Name found in the $oHost object
		.INPUTS
			[System.String]
			[oHost]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/5/2024
			Version 1.1		10/4/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://www.chiark.greenend.org.uk/~sgtatham/putty/
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	[Alias('OOHP')]
	Param(
		#oHost Name
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oHost'})]$Name,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"; IF(!(Get-Command Putty.exe -ErrorAction SilentlyContinue)){Write-Warning "Putty.exe not installed. Download from 'https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html'";BREAK}}
	Process{
		ForEach($Item in ($PSBoundParameters['Name'])){
			$oVirtSSHCredential = $Null
			IF(($PSBoundParameters['Name']).GetType().Name -eq "oHost"){
				Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oHost]"
				Write-Verbose "$($MyInvocation.MyCommand) [$(($PSBoundParameters['Name']).oVirtServer)]"
				$PSBoundParameters['oVirtServerName'] = $(($PSBoundParameters['Name']).oVirtServer)
				$oHostName = $(($PSBoundParameters['Name']).Name)
			}Else{
				$oHostName = $(($PSBoundParameters['Name']))
			}
		
			IF($PSBoundParameters['oVirtSSHCredential']){
				IF($($PSBoundParameters['oVirtSSHCredential']).GetNetworkCredential().password -ne ""){
					$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
					IF($PSBoundParameters['oVirtServerName']){
						($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
					}ElseIF(($oVirtConnections).count -eq 1){
						$oVirtConnections[0].oVirtSSHCredential = $oVirtSSHCredential
					}
				}Else{$oVirtSSHCredential = $Null}
			}
		
			IF(!($oVirtSSHCredential)){
				IF($PSBoundParameters['oVirtServerName']){
					$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential
					$oVirtServerName = $PSBoundParameters['oVirtServerName']
				}ElseIF(($oVirtConnections).count -eq 1){
					$oVirtConnection = ($oVirtConnections[0])
					$oVirtSSHCredential = $oVirtConnection.oVirtSSHCredential
					$oVirtServerName = $oVirtConnection.Name
				}Else{
					#$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).oVirtSSHCredential
				}
			}
			IF($oVirtSSHCredential){
				IF((Get-Command putty.exe -EA SilentlyContinue).Name -ne "putty.exe"){
					Write-Warning "Plink.exe NOT Installed. It is a part of the PuTTY suite, found here: https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html"
					BREAK
				}Else{
					$CmdToSSHInvokeFile = "$($Env:USERPROFILE)\putty_tmp.txt"
					#IF($PSCmdlet.ShouldProcess($oVirtServerName , "Open Putty SSH to oVirt")){
						$CmdToSSHInvoke = "ssh -i /etc/pki/ovirt-engine/keys/engine_id_rsa $($oHostName)"
						Write-Verbose "$($MyInvocation.MyCommand) CmdToSSHInvoke: [$($CmdToSSHInvoke)]"
						IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
						Set-Content -Value $CmdToSSHInvoke -Path $CmdToSSHInvokeFile -NoNewline
						$FirstCheckTime = Get-Date
						IF(!(Test-Path -Path $CmdToSSHInvokeFile)){DO{Start-Sleep -Milliseconds 500}Until((($FirstCheckTime).AddSeconds(3) -LT (Get-Date)) -OR (Test-Path -Path $CmdToSSHInvokeFile))}
						Write-Verbose "$($MyInvocation.MyCommand) Putty Invokation: [putty.exe -ssh -t -l root -pw <obscured for Security> -2 -4 $($oVirtServerName) -m $($CmdToSSHInvokeFile)]"
						putty.exe -ssh -t -l root -pw $($oVirtSSHCredential.GetNetworkCredential().Password) -2 -4 $oVirtServerName -m $CmdToSSHInvokeFile
						Start-Sleep -Milliseconds 500
					#}
					IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
				}
			}Else{
				Write-Warning "No Valid or Matching oVirtConnection or oVirtSSHCredential found to make connection(s)"
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Get-oHostFenceUri{
	<#
		.SYNOPSIS
			This function returns the provided fence agent(s) for oHost(KVM), on an oVirt Server system.
		.DESCRIPTION
			This function returns the provided fence agent(s) for oHost(KVM), on an oVirt Server system.
			This assumes fence agent(s) for oHost(KVM) are configured in oVirt Server system.
		.PARAMETER oHost
			The oHost object(s) 
		.EXAMPLE
			PS> Get-oHostFenceUri $oHost
				Returns the url to the fence agent(s) using the $oHost object
		.INPUTS
			[oHost]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		9/11/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	[Alias('OOHF')]
	Param(
		#oHost Name
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oHost'})]$oHost
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		$FenceAgentURLs = @()
		ForEach($Item in ($PSBoundParameters['oHost'])){
			$FenceAgents = (Get-oUri -RESTUri $Item.link.where({$_.rel -eq "fenceagents"}).href -oVirtServerName $Item.oVirtServer).agent
			IF($FenceAgents){Update-oVirtServer_LastUsedTime -oVirtServerName $Item.oVirtServer}
			$FenceAgentURLs += ($FenceAgents | %{"http://$($_.Address)/"})
		}
		IF($FenceAgentURLs.Count -eq 1){$FenceAgentURLs = $FenceAgentURLs[0]}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"; Return $FenceAgentURLs}
}

Function Open-oHostFenceUri{
	<#
		.SYNOPSIS
			This function Opens a browser to the provided fence agent(s) for oHost(KVM), on an oVirt Server system.
		.DESCRIPTION
			This function Opens a browser to the provided fence agent(s) for oHost(KVM), on an oVirt Server system.
			This assumes fence agent(s) for oHost(KVM) are configured in oVirt Server system.
		.PARAMETER oHost
			The oHost object(s) 
		.EXAMPLE
			PS> Open-oHostFenceUri $oHost
				Opens a browser to the fence agent(s) using the $oHost object
		.INPUTS
			[oHost]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/5/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	[Alias('OOHF')]
	Param(
		#oHost Name
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oHost'})]$oHost
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		ForEach($Item in ($PSBoundParameters['oHost'])){
			$FenceAgents = (Get-oUri -RESTUri $Item.link.where({$_.rel -eq "fenceagents"}).href -oVirtServerName $Item.oVirtServer).agent
			$FenceAgentAddresses = ($FenceAgents | %{$_.Address})
			ForEach($FenceAgentAddress in $FenceAgentAddresses){Start "http://$($FenceAgentAddress)/"}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Invoke-oHostSSHCommand{
	<#
		.SYNOPSIS
			This function Runs a console command over SSH on the provided oHost(KVM), on an oVirt Server system.
		.DESCRIPTION
			This function Runs a console command over SSH on the provided oHost(KVM), by hooping through an oVirt Server system, 
			using the SSH credentials found in the $oVirtConnections matching the provided (or discovered)
			oVirt name.
			This assumes Posh-SSH or Putty(plink) is installed.
			NOTE: OpenSSH is not an option because there’s no option or argument to bypass the password prompt with OpenSSH.
			NOTE: Added an option to go direct vs only through OLVM (this can accidentally run malformed command strings on OLVM instead of the oHost)
		.PARAMETER Name
			The Name(s) of oHost(s)
			Can use Wildcard '*'
		.PARAMETER Command
			The string to run on each oHost(KVM)
			To run multiple commands separate with a semi-colon
		.PARAMETER EnableKVMWebConsole
			Adds 'systemctl enable --now cockpit.socket' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER DisableKVMWebConsole
			Adds 'systemctl disable --now cockpit.socket' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER KVMWebConsoleStatus
			Adds 'systemctl status cockpit.socket' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER RestartWebEngine
			Adds 'systemctl restart httpd.service' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER RestartHostD
			Adds '/etc/init.d/hostd restart' to the Very bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER PowerControl
			Adds 'shutdown now --halt' or 'shutdown now --reboot' or 'shutdown now --poweroff' to the Very bottom of the commands to run on each oHost(KVM)
			Can be used alone
			Valid options Halt, Reboot, Shutdown
		.PARAMETER PoshForce
			Do not perform any host key validation of the host when Posh-SSH is the selection
		.PARAMETER Plink
			Use plink.exe instead of Posh-SSH
		.PARAMETER SSHAutoHostKeyAcceptance
			Auto Accepts New Host Keys if not stored
		.PARAMETER DelaySeconds
			The number of seconds to wait in between VMHosts Processed (if more that one)
		.PARAMETER Base64Encoding
			Switch to BASE64 Encode commands to send to oHost(s), to minimize shell interpreter formatting errors
		.PARAMETER oVirtRootPassword
			The Root Password for the oVirt Server, in clear text or secure string
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER oHostDirect
			Used to connect directly yo each oHost instead of using the oVirt Server's passthru feature
		.PARAMETER oHostRootPassword
			The Root Password for the oHost(KVM), in clear text or secure string
		.PARAMETER oHostSSHCredential
			The PSCredential to be used to connect to the -oHostServerName via SSH
			Default user name is 'root'
			This is for direct oHost connection instead of using the oVirt Server's passthru feature
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Invoke-oHostSSHCommand -oVirtServerName $oVirtServerName -Name "oHostName"
				Runs a console command over SSH on  the oHost(s)
		.EXAMPLE
			PS> Invoke-oHostSSHCommand -Name "oHostName"
				Runs a console command over SSH on the oHost(s) using the oVirt Server found connected
		.EXAMPLE
			PS> Invoke-oHostSSHCommand $oHost
				Runs a console command over SSH on the oHost(s) using the oVirt Server Name found in the $oHost object
		.EXAMPLE
			PS> Invoke-oHostSSHCommand -Name $oHost -Command 'cat /proc/meminfo | grep Huge'
				Retrieves the HugePages data for an $oHost Object (KVM Server)
		.INPUTS
			[System.String]
			[oHost]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/7/2024
			Version 1.0b	8/23/2024
			Version 1.0c	3/11/2025, added -RestartWebEngine
			Version 1.0d	8/14/2025, Change to Send Base64 encoded string to mitigate shell interpreter errors
			Version 1.0e	8/15/2025, Update Putty to version 0.83
			Version 1.1		10/4/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://www.chiark.greenend.7org.uk/~sgtatham/putty/
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	#[CmdletBinding(DefaultParameterSetName = 'Set01')]
	[Alias('IHC')]
	Param(
		#oHost Name
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			#[ValidateScript({($_).GetType().Name -match 'String|oHost'})]
			[PSObject[]]$Name,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Command to Run")]
			[System.String]$Command,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl enable --now cockpit.socket'")]
			[switch]$EnableKVMWebConsole,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl disable --now cockpit.socket'")]
			[switch]$DisableKVMWebConsole,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl status cockpit.socket'")]
			[switch]$KVMWebConsoleStatus,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl restart httpd.service'")]
			[switch]$RestartWebEngine,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs '/etc/init.d/hostd restart'")]
			[switch]$RestartHostD,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'shutdown now --halt' or 'shutdown now --reboot' or 'shutdown now --poweroff'")]
			[ValidateSet("Halt","Reboot","Shutdown")]
			[System.String]$PowerControl,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('PF')]
			[switch]$PoshForce,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Use plink.exe instead of Posh-SSH")]
			[switch]$Plink,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('AA')]
			[switch]$SSHAutoHostKeyAcceptance,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds Delay between Processing oHost(s).")]
			[INT]$DelaySeconds,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Use Base64 Encoding to transport command(s)")]
			[switch]$Base64Encoding,
			
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", HelpMessage="Root Password for oVirt Server.")]
			$oVirtRootPassword,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,
		
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[Alias('HD')]
			[switch]$oHostDirect,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", HelpMessage="Root Password for oHost(s).")]
			$oHostRootPassword,
		#SSH Credentials for oHost Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[System.Management.Automation.PSCredential]$oHostSSHCredential,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#IF(!(Get-Command Putty.exe -ErrorAction SilentlyContinue)){Write-Warning "Putty.exe not installed. Download from 'https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html'";BREAK}
	}
	Process{
		Function Read-Lines{
			Param (
				[parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)][string]$PromptText = "Enter Text"
			)
			$InputString = @()
			$ExecStr = 'Write-Host "$($PromptText): " -NoNewline'
			Write-Host -Fore Cyan "NOTE: Empty Return will End Text Entry"
			Do{
				Invoke-Expression $ExecStr
				$UserText = Read-Host
				$inputstring += ($UserText)
			}While ($UserText)
			Return $InputString
		}
		
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oVirtSSHCredential']){
				IF($($PSBoundParameters['oVirtSSHCredential']).GetNetworkCredential().password -ne ""){
					$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
					IF($PSBoundParameters['oVirtServerName']){
						($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
					}ElseIF(($oVirtConnections).count -eq 1){
						$oVirtServerName = $oVirtConnections[0].oVirtServerName
						$oVirtConnections[0].oVirtSSHCredential = $oVirtSSHCredential
					}
				}Else{$oVirtSSHCredential = $Null}
			}
			IF(!($oVirtSSHCredential)){
				IF($PSBoundParameters['oVirtServerName']){
					$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential
					$oVirtServerName = $PSBoundParameters['oVirtServerName']
				}ElseIF(($oVirtConnections).count -eq 1){
					$oVirtConnection = ($oVirtConnections[0])
					$oVirtSSHCredential = $oVirtConnection.oVirtSSHCredential
					$oVirtServerName = $oVirtConnection.Name
				}Else{
					#$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).oVirtSSHCredential
				}
			}
			
			IF(!($oVirtServerName)){Write-Warning "No oVirt Server available, quitting...";BREAK}
			
			IF((!($oVirtSSHCredential)) -AND ($oVirtServerName)){
				IF($PSBoundParameters.ContainsKey('oVirtRootPassword')){
					$UserName = 'root'
					SWITCH($PSBoundParameters['oVirtRootPassword']){
						{$_ -Is [System.String]}{$oVirtRootPassword = $oVirtRootPassword | ConvertTo-SecureString -AsPlainText -Force}
						{$_ -Is [System.Security.SecureString]}{$oVirtRootPassword = $PSBoundParameters['oVirtRootPassword']}
					}
					$oVirtSSHCredential = (New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList @($UserName,$oVirtRootPassword))
				}Else{
					$oVirtSSHCredential = (Get-Credential -UserName "root" -Message "Enter SSH Credential for oVirt Server [$($oVirtServerName)]")
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF((!($oHostSSHCredential)) -AND (($PSBoundParameters['oHostDirect']).IsPresent -eq $True)){
				IF($PSBoundParameters.ContainsKey('oHostRootPassword')){
					$UserName = 'root'
					SWITCH($PSBoundParameters['oHostRootPassword']){
						{$_ -Is [System.String]}{$oHostRootPassword = $oHostRootPassword | ConvertTo-SecureString -AsPlainText -Force}
						{$_ -Is [System.Security.SecureString]}{$oHostRootPassword = $PSBoundParameters['oHostRootPassword']}
					}
					$oHostSSHCredential = (New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList @($UserName,$oHostRootPassword))
				}Else{
					$oHostSSHCredential = (Get-Credential -UserName "root" -Message "Enter SSH Credential for oHost(s)")
				}
			}
		}
		IF(!(Get-Module Posh-SSH)){	IF(Get-Module -ListAvailable Posh-SSH){Import-Module Posh-SSH}Else{Write-Warning "PowerShell Module 'Posh-SSH' NOT Installed. It can be found here: https://www.powershellgallery.com/packages/Posh-SSH/"} }
		
		IF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF(!($oHostSSHCredential -is [PSCredential])){Write-Warning "No oHost SSH Credential could be created/validated, quitting...";BREAK}
		}Else{
			IF(!($oVirtSSHCredential -is [PSCredential])){Write-Warning "No oVirt SSH Credential could be created/validated, quitting...";BREAK}
		}

		IF(($oVirtSSHCredential) -OR ($oHostSSHCredential)){
			ForEach($Item in ($PSBoundParameters['Name'])){
				$CmdToSSHInvoke = $Null
				IF($PSBoundParameters.ContainsKey('Command')){
					$CmdToSSHInvoke = $PSBoundParameters['Command']
					#$CmdToSSHInvoke = $PSBoundParameters['Command'] -Replace "'","`'"
					#$CmdToSSHInvoke = $CmdToSSHInvoke -Replace "$","`$"
				}ElseIF(!(($PSBoundParameters['EnableKVMWebConsole']) -OR ($PSBoundParameters['DisableKVMWebConsole']) -OR ($PSBoundParameters['KVMWebConsoleStatus']) -OR ($PSBoundParameters['RestartWebEngine']) -OR ($PSBoundParameters['RestartHostD']) -OR ($PSBoundParameters['PowerControl']))){
					#$CmdToSSHInvoke = Read-Host -Prompt "Command to SSH to VMHost(s)"
					$CmdToSSHInvoke = (Read-Lines -PromptText "Command(s) to SSH to VMHost(s) <empty return quits>") -join " ; "
				}
				IF($EnableKVMWebConsole.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl enable --now cockpit.socket ; "}Else{$CmdToSSHInvoke += "systemctl enable --now cockpit.socket"}}
				IF($DisableKVMWebConsole.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl disable --now cockpit.socket ; "}Else{$CmdToSSHInvoke += "systemctl disable --now cockpit.socket"}}
				IF($KVMWebConsoleStatus.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl status cockpit.socket ; "}Else{$CmdToSSHInvoke += "systemctl status cockpit.socket"}}
				IF($RestartWebEngine.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl restart httpd.service ; "}Else{$CmdToSSHInvoke += "systemctl restart httpd.service"}}
				IF($RestartHostD.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; /etc/init.d/hostd restart ; "}Else{$CmdToSSHInvoke += "/etc/init.d/hostd restart"}}
				IF($PSBoundParameters.ContainsKey('PowerControl')){
					SWITCH(($PSBoundParameters['PowerControl'])){
						{$_ -eq "Halt"}{
								IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --halt ; "}Else{$CmdToSSHInvoke += "shutdown now --halt"}
							}
						{$_ -eq "Reboot"}{
								IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --reboot ; "}Else{$CmdToSSHInvoke += "shutdown now --reboot"}
							}
						{$_ -eq "Shutdown"}{
								IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --poweroff ; "}Else{$CmdToSSHInvoke += "shutdown now --poweroff"}
							}
					}
				}
				IF(!($CmdToSSHInvoke)){Write-Warning "No command(s) entered, quitting...";BREAK}
		
				$oHostName = $Null
				IF(($Item).GetType().Name -eq "oHost"){
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oHost]"
					Write-Verbose "$($MyInvocation.MyCommand) [$(($PSBoundParameters['Name']).oVirtServer)]"
					$PSBoundParameters['oVirtServerName'] = $(($Item).oVirtServer)
					$oHostName = $(($Item).Name)
				}Else{
					$oHostName = $(($Item))
				}
				IF(!($oHostName)){Write-Warning "No oHost(s) selected, quitting...";BREAK}
				<#
					Execute single command
						Let us execute uname command over SSH.
						$ ssh linuxtechi@192.168.10.10 uname
						
					Execute multiple commands
						$ ssh linuxtechi@192.168.10.10 "uname;hostname;date"
					
					Execute command with elevated privileges
						$ ssh -t linuxtechi@192.168.10.10 sudo touch /etc/banner.txt
							Note that we have used ‘-t‘ option with SSH, which allows pseudo-terminal allocation. sudo command requires interactive terminal hence this option is necessary.
					
					Execute script
						$ chmod +x system-info.sh
						$ ssh linuxtechi@192.168.10.10 ./system-info.sh
						
					To Make the next line of code dependent on the success of the last line in Bash Shell separate with && instead of ; 
				#>
				<#
					#Using putty.exe to execute example, needs a local tmp file to store commands
					$CmdToSSHInvokeFile = "$($Env:USERPROFILE)\putty_tmp.txt"
					IF($PSCmdlet.ShouldProcess($oHostName , "Run SSH commands through oVirt [$($oVirtServerName)] on oHost [$($oHostName)]")){
						$CmdToSSHInvoke = "ssh -i /etc/pki/ovirt-engine/keys/engine_id_rsa $($oHostName)"
						IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
						Set-Content -Value $CmdToSSHInvoke -Path $CmdToSSHInvokeFile -NoNewLine
						$FirstCheckTime = Get-Date
						IF(!(Test-Path -Path $CmdToSSHInvokeFile)){DO{Start-Sleep -Milliseconds 500}Until((($FirstCheckTime).AddSeconds(3) -LT (Get-Date)) -OR (Test-Path -Path $CmdToSSHInvokeFile))}
						putty.exe -ssh -t -l root -pw $($oVirtSSHCredential.GetNetworkCredential().Password) -2 -4 $oVirtServerName -m $CmdToSSHInvokeFile
						Start-Sleep -Milliseconds 500
					}
					IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
				#>
				<#
					Here I want to Convert $CmdToSSHInvoke to a Base64 Encoded String and preface with a decode command

					Method 1:
					#Convert $MyString to Byte Array
					$ByteArray = $Null; $ByteArray = ([System.Text.UTF8Encoding]::New()).Getbytes($MyString)
					#Convert Byte Array to Base64String
					$Base64String = $Null; $Base64String = [Convert]::ToBase64String($ByteArray)

					Method 2:
					$MemoryStream = New-Object System.IO.MemoryStream
					$CompressedStream = New-Object System.IO.Compression.GZipStream($MemoryStream,
					[System.IO.Compression.CompressionMode]::Compress)
					$StreamWriter = New-Object System.IO.StreamWriter($CompressedStream)
					$StreamWriter.Write($Stream)
					$StreamWriter.Close();
					$Base64String = $Null; $Base64String = [System.Convert]::ToBase64String($MemoryStream.ToArray())


					#Convert $CmdToSSHInvoke to Byte Array
					$ByteArray = $Null; $ByteArray = ([System.Text.UTF8Encoding]::New()).Getbytes($CmdToSSHInvoke)
					#Convert Byte Array to Base64String
					$Base64EncodedCmdToSSHInvoke = $Null; $Base64EncodedCmdToSSHInvoke = [Convert]::ToBase64String($ByteArray)
					#This should work
					$CmdToSSHInvoke = "echo $($Base64EncodedCmdToSSHInvoke) | base64 --decode | sh"


					Linux Convert back
					# 'string' variable contains a base64 encoded command
					command=$(base64 -d <<< "$string"); decode_status=$?
					# run the command only if decode was successful
					# we shouldn't enclose $command in double quotes in this case
					[[ $decode_status == 0 ]] && $command


					#This doesn't work great(at all)
					$RemoteCommand = "`'" +  'command=$(base64 -d <<< "' + $Base64String + '"); decode_status=$? ; [[ $decode_status == 0 ]] && $command' + "`'"
					or
					base64 -D <<< bHMgLWwgLwo= | sh

					$RemoteCommand = "`'" +  'base64 -d <<< "' + $Base64String + '" | sh' + "`'"
				#>				
				IF($Base64Encoding){
					#Convert $CmdToSSHInvoke to Byte Array
					$ByteArray = $Null; $ByteArray = ([System.Text.UTF8Encoding]::New()).Getbytes($CmdToSSHInvoke)
					#Convert Byte Array to Base64String
					$Base64EncodedCmdToSSHInvoke = $Null; $Base64EncodedCmdToSSHInvoke = [Convert]::ToBase64String($ByteArray)
					#This should work, Might need quote encapsulation, need to test
					# c2h1dGRvd24gbm93IC0tcG93ZXJvZmY=
					$CmdToSSHInvoke = "`'echo $($Base64EncodedCmdToSSHInvoke) | base64 --decode | sh`'"
				}
				IF($oVirtSSHCredential){
					$oVirtBaseCmdToSSHInvoke = "ssh -i /etc/pki/ovirt-engine/keys/engine_id_rsa $($oHostName)"
					$CmdToSSHInvoke = $oVirtBaseCmdToSSHInvoke + " " + $CmdToSSHInvoke
				}
				IF((Get-Module Posh-SSH -EA SilentlyContinue) -AND (!($PLINK.IsPresent -eq $True))){
					IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
						#$CmdToSSHInvoke = "echo yes | " + $CmdToSSHInvoke
						$CmdToSSHInvoke = $CmdToSSHInvoke -Replace "ssh ", "ssh -o StrictHostKeyChecking=accept-new "
					}
					Write-Verbose "`$CmdToSSHInvoke: [$($CmdToSSHInvoke)]"
				
					$Session = $NULL; $SSHError = $NULL; $ID = $NULL; 
					IF($PSBoundParameters['PoshForce'].IsPresent -eq $True){
						IF($oVirtSSHCredential){
							IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
								TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}Else{
								TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}
						}ElseIF($oHostSSHCredential){
							IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
								TRY{$Session = New-SSHSession -ComputerName $oHostName -Credential $oHostSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}Else{
								TRY{$Session = New-SSHSession -ComputerName $oHostName -Credential $oHostSSHCredential -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}

						}
					}Else{
						IF($oVirtSSHCredential){
							IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
								TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}Else{
								TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}
						}ElseIF($oHostSSHCredential){
							IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
								TRY{$Session = New-SSHSession -ComputerName $oHostName -Credential $oHostSSHCredential -AcceptKey:$True -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}Else{
								TRY{$Session = New-SSHSession -ComputerName $oHostName -Credential $oHostSSHCredential -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
							}
						}
					}
					IF($Session){
						$ID = $Session.SessionID
					}ElseIf($SSHError.Exception.Message -Match "Permission denied"){
						Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed. ["; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow "]"
					}Else{
						Write-Host -NoNewLine -Fore Yellow "`tFirst Attempt Opening SSH via Posh-SSH Failed. "; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow ", Attempting a second time."
						IF($oVirtSSHCredential){
							$Session = $NULL; $SSHError = $NULL; $Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError
						}ElseIF($oHostSSHCredential){
							$Session = $NULL; $SSHError = $NULL; $Session = New-SSHSession -ComputerName $oHostName -Credential $oHostSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError
						}
						IF($Session){
							$ID = $Session.SessionID
						}Else{
							Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed a Second Time, even using 'Force' (Do not perform any host key validation of the host.). "; Write-Host -Fore RED "$($SSHError.Exception.Message)"
						}
					}
					IF($Session.Connected -eq $True){
						Write-Host -NoNewLine -Fore Green "`tConnected to ["; Write-Host -NoNewLine "$($Session.Host)"; Write-Host -Fore Green "] via SSH"
						IF($PSCmdlet.ShouldProcess($oHostName , "Run Provided Command(s) via SSH on oHost")){
							#Write-Host -NoNewLine -Fore Cyan "`t`$CmdToSSHInvoke: "; Write-Host "$($CmdToSSHInvoke | Out-String)"
							Write-Verbose "`t`$CmdToSSHInvoke: $($CmdToSSHInvoke | Out-String)"
							Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -Fore Cyan "]"
							$Return = Invoke-SSHCommand -SessionId $ID -Command $($CmdToSSHInvoke)
							IF(($Return.ExitStatus -eq 255) -And (!$Return.Output)){
								Write-Warning "No OutPut Response, suggest retry with param -SSHAutoHostKeyAcceptance"
							}Else{
								$Return.Output
							}
						}
					}ElseIF($Session){Write-Host -Fore Red "`tSSH Connect to Posh-SSH Session Failed."}
				}Else{
					#Determine if Putty (plink.exe, specifically) is installed and avaiable in the path
					Try{[void](Invoke-Command {plink.exe}); $PlinkPath = "plink.exe"}catch{
						<#
						IF(!($PlinkPath)){
							#$PlinkPath = "D:\Utilities\Putty\v0.63 beta\putty\PLINK.EXE"
							$PlinkPath = (((Get-Location).Path).Trim('\'))+"\plink.exe"
							IF(!(Test-Path $PlinkPath)){
								$DeletePlink = $True
								#Convert-FileToBase64String -FilePath "C:\Program Files\PuTTY\plink.exe" -OutPutVariableName PlinkAsText -ToClipBoard
								$PlinkAsText = ''
								$PEBytes = [System.Convert]::FromBase64String($PlinkAsText)
								#Write to Disk (tmp location)
								[System.IO.File]::WriteAllBytes($PlinkPath,$PEBytes)
							}
						}
						#>
						Write-Warning "Plink.exe NOT Installed. It is a part of the PuTTY suite, found here: https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html"
						BREAK
					}
					#Set up plink.exe commands
					$PlinkPath = "plink.exe"
					$PlinkPath = ".\plink.exe"
					#Not Sure 'batch' mode needed, interefers with auto accepting host keys
					#$plinkoptions = "-v -batch -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
					#$plinkoptions = "-batch -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
					IF($oVirtSSHCredential){
						$plinkoptions = "-v -ssh -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
					}ElseIF($oHostSSHCredential){
						$plinkoptions = "-v -ssh -pw `'$($oHostSSHCredential.GetNetworkCredential().Password)`'"
					}
					$RemoteCommand = "`'" + $CmdToSSHInvoke + "`'"
					Write-Verbose "`t`$RemoteCommand: $($RemoteCommand)"
					Write-Debug "`t`$RemoteCommand: [$($RemoteCommand)]"
					IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
						IF($oVirtSSHCredential){
							$PlinkCommand = "echo y | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand
						}ElseIF($oHostSSHCredential){
							$PlinkCommand = "echo y | " + $PlinkPath + " " + $plinkoptions + " root@" + $oHostName + " " + $RemoteCommand
						}
					}Else{
						IF($oVirtSSHCredential){
							$PlinkCommand = "echo n | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand
						}ElseIF($oHostSSHCredential){
							$PlinkCommand = "echo n | " + $PlinkPath + " " + $plinkoptions + " root@" + $oHostName + " " + $RemoteCommand
						}
					}
					Write-Verbose "`t`$PlinkCommand: $($PlinkCommand)"
					Write-Debug "`t`$PlinkCommand: [$($PlinkCommand)]"
					$DeletePlink = $False; $PlinkPath = $Null
					IF($PSCmdlet.ShouldProcess($oHostName , "Run Provided Command(s) via SSH on oHost")){
						#Invoke-Expression -command $PlinkCommand -EA SilentlyContinue | Out-Null
						#Invoke-Command -ScriptBlock {$RawOutput = $Null; $RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue}  2>$null 3>$null 5>$null
						IF($oVirtSSHCredential){
							Write-Host -NoNewLine -Fore Green "`tConnecting to ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Green "] via SSH"
						}ElseIF($oHostSSHCredential){
							Write-Host -NoNewLine -Fore Green "`tConnecting to ["; Write-Host -NoNewLine "$($oHostName)"; Write-Host -Fore Green "] via SSH"
						}
						Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -Fore Cyan "]"
						$global:RawOutput = $Null; $global:RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue  2>$null 3>$null 5>$null
						$global:RawOutput
					}
					IF(($DeletePlink -eq $True) -AND ($PlinkAsText)){IF(Test-Path $PlinkPath -EA SilentlyContinue){Remove-Item $PlinkPath -Confirm:$False}}
				}
				
				IF(($PSBoundParameters['DelaySeconds']) -AND ($PSBoundParameters['DelaySeconds'] -GT 0) -AND ($($PSBoundParameters['Name']).Count -gt 1) -AND (([ARRAY]::IndexOf(($PSBoundParameters['Name']),$Item) +1) -lt $($PSBoundParameters['Name']).Count)){
					Write-Host -NoNewLine -Fore Cyan "`tSleeping ["; Write-Host -NoNewLine "$($PSBoundParameters['DelaySeconds'])"; Write-Host -Fore Cyan "] Seconds, In Between oHosts"
					Start-Sleep -Seconds $PSBoundParameters['DelaySeconds']
				}
			}
		}Else{
			Write-Warning "No Valid or Matching oVirtConnection or oVirtSSHCredential found to make connection(s)"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Invoke-oVirtSSHCommand{
	<#
		.SYNOPSIS
			This function Runs a console command over SSH on the provided oVirt Server system.
		.DESCRIPTION
			This function Runs a console command over SSH on the provided oVirt Server system, 
			using the SSH credentials found in the $oVirtConnections matching the provided (or discovered)
			oVirt name.
			This assumes Posh-SSH or Putty(plink) is installed.
			NOTE: OpenSSH is not an option because there’s no option or argument to bypass the password prompt with OpenSSH.
		.PARAMETER Command
			The string to run on each oHost(KVM)
			To run multiple commands separate with a semi-colon
		.PARAMETER sudo
			Run Command as 'sudo', must already be configured for login account
		.PARAMETER RestartoVirtWebEngine
			Adds 'systemctl restart httpd.service' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER RestartoVirtEngine
			Adds 'systemctl restart ovirt-engine' to the bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER RestartHostD
			Adds '/etc/init.d/hostd restart' to the Very bottom of the commands to run on each oHost(KVM)
			Can be used alone
		.PARAMETER PowerControl
			Adds 'shutdown now --halt' or 'shutdown now --reboot' or 'shutdown now --poweroff' to the Very bottom of the commands to run on each oHost(KVM)
			Can be used alone
			Valid options Halt, Reboot, Shutdown
		.PARAMETER PoshForce
			Do not perform any host key validation of the host when Posh-SSH is the selection
		.PARAMETER Plink
			Use plink.exe instead of Posh-SSH
		.PARAMETER EncodePlink
			Some complex commands to send, like handling both Windows & Linux escape characters for multiple nested single and double quotes
			can be very difficult for plink.exe to handle. So this switch causes the command string to be encoded on the sender, then decoded and executed 
			on the remove Linux system, which has proven to be more reliable.
		.PARAMETER SSHAutoHostKeyAcceptance
			Auto Accepts New Host Keys if not stored
		.PARAMETER ShowCommand
			Shows command(s) to be run on screen. Caution May display passwords if included in -Command Input parameter
		.PARAMETER oVirtRootPassword
			The Root Password for the oVirt Server, in clear text or secure string
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "hostname" -Confirm:0
				Runs a console command over SSH on the oVirtServerName(s) using the credential stored in the connection manager
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "hostname" -oVirtSSHCredential (Get-Credential -UserName "root" -Message "Enter SSH Credential for oVirt Server [$($oVirtServerName)]") -Confirm:0
				Saves the provided Credential in the connection manager then
				Runs a console command over SSH on the oVirtServerName(s) using the credential stored in the connection manager
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "hostname" -oVirtRootPassword "SomeRootPassword or Password Saved as a [System.Security.SecureString]"
				Saves the provided oVirtRootPassword in the connection manager with username 'root', then
				Runs a console command over SSH on the oVirtServerName(s) using the credential stored in the connection manager
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "whoami" -oVirtSSHCredential (Get-Credential -UserName "SamAccountName@ADDomain.net" -Message "Enter AD Credential to SSH to oVirt Server [$($oVirtServerName)]") -Confirm:0
				Saves the provided Credential in the connection manager then
				Runs a console command over SSH on the oVirtServerName(s) using the credential stored in the connection manager
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "engine-config -g UserSessionTimeOutInterval" -Confirm:0
				Runs a console command to retrieve the current Web UI & REST API UserSessionTimeOutInterval over SSH on the oVirtServerName(s) 
				using the credential stored in the connection manager
		.EXAMPLE
			PS> Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Command "engine-config -s UserSessionTimeOutInterval=30; systemctl restart ovirt-engine"
				Runs a console command to set the current Web UI & REST API UserSessionTimeOutInterval to 30 minutes (default) over SSH on the oVirtServerName(s) 
				using the credential stored in the connection manager
				Changing the value should also require editting this module to the new value for all instances of $TokenTypicalTimeOutMinutes = 30
		.INPUTS
			[System.String]
			[oVirtConnection]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		3/25/2025
			Version 1.1		8/15/2025 Update Putty to v0.83
			Version 1.2		10/4/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://www.powershellgallery.com/packages/Posh-SSH
			https://www.chiark.greenend.7org.uk/~sgtatham/putty/
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	#[CmdletBinding(DefaultParameterSetName = 'Set01')]
	[Alias('IOC')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Command to Run")]
			[System.String]$Command,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Run Command as 'sudo'")]
			[switch]$sudo,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl restart httpd.service'")]
			[switch]$RestartoVirtWebEngine,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'systemctl restart ovirt-engine'")]
			[switch]$RestartoVirtEngine,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs '/etc/init.d/hostd restart'")]
			[switch]$RestartHostD,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Runs 'shutdown now --halt' or 'shutdown now --reboot' or 'shutdown now --poweroff'")]
			[ValidateSet("Halt","Reboot","Shutdown")]
			[System.String]$PowerControl,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('PF')]
			[switch]$PoshForce,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Use plink.exe instead of Posh-SSH")]
			[switch]$Plink,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[switch]$EncodePlink,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('AA')]
			[switch]$SSHAutoHostKeyAcceptance,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SC')]
			[switch]$ShowCommand,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", HelpMessage="Root Password for oVirt Server.")]
			$oVirtRootPassword,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,
		
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, HelpMessage="oVirtServerName (Name or IP)", Position=0)]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#IF(!(Get-Command Putty.exe -ErrorAction SilentlyContinue)){Write-Warning "Putty.exe not installed. Download from 'https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html'";BREAK}
	}
	Process{
		Function Read-Lines{
			Param (
				[parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)][string]$PromptText = "Enter Text"
			)
			$InputString = @()
			$ExecStr = 'Write-Host "$($PromptText): " -NoNewline'
			Write-Host -Fore Cyan "NOTE: Empty Return will End Text Entry"
			Do{
				Invoke-Expression $ExecStr
				$UserText = Read-Host
				$inputstring += ($UserText)
			}While ($UserText)
			Return $InputString
		}
		
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oVirtSSHCredential']){
				IF($($PSBoundParameters['oVirtSSHCredential']).GetNetworkCredential().password -ne ""){
					$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
					IF($PSBoundParameters['oVirtServerName']){
						($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
					}ElseIF(($oVirtConnections).count -eq 1){
						$oVirtServerName = $oVirtConnections[0].oVirtServerName
						$oVirtConnections[0].oVirtSSHCredential = $oVirtSSHCredential
					}
				}Else{$oVirtSSHCredential = $Null}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters.ContainsKey('oVirtRootPassword')){
				$UserName = 'root'
				SWITCH($PSBoundParameters['oVirtRootPassword']){
					{$_ -Is [System.String]}{$oVirtRootPassword = $oVirtRootPassword | ConvertTo-SecureString -AsPlainText -Force}
					{$_ -Is [System.Security.SecureString]}{$oVirtRootPassword = $PSBoundParameters['oVirtRootPassword']}
				}
				$oVirtSSHCredential = (New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList @($UserName,$oVirtRootPassword))
				IF($PSBoundParameters['oVirtServerName']){
					$oVirtServerName = $PSBoundParameters['oVirtServerName']
					($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
				}ElseIF(($oVirtConnections).count -eq 1){
					($oVirtConnections[0]).oVirtSSHCredential = $oVirtSSHCredential
					$oVirtServerName = ($oVirtConnections[0]).Name
				}
			}
		}
		
		IF(!($oVirtSSHCredential)){
			IF($PSBoundParameters['oVirtServerName']){
				$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential
				$oVirtServerName = $PSBoundParameters['oVirtServerName']
			}ElseIF(($oVirtConnections).count -eq 1){
				$oVirtConnection = ($oVirtConnections[0])
				$oVirtSSHCredential = $oVirtConnection.oVirtSSHCredential
				$oVirtServerName = $oVirtConnection.Name
			}
		}
		
		IF(!($oVirtServerName)){Write-Warning "No oVirt Server available, quitting...";BREAK}
		
		IF((!($oVirtSSHCredential)) -AND ($oVirtServerName)){$oVirtSSHCredential = (Get-Credential -UserName "root" -Message "Enter SSH Credential for oVirt Server [$($oVirtServerName)]")}
		
		IF(!(Get-Module Posh-SSH)){	IF(Get-Module -ListAvailable Posh-SSH){Import-Module Posh-SSH}Else{Write-Warning "PowerShell Module 'Posh-SSH' NOT Installed. It can be found here: https://www.powershellgallery.com/packages/Posh-SSH/"} }
		
		IF($oVirtSSHCredential){
			$CmdToSSHInvoke = $Null
			IF($PSBoundParameters.ContainsKey('Command')){
				$CmdToSSHInvoke = $PSBoundParameters['Command']
				#$CmdToSSHInvoke = $PSBoundParameters['Command'] -Replace "'","`'"
				#$CmdToSSHInvoke = $CmdToSSHInvoke -Replace "$","`$"
			}ElseIF(!(($PSBoundParameters['RestartoVirtWebEngine']) -OR ($PSBoundParameters['RestartoVirtEngine']) -OR ($PSBoundParameters['RestartHostD']))){
				#$CmdToSSHInvoke = Read-Host -Prompt "Command to SSH to VMHost(s)"
				$CmdToSSHInvoke = (Read-Lines -PromptText "Command(s) to SSH to VMHost(s) <empty return quits>") -join " ; "
			}
			IF($RestartoVirtWebEngine.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl restart httpd.service ; "}Else{$CmdToSSHInvoke += "systemctl restart httpd.service"}}
			IF($RestartoVirtEngine.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; systemctl restart ovirt-engine ; "}Else{$CmdToSSHInvoke += "systemctl restart ovirt-engine"}}
			IF($RestartHostD.IsPresent -eq $True){IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; /etc/init.d/hostd restart ; "}Else{$CmdToSSHInvoke += "/etc/init.d/hostd restart"}}
			IF($PSBoundParameters.ContainsKey('PowerControl')){
				SWITCH(($PSBoundParameters['PowerControl'])){
					{$_ -eq "Halt"}{
							IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --halt ; "}Else{$CmdToSSHInvoke += "shutdown now --halt"}
						}
					{$_ -eq "Reboot"}{
							IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --reboot ; "}Else{$CmdToSSHInvoke += "shutdown now --reboot"}
						}
					{$_ -eq "Shutdown"}{
							IF($CmdToSSHInvoke){$CmdToSSHInvoke = ($CmdToSSHInvoke).Trim(' ; ').Trim(' ;').Trim(' ;').Trim(';') + " ; shutdown now --poweroff ; "}Else{$CmdToSSHInvoke += "shutdown now --poweroff"}
						}
				}
			}
			IF(!($CmdToSSHInvoke)){Write-Warning "No command(s) entered, quitting...";BREAK}
	
			<#
				Execute single command
					Let us execute uname command over SSH.
					$ ssh linuxtechi@192.168.10.10 uname
					
				Execute multiple commands
					$ ssh linuxtechi@192.168.10.10 "uname;hostname;date"
				
				Execute command with elevated privileges
					$ ssh -t linuxtechi@192.168.10.10 sudo touch /etc/banner.txt
						Note that we have used ‘-t‘ option with SSH, which allows pseudo-terminal allocation. sudo command requires interactive terminal hence this option is necessary.
				
				Execute script
					$ chmod +x system-info.sh
					$ ssh linuxtechi@192.168.10.10 ./system-info.sh
					
				To Make the next line of code dependent on the success of the last line in Bash Shell separate with && instead of ; 
			#>
			<#
				#Using putty.exe to execute example, needs a local tmp file to store commands
				$CmdToSSHInvokeFile = "$($Env:USERPROFILE)\putty_tmp.txt"
				IF($PSCmdlet.ShouldProcess($oHostName , "Run SSH commands through oVirt [$($oVirtServerName)] on oHost [$($oHostName)]")){
					$CmdToSSHInvoke = "ssh -i /etc/pki/ovirt-engine/keys/engine_id_rsa $($oHostName)"
					IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
					Set-Content -Value $CmdToSSHInvoke -Path $CmdToSSHInvokeFile -NoNewLine
					$FirstCheckTime = Get-Date
					IF(!(Test-Path -Path $CmdToSSHInvokeFile)){DO{Start-Sleep -Milliseconds 500}Until((($FirstCheckTime).AddSeconds(3) -LT (Get-Date)) -OR (Test-Path -Path $CmdToSSHInvokeFile))}
					putty.exe -ssh -t -l root -pw $($oVirtSSHCredential.GetNetworkCredential().Password) -2 -4 $oVirtServerName -m $CmdToSSHInvokeFile
					Start-Sleep -Milliseconds 500
				}
				IF(Test-Path -Path $CmdToSSHInvokeFile){Remove-Item -Path $CmdToSSHInvokeFile -Confirm:0 -EA SilentlyContinue -Force}
			#>
			
			IF($PSBoundParameters['sudo'].IsPresent -eq $True){$CmdToSSHInvoke = "export HISTFILE=/dev/null ; HISTCONTROL=ignorespace ;   echo '$($oVirtCredential.GetNetworkCredential().Password)' | sudo -S " + $CmdToSSHInvoke}
			IF((Get-Module Posh-SSH -EA SilentlyContinue) -AND (!($PLINK.IsPresent -eq $True))){
				Write-Verbose "`$CmdToSSHInvoke: [$($CmdToSSHInvoke)]"
			
				$Session = $NULL; $SSHError = $NULL; $ID = $NULL; 
				IF($PSBoundParameters['PoshForce'].IsPresent -eq $True){
					IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
						Write-Verbose "SSHAutoHostKeyAcceptance is Present"
						TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
					}Else{
						Write-Verbose "SSHAutoHostKeyAcceptance is UnSet"
						TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
					}
				}Else{
					IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
						Write-Verbose "SSHAutoHostKeyAcceptance is Present"
						TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
					}Else{
						Write-Verbose "SSHAutoHostKeyAcceptance is UnSet"
						TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -ErrorAction SilentlyContinue -ErrorVariable SSHError}Catch{}
					}
				}
				IF($Session){
					$ID = $Session.SessionID
				}ElseIf($SSHError.Exception.Message -Match "Permission denied"){
					Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed. ["; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow "]"
				}Else{
					Write-Host -NoNewLine -Fore Yellow "`tFirst Attempt Opening SSH via Posh-SSH Failed. "; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow ", Attempting a second time."
					$Session = $NULL; $SSHError = $NULL; $Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError
					IF($Session){
						$ID = $Session.SessionID
					}Else{
						Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed a Second Time, even using 'Force' (Do not perform any host key validation of the host.). "; Write-Host -Fore RED "$($SSHError.Exception.Message)"
					}
				}
				IF($Session.Connected -eq $True){
					Write-Host -NoNewLine -Fore Green "`tConnected to ["; Write-Host -NoNewLine "$($Session.Host)"; Write-Host -Fore Green "] via Posh-SSH"
					IF($PSCmdlet.ShouldProcess($oVirtServerName , "Run Provided Command(s) via SSH on oVirt Server")){
						IF($PSBoundParameters['ShowCommand'].IsPresent -eq $True){
							#Write-Host -NoNewLine -Fore Cyan "`t`$CmdToSSHInvoke: "; Write-Host "$($CmdToSSHInvoke | Out-String)"
							Write-Verbose "`t`$CmdToSSHInvoke: $($CmdToSSHInvoke | Out-String)"
							Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -Fore Cyan "]"
						}
						$Return = Invoke-SSHCommand -SessionId $ID -Command $($CmdToSSHInvoke)
						IF(($Return.ExitStatus -eq 255) -And (!$Return.Output)){
							Write-Warning "No OutPut Response, suggest retry with param -SSHAutoHostKeyAcceptance"
						}Else{
							$Return.Output
						}
					}
				}ElseIF($Session){Write-Host -Fore Red "`tSSH Connect to Posh-SSH Session Failed."}
			}Else{
				#Determine if Putty (plink.exe, specifically) is installed and avaiable in the path
				Try{[void](Invoke-Command {plink.exe}); $PlinkPath = "plink.exe"}catch{
					<#
					IF(!($PlinkPath)){
						#$PlinkPath = "D:\Utilities\Putty\v0.63 beta\putty\PLINK.EXE"
						$PlinkPath = (((Get-Location).Path).Trim('\'))+"\plink.exe"
						IF(!(Test-Path $PlinkPath)){
							$DeletePlink = $True
							#Convert-FileToBase64String -FilePath "C:\Program Files\PuTTY\plink.exe" -OutPutVariableName PlinkAsText -ToClipBoard
							$PlinkAsText = ''
							$PEBytes = [System.Convert]::FromBase64String($PlinkAsText)
							#Write to Disk (tmp location)
							[System.IO.File]::WriteAllBytes($PlinkPath,$PEBytes)
						}
					}
					#>
					Write-Warning "Plink.exe NOT Installed. It is a part of the PuTTY suite, found here: https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html"
					BREAK
				}
				#Set up plink.exe commands
				$PlinkPath = "plink.exe"
				#$PlinkPath = ".\plink.exe"
				Write-Verbose "Plink.exe Version: [$(plink -V)]"
				#Not Sure 'batch' mode needed, interefers with auto accepting host keys
				#$plinkoptions = "-v -batch -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
				#$plinkoptions = "-batch -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
				$plinkoptions = "-v -ssh -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"
				Write-Verbose "`$CmdToSSHInvoke: [$($CmdToSSHInvoke)]"
				IF($PSBoundParameters['EncodePlink'].IsPresent -eq $True){
					#Convert $CmdToSSHInvoke to Byte Array
					$ByteArray = $Null; $ByteArray = ([System.Text.UTF8Encoding]::New()).Getbytes($CmdToSSHInvoke)
					#Convert Byte Array to Base64String
					$Base64String = $Null; $Base64String = [Convert]::ToBase64String($ByteArray)
					#$RemoteCommand = "`'" +  'base64 -d <<< "' + $Base64String + '" | sh' + "`'"
					#The '<' operator is reserved for future use.
					#$RemoteCommand = "`'" +  'echo -n "' + $Base64String + '" | base64 --decode | sh' + "`'"
					$RemoteCommand = "`'echo -n `"$($Base64String)`" | base64 --decode | sh`'"
				}Else{
					$RemoteCommand = "`'" + $CmdToSSHInvoke + "`'"
				}
				Write-Verbose "`t`$RemoteCommand: $($RemoteCommand)"
				Write-Debug "`t`$RemoteCommand: [$($RemoteCommand)]"
				IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
					Write-Verbose "SSHAutoHostKeyAcceptance is Present"
					$PlinkCommand = "echo y | " + $PlinkPath + " " + $plinkoptions + " $($oVirtSSHCredential.UserName)@" + $oVirtServerName + " " + $RemoteCommand
				}Else{
					Write-Verbose "SSHAutoHostKeyAcceptance is UnSet"
					$PlinkCommand = "echo n | " + $PlinkPath + " " + $plinkoptions + " $($oVirtSSHCredential.UserName)@" + $oVirtServerName + " " + $RemoteCommand
				}
				Write-Verbose "`t`$PlinkCommand: $($PlinkCommand)"
				Write-Debug "`t`$PlinkCommand: [$($PlinkCommand)]"
				$DeletePlink = $False; $PlinkPath = $Null
				IF($PSCmdlet.ShouldProcess($oVirtServerName , "Run Provided Command(s) via SSH on oVirt Server")){
					#Invoke-Expression -command $PlinkCommand -EA SilentlyContinue | Out-Null
					#Invoke-Command -ScriptBlock {$RawOutput = $Null; $RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue}  2>$null 3>$null 5>$null
					Write-Host -NoNewLine -Fore Green "`tConnecting to ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Green "] via Plink.exe SSH"
					IF($PSBoundParameters['ShowCommand'].IsPresent -eq $True){Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -Fore Cyan "]"}
					IF($PSCmdlet.MyInvocation.BoundParameters["Verbose"].IsPresent -eq $True){
						$global:RawOutput = $Null; $global:RawOutput = Invoke-Expression -command $PlinkCommand
					}Else{
						$global:RawOutput = $Null; $global:RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue  2>$null 3>$null 5>$null
					}
					$global:RawOutput
				}
				IF(($DeletePlink -eq $True) -AND ($PlinkAsText)){IF(Test-Path $PlinkPath -EA SilentlyContinue){Remove-Item $PlinkPath -Confirm:$False}}
			}
		}Else{
			Write-Warning "No Valid or Matching oVirtConnection or oVirtSSHCredential found to make connection(s)"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Get-AuthenticatedSession{
	<#
		.SYNOPSIS
			This function connects to the REST API Interface on an oVirt Server system, using authentication session.
		.DESCRIPTION
			This function connects to the REST API Interface on an oVirt Server system, using authentication session.
			Send an initial request with authentication details, then send all subsequent requests using a session cookie to authenticate.
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtCredential
			The PSCredential to be used to connect to the -oVirtServerName
			
			This trys to build a proper OLVM UserName based on the local admin where KeyCloak is NOT used
			$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
			
			This trys to build a proper OLVM UserName based on the local admin where KeyCloak IS used
			$oVirtCredential = (Get-Credential -UserName 'admin@ovirt' -Message "Enter Password for $($oVirtServerName)")
			
			When using AD ldap the user name needs to be submitted in the format: SamAccountName@ADForrest@ADDomain
			
			This trys to build a proper LDAP UserName based on the logged in user and Active Directory Domain
			$oVirtCredential = (Get-Credential -UserName "$(([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.userprincipalname)@$(((((([ADSISEARCHER]"samaccountname=$(($Env:UserName).ToLower())").Findone().Properties.distinguishedname).split(',') | ?{$_ -Match 'DC='}) -Join ',').Split('DC=').Trim(',')|?{$_}) -Join '.')" -Message "Enter Password for $($oVirtServerName)")
		.EXAMPLE
			PS> $JSESSION = Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCredential]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/19/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#_authentication_sessions
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'None')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		#Credentials for oVirt Server (admin@internal is the default user on non KeyCloak authentication servers)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[System.Management.Automation.PSCredential]$oVirtCredential = 'admin@internal'
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		$UserName = $oVirtCredential.GetNetworkCredential().UserName
			Write-Verbose "User Name: $UserName"
		$UserPassword = $oVirtCredential.GetNetworkCredential().Password
		$UserDomain = $oVirtCredential.GetNetworkCredential().Domain
		IF($UserDomain.Length -eq 0){
			IF($UserName -Match "^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$"){
				$UserName = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[0]
				$UserDomain = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[1].Split('.')[0]
				$oVirtCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList "$($UserDomain)\$($UserName)", (ConvertTo-SecureString -String ($oVirtCredential.GetNetworkCredential().Password) -AsPlainText -Force)
			}Else{
				Write-Warning "User Credential REQUIRES a domain configured on the oVirt server, quitting connection..."; BREAK
			}
		}
		$Base64Creds = Convert-StringToBase64String -MyString "$($UserName)@$($UserDomain):$($UserPassword)"
		$Headers = @{"Authorization" = "Basic $($Base64Creds)"; "Prefer"="persistent-auth"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api"
		$Method = "HEAD"
		$Response = $Null; $SessionString = $Null; $CookieString = $Null; $JSESSIONID = $Null
		$Response = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method $Method -SessionVariable 'oVirtServerSession' -EV WebError
		IF($Response){
			Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			$SessionString = ($Response.RawContent | FindStr -i "JSESSIONID")
			IF($SessionString){
				$CookieString = ($SessionString).Split(';')[0]
				IF($CookieString){
					$JSESSIONID = ($CookieString).Split('=')[1]
				}
			}
		}Else{$FormattedWebError = (Format-WebError -WebError $WebError -Body $Null -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError; BREAK}
		IF($JSESSIONID){
			$Headers = @{"Accept" = "application/json";"Cookie" = "JSESSIONID=$($JSESSIONID)"; "Prefer"="persistent-auth"; "All-Content"="true"}
			#$Headers = @{"Cookie" = "JSESSIONID=$($JSESSIONID)"; "Prefer"="persistent-auth"}
			$JSESSION = [PSCustomObject]@{
				JSESSIONID = $JSESSIONID
				oVirtServerName = $oVirtServerName
				oVirtCredential = $oVirtCredential
				Headers = $Headers
				oVirtServerSession = $oVirtServerSession
			}
			$JSESSION
		}
		<#
		Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get
		Invoke-WebRequest -Uri $Uri -Headers $JSESSION.Headers -Method Get -Session $JSESSION.oVirtServerSession
		
		https://ovirt.github.io/ovirt-engine-api-model/4.5/#_requesting_an_authenticated_session
		Send all subsequent requests with the Prefer: persistent-auth and Cookie headers with the JSESSIONID= value. The Authorization header is no longer needed when using an authenticated session.

			HEAD /ovirt-engine/api HTTP/1.1
			Host: myengine.example.com
			Prefer: persistent-auth
			Cookie: JSESSIONID=5dQja5ubr4yvI2MM2z+LZxrK
		
		
		When the session is no longer required, perform a request to the sever without the Prefer: persistent-auth header.

			HEAD /ovirt-engine/api HTTP/1.1
			Host: myengine.example.com
			Authorization: Basic YWRtaW5AaW50ZXJuYWw6bXlwYXNzd29yZA==
			
		#>
	}
	End{}
}

Function Start-oVMConsole{
	<#
		.SYNOPSIS
			This function opens a console to the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
		.DESCRIPTION
			This function opens a console to the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
			Using TightVNC Viewer or Remote-Viewer.exe
		.PARAMETER Name
			The Name of the VM
		.PARAMETER Id
			The Id of the VM
		.PARAMETER Uid
			The Uid of the VM
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system to place the new oVM
		.PARAMETER Viewer
			Remote-Viewer.exe
			Valid options 'RemoteViewer','TigerVNC','TightVNC','UltraVNC'
			Default is TightVNC because Remote-Viewer.exe creates a lot of console output and fails to return without hitting the enter key
			
			CORRECTION: Default is Remote-Viewer.exe because TightVNC, TigerVNC, and UltraVNC do not have Business Approval for 3rd party use.
				All other options are disabled in this release
		.PARAMETER GraphicsProtocol
			Select the Graphics Protocol
			Valid options VNC and SPICE
			If the virtual machine is configured to support only one graphics protocol then the generated authentication token will be valid for that protocol. But if the virtual machine is configured to support multiple protocols, VNC and SPICE, then the authentication token will only be valid for the SPICE protocol.
			If both are Present the default is VNC
			
			Future feature, not working in this version
		.EXAMPLE
			PS> Start-oVMConsole -oVirtServerName $oVirtServerName -Name "oVMName"
				
		.INPUTS
			[System.String]
			[oVM]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/20/2024
			Version 1.0b	8/8/2024
			Version 1.1		10/4/2025
			Version 1.2		10/27/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_graphics_console
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_graphics_console/methods/remote_viewer_connection_file
		.LINK
			Get-Help		
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			#[System.String]$oVM,
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
