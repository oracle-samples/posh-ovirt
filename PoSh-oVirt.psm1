					Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): TypeName [$($TypeName)]"
					Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxOutPutObject [$($oVxOutPutObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name)]"
