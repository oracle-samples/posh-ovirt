					$oHostObjects = $PSBoundParameters['oHost']
				}
				{$_.GetType().Name -eq "oHost"}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals [oHost]"
					$oHostObjects = $PSBoundParameters['oHost']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}

		$ExistingoHostNicObjects = $Null
		IF($oHostObjects){$ExistingoHostNicObjects = $oHostObjects | Get-oHostNic -EA SilentlyContinue}
		$ExistingoNetworkObjects = $Null
		$ExistingoNetworkAttachmentObjects = $Null
		IF($oHostObjects){
			$ExistingoNetworkAttachmentObjects = $oHostObjects | Get-oNetworkAttachment -EA SilentlyContinue
			$ExistingoNetworkAttachmentObjects.GetRelated()
			$ExistingoNetworkObjects = $ExistingoNetworkAttachmentObjects.Network
		}
		
		$oHostBondObjects = $Null
		IF($PSBoundParameters['oHostBondUid']){
			$oHostBondObjects += $($PSBoundParameters['oHostBondUid'] | %{(Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oHostNic" -oVirtServerName $oVirtServerName}) })
			IF($oHostBondObjects){$oHostBondObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oHostBondId']){
