		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("inherit","false","true")]
			[System.String]$MigrationAutoConverge, #I don't see this in the Web UI
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("inherit","false","true")]
			[System.String]$MigrationCompressed, #I don't see this in the Web UI
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("inherit","false","true")]
			[System.String]$MigrationEncrypted,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("disabled","auto","auto_parallel","custom")]
			[System.String]$MigrationParallel,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateRange(2,255)][INT32]$MigrationNumberCustomParallel,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("auto","hypervisor_default","custom")]
			[System.String]$MigrationBandwidth,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateRange(1,([INT32]::MaxValue))][INT32]$MigrationBandwidthLimitMbps,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("MigrateVirtualMachines","MigrateOnlyHighlyAvailableVirtualMachines","DoNotMigrateVirtualMachines")]
			[System.String]$ResiliencePolicy,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$AdditionalRandomNumberGeneratorEnabled,
		#Symmetric Multithreading - Don't see it in the API
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$ThreadsAsCores, # UI Never changes API output
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$TrustedService,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$TunnelMigration,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$VirtService,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$OverriddeSPICEProxyAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({If ($_ -Match "(http[s]?|[s]?ftp[s]?)(:\/\/)([^\s,]+)") { $True } Else { Throw "$_ is not a Web Address!" }})]
			[System.String]$SPICEProxyAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$VncEncryption, #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster/attributes/vnc_encryption
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oCluster]: [$($PSBoundParameters['Name'] -IS [oCluster])]"
		#Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"
		$oClusterObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oCluster]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is [oCluster]"
						$oClusterObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oCluster"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals [oCluster]"
						$oClusterObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oClusterObjects = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObjects Names: $($oClusterObjects.Name)"
		#$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oClusterObject in $oClusterObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObject [$($oClusterObject | Out-String)]"
			$oVirtServerName = $oClusterObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			$oClusterSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('NewName')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['NewName']) }
			IF($PSBoundParameters.ContainsKey('Comment')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('BallooningEnabled')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'ballooning_enabled' -Value $($PSBoundParameters['BallooningEnabled']) }
			
			IF($PSBoundParameters.ContainsKey('CpuType')){
				$SpecCpu = [PSCustomObject]@{
					'architecture'=$(($PSBoundParameters['CpuType']).Split('[]').Where({$_})[1])
					'type'=$(($PSBoundParameters['CpuType']).Split('[]').Where({$_})[0])
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'cpu' -Value $SpecCpu
			
				#"type" = #'i440fx_sea_bios' is 'I440FX Chipset with BIOS', 'q35_sea_bios' is 'Q35 Chipset with BIOS', 'q35_ovmf' is 'Q35 Chipset with UEFI', 'q35_secure_boot' is 'Q35 Chipset with UEFI SecureBoot'
				#$BiosType ONLY WORKS FOR 'x86_64'
				IF($PSBoundParameters.ContainsKey('BiosType')){
					IF($SpecCpu -eq 'x86_64'){
						$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'bios_type' -Value $((($PSBoundParameters['BiosType']).Split('[]') | ?{$_})[1])
					}
				}
			}
			
			IF(($PSBoundParameters.ContainsKey('SchedulingPolicy')) -OR ($PSBoundParameters.ContainsKey('SchedulingPolicyId'))){
				IF($PSBoundParameters.ContainsKey('SchedulingPolicyId')){
					$SchedulingPolicyId = $PSBoundParameters['SchedulingPolicyId']
				}ElseIF($PSBoundParameters.ContainsKey('SchedulingPolicy')){
					$SchedulingPolicyObject = $Null; $SchedulingPolicyObject = Get-oSchedulingPolicy -Name $PSBoundParameters['SchedulingPolicy'] -oVirtServerName $oVirtServerName
					IF($SchedulingPolicyObject){
						IF(($SchedulingPolicyObject).count -eq 1){
							$SchedulingPolicyId = $SchedulingPolicyObject.Id
						}
					}
				}
				IF($SchedulingPolicyId){
					$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'scheduling_policy' -Value $([PSCustomObject]@{'id'=$SchedulingPolicyId})
				}
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster/attributes/version PUT
			IF($PSBoundParameters.ContainsKey('CompatibilityVersion')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'version' -Value $([PSCustomObject]@{'major'=$(($PSBoundParameters['CompatibilityVersion']).Major);'minor'=$(($PSBoundParameters['CompatibilityVersion']).Minor)}) }
			
			#$error_handling, #$oCluster.error_handling.on_error="migrate","do_not_migrate","migrate_highly_available" #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/migrate_on_error
			IF($PSBoundParameters.ContainsKey('ErrorHandling')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'error_handling' -Value $([PSCustomObject]@{'on_error'=$($PSBoundParameters['ErrorHandling'])}) }
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster/attributes/fencing_policy
			IF(($PSBoundParameters.ContainsKey('FencingEnabled')) -OR ($PSBoundParameters.ContainsKey('SkipFencingIfHostHasLiveLeaseOnSstorage')) -OR (($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssues'))) -OR ($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssuesThreshold'))){
				$FencingSpec = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('FencingEnabled')){ $FencingSpec | Add-Member -MemberType NoteProperty -Name 'enabled' -Value $($PSBoundParameters['FencingEnabled']) }
				IF($PSBoundParameters.ContainsKey('SkipFencingIfHostHasLiveLeaseOnSstorage')){ $FencingSpec | Add-Member -MemberType NoteProperty -Name 'skip_if_sd_active' -Value =$([PSCustomObject]@{'enabled'=$($PSBoundParameters['SkipFencingIfHostHasLiveLeaseOnSstorage'])}) }
				IF(($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssues')) -OR ($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssuesThreshold'))){
					$Spec = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssues')){
						$Spec | Add-Member -MemberType NoteProperty -Name 'enabled' -Value $($PSBoundParameters['SkipFencingOnClusterConnectivityIssues'])
					}
					IF($PSBoundParameters.ContainsKey('SkipFencingOnClusterConnectivityIssuesThreshold')){
						$Spec | Add-Member -MemberType NoteProperty -Name 'threshold' -Value $($PSBoundParameters['SkipFencingOnClusterConnectivityIssuesThreshold'])
					}
					$FencingSpec | Add-Member -MemberType NoteProperty -Name 'skip_if_connectivity_broken' -Value = $Spec
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'fencing_policy' -Value = $FencingSpec
			}

			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster/attributes/fips_mode #"disabled","enabled","undefined" is  "Auto Detect"
			IF($PSBoundParameters.ContainsKey('FIPSMode')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'fips_mode' -Value $($PSBoundParameters['FIPSMode']) }
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/firewall_type #"iptables","firewalld"
			IF($PSBoundParameters.ContainsKey('FirewallType')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'firewall_type' -Value $($PSBoundParameters['FirewallType']) }
			IF($PSBoundParameters.ContainsKey('GlusterService')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'gluster_service' -Value $($PSBoundParameters['GlusterService']) }
			IF($PSBoundParameters.ContainsKey('HAReservation')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'ha_reservation' -Value $($PSBoundParameters['HAReservation']) }
			
			IF(($PSBoundParameters.ContainsKey('KSMEnabled')) -OR ($PSBoundParameters.ContainsKey('KSMShareMemoryPages'))){
				$KSMSpec = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('KSMEnabled')){ 
					#$KSMSpec.Add(([PSCustomObject]@{'enabled'=$($PSBoundParameters['KSMEnabled'])}))
					$KSMSpec | Add-Member -MemberType NoteProperty -Name 'enabled' -Value $($PSBoundParameters['KSMEnabled'])
				}
				IF($PSBoundParameters.ContainsKey('KSMShareMemoryPages')){
					IF(($PSBoundParameters['KSMShareMemoryPages']) -eq "Inside_NUMA"){	
						$KSMSpec | Add-Member -MemberType NoteProperty -Name 'merge_across_nodes' -Value $False
					}ElseIF(($PSBoundParameters['KSMShareMemoryPages']) -eq "All_Memory"){
						$KSMSpec | Add-Member -MemberType NoteProperty -Name 'merge_across_nodes' -Value $True
					}
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'ksm' -Value $KSMSpec
			}
			
			IF($PSBoundParameters.ContainsKey('LogMaxMemoryUsedThresholdType')){
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'log_max_memory_used_threshold_type' -Value $($PSBoundParameters['LogMaxMemoryUsedThresholdType'])
				IF(($PSBoundParameters['LogMaxMemoryUsedThresholdType']) -eq "percentage"){	
					$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'log_max_memory_used_threshold' -Value $($PSBoundParameters['LogMaxMemoryUsedThresholdPercent'])
				}ElseIF(($PSBoundParameters['LogMaxMemoryUsedThresholdType']) -eq "absolute_value_in_mb"){
					$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'log_max_memory_used_threshold' -Value $($PSBoundParameters['LogMaxMemoryUsedThresholdMB'])
				}
			}
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/mac_pool
			IF(($PSBoundParameters.ContainsKey('MacPool')) -OR ($PSBoundParameters.ContainsKey('MacPoolId'))){
				IF($PSBoundParameters.ContainsKey('MacPoolId')){
					$MacPoolId = $PSBoundParameters['MacPoolId']
				}ElseIF($PSBoundParameters.ContainsKey('MacPool')){
					$MacPoolObject = $Null; $MacPoolObject = Get-oMacPool -Name $PSBoundParameters['MacPool'] -oVirtServerName $oVirtServerName
					IF($MacPoolObject){
						IF(($MacPoolObject).count -eq 1){
							$MacPoolId = $MacPoolObject.Id
						}
					}
				}
				IF($MacPoolId){$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'mac_pool' -Value $([PSCustomObject]@{'id'=$MacPoolId})}
			}

			IF(($PSBoundParameters.ContainsKey('ManagementNetwork')) -OR ($PSBoundParameters.ContainsKey('ManagementNetworkId'))){
				IF($PSBoundParameters.ContainsKey('ManagementNetworkId')){
					$ManagementNetworkId = $PSBoundParameters['ManagementNetworkId']
				}ElseIF($PSBoundParameters.ContainsKey('ManagementNetwork')){
					$ManagementNetworkObjects = $Null; $ManagementNetworkObjects = Get-oNetwork -Name $PSBoundParameters['ManagementNetwork'] -oVirtServerName $oVirtServerName
					$ManagementNetworkObject = $Null; $ManagementNetworkObject = $ManagementNetworkObjects | ?{$_.data_center[0].id -eq $oClusterObject.data_center.id}
					IF($ManagementNetworkObject){
						IF(($ManagementNetworkObject).count -eq 1){
							$ManagementNetworkId = $ManagementNetworkObject.Id
						}
					}
				}
				IF($ManagementNetworkId){$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'management_network' -Value $([PSCustomObject]@{'id'=$ManagementNetworkId})}
			}

			IF(($PSBoundParameters.ContainsKey('TransparentHugepagesEnabled')) -OR ($PSBoundParameters.ContainsKey('MemoryOptimization'))){
				$Spec = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('TransparentHugepagesEnabled')){ 
					$Spec | Add-Member -MemberType NoteProperty -Name 'transparent_hugepages' -Value $([PSCustomObject]@{'enabled'=$($PSBoundParameters['TransparentHugepagesEnabled'])})
				}
				IF($PSBoundParameters.ContainsKey('MemoryOptimization')){
					IF(($PSBoundParameters['MemoryOptimization']) -eq "None"){	
						$Spec | Add-Member -MemberType NoteProperty -Name 'over_commit' -Value $([PSCustomObject]@{'percent'='0'})
					}ElseIF(($PSBoundParameters['MemoryOptimization']) -eq "ServerLoad"){
						$Spec | Add-Member -MemberType NoteProperty -Name 'over_commit' -Value $([PSCustomObject]@{'percent'='150'})
					}ElseIF(($PSBoundParameters['MemoryOptimization']) -eq "DesktopLoad"){
						$Spec | Add-Member -MemberType NoteProperty -Name 'over_commit' -Value $([PSCustomObject]@{'percent'='200'})
					}
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'memory_policy' -Value $Spec
			}
			
			IF(($PSBoundParameters.ContainsKey('MigrationPolicy')) -OR ($PSBoundParameters.ContainsKey('MigrationPolicyId')) -OR ($PSBoundParameters.ContainsKey('MigrationAutoConverge')) -OR ($PSBoundParameters.ContainsKey('MigrationCompressed')) -OR ($PSBoundParameters.ContainsKey('MigrationEncrypted'))	-OR ($PSBoundParameters.ContainsKey('MigrationParallel')) -OR ($PSBoundParameters.ContainsKey('MigrationNumberCustomParallel'))	-OR ($PSBoundParameters.ContainsKey('MigrationBandwidth')) -OR ($PSBoundParameters.ContainsKey('MigrationBandwidthLimitMbps'))){
				$MigrationSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('MigrationPolicyId')){
					$MigrationPolicyId = $PSBoundParameters['MigrationPolicyId']
				}ElseIF($PSBoundParameters.ContainsKey('MigrationPolicy')){
					#Need to wait for oVirt team to complete SR 3-36677171141, Then create 'Get-oMigrationPolicy'
					#$ManagementNetworkObjects = $Null; $ManagementNetworkObjects = Get-oMigrationPolicy -Name $PSBoundParameters['MigrationPolicy'] -oVirtServerName $oVirtServerName
					$ManagementNetworkObject = $Null; $ManagementNetworkObject = $ManagementNetworkObjects | ?{$_.data_center[0].id -eq $oClusterObject.data_center.id}
					IF($ManagementNetworkObject){
						IF(($ManagementNetworkObject).count -eq 1){
							$MigrationPolicyId = $ManagementNetworkObject.Id
						}
					}
				}
				IF($MigrationPolicyId){$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'policy' -Value $([PSCustomObject]@{'id'=$MigrationPolicyId})}
				IF($PSBoundParameters.ContainsKey('MigrationAutoConverge')){$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'auto_converge' -Value $($PSBoundParameters['MigrationAutoConverge'])}
				IF($PSBoundParameters.ContainsKey('MigrationCompressed')){$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'compressed' -Value $($PSBoundParameters['MigrationCompressed'])}
				IF($PSBoundParameters.ContainsKey('MigrationEncrypted')){$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'encrypted' -Value $($PSBoundParameters['MigrationEncrypted'])}
				IF(($PSBoundParameters.ContainsKey('MigrationParallel')) -OR ($PSBoundParameters.ContainsKey('MigrationNumberCustomParallel'))){
					IF($PSBoundParameters.ContainsKey('MigrationParallel')){$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'parallel_migrations_policy' -Value $($PSBoundParameters['MigrationParallel'])}
					IF(($PSBoundParameters['MigrationParallel'] -eq "custom") -OR (($oClusterObject.migration.parallel_migrations_policy -eq "custom") -AND (!($PSBoundParameters.ContainsKey('MigrationParallel'))))){
						$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'custom_parallel_migrations' -Value $($PSBoundParameters['MigrationNumberCustomParallel'])
					}
				}
				
				IF(($PSBoundParameters.ContainsKey('MigrationBandwidth')) -OR ($PSBoundParameters.ContainsKey('MigrationBandwidthLimitMbps'))){
					$Specs = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('MigrationBandwidth')){$Specs | Add-Member -MemberType NoteProperty -Name 'assignment_method' -Value $($PSBoundParameters['MigrationBandwidth'])}
					IF(($PSBoundParameters['MigrationBandwidth'] -eq "custom") -OR (($oClusterObject.migration.bandwidth.assignment_method -eq "custom") -AND (!($PSBoundParameters.ContainsKey('MigrationBandwidth'))))){
						$Spec | Add-Member -MemberType NoteProperty -Name 'custom_value' -Value $($PSBoundParameters['MigrationBandwidthLimitMbps'])
					}
					$MigrationSpecs | Add-Member -MemberType NoteProperty -Name 'bandwidth' -Value $Specs
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'migration' -Value $MigrationSpecs
			}	
			
			IF($PSBoundParameters.ContainsKey('ResiliencePolicy')){
				$Specs = [PSCustomObject]@{}
				SWITCH(($PSBoundParameters.ContainsKey('ResiliencePolicy'))){
					{$_ -eq "MigrateVirtualMachines"}{$Specs | Add-Member -MemberType NoteProperty -Name 'on_error' -Value "migrate"}
					{$_ -eq "MigrateOnlyHighlyAvailableVirtualMachines"}{$Specs | Add-Member -MemberType NoteProperty -Name 'on_error' -Value "migrate_highly_available"}
					{$_ -eq "DoNotMigrateVirtualMachines"}{$Specs | Add-Member -MemberType NoteProperty -Name 'on_error' -Value "do_not_migrate"}
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'error_handling' -Value $Specs
			}
				
			IF($PSBoundParameters.ContainsKey('AdditionalRandomNumberGeneratorEnabled')){
				$Specs = [PSCustomObject]@{}
				IF(($PSBoundParameters['AdditionalRandomNumberGeneratorEnabled']) -eq $True){
					$Specs | Add-Member -MemberType NoteProperty -Name 'required_rng_source' -Value $("hwrng","urandom")
				}ElseIF(($PSBoundParameters['AdditionalRandomNumberGeneratorEnabled']) -eq $False){
					$Specs | Add-Member -MemberType NoteProperty -Name 'required_rng_source' -Value $("urandom")
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'required_rng_sources' -Value $Specs
			}
				
			IF($PSBoundParameters.ContainsKey('ThreadsAsCores')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'threads_as_cores' -Value $($PSBoundParameters['ThreadsAsCores']) }
			IF($PSBoundParameters.ContainsKey('TrustedService')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'trusted_service' -Value $($PSBoundParameters['TrustedService']) }
			IF($PSBoundParameters.ContainsKey('TunnelMigration')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'tunnel_migration' -Value $($PSBoundParameters['TunnelMigration']) }
			IF($PSBoundParameters.ContainsKey('VirtService')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'virt_service' -Value $($PSBoundParameters['VirtService']) }
			
			IF($PSBoundParameters.ContainsKey('OverriddeSPICEProxyAddress')){
				$Specs = [PSCustomObject]@{}
				IF(($PSBoundParameters['OverriddeSPICEProxyAddress']) -eq $True){
					IF($PSBoundParameters['SPICEProxyAddress']){
						$Specs | Add-Member -MemberType NoteProperty -Name 'proxy' -Value $($PSBoundParameters['SPICEProxyAddress'])
						$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'display' -Value $Specs
					}
				}ElseIF(($PSBoundParameters['OverriddeSPICEProxyAddress']) -eq $False){
					$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'display' -Value $Null
				}
			}
			
			IF($PSBoundParameters.ContainsKey('SerialNumberPolicy')){
				$SerialNumberPolicySpecs = [PSCustomObject]@{}
				IF(($PSBoundParameters['SerialNumberPolicy']) -eq "custom"){
					IF($PSBoundParameters['CustomSerialNumber']){
						$SerialNumberPolicySpecs | Add-Member -MemberType NoteProperty -Name 'value' -Value $($PSBoundParameters['CustomSerialNumber'])
						$SerialNumberPolicySpecs | Add-Member -MemberType NoteProperty -Name 'policy' -Value $($PSBoundParameters['SerialNumberPolicy'])
					}
				}ElseIF(($PSBoundParameters['SerialNumberPolicy'] -eq "SystemDefault")){
					$SerialNumberPolicySpecs | Add-Member -MemberType NoteProperty -Name 'policy' -Value $Null
				}Else{
					$SerialNumberPolicySpecs | Add-Member -MemberType NoteProperty -Name 'policy' -Value $($PSBoundParameters['SerialNumberPolicy'])
				}
				$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'serial_number' -Value $SerialNumberPolicySpecs
				Write-Verbose "$($MyInvocation.MyCommand): `$SerialNumberPolicySpecs: [$SerialNumberPolicySpecs | Out-String]"
			}
			
			IF($PSBoundParameters.ContainsKey('VncEncryption')){ $oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'vnc_encryption' -Value $($PSBoundParameters['VncEncryption']) }
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oClusterSpecs: [$oClusterSpecs | Out-String]"
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/clusters/$($oClusterObject.ID)"
			$Method = "PUT"
			$JsonBody = $oClusterSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oCluster"
			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoCluster = $Null
			TRY{
				$UpdatedoCluster = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError
				Write-Verbose "$($MyInvocation.MyCommand): `$UpdatedoCluster: [$($UpdatedoCluster) | Out-String]"
				IF($UpdatedoCluster){$UpdatedoCluster = Convert-RestResponseTooVirtObject -InputObject $UpdatedoCluster -ObjectType "oCluster" -oVirtServerName $oVirtServerName}
				#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoCluster -ObjectType "Cluster" -oVirtServerName $oVirtServerName)) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Catch{$UpdatedoCluster = $oClusterObject}
			$UpdatedoCluster
		}
	}
	End{}
}

Function Set-oDataCenter{
	<#
		.SYNOPSIS
			This function reconfigures the provided oDataCenter, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oDataCenter, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oDataCenter(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of oDataCenter(s)
		.PARAMETER Uid
			The Uid(s) of oDataCenter(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER CleanFinishedTasks
			Switch to Clean Finished Tasks, if the storage pool manager (SPM) fails to switch to another host due to uncleared SPM tasks
		.PARAMETER Comment
			The Text for the Comment field to set on the oDataCenter
		.PARAMETER CompatibilityVersion
			The Compatibility Version to assign to the oDataCenter
			Supported Modes can be found: (Get-oDataCenter -oVirtServerName $oVirtServerName -Name "ODataCenterName").supported_versions.version
			Then Entered -CompatibilityVersion "4.5"
		.PARAMETER Description
			The Text for the Description field to set on the oDataCenter
		.PARAMETER MacPool
			The Name of the Mac Address Pool to assign to the oDataCenter
		.PARAMETER MacPoolId
			The Id of the Mac Address Pool to assign to the oDataCenter
		.PARAMETER NewName
			The New Name to assign to the oDataCenter
		.PARAMETER QuotaMode
			The Quota Mode to assign to the oDataCenter
				Valid options "disabled","audit","enabled" (Enforced)
		.PARAMETER StorageFormat
			Not Working Yet
		.PARAMETER StorageType
			The Storage Type to assign to the oDataCenter
			Not Working Yet
		.PARAMETER SetMasterStorageDomain
			The Name of the Storage Domain to assign as the oDataCenter storage pool manager (SPM)
		.PARAMETER SetMasterStorageDomainId
			The Id of the Storage Domain to assign as the oDataCenter storage pool manager (SPM)
		.EXAMPLE
			PS> Set-oDataCenter -oVirtServerName $oVirtServerName -NewName "Name"
				Changes the Name of the oDataCenter(s) to the provided NewName
		.INPUTS
			[System.String]
			[oDataCenter]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDataCenter]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/8/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/data_center
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/data_center
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oDatacenter'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[System.String]$NewName,
		[System.String]$Comment,
		[System.String]$Description,
		#Properties  The name, description, storage_type, version, storage_format and mac_pool elements are updatable post-creation
		[ValidateSet("Shared","Local")]
			[System.String]$StorageType,
		[ValidateSet("v5")]
			[System.String]$StorageFormat,
		[System.String]$MacPool,
		[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$MacPoolId,
		[ValidateSet("disabled","audit","enabled")]
			[System.String]$QuotaMode,
		[Version]$CompatibilityVersion,
		[SWITCH]$CleanFinishedTasks, #Currently, the storage pool manager (SPM) fails to switch to another host if the SPM has uncleared tasks
		[System.String]$SetMasterStorageDomain, #Used for manually setting a storage domain in the data center as a master
		[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$SetMasterStorageDomainId, #Used for manually setting a storage domain in the data center as a master
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oDataCenter]: [$($PSBoundParameters['Name'] -IS [oDataCenter])]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"
		$oDataCenterObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDataCenter]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oDataCenter"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oDataCenterObjects = Get-oDataCenter -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObjects Names: $($oDataCenterObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oDataCenterObject in $oDataCenterObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObject [$($oDataCenterObject | Out-String)]"
			$oVirtServerName = $oDataCenterObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			IF((($PSBoundParameters['CleanFinishedTasks']).IsPresent -eq $True) -OR ($PSBoundParameters['SetMasterStorageDomain']) -OR ($PSBoundParameters['SetMasterStorageDomainId'])){
				IF(($PSBoundParameters['CleanFinishedTasks']).IsPresent -eq $True){
					$oDataCenterSpecs = [PSCustomObject]@{}
					$oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value $True
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token))"; "All-Content"="true"}
					$Uri = $BaseURL + "/ovirt-engine/api/datacenters/$($oDataCenterObject.ID)/cleanfinishedtasks"
					$Method = "POST"
					$JsonBody = $oDataCenterSpecs | ConvertTo-Json -Depth 50
					Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to CleanFinishedTasks"
					Write-Verbose "$($JsonBody | Out-String)"
					$UpdatedoDataCenter = $Null
					TRY{$UpdatedoDataCenter = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedoDataCenter = $oDataCenterObject}
					$OutPutItems.Add($UpdatedoDataCenter) | Out-Null
				}
				IF(($PSBoundParameters['SetMasterStorageDomain']) -OR ($PSBoundParameters['SetMasterStorageDomainId'])){
					$oDataCenterSpecs = [PSCustomObject]@{}
					IF($PSBoundParameters['SetMasterStorageDomainId']){
						$StorageDomainId = $PSBoundParameters['SetMasterStorageDomainId']
					}ElseIF($PSBoundParameters['SetMasterStorageDomain']){
						$StorageDomainObject = $Null; $StorageDomainObject = Get-oStorageDomain -Name $PSBoundParameters['SetMasterStorageDomain'] -oVirtServerName $oVirtServerName
						IF($StorageDomainObject){
							IF(($StorageDomainObject).count -eq 1){
								$StorageDomainId = $StorageDomainObject.Id
							}
						}
					}
					IF($StorageDomainId){
						$oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domain' -Value $([PSCustomObject]@{'id'=@($StorageDomainId)})
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token))"; "All-Content"="true"}
						$Uri = $BaseURL + "/ovirt-engine/api/datacenters/$($oDataCenterObject.ID)/cleanfinishedtasks"
						$Method = "POST"
						$JsonBody = $oDataCenterSpecs | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to set storage domain as the storage pool manager (SPM)"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedoDataCenter = $Null
#IF($UpdatedoDataCenter){$UpdatedoDataCenter = Convert-RestResponseTooVirtObject -InputObject $UpdatedoCluster -ObjectType "oCluster" -oVirtServerName $oVirtServerName}
						TRY{$UpdatedoDataCenter = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedoDataCenter = $oDataCenterObject}
						$OutPutItems.Add($UpdatedoDataCenter) | Out-Null
					}
				}
			}
						
			$oDataCenterSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('NewName')){ $oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['NewName']) }
			IF($PSBoundParameters.ContainsKey('Comment')){ $oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('CompatibilityVersion')){ $oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'version' -Value $([PSCustomObject]@{'major'=$(($PSBoundParameters['CompatibilityVersion']).Major);'minor'=$(($PSBoundParameters['CompatibilityVersion']).Minor)}) }
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/mac_pool
			IF(($PSBoundParameters.ContainsKey('MacPool')) -OR ($PSBoundParameters.ContainsKey('MacPoolId'))){
				IF($PSBoundParameters.ContainsKey('MacPoolId')){
					$MacPoolId = $PSBoundParameters['MacPoolId']
				}ElseIF($PSBoundParameters.ContainsKey('MacPool')){
					$MacPoolObject = $Null; $MacPoolObject = Get-oMacPool -Name $PSBoundParameters['MacPool'] -oVirtServerName $oVirtServerName
					IF($MacPoolObject){
						IF(($MacPoolObject).count -eq 1){
							$MacPoolId = $MacPoolObject.Id
						}
					}
				}
				IF($MacPoolId){$oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'mac_pool' -Value $([PSCustomObject]@{'id'=$MacPoolId})}
			}
			IF($PSBoundParameters.ContainsKey('QuotaMode')){ $oDataCenterSpecs | Add-Member -MemberType NoteProperty -Name 'quota_mode' -Value $($PSBoundParameters['QuotaMode']) }
		}
		
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token))"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/datacenters/$($oDataCenterObject.ID)"
		$Method = "PUT"
		$JsonBody = $oDataCenterSpecs | ConvertTo-Json -Depth 50
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oDataCenter"
		Write-Verbose "$($JsonBody | Out-String)"
		$UpdatedoDataCenter = $Null
#IF($UpdatedoDataCenter){$UpdatedoDataCenter = Convert-RestResponseTooVirtObject -InputObject $UpdatedoCluster -ObjectType "oCluster" -oVirtServerName $oVirtServerName}
		TRY{$UpdatedoDataCenter = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedoDataCenter = $oDataCenterObject}
		$OutPutItems.Add($UpdatedoDataCenter) | Out-Null
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oDisk{
	<#
		.SYNOPSIS
			This function updates an oDisk, on an oVirt Server system.
		.DESCRIPTION
			This function updates an oDisk, on a oVirt Server system.
			Returns the job response from the oVirt Server.
			
			WARNING: This function's Input Parameter Names may change in a future release
		.PARAMETER Name
			The Name(s) of the oDisk(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of the oDisk(s)
		.PARAMETER Uid
			The Uid of the oDisk(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oHost
			The Name or oHost object to place the oDisk
			With a host element - in this case, the host is used for sanity checks (e.g., that the LUN is visible) and to retrieve basic information about the LUN (e.g., size and serial).
			Without a host element - in this case, the operation is a database-only operation, and the storage is never accessed.
		.PARAMETER oHostId
			The Id of the oHost to place the oDisk
			With a host element - in this case, the host is used for sanity checks (e.g., that the LUN is visible) and to retrieve basic information about the LUN (e.g., size and serial).
			Without a host element - in this case, the operation is a database-only operation, and the storage is never accessed.
		.PARAMETER oHostUid
			The Uid of the oHost to place the oDisk
			With a host element - in this case, the host is used for sanity checks (e.g., that the LUN is visible) and to retrieve basic information about the LUN (e.g., size and serial).
			Without a host element - in this case, the operation is a database-only operation, and the storage is never accessed.
		.PARAMETER Alias
			Alias for the oDisk
		.PARAMETER Backup
			The backup behavior supported by the disk
			Valid options "none", "incremental"
		.PARAMETER BackupMode
			The backup type that was taken for the disk (full/incremental)
			Valid options "full", "incremental"
		.PARAMETER Description
			The Text for the Description field to set on the oDisk
		.PARAMETER DiskProfileId
			Sets the disk profile if the oDisk storage_type is "image"
		.PARAMETER ProvisionedSize
			The virtual size of the disk, in bytes
		.PARAMETER QcowVersion
			The underlying QCOW version of a QCOW volume
			Valid options "qcow2_v2", "qcow2_v3"
			For VM attached disks, the qcow_version can also be updated
		.PARAMETER Shareable
			Indicates if the disk can be attached to multiple virtual machines
		.PARAMETER WipeAfterDelete
			Indicates if the disk’s blocks will be read back as zeros after it is deleted:
				- On block storage, the disk will be zeroed and only then deleted.
		.PARAMETER Reduce
			Reduces the size of the disk image.
			Invokes reduce on the logical volume (i.e. this is only applicable for block storage domains).
			This is applicable for floating disks and disks attached to non-running virtual machines.
			There is no need to specify the size as the optimal size is calculated automatically.
		.PARAMETER RefreshLUN
			Refreshes a direct LUN disk with up-to-date information from the storage.
			Refreshing a direct LUN disk is useful when:
			The LUN was added using the API without the host parameter, and therefore does not contain any information from the storage (see DisksService::add).
			New information about the LUN is available on the storage and you want to update the LUN with it.
			To refresh direct LUN disk 123 using host 456, send the following request: <action><host id='456'/></action>
		.PARAMETER Sparsify
			Sparsify the disk.
			Sparsification frees space in the disk image that is not used by its filesystem. As a result, the image will occupy less space on the storage.
			Currently sparsification works only on disks without snapshots. Disks having derived disks are also not allowed.
		.PARAMETER register
			Register unregistered disks
			Not available in this version yet
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.EXAMPLE
			PS> Set-oDisk -oVirtServerName $oVirtServerName -Name "MyoDisk" -oHost "oHostName" -ProvisionedSize 1048576 -Description "Some Description"
				Updates an oDisk
		.INPUTS
			[System.String]
			[oHost]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDisk]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/23/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disks
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disks/methods/update
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_backup_mode
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/qcow_version
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_type
			Get-oDisk
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set01", Position=1)]
			[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$NewName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$DiskProfileId, #$disk_profile
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateRange(1,([INT64]::MaxValue))]
			[System.INT64]$ProvisionedSize,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Alias,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("none", "incremental")] #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_backup_mode
			[System.String]$Backup,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("full", "incremental")] #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_backup_mode
			[System.String]$BackupMode,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("qcow2_v2", "qcow2_v3")]
			[System.String]$QcowVersion, #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/qcow_version
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$Shareable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$WipeAfterDelete,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$Reduce,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RefreshLUN,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$Sparsify,
		#-Register not completed yet
		#[SWITCH]$Register,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		<#
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/update
			Updates the parameters of the specified disk.
			This operation allows updating the following floating disk properties:
			For Image disks: provisioned_size, alias, description, wipe_after_delete, shareable, backup and disk_profile.
			For LUN disks: alias, description and shareable.
			Cinder integration has been replaced by Managed Block Storage.
			For Managed Block disks: provisioned_size, alias and description.
			For VM attached disks, the qcow_version can also be updated.
		#>
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#Write-Verbose "$($MyInvocation.MyCommand) Is [oCluster]: [$($PSBoundParameters['Name'] -IS [oCluster])]"
		IF($PSBoundParameters.ContainsKey('oHost')){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oHost'] Type: [$(($PSBoundParameters['oHost']).GetType().Name)]"}
		$oDiskObject = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oDisk]}{
					Write-Verbose "$($MyInvocation.MyCommand) Name is [oDisk]"
					$oDiskObject = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oDisk"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDisk]"
					$oDiskObject = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				$UidUrl = [Uri]$Uid
				$oDiskObject = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		IF($oDiskObject){
			$oHostObject = $Null
			IF($PSBoundParameters['oHost']){
				SWITCH($PSBoundParameters['oHost']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
						}
						IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
						}
						IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oHost]}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is [oHost]"
						$oHostObject = $PSBoundParameters['oHost']
					}
					{$_.GetType().Name -eq "oHost"}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals [oHost]"
						$oHostObject = $PSBoundParameters['oHost']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters['oHostId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oHostObject = Get-oHost -Id $PSBoundParameters['oHostId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oHostObject = Get-oHost -Id $PSBoundParameters['oHostId'] -EA SilentlyContinue
				}
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters['oHostUid']){
				$UidUrl = [Uri]$oHostUid
				$oHostObject = Get-oHost -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Names: $($oDiskObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostObject Names: $($oHostObject.Name)"
			$OutPutItems = [System.Collections.ArrayList]@()
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject [$($oDiskObject | Out-String)]"
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostObject [$($oHostObject | Out-String)]"
			$oVirtServerName = $oDiskObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			#Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Status [$($oDiskObject.Status)]"
				
			$oDiskSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Alias')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'alias' -Value $($PSBoundParameters['Alias']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('NewName')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['NewName']) }

			IF($oDiskObject.storage_type -eq "image"){
				#For Image disks: provisioned_size, alias, description, wipe_after_delete, shareable, backup and disk_profile.	
				IF($HostObject){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $([PSCustomObject]@{'id'=$HostObject.Id}) }
				IF($PSBoundParameters.ContainsKey('ProvisionedSize')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'provisioned_size' -Value $($PSBoundParameters['ProvisionedSize']) }
				IF($PSBoundParameters.ContainsKey('Backup')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'backup' -Value $($PSBoundParameters['Backup']) }
				IF($PSBoundParameters.ContainsKey('BackupMode')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'backup_mode' -Value $($PSBoundParameters['BackupMode']) }
				IF($PSBoundParameters.ContainsKey('Shareable')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'shareable' -Value $($PSBoundParameters['Shareable']) }
				IF($PSBoundParameters.ContainsKey('WipeAfterDelete')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $($PSBoundParameters['WipeAfterDelete']) }
				IF($PSBoundParameters.ContainsKey('DiskProfileId')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'disk_profile' -Value $([PSCustomObject]@{'id'=$($PSBoundParameters['DiskProfileId'])}) }
			}ElseIF($oDiskObject.storage_type -eq "LUN"){
				#This section I have no way to test yet, so the code here is a swag
				#For LUN disks: alias, description and shareable.
				$oDiskLunSpecs = [PSCustomObject]@{}
				oDiskLunLUSpecs = [PSCustomObject]@{}
				#Add host to FloatingDirectLUN Specs
				IF($HostObject){$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $([PSCustomObject]@{'id'=$HostObject.Id}) }
				$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'logical_units' -Value $([PSCustomObject]@{'logical_unit'=@($oDiskLunLUSpecs)})
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'lun_storage' -Value $oDiskLunSpecs
				IF($PSBoundParameters.ContainsKey('Shareable')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'shareable' -Value $($PSBoundParameters['Shareable']) }
			}ElseIF($oDiskObject.storage_type -eq "managed_block_storage"){
				#This section I have no way to test yet, so the code here is a swag
				#<disk id="b7a4c6c5-443b-47c5-967f-6abc79675e8b"><image_id>b548366b-fb51-4b41-97be-733c887fe305</image_id><storage_domains><storage_domain id="123"/></storage_domains><name>mydisk</name><provisioned_size>1048576</provisioned_size><format>cow</format></disk>
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_type
				#For Managed Block disks: provisioned_size, alias and description.
				IF($PSBoundParameters.ContainsKey('ProvisionedSize')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'provisioned_size' -Value $($PSBoundParameters['ProvisionedSize']) }
				
			}
			#For VM attached disks, the qcow_version can also be updated.
			#This never works, need to see if I need to also get disk attachments to determine if attached to a vm
				# $oDiskAttachments = (Get-oVM | Get-oDiskAttachment)
				# $oDiskAttachments | ?{$_.disk.id -eq $oDisk.id} | ?{$_.vm}
			IF($oDiskObject.vms){
				IF($PSBoundParameters.ContainsKey('QcowVersion')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'qcow_version' -Value $($PSBoundParameters['QcowVersion']) }
			}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/disks/$($oDiskObject.id)"
			$Method = "PUT"
			$JsonBody = $oDiskSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oDiskSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oDisk"
			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoDisk = $Null
			#TRY{$UpdatedoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0].Exception.Message)"; $FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			TRY{$UpdatedoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoDisk){
				Write-Verbose "$($MyInvocation.MyCommand): Updated oDisk"
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDisk -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
			
			IF($PSBoundParameters.ContainsKey('Reduce')){
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/reduce
					#Reduces the size of the disk image.
					#Invokes reduce on the logical volume (i.e. this is only applicable for block storage domains).
					#This is applicable for floating disks and disks attached to non-running virtual machines.
					#There is no need to specify the size as the optimal size is calculated automatically.
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/disks/$($oDiskObject.id)/reduce"
				$Method = "POST"
				IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
					$oDiskObjectSpecs = [PSCustomObject]@{async = $True}
				}Else{
					$oDiskObjectSpecs = [PSCustomObject]@{async = $False}
				}
				$JsonBody = $oDiskObjectSpecs | ConvertTo-Json -Depth 50
				#TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
				TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoDiskObject){
					Write-Verbose "$($MyInvocation.MyCommand): Updated oDisk"
					#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDiskObject -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
					$OutPutItems.Add($UpdatedoDiskObject) | Out-Null
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
				}
			}
			IF($PSBoundParameters.ContainsKey('RefreshLUN')){
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/refresh_lun
					#Refreshes a direct LUN disk with up-to-date information from the storage.
					#Refreshing a direct LUN disk is useful when:
					#The LUN was added using the API without the host parameter, and therefore does not contain any information from the storage (see DisksService::add).
					#New information about the LUN is available on the storage and you want to update the LUN with it.
					#To refresh direct LUN disk 123 using host 456, send the following request: <action><host id='456'/></action>
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/disks/$($oDiskObject.id)/refresh_lun"
				$Method = "POST"
				$oDiskObjectSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
					Add-Member -InputObject $oDiskObjectSpecs -Name "async" -Value $True -MemberType "NoteProperty" 
				}Else{
					#$oDiskObjectSpecs = [PSCustomObject]@{async = $False}
					#Add-Member -InputObject $oDiskObjectSpecs -Name "async" -Value $False -MemberType "NoteProperty" 
				}
				IF($oHostObject){
					Add-Member -InputObject $oDiskObjectSpecs -Name "host" -Value @([PSCustomObject]@{id = $($oHostObject.Id)}) -MemberType "NoteProperty" 
				}
				$JsonBody = $oDiskObjectSpecs | ConvertTo-Json -Depth 50
				#TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
				TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoDiskObject){
					Write-Verbose "$($MyInvocation.MyCommand): Updated oDisk"
					#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDiskObject -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
					$OutPutItems.Add($UpdatedoDiskObject) | Out-Null
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
				}
			}
			IF($PSBoundParameters.ContainsKey('Sparsify')){
				 #https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/sparsify
					#Sparsify the disk.
					#Sparsification frees space in the disk image that is not used by its filesystem. As a result, the image will occupy less space on the storage.
					#Currently sparsification works only on disks without snapshots. Disks having derived disks are also not allowed.
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/disks/$($oDiskObject.id)/sparsify"
				$Method = "POST"
				$oDiskObjectSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
					Add-Member -InputObject $oDiskObjectSpecs -Name "async" -Value $True -MemberType "NoteProperty" 
				}Else{
					#$oDiskObjectSpecs = [PSCustomObject]@{async = $False}
					#Add-Member -InputObject $oDiskObjectSpecs -Name "async" -Value $False -MemberType "NoteProperty" 
				}
				$JsonBody = $oDiskObjectSpecs | ConvertTo-Json -Depth 50
				#TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
				TRY{$UpdatedoDiskObject = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoDiskObject){
					Write-Verbose "$($MyInvocation.MyCommand): Updated oDisk"
					#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDiskObject -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
					$OutPutItems.Add($UpdatedoDiskObject) | Out-Null
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
				}
			}
			IF($PSBoundParameters.ContainsKey('Register')){
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain_disk
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain_disk/methods/register
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain_disks/methods/add/parameters/unregistered
					<#
						Indicates if a new disk should be added or if an existing unregistered disk should be registered. If the value is true then the identifier of the disk to register needs to be provided. For example, to register the disk with id 456 send a request like this:

						POST /ovirt-engine/api/storagedomains/123/disks?unregistered=true
						With a request body like this:

						<disk id="456"/>
						If the value is false then a new disk will be created in the storage domain. In that case the provisioned_size, format and name attributes are mandatory. For example, to create a new copy on write disk of 1 GiB, send a request like this:

						POST /ovirt-engine/api/storagedomains/123/disks
						With a request body like this:

						<disk>
						  <name>mydisk</name>
						  <format>cow</format>
						  <provisioned_size>1073741824</provisioned_size>
						</disk>
						The default value is false.
					#>
				
				#Register unregistered disks
			}
		}Else{
			$oDiskInputString = $Null
			IF($PSCmdlet.ParameterSetName -eq "Set01"){
				SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_.GetType().Name -eq "String"}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_ -IS [oDisk]}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				{$_.GetType().Name -eq "oDisk"}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				}
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
				$oDiskInputString = $PSBoundParameters['Id']
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
				$oDiskInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
			}
			IF($PSBoundParameters['oVirtServerName']){
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
			}Else{
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)]"
			}
		}
		
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oDiskAttachment{
	<#
		.SYNOPSIS
			This function updates an oDiskAttachment, for an oDisk, on a virtual machine, on an oVirt Server system
		.DESCRIPTION
			This function updates an oDiskAttachment, for an oDisk, on a virtual machine, on an oVirt Server system
		.PARAMETER Name
			The Name(s) of the oDiskAttachment(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of the oDiskAttachment(s)
		.PARAMETER Uid
			The Uid of the oDiskAttachment(s)
		.PARAMETER oDisk
			The Name or Object of the replacement oDisk to attach
			Can use Wildcard '*'
		.PARAMETER oDiskId
			The ID of the replacement oDisk to attach
		.PARAMETER oDiskUid
			The Uid of the replacement oDisk to attach
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER Active
			Defines whether the disk is active in the virtual machine it’s attached to
			$True or $False
		.PARAMETER Bootable
			Defines whether the disk is bootable
			$True or $False
		.PARAMETER PassDiscard
			Defines whether the virtual machine passes discard commands to the storage
			$True or $False
		.PARAMETER Interface
			The underlying storage interface of disks communication with controller
			Valid options "ide", "sata", "spapr_vscsi", "virtio", "virtio_scsi"
				ide - Legacy controller device. Works with almost all guest operating systems, so it is good for compatibility. Performance is lower than with the other alternatives.
				sata - SATA controller device.
				spapr_vscsi - Para-virtualized device supported by the IBM pSeries family of machines, using the SCSI protocol.
				virtio - Virtualization interface where just the guest’s device driver knows it is running in a virtual environment. Enables guests to get high performance disk operations.
				virtio_scsi - Para-virtualized SCSI controller device. Fast interface with the guest via direct physical storage device address, using the SCSI protocol.
		.EXAMPLE
			PS> Set-oDiskAttachment -oVirtServerName $oVirtServerName -Name "MyoDiskAttachment" -oDisk "oDiskName" -Active $True -Bootable $True -Interface "virtio"
				Updates an oDiskAttachment to the virtual machine for existing oDisk, or replacemnet oDisk, and the disk properties within it
		.INPUTS
			[System.String]
			[oDiskAttachment]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDiskAttachment]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/24/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachments
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachment/methods/update
			Get-oDisk
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$oDisk,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDiskId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDiskUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$Active,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$Bootable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$PassDiscard, #pass_discard
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("ide", "sata", "spapr_vscsi", "virtio", "virtio_scsi")]
			[System.String]$Interface,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#Write-Verbose "$($MyInvocation.MyCommand) Is [oCluster]: [$($PSBoundParameters['Name'] -IS [oCluster])]"
		IF($PSBoundParameters.ContainsKey('oDisk')){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oDisk'] Type: [$(($PSBoundParameters['oDisk']).GetType().Name)]"}
		$oDiskAttachmentObject = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskAttachmentObject = Get-oDiskAttachment -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskAttachmentObject = Get-oDiskAttachment -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskAttachmentObject){$oDiskAttachmentObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskAttachmentObject = Get-oDiskAttachment -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskAttachmentObject = Get-oDiskAttachment -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskAttachmentObject){$oDiskAttachmentObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oDiskAttachment]}{
					Write-Verbose "$($MyInvocation.MyCommand) Name is [oDiskAttachment]"
					$oDiskAttachmentObject = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oDiskAttachment"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDiskAttachment]"
					$oDiskAttachmentObject = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskAttachmentObject = Get-oDiskAttachment -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskAttachmentObject = Get-oDiskAttachment -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDiskAttachmentObject){$oDiskAttachmentObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				$UidUrl = [Uri]$Uid
				$oDiskAttachmentObject = Get-oDiskAttachment -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskAttachmentObject){$oDiskAttachmentObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		IF($oDiskAttachmentObject){
			$oVirtServerName = $oDiskAttachmentObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$oVMId = $Null
			$oVMId = $oDiskAttachmentObject.vm.id
			$oDiskObject = $Null
			IF($PSBoundParameters['oDisk']){
				SWITCH($PSBoundParameters['oDisk']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskObject = Get-oDisk -Name $PSBoundParameters['oDisk'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskObject = Get-oDisk -Name $PSBoundParameters['oDisk'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskObject = Get-oDisk -Name $PSBoundParameters['oDisk'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskObject = Get-oDisk -Name $PSBoundParameters['oDisk'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDisk]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is [oDisk]"
						$oDiskObject = $PSBoundParameters['oDisk']
					}
					{$_.GetType().Name -eq "oDisk"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals [oDisk]"
						$oDiskObject = $PSBoundParameters['oDisk']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters['oDiskId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['oDiskId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['oDiskId'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
				}
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters['oDiskUid']){
				$UidUrl = [Uri]$oDiskUid
				$oDiskObject = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskAttachmentObject Names: $($oDiskAttachmentObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Names: $($oDiskObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskAttachmentObject [$($oDiskAttachmentObject | Out-String)]"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject [$($oDiskObject | Out-String)]"
			$OutPutItems = [System.Collections.ArrayList]@()
			$oDiskAttachmentSpecs = [PSCustomObject]@{}
			
			IF($PSBoundParameters.ContainsKey('Active')){ $oDiskAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'active' -Value $($PSBoundParameters['Active']) }
			IF($PSBoundParameters.ContainsKey('Bootable')){ $oDiskAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'bootable' -Value $($PSBoundParameters['Bootable']) }
			IF($PSBoundParameters.ContainsKey('Interface')){ $oDiskAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'interface' -Value $($PSBoundParameters['Interface']) }
			IF($PSBoundParameters.ContainsKey('PassDiscard')){ $oDiskAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'pass_discard' -Value $($PSBoundParameters['PassDiscard']) }
			IF($oDiskObject){
				$oDiskAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'disk' -Value $([PSCustomObject]@{'id'=$oDiskObject.Id})
			}Else{
				$oDiskInputString = $Null
				IF($PSBoundParameters['oDisk']){
					SWITCH($PSBoundParameters['oDisk']){
					{$_ -IS [System.String]}{$oDiskInputString = $PSBoundParameters['oDisk']}
					{$_.GetType().Name -eq "String"}{$oDiskInputString = $PSBoundParameters['oDisk']}
					{$_ -IS [oDisk]}{$oDiskInputString = $PSBoundParameters['oDisk'].Name}
					{$_.GetType().Name -eq "oDisk"}{$oDiskInputString = $PSBoundParameters['oDisk'].Name}
					}
				}ElseIF($PSBoundParameters['oDiskId']){
					$oDiskInputString = $PSBoundParameters['oDiskId']
				}ElseIF($PSBoundParameters['oDiskUid']){
					$oDiskInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
				}
				IF($oDiskInputString){
					IF($PSBoundParameters['oVirtServerName']){
						Write-Warning "Could not locate oDisk by input [$($oDiskInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
					}Else{
						Write-Warning "Could not locate oDisk by input [$($oDiskInputString)]"
					}
				}
			}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/vms/$($oVMId)/diskattachments/$($oDiskAttachmentObject.Id)"
			
			$Method = "PUT"
			$JsonBody = $oDiskAttachmentSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oDiskAttachmentSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oDiskAttachment"
			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoDiskAttachment = $Null
			#TRY{$UpdatedoDiskAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0].Exception.Message)"; $OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
			TRY{$UpdatedoDiskAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoDiskAttachment){
				Write-Verbose "$($MyInvocation.MyCommand): Updated oDiskAttachment to oVM"
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDiskAttachment -ObjectType "oDiskAttachment" -oVirtServerName $oVirtServerName)) | Out-Null
				#$OutPutItems.Add($UpdatedoDiskAttachment) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
		}Else{
			$oDiskAttachmentInputString = $Null
			IF($PSCmdlet.ParameterSetName -eq "Set01"){
				SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{$oDiskAttachmentInputString = $PSBoundParameters['Name']}
				{$_.GetType().Name -eq "String"}{$oDiskAttachmentInputString = $PSBoundParameters['Name']}
				{$_ -IS [oDiskAttachment]}{$oDiskAttachmentInputString = $PSBoundParameters['Name'].Name}
				{$_.GetType().Name -eq "oDiskAttachment"}{$oDiskAttachmentInputString = $PSBoundParameters['Name'].Name}
				}
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
				$oDiskAttachmentInputString = $PSBoundParameters['Id']
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
				$oDiskAttachmentInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
			}
			IF($PSBoundParameters['oVirtServerName']){
				Write-Warning "Could not locate oDiskAttachment by input [$($oDiskAttachmentInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
			}Else{
				Write-Warning "Could not locate oDiskAttachment by input [$($oDiskAttachmentInputString)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oHost{
	<#
		.SYNOPSIS
			This function reconfigures the provided oHost(KVM), on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oHost(KVM), on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oHost(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of oHost(s)
		.PARAMETER Uid
			The Uid(s) of oHost(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER CaseSensitive
			Switch to search Case Sensitive oHost name(s)
		.PARAMETER NewName
			String new name for KVM host (does not change connection name/IP, only visible name)
		.PARAMETER Comment
			Comment field text
		.PARAMETER Description
			Description field text
		.PARAMETER OverrideDisplayAddress
			Indicates if to override the display address per host. Relevant only for the Host.display attribute. 
			If set, the graphical console address of a virtual machine will be overridden by the host specified 
			display address. if not set, the graphical console address of a virtual machine will not be overridden.
			Boolean to Enable/Disable Override
		.PARAMETER DisplayAddress
			Display Address Text String
				The IP address of the guest to connect the graphic console client to.
		.PARAMETER vGPUPlacement
			The vGPU placement strategy.
			Place vGPUs on the first available physical cards, or spread them over multiple physical cards.
				Valid options "Consolidated","Separated"
		.PARAMETER SPMPriority
			 Set the Storage Pool Manager (SPM) priority of this host
				Valid options "Never","Low","Normal","High"
		.PARAMETER SelectAsSPM
			Switch To manually set a host as the storage pool manager (SPM).
		.PARAMETER OperationalState
			Select the operational service state of the oHost
				Valid options "Activate","Maintenance"
		.PARAMETER FencePowerAction
			Select a Power Change Action utilizing the configured Fencing agent, the Lights Out Management 
			or Remote Access Controller out-of-band management platforms are typical
			Valid options "PowerOn","PowerOff","Reboot"
			Cluster fencing is the process of isolating, or separating, a node from using its resources 
			or starting services, which it should not have access to, and from the rest of the nodes as well.
		.PARAMETER MaintenanceAfterPowerOn
			Indicates if host should be put into maintenance after boot by fence agent
			Doesn't seem to work, but does display in the returned object, yet omitted in oVirt documentation
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/fence
			Boolean
		.PARAMETER MaintenanceAfterFenceReboot
			Indicates if host should be put into maintenance after restart by fence agent
			Doesn't seem to work, and does NOT display in the returned object, in contradiction to oVirt documentation
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/fence
			Boolean
		.PARAMETER ActivateHostAfterInstall
			Activate Host After Installing the latest version of VDSM and related software on the host.
			When set to 'true', this host will be activated after its installation completes. 
			When set to 'false' the host will remain in 'maintenance' status after its installation. 
			Absence of this parameter will be interpreted as 'true', since the desired default behavior 
			is activating the host after install.
