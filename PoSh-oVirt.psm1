						$JsonBody = $Body | ConvertTo-Json -Depth 50
						#$NewNumaNodes = (Get-oUri -RESTUri $UpdatedVM.link.where({$_.rel -eq "numanodes"}).href -oVirtServerName $UpdatedVM.oVirtServer -Method POST -Body $JsonBody).vm_numa_node
						
