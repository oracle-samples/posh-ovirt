				}ElseIF($PSBoundParameters['HeadlessMode'] -EQ $True){
					<#
					$VMSpecsDisplay = [PSCustomObject]@{
						"allow_override" = ""
						"copy_paste_enabled" = ""
						"disconnect_action" = ""
						"disconnect_action_delay" = ""
						"file_transfer_enabled" = ""
						"monitors" = ""
						"SmartCardEnabled" = ""
						"type" = ""
						"keyboard_layout" = ""
					}
					#>
					$VMSpecsDisplay = $Null
					#$VMSpecsDisplay = [PSCustomObject]@{"type"="none"}
					#DELETE ..api/vms/<vm-id>/graphicsconsoles/<console-id>
				}ElseIF($PSBoundParameters['HeadlessMode'] -EQ $False){
					$VMSpecsDisplay = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('DisplayAllowOverRide')){Add-Member -NotePropertyName "allow_override" -NotePropertyValue $PSBoundParameters['DisplayAllowOverRide'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "allow_override" -NotePropertyValue $true -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('DisplayCopyPasteEnabled')){Add-Member -NotePropertyName "copy_paste_enabled" -NotePropertyValue $PSBoundParameters['DisplayCopyPasteEnabled'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "copy_paste_enabled" -NotePropertyValue $true -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('ConsoleDisconnectAction')){Add-Member -NotePropertyName "disconnect_action" -NotePropertyValue $PSBoundParameters['ConsoleDisconnectAction'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "disconnect_action" -NotePropertyValue "LOCK_SCREEN" -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('DisconnectActionDelayinMinutes')){Add-Member -NotePropertyName "disconnect_action_delay" -NotePropertyValue $PSBoundParameters['DisconnectActionDelayinMinutes'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "disconnect_action_delay" -NotePropertyValue '0' -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('DisplayFileTransferEnabled')){Add-Member -NotePropertyName "file_transfer_enabled" -NotePropertyValue $PSBoundParameters['DisplayFileTransferEnabled'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "file_transfer_enabled" -NotePropertyValue $true -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('Monitors')){Add-Member -NotePropertyName "monitors" -NotePropertyValue $PSBoundParameters['Monitors'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "monitors" -NotePropertyValue '1' -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('SmartCardEnabled')){Add-Member -NotePropertyName "smartcard_enabled" -NotePropertyValue $PSBoundParameters['SmartCardEnabled'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "smartcard_enabled" -NotePropertyValue $false -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('GraphicsProtocol')){Add-Member -NotePropertyName "type" -NotePropertyValue $PSBoundParameters['GraphicsProtocol'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "type" -NotePropertyValue "vnc" -inputObject $VMSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('VNCKeyboardLayout')){Add-Member -NotePropertyName "keyboard_layout" -NotePropertyValue $PSBoundParameters['VNCKeyboardLayout'] -inputObject $VMSpecsDisplay}Else{Add-Member -NotePropertyName "keyboard_layout" -NotePropertyValue "en-us" -inputObject $VMSpecsDisplay}
				}
				
				IF($TimeZone){
					IF($TargetoVM.time_zone.name -ne ((($TimeZone).Split('[]') | ?{$_})[1])){
						$VMSpecsTimeZone = [PSCustomObject]@{
							#"name" = ($TimeZoneLookupArray | ?{$_.DropDown_Item -eq $TimeZone}).Name
							"name" = ((($TimeZone).Split('[]') | ?{$_})[1])
							#"utc_offset" = "GMT+1"
						}
					}
				}
				
				IF($PSBoundParameters.ContainsKey('UsbEnabled')){
					IF($TargetoVM.Usb.Enabled -ne $PSBoundParameters['UsbEnabled']){
						$VMSpecsUsb = [PSCustomObject]@{
							"enabled" = $UsbEnabled
							#"type" = $(IF($PSBoundParameters['UsbEnabled']){"native"}Else{$Null})
						}
						IF($PSBoundParameters['UsbEnabled']){Add-Member -NotePropertyName "type" -NotePropertyValue "native" -inputObject $VMSpecsUsb}
					}
				}
				
				IF($PSBoundParameters.ContainsKey('VirtIOSerialConsoleEnabled')){
					IF($TargetoVM.console.enabled -ne $PSBoundParameters['VirtIOSerialConsoleEnabled']){
						$VMSpecsSerialConsole = [PSCustomObject]@{
							"enabled" = $PSBoundParameters['VirtIOSerialConsoleEnabled']
						}
					}
				}
				
				IF(($PSBoundParameters.ContainsKey('MigrationEncrypted') -OR ($MigrationParallel) -OR ($PSBoundParameters.ContainsKey('MigrationCompressed') -OR ($PSBoundParameters.ContainsKey('MigrationAutoConverge'))))){
					$VMSpecsMigration = [PSCustomObject]@{}
					IF($TargetoVM.migration.encrypted -ne $MigrationEncrypted){IF($MigrationEncrypted){Add-Member -NotePropertyName "encrypted" -NotePropertyValue $MigrationEncrypted -inputObject $VMSpecsMigration}}
					IF($TargetoVM.migration.parallel_migrations_policy -ne $MigrationParallel){IF($MigrationParallel){Add-Member -NotePropertyName "parallel_migrations_policy" -NotePropertyValue $MigrationParallel -inputObject $VMSpecsMigration}}
					IF($TargetoVM.migration.compressed -ne $MigrationCompressed){IF($MigrationCompressed){Add-Member -NotePropertyName "compressed" -NotePropertyValue $MigrationCompressed -inputObject $VMSpecsMigration}} #"inherit", need to get back to this one
					IF($TargetoVM.migration.auto_converge -ne $MigrationAutoConverge){IF($MigrationAutoConverge){Add-Member -NotePropertyName "auto_converge" -NotePropertyValue $MigrationAutoConverge -inputObject $VMSpecsMigration}} #"inherit", need to get back to this one
					#"policy" = @{id=a7aeedb2-8d66-4e51-bb22-32595027ce71} This sets a Migation Policy, from those available 
				}
				
				IF(($PSBoundParameters.ContainsKey('MemoryBallooning')) -OR ($PSBoundParameters.ContainsKey('MemoryGuaranteed')) -OR ($PSBoundParameters.ContainsKey('MemoryMax')) -OR ($PSBoundParameters.ContainsKey('MemoryOverCommitPercentage')) -OR ($PSBoundParameters.ContainsKey('MemoryTHPEnabled'))){
					$VMSpecsMemoryPolicy = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('MemoryBallooning')){
						#Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters ContainsKey 'MemoryBallooning'"
						IF($TargetoVM.memory_policy.ballooning -ne $PSBoundParameters['MemoryBallooning']){Add-Member -NotePropertyName "ballooning" -NotePropertyValue $PSBoundParameters['MemoryBallooning'] -inputObject $VMSpecsMemoryPolicy}
					#}Else{
					#	Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters NOT ContainsKey 'MemoryBallooning'"
					}
					IF($TargetoVM.memory_policy.guaranteed -ne $PSBoundParameters['MemoryGuaranteed']){IF($PSBoundParameters.ContainsKey('MemoryGuaranteed')){Add-Member -NotePropertyName "guaranteed" -NotePropertyValue $PSBoundParameters['MemoryGuaranteed'] -inputObject $VMSpecsMemoryPolicy}}
					IF($TargetoVM.memory_policy.max -ne $PSBoundParameters['MemoryMax']){IF($PSBoundParameters.ContainsKey('MemoryMax')){Add-Member -NotePropertyName "max" -NotePropertyValue $PSBoundParameters['MemoryMax'] -inputObject $VMSpecsMemoryPolicy}}
					IF($TargetoVM.memory_policy.over_commit -ne $PSBoundParameters['MemoryOverCommitPercentage']){IF($PSBoundParameters.ContainsKey('MemoryOverCommitPercentage')){Add-Member -NotePropertyName "over_commit" -NotePropertyValue $PSBoundParameters['MemoryOverCommitPercentage'] -inputObject $VMSpecsMemoryPolicy}}
					IF($TargetoVM.memory_policy.transparent_huge_pages -ne $PSBoundParameters['MemoryTHPEnabled']){IF($PSBoundParameters.ContainsKey('MemoryTHPEnabled')){Add-Member -NotePropertyName "transparent_huge_pages" -NotePropertyValue ([PSCustomObject]@{enabled = $PSBoundParameters['MemoryTHPEnabled']}) -inputObject $VMSpecsMemoryPolicy}}
				}
				Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsMemoryPolicy: [$($VMSpecsMemoryPolicy | Out-String)]"
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['MemoryBallooning']: [$($PSBoundParameters['MemoryBallooning'])]"
				Write-Verbose "$($MyInvocation.MyCommand): `$MemoryBallooning: [$($MemoryBallooning)]"
		
				IF($PSBoundParameters.ContainsKey('HAEnabled')){
					$VMSpecsHA = [PSCustomObject]@{"enabled" = $PSBoundParameters['HAEnabled']}
					IF(($PSBoundParameters['HAEnabled'] -eq $True) -AND ($PSBoundParameters['HAPriority'])){
						SWITCH($HAPriority){
							{$_ -eq "Low"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 1 -inputObject $VMSpecsHA}
							{$_ -eq "Medium"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 50 -inputObject $VMSpecsHA}
							{$_ -eq "High"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 100 -inputObject $VMSpecsHA}
						}
					}
				}Else{
					IF(($TargetoVM.high_availability.enabled -eq $True) -AND ($PSBoundParameters['HAPriority'])){
						$VMSpecsHA = [PSCustomObject]@{}
						SWITCH($HAPriority){
							{$_ -eq "Low"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 1 -inputObject $VMSpecsHA}
							{$_ -eq "Medium"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 50 -inputObject $VMSpecsHA}
							{$_ -eq "High"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 100 -inputObject $VMSpecsHA}
						}
					}	
				}
				
				IF($PSBoundParameters['CPUShares']){
					SWITCH($PSBoundParameters['CPUShares']){
						{$_ -eq 'disabled'}{IF($TargetoVM.cpu_shares -ne 0){$cpu_shares = 0}}
						{$_ -eq 'low'}{IF($TargetoVM.cpu_shares -ne 512){$cpu_shares = 512}}
						{$_ -eq 'medium'}{IF($TargetoVM.cpu_shares -ne 1024){$cpu_shares = 1024}}
						{$_ -eq 'high'}{IF($TargetoVM.cpu_shares -ne 2048){$cpu_shares = 2048}}
						{$_ -eq 'custom'}{IF($PSBoundParameters.ContainsKey('CPUSharesInt')){IF($TargetoVM.cpu_shares -ne $PSBoundParameters['CPUSharesInt']){$cpu_shares = $PSBoundParameters['CPUSharesInt']}}Else{IF($TargetoVM.cpu_shares -ne 0){$cpu_shares = 0}}}
					}
				}

				#PoweredOFF, only to take affect
				IF($PSBoundParameters['CpuCoresPerSocket'] -OR $PSBoundParameters['CpuSockets'] -OR $PSBoundParameters['CpuThreads']){
					$VMSpecsCpuTopology = [PSCustomObject]@{}
					IF($TargetoVM.cpu.topology.cores -ne $PSBoundParameters['CpuCoresPerSocket']){Add-Member -NotePropertyName "cores" -NotePropertyValue $PSBoundParameters['CpuCoresPerSocket'] -inputObject $VMSpecsCpuTopology}
					IF($TargetoVM.cpu.topology.sockets -ne $PSBoundParameters['CpuSockets']){Add-Member -NotePropertyName "sockets" -NotePropertyValue $PSBoundParameters['CpuSockets'] -inputObject $VMSpecsCpuTopology}
					IF($TargetoVM.cpu.topology.threads -ne $PSBoundParameters['CpuThreads']){Add-Member -NotePropertyName "threads" -NotePropertyValue $PSBoundParameters['CpuThreads'] -inputObject $VMSpecsCpuTopology}
				}
	
				#PoweredOFF, only to take affect
				IF($PSBoundParameters.ContainsKey('CpuType') -OR $VMSpecsCpuTopology -OR $PSBoundParameters['VMType'] -OR $PSBoundParameters.ContainsKey('PassThroughHostCPU')){
					$VMSpecsCpu = [PSCustomObject]@{}
					#"topology" = $VMSpecsCpuTopology
					#"architecture" = $CpuType
					#"mode"="host_passthrough" #Only if VM is Pinned to host
						#$oVM.cpu.mode = "host_passthrough"
					IF($VMSpecsCpuTopology){Add-Member -NotePropertyName "topology" -NotePropertyValue $VMSpecsCpuTopology -inputObject $VMSpecsCpu}
					IF($PSBoundParameters['CpuType']){IF($TargetoVM.cpu.architecture -ne $PSBoundParameters['CpuType']){Add-Member -NotePropertyName "architecture" -NotePropertyValue $$PSBoundParameters['CpuType'] -inputObject $VMSpecsCpu}}
					IF((($PSBoundParameters['VMType'] -eq "high_performance") -OR ((!($PSBoundParameters.ContainsKey('VMType'))) -AND ($TargetoVM.type -eq "high_performance"))) -AND ((($PSBoundParameters['MigrationMode'] -eq 'pinned') -OR ($PSBoundParameters['MigrationMode'] -eq 'user_migratable')) -OR ((!($PSBoundParameters['MiGrationMode'])) -AND (($TargetoVM.placement_policy.affinity -eq 'pinned') -OR ($TargetoVM.placement_policy.affinity -eq 'user_migratable'))))){
						#Disabled migration
						IF($PSBoundParameters.ContainsKey('PassThroughHostCPU')){
							IF(($PSBoundParameters['PassThroughHostCPU'] -eq $True) -AND ($TargetoVM.cpu.mode -ne "host_passthrough")){
								Add-Member -NotePropertyName "mode" -NotePropertyValue "host_passthrough" -inputObject $VMSpecsCpu
							}ElseIF(($PSBoundParameters['PassThroughHostCPU'] -eq $False) -AND ($TargetoVM.cpu.mode -eq "host_passthrough")){
								Add-Member -NotePropertyName "mode" -NotePropertyValue "host_model" -inputObject $VMSpecsCpu
							}
						}
					}Else{
						Write-Verbose "$($MyInvocation.MyCommand): Failed to Create 'PassThroughHostCPU' config"
						#IF($TargetoVM.cpu.mode -eq "host_passthrough"){Add-Member -NotePropertyName "mode" -NotePropertyValue "" -inputObject $VMSpecsCpu}
					}
					IF($VMSpecsCpu.psobject.Properties.count -lt 1){$VMSpecsCpu = $Null; Remove-Variable -Name VMSpecsCpu -Force -Confirm:0}
					Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsCpu: [$($VMSpecsCpu)]"
				}
				
				IF(($PSBoundParameters.ContainsKey('CpuProfile')) -or ($PSBoundParameters.ContainsKey('CpuProfileId'))){
					$VMSpecsCpuProfile = [PSCustomObject]@{}
					IF(($PSBoundParameters['CpuProfileId'] -And !$PSBoundParameters['CpuProfile']) -AND ($TargetoVM.cpu_profile.id -ne $PSBoundParameters['CpuProfileId'])){
						#$PSBoundParameters['CpuProfile'] = (Get-oCpuProfile -oCpuProfileId $PSBoundParameters['CpuProfileId']  -oVirtServerName $oVirtServerName).Name
						$PSBoundParameters['CpuProfile'] = (Get-oUri -RESTUri "/ovirt-engine/api/cpuprofiles/$($PSBoundParameters['CpuProfileId'])" -oVirtServerName $oVirtServerName).name #Faster
						#Add-Member -NotePropertyName "id" -NotePropertyValue $PSBoundParameters['CpuProfileId'] -inputObject $VMSpecsDisplay
					}Else{
						$CurrentCpuProfileItem = $Null; $CurrentCpuProfileItem = (Get-oUri -RESTUri "/ovirt-engine/api/cpuprofiles/$($TargetoVM.cpu_profile.id)" -oVirtServerName $TargetoVM.oVirtServer)
						IF(($PSBoundParameters['CpuProfile']) -AND ($CurrentCpuProfileItem.Name -ne $PSBoundParameters['CpuProfile'])){Add-Member -NotePropertyName "name" -NotePropertyValue $PSBoundParameters['CpuProfile'] -inputObject $VMSpecsCpuProfile}
					}
				}
				
				IF($PSBoundParameters.ContainsKey('BiosBootMenuEnabled') -or $PSBoundParameters['BiosType']){
					$VMSpecsBios = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('BiosBootMenuEnabled')){
						IF($TargetoVM.bios.boot_menu.enabled -ne $PSBoundParameters['BiosBootMenuEnabled']){
							$VMSpecsBiosBoot_menu = [PSCustomObject]@{"enabled" = $PSBoundParameters['BiosBootMenuEnabled']}
							Add-Member -NotePropertyName "boot_menu" -NotePropertyValue $VMSpecsBiosBoot_menu -inputObject $VMSpecsBios
						}
						#"type" = #'i440fx_sea_bios' is 'I440FX Chipset with BIOS', 'q35_sea_bios' is 'Q35 Chipset with BIOS', 'q35_ovmf' is 'Q35 Chipset with UEFI', 'q35_secure_boot' is 'Q35 Chipset with UEFI SecureBoot'
					}
					IF(($PSBoundParameters['BiosType']) -AND ($TargetoVM.bios.type -ne $PSBoundParameters['BiosType'])){Add-Member -NotePropertyName "type" -NotePropertyValue ((($BiosType).Split('[]') | ?{$_})[1]) -inputObject $VMSpecsBios}
				}
		
				#There can be only 1 of each device type hd, cd, network for the entire VM
				IF(($FirstBootDevice -OR $SecondBootDevice) -AND $TargetoVM.os.boot.devices.device){
					#Test for Conflict with current setting
					#IF Only 1 is requested to be set
					IF($FirstBootDevice -XOR $SecondBootDevice){
						#Can't have 2 of the same Warn and Quit
						IF(($FirstBootDevice -eq $TargetoVM.os.boot.devices.device[1]) -AND ($SecondBootDevice -ne "none")){
							$SecondBootDevice = "none"
							#Write-Warning "FirstBootDevice [$($FirstBootDevice)] and Current SecondBootDevice [$($TargetoVM.os.boot.devices.device[1])] Can NOT be the same, make a better choice, quitting...."
							#BREAK
						}ElseIF($SecondBootDevice -eq $TargetoVM.os.boot.devices.device[0]){
							Write-Warning "SecondBootDevice [$($SecondBootDevice)] and Current FirstBootDevice [$($TargetoVM.os.boot.devices.device[0])] Can NOT be the same, make a better choice, quitting...."
							BREAK
						}
						IF($FirstBootDevice){
							IF($TargetoVM.os.boot.devices.device.count -gt 1){IF($SecondBootDevice -ne "none"){$SecondBootDevice = $TargetoVM.os.boot.devices.device[1]}}
						}ElseIF($SecondBootDevice){
							IF($TargetoVM.os.boot.devices.device[0]){$FirstBootDevice = $TargetoVM.os.boot.devices.device[0]}
						}
					}
				}
				#$BootArray = [System.Collections.ArrayList]@()
				#IF($FirstBootDevice){$BootArray.Add($FirstBootDevice) | Out-Null}
				#IF($SecondBootDevice){$BootArray.Add($SecondBootDevice) | Out-Null}
				$BootArray = @()
				IF($FirstBootDevice){$BootArray += $FirstBootDevice}
				IF($SecondBootDevice){
					IF($SecondBootDevice -ne "none"){
						$BootArray += $SecondBootDevice
					}Else{
						$BootArray += $Null
					}
				}
				IF($BootArray.Count -ge 1){
					Write-Verbose "$($MyInvocation.MyCommand): `$BootArray: [$($BootArray)]"
					$VMSpecsOSBootDevices = [PSCustomObject]@{"device" = $BootArray}
					Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsOSBootDevices: [$($VMSpecsOSBootDevices)]"
					#$xml = ([xml]"<boot><devices><device>hd</device><device>cdrom</device><device>network</device></devices></boot>")
					#$obj = Convert-XMLtoPSObject -XML $xml
					$VMSpecsOSBoot = $Null
					$VMSpecsOSBoot = [PSCustomObject]@{"devices" = $VMSpecsOSBootDevices}
					Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsOSBoot: [$($VMSpecsOSBoot)]"
					
				}
				
				#PoweredOFF for OS Type Powered ON for Boot Order
				$VMSpecsOS = $Null; $VMSpecsOSType = $Null
				#(gou /ovirt-engine/api/operatingsystems).operating_system|Select architecture,name,description,id|Sort architecture,name,description
				IF($OSType -OR $VMSpecsOSBoot){
					IF($OSType){
						$OSTypeLookup = ($OSTypeLookupArray | ?{$_.Name -eq ((($OSType).Split('[]') | ?{$_})[1])})
						IF($OSTypeLookup.Architecture -ne $CpuType){
							Write-Warning "You Selected OSType: [$(((($OSType).Split('[]') | ?{$_})[0]))] which is for CPUType [$($OSTypeLookup.Architecture)] but the CPUType  is set to [$($CpuType)], they are incompatibile, quitting..."
							BREAK
						}
					
						IF($VMSpecsOSBoot -OR $OSTypeLookup){
							$VMSpecsOSType = ((($OSType).Split('[]') | ?{$_})[1])
							$VMSpecsOS = [PSCustomObject]@{}
							IF($VMSpecsOSBoot){Add-Member -NotePropertyName "boot" -NotePropertyValue $VMSpecsOSBoot -inputObject $VMSpecsOS}
							IF(($VMSpecsOSType) -AND ($TargetoVM.os.type -ne $VMSpecsOSType)){Add-Member -NotePropertyName "type" -NotePropertyValue $VMSpecsOSType -inputObject $VMSpecsOS}
							Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsOS: [$($VMSpecsOS)]"
						}
					}ElseIF($VMSpecsOSBoot){
						$VMSpecsOS = [PSCustomObject]@{"boot"=$VMSpecsOSBoot}
						Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsOS: [$($VMSpecsOS)]"
					}
				}
		
				IF($PSBoundParameters.ContainsKey('TPMDeviceEnabled')){
					Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section"
					IF($TargetoVM.tpm_enabled -ne $PSBoundParameters['TPMDeviceEnabled']){
						#$oVM.bios.type
						#(($PSBoundParameters['BiosType']) -AND ($TargetoVM.bios.type -ne $PSBoundParameters['BiosType']))
						#'I440FX Chipset with BIOS [i440fx_sea_bios]', 'Q35 Chipset with BIOS [q35_sea_bios]', 'Q35 Chipset with UEFI [q35_ovmf]', 'Q35 Chipset with UEFI SecureBoot [q35_secure_boot]'
						# TPM must have a BIOS Type UEFI ("q35_ovmf" -OR "q35_secure_boot")
						IF(!($PSBoundParameters.ContainsKey('CpuType'))){
							$CpuType = $TargetoVM.cpu.architecture; #Write-Host -Fore Cyan "CpuType: [$($CpuType)]"
						}
						Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section: CpuType [$($CpuType)]"
						IF(!($PSBoundParameters.ContainsKey('BiosType'))){
							#Write-Host -Fore Cyan "BIOS Switch"
							Switch(($TargetoVM.bios.type)){
								{$_ -eq "i440fx_sea_bios"}{$BiosType = 'I440FX Chipset with BIOS [i440fx_sea_bios]'}
								{$_ -eq "q35_sea_bios"}{$BiosType = 'Q35 Chipset with BIOS [q35_sea_bios]'}
								{$_ -eq "q35_ovmf"}{$BiosType = 'Q35 Chipset with UEFI [q35_ovmf]'}
								{$_ -eq "q35_secure_boot"}{$BiosType = 'Q35 Chipset with UEFI SecureBoot [q35_secure_boot]'}
							}
							#Write-Host -Fore Cyan "BIOS: [$($BiosType)]"
						}
						Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section: BiosType [$($BiosType)]"
						IF(!($PSBoundParameters.ContainsKey('OSType'))){
							$OSTypeLookup = ($OSTypeLookupArray | ?{$_.Name -eq $TargetoVM.os.type})
							$OSType = "$($OSTypeLookup.description) [$($OSTypeLookup.Name)]"
							#Write-Host -Fore Cyan "1) OSTypeLookup: [$($OSTypeLookup)]"
							#Write-Host -Fore Cyan "1) OSType: [$($OSType)]"
						}
						Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section: OSType [$($OSType)]"
						IF((($BiosType -Match "q35_ovmf") -OR ($BiosType -Match "q35_secure_boot")) -AND ($PSBoundParameters['TPMDeviceEnabled'] -eq $True)){
							IF(!($OSTypeLookup)){$OSTypeLookup = ($OSTypeLookupArray | ?{$_.Name -eq ((($OSType).Split('[]') | ?{$_})[1])})}
							#Write-Host -Fore Cyan "2) OSTypeLookup: [$($OSTypeLookup)]"
							Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section: OSTypeLookup [$($OSTypeLookup | Out-String)]"
							IF($OSTypeLookup.Architecture -eq $CpuType){
								Write-VerBose "`$TPMDeviceEnabled Section: OSTypeLookup Architecture equals CpuType: [$($CpuType)]"
								IF((($BiosType -Match "q35_ovmf") -OR ($BiosType -Match "q35_secure_boot"))){
									#Write-Host -Fore Cyan "1) Is UEFI"
									Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section(1): OSTypeLookup Architecture equals BiosType: [$($BiosType)]"
									$VMSpecsTPMEnabled = $True
								}
							}Else{
								Write-VerBose "$($MyInvocation.MyCommand): `$TPMDeviceEnabled Section: OSTypeLookup Architecture does NOT equal CpuType: [$($CpuType)]"
								Write-Warning "Can not enable TPM Device For oVM [$($TargetoVM.Name)], CPU Architecture and OS Type Architecture do not match"
							}
						}ElseIF(($TargetoVM.tpm_enabled -eq $True) -AND (($PSBoundParameters['TPMDeviceEnabled'] -eq $False))){$VMSpecsTPMEnabled = $False}
						#Write-Host -Fore Cyan "VMSpecsTPMEnabled: [$($VMSpecsTPMEnabled)]"
						IF(($VMSpecsTPMEnabled -eq $True) -AND ($TargetoVM.status -eq "up")){Write-Host -ForeGroundColor DarkYellow -BackGroundColor BLACK "Enabling TPM, requires a Cold Boot, and will be applied after a reboot"}
