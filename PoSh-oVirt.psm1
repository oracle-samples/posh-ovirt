					}
					IF($CpuProfile){Add-Member -NotePropertyName "name" -NotePropertyValue $CpuProfile -inputObject $TemplateSpecsCpuProfile}
				}
						
				IF($PSBoundParameters.ContainsKey('BiosBootMenuEnabled') -or $BiosType){
