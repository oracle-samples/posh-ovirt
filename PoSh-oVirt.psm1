		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oUserId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[MailAddress]$UserPrincipalName,
		
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName = 'Set01')]
			[ValidateScript({($_).GetType().Name -match 'String|oRole'})]$oRole,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName = 'Set02')]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oRoleId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('RU')]
			[System.String[]]$oRoleUid,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$AuthSource,
		#User not working for ldap, disabling for this release
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.Management.Automation.PSCredential]$LdapCredential,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$System,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		IF((($PSBoundParameters.ContainsKey('oGroup')) -OR ($PSBoundParameters.ContainsKey('oGroupId')) -OR ($PSBoundParameters.ContainsKey('oGroupUid'))) -AND (($PSBoundParameters.ContainsKey('oUser')) -OR ($PSBoundParameters.ContainsKey('oUserId')) -OR ($PSBoundParameters.ContainsKey('UserPrincipalName')))){Throw "Can't Use BOTH -oGroupxxx & (-oUser or -oUserId -or -UserPrincipalName) together"}
		IF(!(($PSBoundParameters.ContainsKey('oGroup')) -OR ($PSBoundParameters.ContainsKey('oGroupId')) -OR ($PSBoundParameters.ContainsKey('oGroupUid')) -OR ($PSBoundParameters.ContainsKey('oUser')) -OR ($PSBoundParameters.ContainsKey('oUserId')) -OR ($PSBoundParameters.ContainsKey('UserPrincipalName')))){Throw "-oGroup OR -oUser OR -oUserId OR UserPrincipalName Required"}
