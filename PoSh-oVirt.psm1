<#
Import-Module Posh-oVirt -Force
$oVirtServerName = "ServerName.Domain.com"
$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
Connect-oVirtServer -oVirtServerName $oVirtServerName -oVirtCredential $oVirtCredential -CloneoVirtCredentialForSSH
$oVirt = Get-oVirt -oVirtServerName $oVirtServerName

#List of OLVM servers here:
Import-Module Posh-oVirt -Force
$oVirtServerNames = "server01","server02","server03"
$oVirtCredential = (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
$oVirtServerNames | %{Connect-oVirtServer -oVirtServerName $_ -oVirtCredential $oVirtCredential -CloneoVirtCredentialForSSH}

Show-oVirtConnection
#>

