Function Get-UserAnswerPopUp{ 
    <#
        .SYNOPSIS
            Creates a Message Popup Dialog Box with a timeout
        .DESCRIPTION
            Creates a Message Popup Dialog Box with a timeout
        .PARAMETER Message
            Message to display
        .PARAMETER Title
            The Message Box Title
        .PARAMETER TimeOut
            The Timeout Value of the MessageBox in seconds
				MessageBox closes and returns a value of -1, When the Timeout is reached
				The Default is 0 - No Timeout
        .PARAMETER ButtonSet
			Buttons to be Displayed in the Message Box
			Values:
				Value     Buttons
				OK        OK 					- This is the Default
				OC        OK Cancel
				AIR       Abort Ignore Retry
				YNC       Yes No Cancel
				YN        Yes No
				RC        Retry Cancel
        .PARAMETER IconType
            Icon to be Displayed in the Message Box
			Values:
				None      - This is the Default
				Critical
				Question
				Exclamation
				Information
        .EXAMPLE
            $ReturnedValue = Show-PopUp -Message "My Message" -Title "Title" -TimeOut 5 -ButtonSet YNC -Icon Exclamation
        .OUTPUTS
			The Value of the Button Selected or -1, if the Popup Times Out
			Values:
				-1  Timeout
				 1  OK
				 2  Cancel
				 3  Abort
				 4  Retry
				 5  Ignore
				 6  Yes
				 7  No
     #>
    [CmdletBinding()]
	[OutputType([INT])]
	Param(
        [Parameter(Mandatory=$True, ValueFromPipeLine=$True, ValueFromPipelineByPropertyName=$True)]
			[Alias("M")]
			[System.String]$Message,
        [Parameter(Mandatory=$False, ValueFromPipeLine=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias("T")]
			[System.String]$Title = $null,
        [Parameter(Mandatory=$False, ValueFromPipeLine=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias("TO")]
			[INT]$TimeOut = 0,
        [Parameter(Mandatory=$False, ValueFromPipeLine=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias("B")]
			[ValidateSet("OK", "OC", "AIR", "YNC" , "YN" , "RC")]
			[System.String]$ButtonSet = "OK",
        [Parameter(Mandatory=$False, ValueFromPipeLine=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias("I")]
			[ValidateSet("None", "Critical", "Question", "Exclamation" , "Information")]
			[System.String]$IconType = "None"
	)
    $ButtonSets = "OK", "OC", "AIR", "YNC" , "YN" , "RC"
    $IconTypes  = "None", "Critical", "Question", "Exclamation" , "Information"
    $IconVals = 0,16,32,48,64
    IF((($PSVersionTable.GetEnumerator() | ?{$_.Name -eq "PSVersion"}).Value).Major -ge 3){ 
        $Button   = $ButtonSets.IndexOf($ButtonSet) 
        $Icon     = $IconVals[$IconTypes.IndexOf($IconType)] 
	}Else{
        $ButtonSets| ForEach -Begin{$Button = 0;$idx=0} -Process{ IF($_.Equals($ButtonSet)){$Button = $idx}; $idx++ } 
        $IconTypes | ForEach -Begin{$Icon = 0;$idx=0} -Process{ IF($_.Equals($IconType)){$Icon   = $IconVals[$idx]}; $idx++ } 
	} 
    $ObjectShell = New-Object -com "Wscript.Shell" 
    $ObjectShell.Popup($Message,$TimeOut,$Title,$Button+$Icon)  
} 

