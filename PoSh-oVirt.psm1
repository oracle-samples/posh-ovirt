				#$oClusters = (Get-oCluster -oVirtServerName $oVirtServerName)
				#$oClusters = (gou /ovirt-engine/api/clusters -oVirtServerName $oVirtServerName).cluster #Faster, no need to create class objects
				<#
				$oClusters[0].data_center
				(gou ((gou $oClusters[1].data_center.href).link | ?{$_.rel -eq "clusters"}).href).cluster
				(gou ((gou $oClusters[1].data_center.href).link | ?{$_.rel -eq "storagedomains"}).href).storage_domain
				#>
			}ElseIF($oStorageDomain -or $oStorageDomainId){
			#I THINK I FORGOT TO FINISH THIS, OR IT IS MOVED BELOW TO THE VMDISK SECTION
				IF($oStorageDomain){}ElseIF($oStorageDomainId){}
			}
		}

		IF($oHost){
