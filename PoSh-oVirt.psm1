						}
						
						#The API only allows you to look up all items or a single item, 
						#so looping (or filtering of all) will be necessary when multiple returns are required
							#For Now this will just loops consequitive web requests, but I have added the SWITCH $BatchRetrieve
							#To test retrieving all Items then filtering for matches to compare performance
						SWITCH(($oVxName)){
