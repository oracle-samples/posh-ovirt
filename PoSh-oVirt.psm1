						IF(($oObjects = Get-oCluster -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oDataCenter -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oHost -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oStorageDomain -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oTemplate -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oVM -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}ElseIF(($oObjects = Get-oVmPool -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
						}Else{($oObjects = Get-oVnicProfile -Name $PSBoundParameters['oObject'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null}
					}
					{($InputObjectTypes -Contains {$PSBoundParameters['oObject'].GetType().Name}) -OR ($InputObjectTypes | %{Invoke-Expression "`$PSBoundParameters['oObject'] -is [$($_)]"})}{
						Write-Verbose "$($MyInvocation.MyCommand) oObject is GetType: $($_.GetType() | Out-String)"
						$oVirtServerName = ($PSBoundParameters['oObject']).oVirtServerName
						$oObjects = $PSBoundParameters['oObject']
					}
					#DEFAULT{Write-Warning "No Target Object found for new oPermission, quitting..."; BREAK}
				}
			}ElseIF($PSBoundParameters['oObjectId']){
				IF(($oObjects = Get-oCluster -Name $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oDataCenter -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oHost -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oStorageDomain -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oTemplate -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oVM -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}ElseIF(($oObjects = Get-oVmPool -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null){
				}Else{($oObjects = Get-oVnicProfile -Id $PSBoundParameters['oObjectId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue) | Out-Null}
			}ElseIF($PSBoundParameters['oObjectUid']){
				$UidUrl = [Uri]$oObjectUid
				$oObjects = Get-oUri -Uri $oObjectUid -oVirtServerName $oVirtServerName -EA SilentlyContinue
				$ObjectType = ($oVxObjectLookupArray | ?{$_.WebObjectPluralName -eq ($UidUrl.Segments[($UidUrl.Segments.count -2)]).Replace('/','')}).oVxObjectName
			}
		}
		IF($oObjects){$oObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		IF(!$oObjects){Write-Warning "No Target Object found for new oPermission, quitting..."; BREAK} #Else{Write-Host "$($oObjects | Select Name, ID | Out-String)"}
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oRole']){
				SWITCH($PSBoundParameters['oRole']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['oRole'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['oRole'] -EA SilentlyContinue
						}
						IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['oRole'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['oRole'] -EA SilentlyContinue
						}
						IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oRole]}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole is [oRole]"
						$oRoleObjects = $PSBoundParameters['oRole']
					}
					{$_.GetType().Name -eq "oRole"}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole GetType equals [oRole]"
						$oRoleObjects = $PSBoundParameters['oRole']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oRole is GetType: $($_.GetType() | Out-String)"
