			IF($NewoVmNic){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoVmNic -ObjectType "oVmNic" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
