Function Get-oVMConsoleTicket{
	<#
		.SYNOPSIS
			This function retrieves a Console Ticket for the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
			PipedObject should be type(s) oVM.
		.DESCRIPTION
			This function retrieves a Console Ticket for the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
			If the virtual machine is configured to support only one graphics protocol then the generated authentication token will be valid for that protocol. 
			But if the virtual machine is configured to support multiple protocols, VNC and SPICE, then the authentication token will only be valid for the SPICE protocol.
			This function accepts piped object types: oVM
		.PARAMETER Name
			The Name of the VM
		.PARAMETER Id
			The Id of the VM
		.PARAMETER Uid
			The Uid of the VM
		.PARAMETER Syncopate
			Switch to Syncopate (truncate/abridge) returned data set
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system to place the new oVM
		.EXAMPLE
			PS> Get-oVMConsoleTicket -oVirtServerName $oVirtServerName -Name "oVMName"
				
		.INPUTS
			[System.String]
			[oVM]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/ticket
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_graphics_console
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_graphics_console/methods/ticket
		.LINK
			Get-Help		
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			#[System.String]$oVM,
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		IF($PSBoundParameters.ContainsKey['Name']){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"}
		$oVMOBjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oVMOBjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oVMOBjects Names: $($oVMOBjects.Name)"
		
		ForEach($TargetoVM in $oVMOBjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoVM [$($TargetoVM.Name)]"
			$oVirtServerName = $TargetoVM.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_status
			$AcceptableRunStates = @('up','powering_up','powering_down','reboot_in_progress','restoring_state','saving_state')
			IF($AcceptableRunStates -Contains $TargetoVM.status){
				$GraphicsConsoles = (Get-oUri -RESTUri "$($TargetoVM.link.where({$_.rel -eq "graphicsconsoles"}).href)?current=true" -oVirtServerName $TargetoVM.oVirtServer).graphics_console
				IF($Null -eq $GraphicsConsoles){
					Write-Error "No SPICE or VNC console found for VM [$($TargetoVM.Name)]"
					Continue
				}
				IF($GraphicsConsoles){
					ForEach($GraphicsConsole in $GraphicsConsoles){
						$Uri = $BaseURL + $GraphicsConsole.actions.link.where({$_.rel -eq "ticket"}).href
						$VMActions = [PSCustomObject]@{'ticket'=$null}
						$JsonBody = $VMActions | ConvertTo-Json -Depth 50
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).AccessToken)"; "All-Content"="true"}
						TRY{$TicketResponse = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method POST -ContentType 'application/json' -Body $JsonBody -EV WebError}Catch{$FormattedWebError = $Null; $FormattedWebError = (Format-WebError -WebError $WebError -Body $Null -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
					}
				}
			}Else{
				#NotifyAndSkip
				Write-Warning "oVM [$($TargetoVM.Name)] is in state [$($TargetoVM.status)], console ticket not available"
			}
		}
	}
	End{$TicketResponse}
}

