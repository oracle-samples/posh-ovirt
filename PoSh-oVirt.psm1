				#<host id="789"/>
				
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/affinity_group_vm_labels/methods/add
				#POST /ovirt-engine/api/clusters/123/affinitygroups/456/vmlabels
				#<affinity_label id="789"/>
				
