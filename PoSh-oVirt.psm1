							IF($TypeName -eq "oVirt"){
								$oVxObjects | %{$_ | Add-Member -MemberType NoteProperty -Name Uid -Value "https://$($oVirtServerName):443/ovirt-engine/api"}
							}Else{
								$oVxObjects | %{$_ | Add-Member -MemberType NoteProperty -Name Uid -Value "https://$($oVirtServerName):443$($_.href)"}
