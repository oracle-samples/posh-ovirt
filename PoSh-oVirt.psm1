				Add-Member -NotePropertyName "ballooning" -NotePropertyValue $MemoryBallooning -inputObject $VMSpecsMemoryPolicy
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters NOT ContainsKey 'MemoryBallooning'"
			}
			IF($MemoryGuaranteed){Add-Member -NotePropertyName "guaranteed" -NotePropertyValue $MemoryGuaranteed -inputObject $VMSpecsMemoryPolicy}
			IF($MemoryMax){Add-Member -NotePropertyName "max" -NotePropertyValue $MemoryMax -inputObject $VMSpecsMemoryPolicy}
			IF($MemoryOverCommitPercentage){Add-Member -NotePropertyName "over_commit" -NotePropertyValue $MemoryOverCommitPercentage -inputObject $VMSpecsMemoryPolicy}
			IF($PSBoundParameters.ContainsKey('MemoryTHPEnabled')){Add-Member -NotePropertyName "transparent_huge_pages" -NotePropertyValue ([PSCustomObject]@{enabled = $MemoryTHPEnabled}) -inputObject $VMSpecsMemoryPolicy}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsMemoryPolicy: [$($VMSpecsMemoryPolicy | Out-String)]"
		Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['MemoryBallooning']: [$($PSBoundParameters['MemoryBallooning'])]"
		Write-Verbose "$($MyInvocation.MyCommand): `$MemoryBallooning: [$($MemoryBallooning)]"
		

		IF($PSBoundParameters.ContainsKey('HAEnabled')){
			$VMSpecsHA = [PSCustomObject]@{"enabled" = $HAEnabled}
			SWITCH($HAPriority){
				{$_ -eq "Low"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 1 -inputObject $VMSpecsHA}
				{$_ -eq "Medium"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 50 -inputObject $VMSpecsHA}
				{$_ -eq "High"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 100 -inputObject $VMSpecsHA}
			}
		}
		
		IF($CPUShares){
			SWITCH($CPUShares){
				{$_ -eq 'disabled'}{$cpu_shares = 0}
				{$_ -eq 'low'}{$cpu_shares = 512}
				{$_ -eq 'medium'}{$cpu_shares = 1024}
				{$_ -eq 'high'}{$cpu_shares = 2048}
				{$_ -eq 'custom'}{IF($CPUSharesInt){$cpu_shares = $CPUSharesInt}Else{$cpu_shares = 0}}
			}
		}
		
		#PoweredOFF
		IF($CpuCoresPerSocket -OR $CpuSockets -OR $CpuThreads){
			$VMSpecsCpuTopology = [PSCustomObject]@{
				"cores" = $CpuCoresPerSocket
				"sockets" = $CpuSockets
				"threads" = $CpuThreads
			}
		}
		
		# (gou /ovirt-engine/api/operatingsystems).operating_system|Select -ExpandProperty architecture|Sort -u
		#PoweredOFF
		IF($CpuType -OR $VMSpecsCpuTopology -OR $VMType){
			$VMSpecsCpu = [PSCustomObject]@{}
			IF($VMSpecsCpuTopology){Add-Member -NotePropertyName "topology" -NotePropertyValue $VMSpecsCpuTopology -inputObject $VMSpecsCpu}
			IF($CpuType){Add-Member -NotePropertyName "architecture" -NotePropertyValue $CpuType -inputObject $VMSpecsCpu}
			IF(($VMType -eq "high_performance") -AND ($MigrationMode -eq 'pinned' -OR 'user_migratable')){
				#Disabled migration
				IF($PSBoundParameters['PassThroughHostCPU'] -eq $True){
					Add-Member -NotePropertyName "mode" -NotePropertyValue "host_passthrough" -inputObject $VMSpecsCpu
				}Else{
					Add-Member -NotePropertyName "mode" -NotePropertyValue $Null -inputObject $VMSpecsCpu
				}
			}ElseIF(($PSBoundParameters['PassThroughHostCPU'] -eq $True) -AND ($MigrationMode -eq 'pinned' -OR 'user_migratable')){
				Add-Member -NotePropertyName "mode" -NotePropertyValue "host_passthrough" -inputObject $VMSpecsCpu
			}Else{
				Add-Member -NotePropertyName "mode" -NotePropertyValue $Null -inputObject $VMSpecsCpu
			}
		}
		
		IF(($CpuProfile) -or ($CpuProfileId)){
			$VMSpecsCpuProfile = [PSCustomObject]@{}
			IF($CpuProfileId -And !$CpuProfile){
				$CpuProfile = (Get-oUri -RESTUri "/ovirt-engine/api/cpuprofiles/$($CpuProfileId)" -oVirtServerName $oVirtServerName).name #Faster
			}
			IF($CpuProfile){Add-Member -NotePropertyName "name" -NotePropertyValue $CpuProfile -inputObject $VMSpecsCpuProfile}
		}

		IF($PSBoundParameters.ContainsKey('BiosBootMenuEnabled') -or $BiosType){
			$VMSpecsBios = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('BiosBootMenuEnabled')){
				$VMSpecsBiosBoot_menu = [PSCustomObject]@{"enabled" = $BiosBootMenuEnabled}
			}
			IF($VMSpecsBiosBoot_menu){Add-Member -NotePropertyName "boot_menu" -NotePropertyValue $VMSpecsBiosBoot_menu -inputObject $VMSpecsBios}
			IF($BiosType){Add-Member -NotePropertyName "type" -NotePropertyValue ((($BiosType).Split('[]') | ?{$_})[1]) -inputObject $VMSpecsBios}
		}
		
		$BootArray = [System.Collections.ArrayList]@()
		IF($FirstBootDevice){$BootArray.Add($FirstBootDevice) | Out-Null}
		IF($SecondBootDevice){$BootArray.Add($SecondBootDevice) | Out-Null}
		IF($BootArray.Count -ge 1){
			$VMSpecsOSBootDevices = [PSCustomObject]@{"device" = $BootArray}
			$VMSpecsOSBoot = $Null
			$VMSpecsOSBoot = [PSCustomObject]@{"devices" = $VMSpecsOSBootDevices}
		}
		
		$VMSpecsOS = $Null
		#(gou /ovirt-engine/api/operatingsystems).operating_system|Select architecture,name,description,id|Sort architecture,name,description
		IF($OSType -OR $VMSpecsOSBoot){
			$OSTypeLookup = ($OSTypeLookupArray | ?{$_.Name -eq ((($OSType).Split('[]') | ?{$_})[1])})
			IF($OSTypeLookup.Architecture -ne $CpuType){
				Write-Warning "You Selected OSType: [$(((($OSType).Split('[]') | ?{$_})[0]))] which is for CPUType [$($OSTypeLookup.Architecture)] but the CPUType  is set to [$($CpuType)], they are incompatibile, quitting..."
				BREAK
			}
			IF($VMSpecsOSBoot -OR $OSTypeLookup){
				$VMSpecsOSType = ((($OSType).Split('[]') | ?{$_})[1])
				$VMSpecsOS = [PSCustomObject]@{}
				IF($VMSpecsOSBoot){Add-Member -NotePropertyName "boot" -NotePropertyValue $VMSpecsOSBoot -inputObject $VMSpecsOS}
				IF($VMSpecsOSType){Add-Member -NotePropertyName "type" -NotePropertyValue $VMSpecsOSType -inputObject $VMSpecsOS}
			}
		}
		#Limitation: TPM devices can be used only with UEFI BIOS
		IF($PSBoundParameters.ContainsKey('TPMDeviceEnabled')){
			Write-VerBose "`$TPMDeviceEnabled Section"
			#$oVM.bios.type
			#'I440FX Chipset with BIOS [i440fx_sea_bios]', 'Q35 Chipset with BIOS [q35_sea_bios]', 'Q35 Chipset with UEFI [q35_ovmf]', 'Q35 Chipset with UEFI SecureBoot [q35_secure_boot]'
			# TPM must have a BIOS Type UEFI ("q35_ovmf" -OR "q35_secure_boot")
			#IF($BiosType -Match "UEFI"){
			IF((($BiosType -Match "q35_ovmf") -OR ($BiosType -Match "q35_secure_boot")) -AND ($PSBoundParameters['TPMDeviceEnabled'] -eq $True)){
				IF($CpuType){
					IF($OSType){
						Write-VerBose "`$TPMDeviceEnabled Section: OSType [$($OSType)]"
						$OSTypeLookup = ($OSTypeLookupArray | ?{$_.Name -eq ((($OSType).Split('[]') | ?{$_})[1])})
						IF($OSTypeLookup){
							Write-VerBose "`$TPMDeviceEnabled Section: OSTypeLookup [$($OSTypeLookup | Out-String)]"
							IF($OSTypeLookup.Architecture -eq $CpuType){
								Write-VerBose "`$TPMDeviceEnabled Section: OSTypeLookup Architecture equals CpuType: [$($CpuType)]"
								IF((($BiosType -Match "q35_ovmf") -OR ($BiosType -Match "q35_secure_boot"))){
									Write-VerBose "`$TPMDeviceEnabled Section(1): OSTypeLookup Architecture equals BiosType: [$($BiosType)]"
									$VMSpecsTPMEnabled = $True
								}
							}Else{
								Write-VerBose "`$TPMDeviceEnabled Section: OSTypeLookup Architecture does NOT equal CpuType: [$($CpuType)]"
								Write-Warning "Can not enable TPM Device For oVM [$($Name)], CPU Architecture and OS Type Architecture do not match"
							}
						}Else{
							Write-VerBose "`$TPMDeviceEnabled Section: OSTypeLookup [Not Found]"
							$VMSpecsTPMEnabled = $False
						}
					}Else{
						Write-VerBose "`$TPMDeviceEnabled Section: No OSType provided"
						$VMSpecsTPMEnabled = $False
					}
				}Else{
					Write-VerBose "`$TPMDeviceEnabled Section: No CpuType provided"
					$VMSpecsTPMEnabled = $False
				}
			}Else{
				Write-Warning "Can NOT Enable TPM unless BiosType is UEFI (`'q35_ovmf`' OR `'q35_secure_boot`')"
			}
		}
		
		IF($PSBoundParameters.ContainsKey('SerialNumberPolicy') -or $PSBoundParameters['CustomSerialNumber']){
			#Needs Restart or possibly being in down state, changed, then oVM object updates on power on state
			IF($PSBoundParameters['SerialNumberPolicy']){
				$SerialNumberSpec = [PSCustomObject]@{'policy' = $($PSBoundParameters['SerialNumberPolicy'])}
				IF($PSBoundParameters['SerialNumberPolicy'] -eq "custom"){
					IF($PSBoundParameters['CustomSerialNumber']){
						Add-Member -NotePropertyName "value" -NotePropertyValue $PSBoundParameters['SerialNumberPolicy'] -inputObject $SerialNumberSpec
					}
				}
			}
		}
				
		
		$VMSpecs = $Null
		$TempVMSpecs = $Null
		$TempVMSpecs = [PSCustomObject]@{
			name = $Name
			instance_type = $VMSpecsInstanceType
			template = $VMSpecstemplate
			cluster = $VMSpecscluster
			cpu = $VMSpecsCpu
			os = $VMSpecsOS
			placement_policy = $VMSpecsPlacementPolicy
			comment = $comment
			description = $description
			type = $VMType
			memory = $Memory
			display = $VMSpecsDisplay
			io = $VMSpecsIO
			auto_pinning_policy = $AutoPinningPolicy
			cpu_pinning_policy = $CPUPinningPolicy
			cpu_shares = $cpu_shares
			high_availability = $VMSpecsHA
			lease = $VMSpecsLeaseStorageDomain
			memory_policy = $VMSpecsMemoryPolicy
			migration = $VMSpecsMigration
			storage_error_resume_behaviour = $VmStorageErrorResumeBehaviour
			time_zone = $VMSpecsTimeZone
			#guest_time_zone = $VMSpecsTimeZone
			usb = $VMSpecsUsb
			console = $VMSpecsSerialConsole
			virtio_scsi = $VMSpecsVirtioScsi
			virtio_scsi_multi_queues_enabled = $VirtIOSCSIMultiQueuesEnabled
			virtio_scsi_multi_queues = $(IF($PSBoundParameters.ContainsKey('VirtIOSCSIMultiQueuesCustomCount')){$(IF($PSBoundParameters['VirtIOSCSIMultiQueues'] -eq "custom"){$PSBoundParameters['VirtIOSCSIMultiQueuesCustomCount']}ElseIF($PSBoundParameters['VirtIOSCSIMultiQueues'] -eq "automatic"){"0"})})
			serial_number = $SerialNumberSpec
			rng_device = $VMSpecsRandomGeneratorDevice
			bios = $VMSpecsBios
			custom_cpu_model = $CustomCPU
			custom_emulated_machine = $CustomEmulatedMachine
			cpu_profile = $VMSpecsCpuProfile
			tpm_enabled = $VMSpecsTPMEnabled
			custom_properties = $VMSpecsCustomProperties
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$TempVMSpecs: [$($TempVMSpecs | Out-String)]"
		$VMSpecs = [PSCustomObject]@{}
		
		ForEach($Item in ($TempVMSpecs.psobject.Members | ?{$_.MemberType -Match "Property"}  | ?{-not [String]::IsNullOrEmpty($_.value)})){
			Add-Member -NotePropertyName $Item.Name -NotePropertyValue $Item.Value -inputObject $VMSpecs
		}
		IF($PSBoundParameters.ContainsKey('Stateless')){Add-Member -MemberType NoteProperty -Name stateless -Value $PSBoundParameters['Stateless'] -InputObject $VMSpecs}
		IF($PSBoundParameters.ContainsKey('DeleteProtected')){Add-Member -MemberType NoteProperty -Name delete_protected -Value $PSBoundParameters['DeleteProtected'] -InputObject $VMSpecs}
		IF($PSBoundParameters.ContainsKey('MultiQueuesEnabled')){Add-Member -MemberType NoteProperty -Name multi_queues_enabled -Value $PSBoundParameters['MultiQueuesEnabled'] -InputObject $VMSpecs}
		IF($PSBoundParameters.ContainsKey('SoundCardEnabled')){
			IF($VMType -ne "high_performance"){Add-Member -MemberType NoteProperty -Name "soundcard_enabled" -Value $PSBoundParameters['SoundCardEnabled'] -InputObject $VMSpecs}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['SoundCardEnabled']: [$($PSBoundParameters['SoundCardEnabled'])]"
		
		IF($PSBoundParameters.ContainsKey('StartPaused')){Add-Member -MemberType NoteProperty -Name start_paused -Value $PSBoundParameters['StartPaused'] -InputObject $VMSpecs}
		IF($PSBoundParameters.ContainsKey('TPMDeviceEnabled')){Add-Member -MemberType NoteProperty -Name tpm_enabled -Value $VMSpecsTPMEnabled -InputObject $VMSpecs}
				
		Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecs Updated: [$($VMSpecs | Out-String)]"
		
		$Token = $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vms/methods/add/parameters/clone
		IF($ForkTemplateDisk.IsPresent -eq $True){
			$Uri = $BaseURL + '/ovirt-engine/api/vms'
		}Else{
			$Uri = $BaseURL + '/ovirt-engine/api/vms?clone=true'
		}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vms/methods/add/parameters/clone_permissions
		IF($CloneTemplatePermissions.IsPresent -eq $True){
			$Uri = ?clone_permissions=true
			IF($ForkTemplateDisk.IsPresent -eq $True){
				$Uri = $Uri + '?clone_permissions=true'
			}Else{
				$Uri = $Uri + '&clone_permissions=true'
			}
		}
		
		$XMLBody = "<vm><name>$($Name)</name><cluster><name>$($oCluster)</name></cluster><template><name>Blank</name></template></vm>"
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$BaseVMSpecs = [PSCustomObject]@{
			name = $Name
			cluster = $VMSpecscluster
			template = ([PSCustomObject]@{'name'="Blank"})
		}
		$XMLBody = Convert-PSCustomObjectToXMLString -PSCustomObject $BaseVMSpecs -RootName vm  -replace "`n",", " -replace "`r",", "
		$XMLBody = [string]::join("",($XMLBody.Split("`n").Split("`r")))
		
		$Method = "POST"
		IF($BaseVMSpecsOnly.IsPresent -eq $True){
			$JsonBody = $BaseVMSpecs | ConvertTo-Json -Depth 50
		}Else{
			$JsonBody = $VMSpecs | ConvertTo-Json -Depth 50
		}
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oVM"
		Write-Verbose "$($JsonBody | Out-String)"
		Try{$NewVM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{
			$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError
		}
		
		IF($NewVM){
			Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			
			#This is still failing sometimes with message: "Cannot edit VM. Related operation is currently in progress. Please try again later.", added 500ms wait after down state detection
			IF($PSBoundParameters.ContainsKey('RandomGeneratorEnabled')){
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['RandomGeneratorEnabled']: [$($PSBoundParameters['RandomGeneratorEnabled'])]"
				IF($PSBoundParameters['RandomGeneratorEnabled'] -ne $True){
					$MaxLoopWaitSeconds = 60
					$DoLoopStopWatch = New-Object -TypeName System.Diagnostics.Stopwatch
					$DoLoopStopWatch.Start()
					Do{
						Start-Sleep -Seconds 1
						$TmpoVM = $Null; $TmpoVM = Get-oUri -RESTUri $NewVM.href -oVirtServerName $(([URI]$Uri).Host)
					}Until(($TmpoVM.Status -eq "down") -OR ($DoLoopStopWatch.Elapsed.TotalSeconds -gt $MaxLoopWaitSeconds))
					$DoLoopStopWatch.Stop(); $DoLoopStopWatch = $Null
					Start-Sleep -Milliseconds 500 
					#Looping above should keep the Token valid
					IF($TmpoVM.Status -eq "down"){
						$VMSpecs = $Null
						$VMSpecs = [PSCustomObject]@{rng_device = [PSCustomObject]@{}}
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						$Uri = $BaseURL + $NewVM.href
						$Method = "PUT"
						$JsonBody = $VMSpecs | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oVM Random Number Generator"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedVM = $Null
						Try{$UpdatedVM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError | Select *; Write-Error $FormattedWebError.ResponseBody.Detail; $FormattedWebError}
						IF($UpdatedVM){$NewVM = $UpdatedVM; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}Else{Write-Warning "Provisioning of oVM took longer than [$($MaxLoopWaitSeconds)] seconds, 'Random Number Generator' NOT Disabled"}
				}ElseIF(($PSBoundParameters['RandomGeneratorEnabled'] -eq $True) -AND ($NewVM.rng_device.source -ne "urandom")){
					$MaxLoopWaitSeconds = 60
					$DoLoopStopWatch = New-Object -TypeName System.Diagnostics.Stopwatch
					$DoLoopStopWatch.Start()
					Do{
						Start-Sleep -Seconds 1
						$TmpoVM = $Null; $TmpoVM = Get-oUri -RESTUri $NewVM.href -oVirtServerName $(([URI]$Uri).Host)
					}Until(($TmpoVM.Status -eq "down") -OR ($DoLoopStopWatch.Elapsed.TotalSeconds -gt $MaxLoopWaitSeconds))
					$DoLoopStopWatch.Stop(); $DoLoopStopWatch = $Null
					Start-Sleep -Milliseconds 500 
					IF($TmpoVM.Status -eq "down"){
						$VMSpecsRandomGeneratorDevice = $Null
						$VMSpecsRandomGeneratorDevice = [PSCustomObject]@{"rng_device" = ([PSCustomObject]@{"source" = "urandom"})}
						IF(($RandomGeneratorDurationMs) -AND ($RandomGeneratorBytesPerSec)){
							$VMSpecsRandomGeneratorDeviceRate = [PSCustomObject]@{
								period=$RandomGeneratorDurationMs
								bytes=$RandomGeneratorBytesPerSec
							}
							Add-Member -NotePropertyName "rate" -NotePropertyValue $VMSpecsRandomGeneratorDeviceRate -inputObject $VMSpecsRandomGeneratorDevice
						}
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						$Uri = $BaseURL + $NewVM.href
						$Method = "PUT"
						$JsonBody = $VMSpecsRandomGeneratorDevice | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oVM Random Number Generator"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedVM = $Null
						Try{$UpdatedVM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError | Select *; Write-Error $FormattedWebError.ResponseBody.Detail; $FormattedWebError}
						IF($UpdatedVM){$NewVM = $UpdatedVM; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}Else{Write-Warning "Provisioning of oVM took longer than [$($MaxLoopWaitSeconds)] seconds, 'Random Number Generator' NOT Enabled"}
				}
			}
			
			Write-Verbose "$($MyInvocation.MyCommand): Converting Rest Object to oVM Object"
			$NewVM = (Convert-RestResponseTooVirtObject -InputObject $NewVM -ObjectType "oVM" -oVirtServerName $oVirtServerName)
		}
		#endregion BuildVMContainer

		IF($NewVM -AND ($BaseVMSpecsOnly.IsPresent -ne $True)){
			Write-Verbose "$($MyInvocation.MyCommand): Created oVM"
			#region SetHeadlessMode
			#DELETE /ovirt-engine/api/vms/<vm-id>/graphicsconsoles/<console-id>
			IF($PSBoundParameters['HeadlessMode'] -Eq $True){
				ForEach($GraphicsConsoleHref in ((Get-oUri -RESTUri $NewVM.link.where({$_.rel -eq "graphicsconsoles"}).href -oVirtServerName $oVirtServerName).graphics_console.href)){
					Get-oUri -RESTUri $GraphicsConsoleHref -oVirtServerName $oVirtServerName -Method DELETE | Out-Null
				}
				$TempNewVM = $Null; $TempNewVM = Get-oVM -Id $NewVM.Id -oVirtServerName $NewVM.oVirtServer -EA SilentlyContinue
				IF($TempNewVM){$NewVM = $TempNewVM}
			}
			#endregion SetHeadlessMode
			#region BuildVMNic
			IF($oVNicProfile -AND (!($oVNicProfileId))){
				#Get ALL Available oVNicProfiles
				$ALLAvailableoVNicProfiles = ((Get-oUri -RESTUri "/ovirt-engine/api/vnicprofiles" -oVirtServerName $oVirtServerName).vnic_profile)
				$oVMCluster = (Get-oUri -RESTUri $NewVM.cluster.href -oVirtServerName $oVirtServerName)
				$oVMDataCenter = (Get-oUri -RESTUri $oVMCluster.data_center.href -oVirtServerName $oVirtServerName)
				$AvailableoVNicProfiles = $ALLAvailableoVNicProfiles | ?{(Get-oUri -RESTUri $_.network.href -oVirtServerName $oVirtServerName).data_center.id -eq $oVMDataCenter.Id}
				$oVNicProfileId = ($AvailableoVNicProfiles | ?{$_.Name -eq $oVNicProfile}).id				
			}
			IF($oVNicProfileId){
				IF(!$oNicName){$oNicName = "$($NewVM.Name)_oNic0"}
				$VMSpecsnicVNicProfileId = [PSCustomObject]@{id=$oVNicProfileId}
				#$CustomMACaddress = "56:6f:df:3c:00:39"
				IF($CustomMACaddress){$VMSpecsnicVNicCustomMACaddress = [PSCustomObject]@{address = $CustomMACaddress}}
				$TempVMSpecsnic = [PSCustomObject]@{
					name = $oNicName
					comment = $oNicComment
					description = $oNicDescription
					interface = $oNicType
					vnic_profile = $VMSpecsnicVNicProfileId
					mac = $VMSpecsnicVNicCustomMACaddress
				}
				IF($PSBoundParameters.ContainsKey('oNicLinkedEnable')){Add-Member -MemberType NoteProperty -Name linked -Value $oNicLinkedEnable -InputObject $TempVMSpecsnic}
				IF($PSBoundParameters.ContainsKey('oNicPluggedEnable')){Add-Member -MemberType NoteProperty -Name plugged -Value $oNicPluggedEnable -InputObject $TempVMSpecsnic}
				IF($PSBoundParameters.ContainsKey('oNicConnectOnBoot')){Add-Member -MemberType NoteProperty -Name on_boot -Value $oNicConnectOnBoot -InputObject $TempVMSpecsnic}
				
				$VMSpecsnic = [PSCustomObject]@{}
				ForEach($Item in ($TempVMSpecsnic.psobject.Members|?{$_.MemberType -Match "Property"}|?{$_.value -ne $Null}|?{$_.value -ne ""})){
					Add-Member -NotePropertyName $Item.Name -NotePropertyValue $Item.Value -inputObject $VMSpecsnic
				}
		
				Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsnic"
				Write-Verbose "$($VMSpecsnic | Out-String)"
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/nics"
				$Method = "POST"
				$JsonBody = $VMSpecsnic | ConvertTo-Json -Depth 50
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create vNIC"
				Write-Verbose "$($JsonBody | Out-String)"
				Try{$NewVMNic = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $NewVMNicError = $FormattedWebError}
			}Else{Write-Verbose "$($MyInvocation.MyCommand): `$oVNicProfileId missing, can't create connection to Network, skipping vNic creation"}
			#endregion BuildVMNic

			#region BuildVMDisk
			#NOTE: Storage Mandatory for a new VM's disk, But NOT a VM container
		
			IF($NoDisk.IsPresent -ne $True){
				#https://github.com/oVirt/ovirt-engine-api-model/blob/master/src/main/java/004-QuickStartExample.adoc
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#_create_virtual_machine_disk
				#POST /ovirt-engine/api/vms/007/diskattachments
				#It is important to recognize the difference between a disk entity and a disk attachment, which is an assignment of disk to VM
				#Create the disk first then attach it, because the attachment/create combination only seems to work with XML
				IF($oStorageDomainId -and (!($oStorageDomain))){
					Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainId: [$($oStorageDomainId)]"
					$VMSpecsDiskStorageDomain = [PSCustomObject]@{"id" = "$($oStorageDomainId)"}
				}ElseIF(!($oStorageDomain)){
					$NewVMCluster =  Get-oUri -RESTUri $NewVM.Cluster.href -oVirtServerName $oVirtServerName
					$NewVMDataCenter =  Get-oUri -RESTUri ($NewVMCluster.data_center.href) -oVirtServerName $oVirtServerName
					$NewVMStorageDomains =  (Get-oUri -RESTUri (($NewVMDataCenter.link | ?{$_.rel -eq "storagedomains"}).href) -oVirtServerName $oVirtServerName).storage_domain
					$oStorageDomain = ($NewVMStorageDomains | ?{$_.Status -eq "active"} | ?{$_.available -ge $DiskSize} | Select -First 1).Name
				}
				IF($oStorageDomain -and (!($oStorageDomainId))){$VMSpecsDiskStorageDomain = [PSCustomObject]@{"name" = "$($oStorageDomain)"}}
				IF($VMSpecsDiskStorageDomain){
					Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsDiskStorageDomain: [$($VMSpecsDiskStorageDomain | Out-String)]"
					$VMSpecsDiskStorageDomains = [PSCustomObject]@{"storage_domain" = @($VMSpecsDiskStorageDomain)} #Works with JSON
					
					IF(!$DiskName){$DiskName = "$($NewVM.Name)_OS_Disk"}
					IF(!$DiskName){$DiskName = "mybootdisk"}
					IF($DiskFormat -AND $DiskSize -AND $DiskType -AND $DiskInterface){
						#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk
						$TempVMSpecsDisk = [PSCustomObject]@{
							# "active" = $true
							"backup" = "incremental"
							#"backup_mode" = "full" or "incremental"
							#"bootable" = $true
							"comment" = $DiskComment
							#"content_type" = 'data'
							"description" = $DiskDescription
							#disk_profile = ""
							"format" = $DiskFormat
							"name" = $DiskName
							"provisioned_size" = $DiskSize
							"sparse" = $false
							"storage_domains" = $VMSpecsDiskStorageDomains
							#"quota" = "someID"
							"shareable" = $false
							#"storage_type" = $DiskType
							#"uses_scsi_reservation" = $false
							"wipe_after_delete" = $false
						}
						$VMSpecsDisk = [PSCustomObject]@{}
						ForEach($Item in ($TempVMSpecsDisk.psobject.Members|?{$_.MemberType -Match "Property"}|?{$_.value -ne $Null}|?{$_.value -ne ""})){
							Add-Member -NotePropertyName $Item.Name -NotePropertyValue $Item.Value -inputObject $VMSpecsDisk
						}
			
						#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachments
						$TempVMSpecsDiskAttachment = [PSCustomObject]@{
							"active" = $true
							"bootable" = $true
							"interface" = $DiskInterface
							#"pass_discard" = $true #might be depricated
							#"read_only" = $false
							"disk" = $VMSpecsDisk
							#uses_scsi_reservation = $false
						}
						$VMSpecsDiskAttachment = [PSCustomObject]@{}
						ForEach($Item in ($TempVMSpecsDiskAttachment.psobject.Members|?{$_.MemberType -Match "Property"}|?{$_.value -ne $Null}|?{$_.value -ne ""})){
							Add-Member -NotePropertyName $Item.Name -NotePropertyValue $Item.Value -inputObject $VMSpecsDiskAttachment
						}
						Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsDiskAttachments"
						Write-Verbose "$($VMSpecsDiskAttachments | Out-String)"
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/diskattachments"
						$Method = "POST"
						$JsonBody = $VMSpecsDiskAttachment | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oDiskAttachment"
						Write-Verbose "$($JsonBody | Out-String)"
						Try{$NewVMDiskAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $NewVMDiskAttachmentError = $FormattedWebError}
					}Else{Write-Host -Fore Yellow "Missing Disk definition(s) required to create Disk for oVM [$($Name)]"}
				}Else{Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomain missing/undetermined, can't create diskattackment, skipping Disk creation"}
			}Else{Write-Verbose "$($MyInvocation.MyCommand): `$NoDisk switch parameter detected, skipping Disk creation"}
			#endregion BuildVMDisk

			#region BuildVMCD

			#Attach CDROM/ISO It seems a blank CD device is created with the VM you just have to load it with an ISO
			#Currently virtual machines have exactly one CDROM device. No new devices can be added, and the existing one can’t be removed, thus there are no add or remove methods.
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_cdroms
			#GET /ovirt-engine/api/vms/123/cdroms
			#To change or eject the disk by changing the value of the file attribute PERMANENT
			#PUT /ovirt-engine/api/vms/123/cdroms/00000000-0000-0000-0000-000000000000
			
			#To change the disk that is visible to the current running virtual machine, add the current=true
			#changes made with the current=true parameter are never persisted
			#PUT /ovirt-engine/api/vms/123/cdroms/00000000-0000-0000-0000-000000000000?current=true
			
			$ExistingAttachedCD = $Null
			$ExistingAttachedCD = (Get-oUri -RESTUri ($NewVM.link | ?{$_.rel -eq "cdroms"}).href -oVirtServerName $oVirtServerName).cdrom
			
			IF($AttachCD -eq 'StartConnected'){
				IF($BootCDImage -or $BootCDImageId){
					IF($BootCDImageId){
						$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{id = $BootCDImageId}} #works
					}ElseIF($BootCDImage){
						#Get ALL Available ISO files
						$oVMCluster = (Get-oUri -RESTUri $NewVM.cluster.href -oVirtServerName $oVirtServerName)
						$oVMDataCenter = (Get-oUri -RESTUri $oVMCluster.data_center.href -oVirtServerName $oVirtServerName)
						$oVMStorageDomains = (Get-oUri -RESTUri ($oVMDataCenter.link | ?{$_.rel -eq "storagedomains"}).href -oVirtServerName $oVirtServerName).storage_domain
						$oVMStorageDomainISOs = ($oVMStorageDomains.link | ?{$_.rel -eq "disks"}).href | %{(Get-oUri -RESTUri $_ -oVirtServerName $oVirtServerName).disk | ?{$_.content_type -eq "iso"}}
						$AvailableISOImages = $oVMStorageDomainISOs
						$BootCDImageId = ($AvailableISOImages | ?{$_.Name -eq $BootCDImage}).Id
						$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{id = $BootCDImageId}}
					}
					
					IF($BootCDImageId){
						Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecCDROM"
						Write-Verbose "$($VMSpecCDROM | Out-String)"
						$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						#Remember there are 2 options here, 1 for setting permanent boot CD, 1 for popping the tray open and dropping in a CD
						<#
							#For live CD access NOT Boot settings
							#The changes made with the current=true parameter are never persisted, so they won’t have any effect after the virtual machine is rebooted.
							$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/cdroms/$($ExistingAttachedCD.Id)?current=true"
							$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/cdroms/$($ExistingAttachedCD.Id)?current=true"
						#>
						
						$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/cdroms/$($ExistingAttachedCD.Id)"
						$Method = "PUT"
						$JsonBody = $VMSpecCDROM | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create CDROM ISO Attachment"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedCDROM = $Null; 
						Try{$UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $UpdatedCDROMError = $FormattedWebError}
					}Else{Write-Warning "CDROM Image [$($BootCDImage)] not found"}
				}
			}ElseIF($AttachCD -eq 'StartDisConnected'){
				#Remove ISO from Virtual CDROM
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Method = "PUT"
				$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/cdroms/$($ExistingAttachedCD.Id)"
				$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{id = ''}}
				$JsonBody = $VMSpecCDROM | ConvertTo-Json -Depth 50
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Remove CDROM ISO Attachment"
				Write-Verbose "$($JsonBody | Out-String)"
				$UpdatedCDROM = $Null; 
				Try{$UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $UpdatedCDROMError = $FormattedWebError}
			}

			#endregion BuildVMCD

			#region BuildVMWatchdog
			IF($WatchDogModel){
				IF($WatchDogModel -ne "no_watchdog" ){
					$VMSpecsWatchDogs = [PSCustomObject]@{
						model = $WatchDogModel
						action = $WatchDogAction
					}
					Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsWatchDogs"
					Write-Verbose "$($VMSpecsWatchDogs | Out-String)"
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$Uri = $BaseURL + "/ovirt-engine/api/vms/$($NewVM.Id)/watchdogs"
					$Method = "POST"
					$JsonBody = $VMSpecsWatchDogs | ConvertTo-Json -Depth 50
					Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create WatchDog"
					Write-Verbose "$($JsonBody | Out-String)"
					Try{$NewWatchDog = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $NewWatchDogError = $FormattedWebError}
				}
			}

			#endregion BuildVMWatchdog
		}
	}
	End{$NewVM}
}

Function Set-oVMPowerState{
	<#
		.SYNOPSIS
			This function starts the provided oVM, on an oVirt Server system.
		.DESCRIPTION
			This function starts the provided oVM, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oVM(s)
			Can use Wildcard '*'
				I.e. MyIte*
		.PARAMETER Id
			The Id(s) of oVM(s)
		.PARAMETER Uid
			The Uid(s) of oVM(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER PowerState
			The desired power state
			Valid Options "Start", "Shutdown", "Stop", "Suspend", "Reboot", "Reset"
		.PARAMETER CaseSensitive
			Switch to search Case Sensitive oVM name(s)
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER filter
			Indicates if the results should be filtered according to the permissions of the user.
		.PARAMETER authorized_key
			NOTE: Feature NOT Defined in this version of Function, Reserved for Future Release
		.PARAMETER pause
			If set to true, start the virtual machine in paused mode.
		.PARAMETER use_cloud_init
			If set to true, the initialization type is set to cloud-init.
		.PARAMETER use_ignition
			If set to true, the initialization type is set to Ignition.
		.PARAMETER use_initialization
			If set to true, the initialization type is set by the VM’s OS.
		.PARAMETER use_sysprep
			If set to true, the initialization type is set to Sysprep.
		.PARAMETER vmdefinition
			The definition of the virtual machine for this specific run.
			NOTE: Feature NOT Defined in this version of Function, Reserved for Future Release
		.PARAMETER volatile
			Indicates that this run configuration will be discarded even in the case of guest-initiated reboot.
		.EXAMPLE
			PS> Set-oVMPowerState -oVirtServerName $oVirtServerName -Name "Name" -PowerState Start
				Changes the Power State of the oVM(s) by provided Name
		.EXAMPLE
			PS> Set-oVMPowerState -oVirtServerName $oVirtServerName -Id "Id" -PowerState Start
				Changes the Power State of the oVM(s) by provided Id
		.EXAMPLE
			PS> Get-oVM -oVirtServerName $oVirtServerName -Name "Name" | Set-oVMPowerState -PowerState Start
				Changes the Power State of the Piped oVM(s)
		.INPUTS
			[System.String]
			[oVirtToken]
			[oVM]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVM]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		4/18/2024
			Version 1.0b	9/20/2024
			Version 1.0c	3/14/2025 #PI Day
			Version 1.0d	4/21/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set02')]
	Param(
		#oAffinityLabel Name
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0)]
			[Alias('N')]
			[ValidateScript({$_ | %{(($_).GetType().Name -match 'oVM|String')}})]$Name,
		
        #oAffinityLabel Id
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('I')]
			[System.String[]]$Id,
		
       [Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set04")]
			[Alias('U')]
			[System.String[]]$Uid,
		
        #Switch to search Case Sensitive oDomain name(s)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
			[Alias('CS')]
			[SWITCH]$CaseSensitive,
			
		#Switch to set Desired Power State
		[Parameter(Mandatory=$True, ValueFromPipelineByPropertyName=$True, Position=1)]
			[Alias('PS')]
			[ValidateSet("Start","Shutdown","Stop","Suspend","Reboot","Reset")][System.String]$PowerState,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$RunAsync,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[PSCustomObject]$authorized_key,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$filter,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$pause,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$use_cloud_init,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$use_ignition,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$use_initialization,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$use_sysprep,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[SWITCH]$vmdefinition,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$volatile,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Process"
		$oVxObjectName = "oVM"
		$Method = "POST"
		$BaseURL = "https://$($oVirtServerName)/ovirt-engine/api/vms"
		$RetreivedRawoVM = $Null
		$RetreivedoVM = $Null
		$oVMOBjects = $Null
		$URIs = $Null
		IF($PSBoundParameters['Id']){
			ForEach($IdItem in $PSBoundParameters['Id']){
				IF($oVirtServerName){
					#$RetreivedRawoVM = Get-oUri -oVirtServerName $oVirtServerName -RESTUri "/ovirt-engine/api/vms/$($PSBoundParameters['Id'])"
					$oVMOBjects += Get-oVM -Id $IdItem -oVirtServerName $oVirtServerName
				}Else{
					#$RetreivedRawoVM = Get-oUri -RESTUri "/ovirt-engine/api/vms/$($PSBoundParameters['Id'])"
					#Above, while faster, won't work because it does not return the oVirt Server name, which is required to insure accurate results, where duplicate oVM IDs may exist across multiple OLVM servers
					$RetreivedoVM = $Null
					$RetreivedoVM = Get-oVM -Id $PSBoundParameters['Id']
					IF($RetreivedoVM.Count -eq 1){
						$oVMOBjects += $RetreivedoVM
						$oVirtServerName = $RetreivedoVM.oVirtServer
					}ElseIF($RetreivedoVM.Count -gt 1){
						IF(($RetreivedoVM.oVirtServer | Sort -Unique) -gt 1){
							#Warn of multiple results, suggest providing $oVirtServerName
							WRITE-WARNING "More than One $($oVxObjectName) discovered, recommend also providing -oVirtServerName, to eliminate potential duplicates from different oVirt servers, skipping..."; BREAK
						}
					}
				}
			}
		}ElseIF($PSBoundParameters['Uid']){
			ForEach($UidItem in $PSBoundParameters['Uid']){
				$Uri = $Null; $Uri = $PSBoundParameters['Uid'] + "/$(($PowerState).ToLower())"
				IF($Uri){$URIs += $Uri}
			}
		}ElseIF($PSBoundParameters['Name']){
			ForEach($NameItem in $PSBoundParameters['Name']){
				$oVMOBjectDiscovered = $Null
				SWITCH($NameItem){
					{($_ -IS [System.String]) -or ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand): oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjectDiscovered = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjectDiscovered = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjectDiscovered){
							$oVMOBjectDiscovered | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
							$oVMOBjects += $oVMOBjectDiscovered
						}
					}
					{($_ -IS [oVM]) -or ($_.GetType().Name -eq "oVM")}{
						Write-Verbose "$($MyInvocation.MyCommand): oVM is [oVM]"
						$oVMOBjects += $NameItem
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand): DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand): oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand): `$_: $($_ | Out-String)"
					}
				}
			}
		}
		IF($oVMOBjects){
			ForEach($oVMOBject in $oVMOBjects){
				$Uri = $oVMOBject.Uid + "/$(($PowerState).ToLower())"
				$URIs += $Uri
			}	
		}
		IF($URIs){
			ForEach($URI in $URIs){
				$oVirtServerName = ([URI]$Uri).Host
				$VMActionParameters = [PSCustomObject]@{
					'async' = $(IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){$True}Else{$False})
					#'authorized_key' = $(IF($PSBoundParameters['Exclusive'].IsPresent -eq $True){$True}Else{$False})
					#'filter' = $(IF($PSBoundParameters['filter'].IsPresent -eq $True){$True}Else{$False})
					#'pause' = $(IF($PSBoundParameters['pause'].IsPresent -eq $True){$True}Else{$False})
					#'use_cloud_init' = $(IF($PSBoundParameters['use_cloud_init'].IsPresent -eq $True){$True}Else{$False})
					#'use_ignition' = $(IF($PSBoundParameters['use_ignition'].IsPresent -eq $True){$True}Else{$False})
					#'use_initialization' = $(IF($PSBoundParameters['use_initialization'].IsPresent -eq $True){$True}Else{$False})
					#'use_sysprep' = $(IF($PSBoundParameters['use_sysprep'].IsPresent -eq $True){$True}Else{$False})
					#'vm' = $vmdefinition
					#'volatile' = $(IF($PSBoundParameters['volatile'].IsPresent -eq $True){$True}Else{$False})
				}
				IF($PSBoundParameters.ContainsKey('authorized_key')){IF($PSBoundParameters['authorized_key'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'authorized_key' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'authorized_key' -Value $False}}
				IF($PSBoundParameters.ContainsKey('filter')){IF($PSBoundParameters['filter'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'filter' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'filter' -Value $False}}
				IF($PSBoundParameters.ContainsKey('pause')){IF($PSBoundParameters['pause'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'pause' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'pause' -Value $False}}
				IF($PSBoundParameters.ContainsKey('use_cloud_init')){IF($PSBoundParameters['use_cloud_init'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_cloud_init' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_cloud_init' -Value $False}}
				IF($PSBoundParameters.ContainsKey('use_ignition')){IF($PSBoundParameters['use_ignition'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_ignition' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_ignition' -Value $False}}
				IF($PSBoundParameters.ContainsKey('use_initialization')){IF($PSBoundParameters['use_initialization'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_initialization' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_initialization' -Value $False}}
				IF($PSBoundParameters.ContainsKey('use_sysprep')){IF($PSBoundParameters['use_sysprep'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_sysprep' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'use_sysprep' -Value $False}}
				IF($PSBoundParameters.ContainsKey('volatile')){IF($PSBoundParameters['volatile'].IsPresent -eq $True){$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'volatile' -Value $True}Else{$VMActionParameters | Add-Member -MemberType NoteProperty -Name 'volatile' -Value $False}}
				
				$JsonBody = $VMActionParameters | ConvertTo-Json -Depth 50
				$oVirtAuthToken = (Resolve-oVirtConnection -oVirtServerName $oVirtServerName).AccessToken
				$Headers = @{'Authorization' = "Bearer $oVirtAuthToken"; "Accept" = "application/json"}
				Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
				Write-Verbose "$($MyInvocation.MyCommand): Headers: $($Headers | Out-String)"
				Write-Verbose "$($MyInvocation.MyCommand): JsonBody: $($JsonBody | Out-String)"
				IF($PSCmdlet.ShouldProcess("oVM [$($RetreivedRawoVM.Name)]" , "Set the PowerState to [$($PowerState)]")) {
					Try{$Response = Invoke-RestMethod -Headers $Headers -Method $Method -Uri $Uri -Body $JsonBody -ContentType 'application/json' -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $FormattedWebError}
					$Response
				}
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Move-oVM{
	<#
		.SYNOPSIS
			This function Migrates the provided oVM, on an oVirt Server system.
		.DESCRIPTION
			This function Migrates the provided oVM, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oVM(s)
			Can use Wildcard '*'
				I.e. MyIte*
		.PARAMETER Id
			The Id(s) of oVM(s)
		.PARAMETER Uid
			The Uid(s) of oVM(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER CaseSensitive
			Switch to search Case Sensitive oVM name(s)
		.EXAMPLE
			PS> Move-oVM -oVirtServerName $oVirtServerName -Name "Name"
				Migrate the oVM(s) by provided Name
		.EXAMPLE
			PS> Move-oVM -oVirtServerName $oVirtServerName -Id "Id"
				Migrate the oVM(s) by provided Id
		.EXAMPLE
			PS> Get-oVM -oVirtServerName $oVirtServerName -Name "Name" | Move-oVM
				Migrate the oVM(s) by provided Name
		.INPUTS
			[System.String]
			[oVirtToken]
			[oVM]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVM]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		4/17/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oAffinityLabel Name
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0)]
			[Alias('N')]
			[System.String[]]$Name,
		
        #oAffinityLabel Id
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('I')]
			[System.String[]]$Id,
		
       [Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set04")]
			[Alias('U')]
			[System.String[]]$Uid,
		
        #Switch to search Case Sensitive oDomain name(s)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
			[Alias('CS')]
			[SWITCH]$CaseSensitive,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'String|oHost'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'String|oCluster'})]$oCluster,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oClusterId,

		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
        #Generic Input to facilitate Piping between Functions
		[Parameter(ValueFromPipeline, ValueFromPipelineByPropertyName, ParameterSetName="Solo", DontShow)]
			$PipedObject
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Process"
		$oVxObjectName = "$((($MyInvocation.MyCommand) -Split('-'))[1])"
		$Method = "POST"

		#POST /ovirt-engine/api/vms/123/migrate
		$BaseURL = "https://$($oVirtServerName)/ovirt-engine/api/vms"
		$RetreivedRawoVM = $Null
		$RetreivedoVM = $Null
		IF($PSBoundParameters['PipedObject']){
			IF(($PSBoundParameters['PipedObject']).GetType().Name -eq $oVxObjectName){
				$oVirtServerName = "$(($PSBoundParameters['PipedObject']).oVirtServer)"
				#$Uri = "https://$($oVirtServerName)/ovirt-engine/api/vms/$(($PSBoundParameters['PipedObject']).Id)/migrate"
				$Uri = "$(($PSBoundParameters['PipedObject']).Uid)/migrate"
				$RetreivedoVM = $PSBoundParameters['PipedObject']
			}Else{
				WRITE-WARNING "Input Object is NOT an $($oVxObjectName)"; BREAK
			}
		}ElseIF($PSBoundParameters['Id']){
			IF($oVirtServerName){
				$RetreivedRawoVM = Get-oUri -oVirtServerName $oVirtServerName -RESTUri "/ovirt-engine/api/vms/$($PSBoundParameters['Id'])"
			}Else{
				#$RetreivedRawoVM = Get-oUri -RESTUri "/ovirt-engine/api/vms/$($PSBoundParameters['Id'])"
				#Above, while faster, won't work because it does not return the oVirt Server name, which is required to insure accurate results, where duplicate oVM IDs may exist across multiple OLVM servers
				$RetreivedoVM = Get-oVM -Id $PSBoundParameters['Id']
				IF($RetreivedoVM.Count -eq 1){
					$RetreivedRawoVM = $RetreivedoVM
					$oVirtServerName = $RetreivedoVM.oVirtServer
				}ElseIF($RetreivedoVM.Count -gt 1){
					#Warn of multiple results, suggest providing $oVirtServerName
					WRITE-WARNING "More than One $($oVxObjectName) discovered, recommend also providing -oVirtServerName, to eliminate duplicates, skipping..."; BREAK
				}
			}
			IF($RetreivedRawoVM.Count -gt 1){
				#Warn of multiple results, suggest providing $oVirtServerName
				WRITE-WARNING "More than One $($oVxObjectName) discovered, recommend also providing -oVirtServerName, to eliminate duplicates, skipping..."; BREAK
			}Else{
				#Warn None Found
				WRITE-WARNING "No $($oVxObjectName) discovered matching provided -Id, skipping..."; BREAK
			}
			$Uri = $BaseURL + "/$($PSBoundParameters['Id'])" + "/migrate"
		}ElseIF($PSBoundParameters['Uid']){
			$Uri = $PSBoundParameters['Uid'] + "/migrate"
			$oVirtServerName = ([URI]$Uri).Host
			$RetreivedoVM = Get-oVM -ID ($PSBoundParameters['Uid']).Split('/')[-1] -oVirtServerName $oVirtServerName
		}ElseIF($PSBoundParameters['Name']){
			IF($oVirtServerName){
				$RetreivedRawoVM = (Get-oUri -oVirtServerName $oVirtServerName -RESTUri "/ovirt-engine/api/vms/?search=$([uri]::EscapeDataString($PSBoundParameters['Name']))").vm
			}Else{
				#$RetreivedRawoVM = (Get-oUri -RESTUri "/ovirt-engine/api/vms/?search=$([uri]::EscapeDataString($PSBoundParameters['Name']))").vm
				#Above, while faster, won't work because it does not return the oVirt Server name, which is required to insure accurate results, where duplicate oVM IDs may exist across multiple OLVM servers
				$RetreivedoVM = Get-oVM -Name $PSBoundParameters['Name']
				IF($RetreivedoVM.Count -eq 1){
					$RetreivedRawoVM = $RetreivedoVM
					$oVirtServerName = $RetreivedoVM.oVirtServer
				}ElseIF($RetreivedoVM.Count -gt 1){
					#Warn of multiple results, suggest providing $oVirtServerName
					WRITE-WARNING "More than One $($oVxObjectName) discovered, recommend also providing -oVirtServerName, to eliminate duplicates, skipping..."; BREAK
				}
			}
			IF($RetreivedRawoVM.Count -gt 1){
				#Warn of multiple results, suggest providing $oVirtServerName
				WRITE-WARNING "More than One $($oVxObjectName) discovered, recommend also providing -oVirtServerName, to eliminate duplicates, skipping..."; BREAK
			}Else{
				#Warn None Found
				WRITE-WARNING "No $($oVxObjectName) discovered matching provided -Name, skipping..."; BREAK
			}
		}
		IF($RetreivedRawoVM.Count -eq 1){
			IF($RetreivedRawoVM.Uid){
				$Uri = $RetreivedRawoVM.Uid + "/migrate"
				#$oVirtServerName = ([URI]$Uri).Host
				$oVirtServerName = $RetreivedRawoVM.oVirtServer
			}ElseIF($oVirtServerName){
				$Uri = "https://$($oVirtServerName)$(($RetreivedRawoVM).href)/migrate"
			}
		}
		IF($Uri){
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/migrate
			#POST /ovirt-engine/api/vms/123/migrate
			$VMTargetHostParameters = $Null		
			$VMTargetClusterParameters = $Null		
			$VMActionParameters = $Null		
			IF(($PSBoundParameters['oHost']) -OR ($PSBoundParameters['oHostId'])){
				#Placing ID param at the bottom places presidence over Name
				IF($PSBoundParameters['oHost']){
					IF(($PSBoundParameters['oHost']).GetType().Name -eq "String"){
						$VMTargetHostParameters = [PSCustomObject]@{name = $PSBoundParameters['oHost']}
					}ElseIF(($PSBoundParameters['oHost']).GetType().Name -eq "oHost"){
						$VMTargetHostParameters = [PSCustomObject]@{id = $PSBoundParameters['oHost'].id}
					}
				}
				IF($PSBoundParameters['oHostId']){$VMTargetHostParameters = [PSCustomObject]@{id = $PSBoundParameters['oHostId']}}
				$VMActionParameters = [PSCustomObject]@{'host' = $VMTargetHostParameters}
			}ElseIF(($PSBoundParameters['oCluster']) -OR ($PSBoundParameters['oClusterId'])){
				IF($PSBoundParameters['oCluster']){
					$VMTargetClusterParameters = [PSCustomObject]@{name = $PSBoundParameters['oCluster']}
					IF(($PSBoundParameters['oCluster']).GetType().Name -eq "String"){
						$VMTargetClusterParameters = [PSCustomObject]@{name = $PSBoundParameters['oCluster']}
					}ElseIF(($PSBoundParameters['oCluster']).GetType().Name -eq "oCluster"){
						$VMTargetClusterParameters = [PSCustomObject]@{id = $PSBoundParameters['oCluster'].id}
					}
				}
				IF($PSBoundParameters['oClusterId']){$VMTargetClusterParameters = [PSCustomObject]@{id = $PSBoundParameters['oClusterId']}}
				$VMActionParameters = [PSCustomObject]@{'cluster' = $VMTargetClusterParameters}
			}Else{
				$VMActionParameters = [PSCustomObject]@{} #Sending with Null Parameters, auto selects a different host in the same cluster
			}
			$JsonBody = $VMActionParameters | ConvertTo-Json -Depth 50
			$oVirtAuthToken = (Resolve-oVirtConnection -oVirtServerName $oVirtServerName).AccessToken
			$Headers = @{'Authorization' = "Bearer $oVirtAuthToken"; "Accept" = "application/json"}
			Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
			Write-Verbose "$($MyInvocation.MyCommand): Headers: $($Headers | Out-String)"
			Write-Verbose "$($MyInvocation.MyCommand): JsonBody: $($JsonBody | Out-String)"
			IF($PSCmdlet.ShouldProcess("oVM" , "Migrate")) {
				Try{Invoke-RestMethod -Headers $Headers -Method $Method -Uri $Uri -Body $JsonBody -ContentType 'application/json' -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Set-oImageTransferStatus{
	<#
		.SYNOPSIS
			This function reconfigures the provided oImageTransfer, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oImageTransfer, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oImageTransfer(s)
			Can use Wildcard '*'
			Most seem to have no name even though it is a spec in the oVirt documentation
		.PARAMETER Id
			The Id(s) of oImageTransfer(s)
		.PARAMETER Uid
			The Uid(s) of oImageTransfer(s)
		.PARAMETER Status
			Valid options "cancel","extend","finalize","pause","resume"
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransfer.Id -Status "cancel"
		.INPUTS
			[System.String]
			[oImageTransfer]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oImageTransfer]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/29/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oImageTransfer|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("cancel","extend","finalize","pause","resume")]
		[System.String]$Status,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oImageTransfer]: [$($PSBoundParameters['Name'] -IS [oImageTransfer])]"
		IF($PSBoundParameters.ContainsKey('Name')){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"}
		$oImageTransferObjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oImageTransfer is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oImageTransferObjects = Get-oImageTransfer -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oImageTransferObjects = Get-oImageTransfer -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oImageTransferObjects){$oImageTransferObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oImageTransfer GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oImageTransferObjects = Get-oImageTransfer -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oImageTransferObjects = Get-oImageTransfer -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oImageTransferObjects){$oImageTransferObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oImageTransfer]}{
						Write-Verbose "$($MyInvocation.MyCommand) oImageTransfer is [oImageTransfer]"
						$oImageTransferObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oImageTransfer"}{
						Write-Verbose "$($MyInvocation.MyCommand) oImageTransfer GetType equals [oImageTransfer]"
						$oImageTransferObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oImageTransfer is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oImageTransferObjects = Get-oImageTransfer -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oImageTransferObjects = Get-oImageTransfer -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oImageTransferObjects){$oImageTransferObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oImageTransferObjects = Get-oImageTransfer -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oImageTransferObjects){$oImageTransferObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oImageTransferObjects Names: $($oImageTransferObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oImageTransferObject in $oImageTransferObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oImageTransferObject [$($oImageTransferObject | Out-String)]"
			$oVirtServerName = $oImageTransferObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oImageTransferObject Status [$($oImageTransferObject.Status)]"
			
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			IF($PSBoundParameters.ContainsKey('Status')){
				$Uri = $BaseURL + $oImageTransferObject.actions.link.where({$_.rel -eq $PSBoundParameters['Status']}).href
				$Method = "POST"
			}Else{
				$Uri = $BaseURL + "/ovirt-engine/api/imagetransfers/" + $oImageTransferObject.Id
				$Method = "GET"
			}
			$ImageTransferSession = $Null
			#TRY{$ImageTransferSession = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $Null -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0] | Out-String)"; $OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
			TRY{$ImageTransferSession = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $Null -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($ImageTransferSession){$OutPutItems.Add($ImageTransferSession) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Get-oVirtEngineLog{
	<#
		.SYNOPSIS
			This function retrieves content of the "/var/log/ovirt-engine/engine.log" on an oVirt Server system.
		.DESCRIPTION
			This function retrieves content of the "/var/log/ovirt-engine/engine.log" on an oVirt Server system.
			Needs Posh-SSH Module
			NOTE: OpenSSH is not an option because there’s no option or argument to bypass the password prompt with OpenSSH.
			
			Additionally can Retrieve
				/var/log/httpd/access_log
				/var/log/httpd/error_log
				/var/log/httpd/ovirt-requests-log
				/var/log/httpd/ssl_access_log
				/var/log/httpd/ssl_error_log
				/var/log/httpd/ssl_request_log
		.PARAMETER Action
			Valid options "cat","head","tail"
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER engine
			Switch to retrieve /var/log/ovirt-engine/engine.log
		.PARAMETER access_log
			Switch to retrieve /var/log/httpd/access_log
		.PARAMETER error_log
			Switch to retrieve /var/log/httpd/error_log
		.PARAMETER ovirt_requests_log
			Switch to retrieve /var/log/httpd/ovirt-requests-log
		.PARAMETER ssl_access_log
			Switch to retrieve /var/log/httpd/ssl_access_log
		.PARAMETER ssl_error_log
			Switch to retrieve /var/log/httpd/ssl_error_log
		.PARAMETER ssl_request_log
			Switch to retrieve /var/log/httpd/ssl_request_log
		.EXAMPLE
			PS> Get-oVirtEngineLog -oVirtServerName $oVirtServerName -Action "cat"
		.EXAMPLE
			PS> Get-oVirtEngineLog -oVirtServerName $oVirtServerName -Action "tail"
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/29/2024
			Version 1.0b	6/14/2024
			Version 1.1		10/4/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'none')]
	[ALIAS('OEL')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("cat","head","tail")]
		[System.String]$Action,
		
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,
		
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$engine,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$access_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$error_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$ovirt_requests_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$ssl_access_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$ssl_error_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[SWITCH]$ssl_request_log,
			
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[SWITCH]$all_logs,
			
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "PSBoundParameters.Keys: [$($PSBoundParameters.Keys)]"
		Write-Verbose "PSBoundParameters Key/Value: [$(foreach($boundparam in $PSBoundParameters.GetEnumerator()) {'Key={0} Value={1}' -f $boundparam.Key,$boundparam.Value})]"
		
		#Build SSH Command
		$AllSwitchNames = @("engine","access_log","error_log","ovirt_requests_log","ssl_access_log","ssl_error_log","ssl_request_log")
		IF($PSBoundParameters.Keys | ?{$AllSwitchNames -Contains $_}){
			#this is a command that does nothing as a placeholder
			$SSHCommand = ":"
			Switch(($PSBoundParameters.Keys))
			{
				"engine" {$SSHCommand = $SSHCommand + "; echo '/var/log/ovirt-engine/engine.log'; $($PSBoundParameters['Action']) /var/log/ovirt-engine/engine.log"}
				"access_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/access_log' ; $($PSBoundParameters['Action']) /var/log/httpd/access_log"}
				"error_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/error_log'; $($PSBoundParameters['Action']) /var/log/httpd/error_log"}
				"ovirt_requests_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/ovirt-requests-log'; $($PSBoundParameters['Action']) /var/log/httpd/ovirt-requests-log"}
				"ssl_access_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/ssl_access_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_access_log"}
				"ssl_error_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/ssl_error_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_error_log"}
				"ssl_request_log" {$SSHCommand = $SSHCommand + "; echo '/var/log/httpd/ssl_request_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_request_log"}
				<#
				Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Confirm:0 -Command "cd /; find . -name \*.log -ls | sort -r -n -k7"
				Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Confirm:0 -Command "cd /; find . -iname '*.log' | sort -r -n -k7"
				Invoke-oVirtSSHCommand -oVirtServerName $oVirtServerName -Confirm:0 -Command "cd /; find /var/log/*/*.log"
				
				/var/log/audit/audit.log
				/var/log/chef/client.log
				/var/log/grafana/grafana.log
				/var/log/openvswitch/ovsdb-server.log
				/var/log/openvswitch/ovs-vswitchd.log
				/var/log/ovirt-engine-backup/ovirt-engine-backup-20241115104629.log
				/var/log/ovirt-engine-backup/ovirt-engine-backup-20250331151527.log
				/var/log/ovirt-engine/boot.log
				/var/log/ovirt-engine/console.log
				/var/log/ovirt-engine-dwh/ovirt-engine-dwhd.log
				/var/log/ovirt-engine/engine.log
				/var/log/ovirt-engine/ovirt-sso-register-client.log
				/var/log/ovirt-engine/server.log
				/var/log/ovirt-engine/ui.log
				/var/log/ovirt-imageio/daemon.log
				/var/log/ovn/ovn-northd.log
				/var/log/ovn/ovsdb-server-nb.log
				/var/log/ovn/ovsdb-server-sb.log
			
				./run/libpod/events/events.log
				./root/scripts/restapi/example.log
				./root/ansible/.logs/ansible.log
				./var/lib/pgsql/data/log/postgresql-Mon.log
				./var/lib/pgsql/initdb_postgresql.log
				./var/log/ovirt-engine/boot.log
				./var/log/ovirt-engine/console.log
				./var/log/ovirt-engine/server.log
				./var/log/ovirt-engine/engine.log
				./var/log/ovirt-engine/ui.log
				./var/log/ovirt-cockpit-sso.install.log
				./var/log/ovirt-engine-dwh/ovirt-engine-dwhd.log
				./var/log/ovirt-provider-ovn.log
				./var/log/chef/client.log
				./var/log/hawkey.log
				./var/log/dnf.log
				./var/log/dnf.librepo.log
				./usr/lib/rpm/rpm.log
				./backup/log/ovirt-engine-backup.log

				
				
				#>
				
				#/var/log/ovirt-engine/ovirt-sso-register-client.log
				#/var/log/ovirt-engine/server.log
				#/var/log/ovirt-engine/ui.log
				#
				#default {}
			}
		}ElseIF($PSBoundParameters.ContainsKey('all_logs')){
			$SSHCommand = "echo '/var/log/ovirt-engine/engine.log'; $($PSBoundParameters['Action']) /var/log/ovirt-engine/engine.log; echo '/var/log/httpd/access_log'; $($PSBoundParameters['Action']) /var/log/httpd/access_log; echo '/var/log/httpd/error_log'; $($PSBoundParameters['Action']) /var/log/httpd/error_log; echo '/var/log/httpd/ovirt-requests-log'; $($PSBoundParameters['Action']) /var/log/httpd/ovirt-requests-log; echo '/var/log/httpd/ssl_access_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_access_log; echo '/var/log/httpd/ssl_error_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_error_log; echo '/var/log/httpd/ssl_request_log'; $($PSBoundParameters['Action']) /var/log/httpd/ssl_request_log"
		}Else{
			#Default, just get the Engine log data
			$SSHCommand = "echo '/var/log/ovirt-engine/engine.log'; $($PSBoundParameters['Action']) /var/log/ovirt-engine/engine.l; echo '/var/log/httpd/access_log'g"
		}
		Write-Verbose "$($MyInvocation.MyCommand) `$SSHCommand: [$($SSHCommand | Out-String)]"
		
		IF(Get-Module -ListAvailable -Name Posh-SSH){
			IF(!(Get-Module -Name Posh-SSH)){Import-Module -Name Posh-SSH}
			IF(Get-Module -Name Posh-SSH){
				Remove-SSHTrustedHost -HostName $oVirtServerName -ErrorAction SilentlyContinue
				$oVirtConnection = $($oVirtConnections | ?{$_.Name -eq $oVirtServerName})
				IF($oVirtConnection){
					IF($PSBoundParameters.ContainsKey('oVirtSSHCredential')){
						$($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
					}ElseIF($oVirtConnection.oVirtSSHCredential){
						$oVirtSSHCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList $oVirtConnection.oVirtSSHCredential.UserName, (ConvertTo-SecureString -String ($oVirtConnection.oVirtSSHCredential.GetNetworkCredential().Password) -AsPlainText -Force)
					}Else{Write-Warning "No SSH Credential for [$($oVirtServerName)] Connection in oVirt Connection Manager"}
					IF($oVirtSSHCredential){
						$oVirtSSHConnection = New-SSHSession -ComputerName $oVirtConnection.Name -Credential $oVirtSSHCredential -AcceptKey -Force -EA SilentlyContinue
						IF($oVirtSSHConnection){
							#$SSHResponse = Invoke-SSHCommand -SSHSession $oVirtSSHConnection -Command "$($PSBoundParameters['Action']) /var/log/ovirt-engine/engine.log"
							$SSHResponse = Invoke-SSHCommand -SSHSession $oVirtSSHConnection -Command $SSHCommand
							Remove-SSHSession -SSHSession $oVirtSSHConnection
							$SSHResponse.Output
						}Else{Write-Warning "No SSH Connection Established to [$($oVirtServerName)]"}
					}
				}Else{Write-Warning "No oVirt Connection for [$($oVirtServerName)]"}
			}
		}Else{Write-Warning "PowerShell Module 'Posh-SSH' NOT Installed. It can be found here: https://www.powershellgallery.com/packages/Posh-SSH/"}
	}
	End{}
}

Function Export-oDiskImage{
	<#
		.SYNOPSIS
			This function downloads an oDisk, on an oVirt Server system to a new oDisk Image File.
		.DESCRIPTION
			This function downloads an oDisk, on an oVirt Server system to a new oDisk Image File.
		.PARAMETER Name
			The Name(s) of the oDisk(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of the oDisk(s)
		.PARAMETER Uid
			The Uid of the oDisk(s)
		.PARAMETER ImageFolderPath
			The folder to save the downloaded oDisk Image File
		.PARAMETER ChunkSize
			32-bit integer setting for the Size of the chunks of the image file to be uploaded
			Default is 64MB as a conservative value, can be adjusted for performance if memory is sufficient
			-ChunkSize 1024MB
			-ChunkSize 1073741824
		.PARAMETER UseProxyUrl
			OverRides Image Transfer Session default 'transfer_url', to use alternate 'proxy_url'
		.PARAMETER Compression
			Enable download compression method
			Valid options "deflate", "gzip"
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Export-oDiskImage -oVirtServerName $oVirtServerName -Name "MyoDisk" -ImageFolderPath "C:\temp"
				Exports an oDisk Image File
		.EXAMPLE
			PS> $oVM = New-oVM -Name "oDisk_Test" -oCluster "TestCluster" -DiskFormat cow -DiskSize 1048576 -DiskType image -DiskInterface virtio -oVirtServerName $oVirtServerName
			PS> $oDiskAttachment = $oVM | Get-oDiskAttachment
			PS> $oDisk = Get-oDisk -Id $oDiskAttachment.disk.id -oVirtServerName $oVirtServerName
			PS> $oDiskAttachment | Remove-oDiskAttachment -Confirm:0
			PS> Remove-oVM -Name $oVM -Confirm:0
			PS> $oDiskImage = Export-oDiskImage -oVirtServerName $oVirtServerName -Id $oDisk.Id -ImageFolderPath "C:\temp"
			PS> Remove-oDisk -Id $oDisk.Id -oVirtServerName $oVirtServerName
			PS> Remove-Item -Path $oDiskImage.FullName -Confirm:0 -Force
				Creates an oVM with a small oDisk
				Deletes the oDiskAttachment between the oVM and the oDisk
				Deletes the oVM
				Downloads a copy of the oDisk as an oDiskImage to "C:\temp"
				Deletes the oDisk
				Deletes the oDisk Image from Download location
		.INPUTS
			[System.String]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/30/2024
				Added destination free space check 6/6/2024
			Version 1.0b	7/15/2024
			Version 1.0c	7/17/2024, changed to System.Net.Http.HttpClient
			Version 1.0d	7/18/2024, added handling for short file lengths (less than oDisk.provisioned_size)
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/image_transfer
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/image_transfer
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/image_transfers
			Get-oDisk
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		#Existing oDisk
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		#Local Path to Place the Image Transfer File
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$ImageFolderPath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,([INT32]::MaxValue))]
			[System.INT32]$ChunkSize,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet("proxy_url","transfer_url")]
			[Switch]$UseProxyUrl,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("deflate","gzip")]
			[System.String]$Compression,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		$oDisk = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH($PSBoundParameters['Name']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oDisk]}{
					Write-Verbose "$($MyInvocation.MyCommand) Name is [oDisk]"
					$oDisk = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oDisk"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDisk]"
					$oDisk = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDisk = Get-oDisk -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDisk = Get-oDisk -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				$UidUrl = [Uri]$Uid
				$oDisk = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		IF($oDisk){
			IF(($oDisk.provisioned_size -eq 0) -AND ($oDisk.actual_size -eq 0) -AND ($oDisk.total_size -eq 0)){WRITE-WARNING "CAN NOT DOWNLOAD A 0 BYTE FILE"; BREAK}
			$oVirtServerName = $oDisk.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$ImageTransferSpecs = [PSCustomObject]@{}
			IF(!($PSBoundParameters.ContainsKey("ImageFolderPath"))){
				$PSBoundParameters['ImageFolderPath'] = Get-oFolderPath -Title 'Where Do You Want to Put That oDisk Image File?' -SpecialFolder MyComputer
			}
			IF($PSBoundParameters['ImageFolderPath']){
				$OutFolderObject = Get-ChildItem -Path $(Split-Path -Parent -Path $PSBoundParameters['ImageFolderPath']) -Filter $(Split-Path -Leaf -Path $PSBoundParameters['ImageFolderPath']) -Directory -EA SilentlyContinue
				IF($OutFolderObject){
					#Check for freespace on target
					IF($OutFolderObject.Root.FullName -Match "^\\(?:\\[^<>:`"/\\|?*]+)+$"){
						#UNC Path
						#Find Available Drive Letter
						(65..90) | %{[char]$_} | %{IF(!(Test-Path -Path ($_ + ":"))){$FreeDriveLetter = $_; Break}}
						$OutFolderObjectPSDrive = New-PSDrive -Name $FreeDriveLetter -PSProvider FileSystem -Root $OutFolderObject.FullName -Persist
						IF($OutFolderObjectPSDrive.Free -lt $oDisk.provisioned_size){Write-Warning "ImageFolderPath: [$($PSBoundParameters['ImageFolderPath'])] FreeSpace [$($OutFolderObjectPSDrive.Free)] is less than oDiskImage Provisioned Size  [$($oDisk.provisioned_size)]. Quitting... "; Remove-PSDrive $OutFolderObjectPSDrive -Force -Confirm:0; Break}
					}ElseIF($OutFolderObject.Root.FullName -Match '^([a-zA-Z]+:)?(\\[a-zA-Z0-9_.-: :]+)*\\?$'){
						#Local Drive Path
						$OutFolderObjectVolume = Get-Volume -DriveLetter $OutFolderObject.Root.Name.Substring(0,1)
						IF($OutFolderObjectVolume.SizeRemaining -lt $oDisk.provisioned_size){Write-Warning "ImageFolderPath: [$($PSBoundParameters['ImageFolderPath'])] FreeSpace [$($OutFolderObjectPSDrive.SizeRemaining)] is less than oDiskImage Provisioned Size  [$($oDisk.provisioned_size)]. Quitting... "; Break}
					}
					
					$ImageFilePath = $OutFolderObject.FullName + '\' + $oDisk.Name + '.' + $oDisk.storage_type
					$ImageFilePath = $OutFolderObject.FullName + '\' + $oDisk.Name + '.' + $oDisk.format
					$ImageFilePath = [System.IO.Path]::Combine($OutFolderObject.FullName,$oDisk.Name + '.' + $oDisk.format)
					
					$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'disk' -Value $([PSCustomObject]@{'id'=$oDisk.Id})
					$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'direction' -Value "download"
					
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true"}
					$Uri = $BaseURL + "/ovirt-engine/api/imagetransfers"
					$Method = "POST"
					$JsonBody = $ImageTransferSpecs | ConvertTo-Json -Depth 50
					Write-Verbose "$($MyInvocation.MyCommand) JsonBody: [$($JsonBody | Out-String)]"
					$ImageTransferSession = $Null
					
					Write-Host "Creating Image Transfer Session"
					Try{$ImageTransferSession = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; Write-Warning  "$($FormattedWebError.ResponseBody | Out-String)"}
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/image_transfer_phase
					$ImageTransferStates = @("cancelled","cancelled_system","cancelled_user","finalizing_cleanup","finalizing_failure","finalizing_success","finished_cleanup","finished_failure","finished_success","initializing","paused_system","paused_user","resuming","transferring","unknown")
						
					IF($ImageTransferSession){
						Write-Host -Fore Green "`tSuccessfully created Image Transfer Session Id: [$($ImageTransferSession.Id)]"
						Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
						IF($ImageTransferSession.phase -ne "transferring"){
							#Check for Prepping States
							IF(@("initializing","resuming") -Contains $ImageTransferSession.phase){
								Write-Host "Waiting for Image Transfer Session State 'transferring'..."
								#Loop and wait for ready or failure/cancel
								Write-Verbose "$($MyInvocation.MyCommand) Waiting for Transfer State 'transferring'"
								Do{$oImageTransfer = Get-oImageTransfer -Id $ImageTransferSession.Id -oVirtServerName $oVirtServerName; Write-Verbose "$($MyInvocation.MyCommand) `$oImageTransfer.phase: [$($oImageTransfer.phase)]"; IF($oImageTransfer){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}}Until(($oImageTransfer.phase -eq "transferring") -OR ((($ImageTransferSessionStartTime).AddSeconds($ImageTransferSession.inactivity_timeout)) -lt (Get-Date)))
							}
							#Check for Failure/Cancel States
							IF(($ImageTransferSession.phase -ne "transferring") -AND ($oImageTransfer.phase -ne "transferring")){
								IF($oImageTransfer){
									Write-Warning "Image Transfer Session Failed State [$($oImageTransfer.phase)]"; BREAK
								}Else{
									Write-Warning "Image Transfer Session Failed State [$($ImageTransferSession.phase)]"; BREAK
								}
							}
						}
					}Else{Write-Warning "Failed to Create Image Transfer Session"}
					IF(($ImageTransferSession.phase -eq "transferring") -OR ($oImageTransfer.phase -eq "transferring")){
						Write-Host -Fore Green "`tBeginning Image Transfer"
						#Execute Transfer Action
						Write-Verbose "$($MyInvocation.MyCommand) Executing Transfer Action"
						IF($oDisk.Name){
							IF($PSBoundParameters['ChunkSize']){$ChunkSize = $PSBoundParameters['ChunkSize']}Else{$ChunkSize = 64MB}
							Write-Verbose "$($MyInvocation.MyCommand) ChunkSize: [$($ChunkSize | Out-String)]"

							# Import necessary namespaces
							Add-Type -AssemblyName System.Net.Http
							
							# Initialize variables
							$BufferSize = 1MB      		# Size of each chunk to download (1MB in this example)
							$BufferSize = $ChunkSize   	# Size of each chunk to download
							$ChunkMB = "$(($ChunkSize/([MATH]::Pow(1024,2)))) MB"
							$BytesTotal = 0        		# Total bytes downloaded
							
							#HttpClientHandler & Compression could mess with Ryan's WinRM, remove if problematic
							$HttpClientHandler = New-Object System.Net.Http.HttpClientHandler
							$HttpClientHandler.ServerCertificateCustomValidationCallback = [System.Net.Http.HttpClientHandler]::DangerousAcceptAnyServerCertificateValidator ## System.Net.Http.
							IF($PSBoundParameters.ContainsKey('Compression')){
								#$HttpClientHandler.SupportsAutomaticDecompression #Read-Only
								IF($PSBoundParameters['Compression'] -eq "deflate"){
									$HttpClientHandler.AutomaticDecompression = [System.Net.DecompressionMethods]::Deflate
								}ElseIF($PSBoundParameters['Compression'] -eq "gzip"){
									$HttpClientHandler.AutomaticDecompression = [System.Net.DecompressionMethods]::gzip
								}
							}
							$HttpClient = New-Object System.Net.Http.HttpClient
							Write-Verbose "$($MyInvocation.MyCommand) `$HttpClient: [$($HttpClient | Out-String)]"
							IF($PSBoundParameters.ContainsKey('Compression')){
								Write-Host "Compression: $($PSBoundParameters['Compression'])"
								#$HttpClientHandler.SupportsAutomaticDecompression #Read-Only
								IF($PSBoundParameters['Compression'] -eq "deflate"){
									$HttpClient.DefaultRequestHeaders.AcceptEncoding.add([System.Net.Http.Headers.StringWithQualityHeaderValue]::new([System.Net.DecompressionMethods]::Deflate))
								}ElseIF($PSBoundParameters['Compression'] -eq "gzip"){
									$HttpClient.DefaultRequestHeaders.AcceptEncoding.add([System.Net.Http.Headers.StringWithQualityHeaderValue]::new([System.Net.DecompressionMethods]::gzip))
								}
								Write-Verbose "$($MyInvocation.MyCommand) `$HttpClient.DefaultRequestHeaders.AcceptEncoding: [$($HttpClient.DefaultRequestHeaders.AcceptEncoding | Out-String)]"
							}
							$FileStream = $Null
							$ReportedFileLength = $Null
							$ImageSize = $oDisk.provisioned_size
							$BytesRead = 0
							$PercentComplete = 0; $ETA_Seconds = [INT32]::MaxValue
							$ImageTransferSessionStartTime = Get-Date
							IF($PSBoundParameters['UseProxyUrl'].IsPresent -eq $True){
								$ImageTransferSessionUri = $ImageTransferSession.proxy_url
							}Else{
								$ImageTransferSessionUri = $ImageTransferSession.transfer_url
							}
							Write-Host "$($oDisk | Select Name, provisioned_size, actual_size, total_size | Out-String)"	
							
							#Try{
								Write-Verbose "$($MyInvocation.MyCommand) `$ImageTransferSessionUri: [$($ImageTransferSessionUri | Out-String)]"
								# Loop until all bytes are downloaded
								$LoopCounter = 0
								Write-Verbose "$($MyInvocation.MyCommand) Open file stream on first chunk"
								# Open file stream on first chunk
								IF($FileStream -eq $Null){$FileStream = [System.IO.File]::OpenWrite($ImageFilePath)}
								
								Write-Verbose "$($MyInvocation.MyCommand) Retreive ReportedFileLength before first chunk"
								#Update Bearer Token
								$HttpClient.DefaultRequestHeaders.Authorization = [System.Net.Http.Headers.AuthenticationHeaderValue]::Parse("Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)")
								$Request = [System.Net.Http.HttpRequestMessage]::new($([System.Net.Http.HttpMethod]::Get), $ImageTransferSessionUri)
								$Request.Headers.Range = New-Object System.Net.Http.Headers.RangeHeaderValue(0, 0)
								Write-Verbose "$($MyInvocation.MyCommand) `$Request: $($Request | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Request.Headers: $($Request.Headers | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Request.Headers.Range: $($Request.Headers.Range | Out-String)"
								$Return = $Null; $Return = $HttpClient.SendAsync($Request)
								Write-Verbose "$($MyInvocation.MyCommand) `$Return: $($Return | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result: $($Return.Result | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content: $($Return.Result.Content | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers: $($Return.Result.Content.Headers | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers.ContentRange: $($Return.Result.Content.Headers.ContentRange | Out-String)"
								Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers.ContentRange.Length: $($Return.Result.Content.Headers.ContentRange.Length | Out-String)"
								$ReportedFileLength = [INT64]$Return.Result.Content.Headers.ContentRange.Length
								Write-Verbose "$($MyInvocation.MyCommand) `$ReportedFileLength: [$($ReportedFileLength | Out-String)]"
								Write-Host -Fore Cyan -Back Black "`$ReportedFileLength: [$($ReportedFileLength)]"
								IF($ReportedFileLength -gt 0){
									Write-Progress -Id 1 -Activity "Downloading [$($oDisk.Name)] in $($ChunkMB) Chunks, `$StartRange, `$EndRange: 0 - 0, PercentComplete: 0" -Status "Downloaded 0 MB, of $($ImageSizeMB) MB in 0 Minutes, at 0 MB/s" -PercentComplete 0
									DO{
										$LoopCounter += 1
										Write-Verbose "$($MyInvocation.MyCommand) In the Download Loop: $($LoopCounter)"
										Write-Verbose "$($MyInvocation.MyCommand) Update Bearer Token"
										#Update Bearer Token
										$HttpClient.DefaultRequestHeaders.Authorization = [System.Net.Http.Headers.AuthenticationHeaderValue]::Parse("Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)")

										Write-Verbose "$($MyInvocation.MyCommand) Calculate range for the next chunk"
										# Calculate range for the next chunk
										$StartRange = $BytesTotal
										#$EndRange = [math]::Min([INT64]($BytesTotal + $BufferSize - 1), [INT64]($ImageSize - 1))
										#IF($ReportedFileLength -ne $Null){$EndRange = [math]::Min([INT64]$EndRange, [INT64]($ReportedFileLength - 1))}
										#IF($LoopCounter -eq 1){
											#This is a swag because we don't yet have a reported file size to download before the first call, so unless a file size less than the $BufferSize or oDiskImage size, it should work
										#	$EndRange = [math]::Min([INT64]($BytesTotal + $BufferSize - 1), [INT64]($ImageSize - 1))#
										#}Else{
											$EndRange = ([INT64]($BytesTotal + $BufferSize - 1))
										#}#
										#This should only alter the number of bytes requested in the chunk IF the $ReportedFileLength is less than the $BufferSize
										IF($ReportedFileLength -ne $Null){$EndRange = [math]::Min([INT64]$EndRange, [INT64]($ReportedFileLength - 1))}
										IF($StartRange -gt $EndRange){BREAK}
										
										#[System.Net.Http.HttpCompletionOption]::ResponseHeadersRead
										Write-Verbose "$($MyInvocation.MyCommand) Create a range request for the next chunk"
										# Create a range request for the next chunk
										$Request = [System.Net.Http.HttpRequestMessage]::new($([System.Net.Http.HttpMethod]::Get), $ImageTransferSessionUri)
										Write-Verbose "$($MyInvocation.MyCommand) `$Request: [$($Request | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Request.Headers: [$($Request.Headers | Select * | Out-String)]"
										$Request.Headers.Range = New-Object System.Net.Http.Headers.RangeHeaderValue($StartRange, $EndRange)
										Write-Verbose "$($MyInvocation.MyCommand) `$Request.Headers.Range: [$($Request.Headers.Range | Select * | Out-String)]"
									
										Write-Verbose "$($MyInvocation.MyCommand) Get the response from the server"
										$Trial = "15" #Added Try and Trial Verbosity around GetAsync
										$LastCommandExecuted = $Null;
										# Get the response from the server
										$Return = $Null;
										Try{
											Write-Verbose "============================ Trial $($Trial) START ============================"
											#$Return = $HttpClient.SendAsync($Request,[System.Net.Http.HttpCompletionOption]::ResponseHeadersRead) #Dont use ResponseHeadersRead, it tells the server to breakup the sent response which we are already doing
											$Return = $HttpClient.SendAsync($Request)
										}Catch{
											Write-Verbose "============================ Trial $($Trial) CATCH ============================"
										}Finally{
											Write-Verbose "============================ Trial $($Trial) END ============================"
										}
										$LastCommandExecuted = $(Get-History -ErrorAction SilentlyContinue | Select -Last 1 -ExpandProperty commandline -ErrorAction SilentlyContinue)
										#IF($Return.Result){$Return.Result.EnsureSuccessStatusCode() | Out-Null}
										$Response = $Return.Result
										Write-Verbose "$($MyInvocation.MyCommand) `$Response: [$($Response | Select * | Out-String)]"
											
										Write-Verbose "$($MyInvocation.MyCommand) `$LastCommandExecuted: [$($LastCommandExecuted | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return State: [$($Return.GetType().Name | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return Members: [$($Return | Get-Member | Select Name, MemberType | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return Null: [$(($Return -eq $Null))]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return Not Null: [$(($Return -ne $Null))]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return '': [$(($Return -eq ''))]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return: [$($Return | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Exception: [$($Return.Exception | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result: [$($Return.Result | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content: [$($Return.Result.Content | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers: [$($Return.Result.Content.Headers | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers.ContentRange: [$($Return.Result.Content.Headers.ContentRange | Select * | Out-String)]"
										Write-Verbose "$($MyInvocation.MyCommand) `$Return.Result.Content.Headers.ContentRange.Length: [$($Return.Result.Content.Headers.ContentRange.Length)]"
										$ReportedFileLength = [INT64]$Return.Result.Content.Headers.ContentRange.Length
										#IF($LoopCounter -eq 1){Write-Host -Fore Cyan -Back Black "`$ReportedFileLength: [$($ReportedFileLength)]"}
										Write-Verbose "$($MyInvocation.MyCommand) `$ReportedFileLength: [$($ReportedFileLength)]"
										
										IF($Return.IsFaulted){
											Write-Verbose "$($MyInvocation.MyCommand) `$Return IsFaulted"
											#Write-Warning "$($Response.Exception.InnerException.InnerException | Select * | Out-String)"
											Write-Warning "$($Return.Result.Exception.InnerException.InnerException | Select * | Out-String)"
											#IF($Response.Exception.InnerException.InnerException.Message -Match "The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel."){
											IF($Return.Result.Exception.InnerException.InnerException.Message -Match "The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel."){
												Write-Host -Fore Cyan "Attempting recovery, and resubmission of request"
												Set-SSLTLS *>1
												Import-oVirtCertificate -oVirtServerName $oVirtServerName *>1
												$HttpClient.DefaultRequestHeaders.Authorization = [System.Net.Http.Headers.AuthenticationHeaderValue]::Parse("Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)")
												Invoke-Command $LastCommandExecuted
												IF($Return.IsFaulted){
													Write-Warning "$($MyInvocation.MyCommand) `$Return IsFaulted Still"
													#Write-Warning "$($Response.Exception.InnerException.InnerException | Select * | Out-String)"
													Write-Warning "$($Return.Result.Exception.InnerException.InnerException | Select * | Out-String)"
													BREAK
												}
											}Else{
												Write-Warning "$($MyInvocation.MyCommand) `$Return IsFaulted"
												#Write-Warning "$($Response.Exception.InnerException.Message | Select * | Out-String)"
												Write-Warning "$($Return.Result.Exception.InnerException.Message | Select * | Out-String)"
												BREAK
											}
										}
										IF($Return.result.IsSuccessStatusCode -ne $True){
											Write-Verbose "$($MyInvocation.MyCommand) `$Return [$($Return | Select * | Out-String)]"
											Write-Verbose "$($MyInvocation.MyCommand) `$Return.result [$($Return.result | Select * | Out-String)]"
											Write-Host Fore -Yellow -Back Black "Failed to Retrieve data retrying [$($LastCommandExecuted | Select * | Out-String)]"
											$HttpClient.DefaultRequestHeaders.Authorization = [System.Net.Http.Headers.AuthenticationHeaderValue]::Parse("Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)")
											Invoke-Command $LastCommandExecuted
										}
										IF($Return.result.IsSuccessStatusCode){
											#$ResponseStream = $Response.Content.ReadAsStreamAsync().Result
											$ResponseStream = $Return.Result.Content.ReadAsStreamAsync().Result
											#$ResponseStream = $Response.Content.ReadAsByteArrayAsync().Result
											$Buffer = New-Object byte[] $BufferSize
											$Error.Clear()
											#Write-Verbose "$($MyInvocation.MyCommand) `$BufferSize: [$($BufferSize | Select * | Out-String)]"
											#Write-Verbose "$($MyInvocation.MyCommand) `$Buffer: [$($Buffer | GM | Out-String)]"
											#Write-Host "$($MyInvocation.MyCommand) `$BufferSize: [$($BufferSize)]"
											#Write-Host "$($MyInvocation.MyCommand) `$Buffer: [$($Buffer | GM | Out-String)]"
											
											Write-Verbose "$($MyInvocation.MyCommand) Read the response stream"
											$BytesRead = $ResponseStream.Read($Buffer, 0, $BufferSize)
											Write-Verbose "$($MyInvocation.MyCommand) write it to the file"
											$FileStream.Write($Buffer, 0, $BytesRead)
											Write-Verbose "$($MyInvocation.MyCommand) Update the total bytes downloaded"
											# Update the total bytes downloaded
											$BytesTotal += $BytesRead
											Write-Verbose "$($MyInvocation.MyCommand) `$BytesRead [$($BytesRead)]"
											Write-Verbose "$($MyInvocation.MyCommand) `$BytesTotal [$($BytesTotal)]"
											Write-Verbose "$($MyInvocation.MyCommand) `$ReportedFileLength [$($ReportedFileLength)]"
											Write-Verbose "$($MyInvocation.MyCommand) `$ImageSize [$($ImageSize)]"
											$ElapsedTime = (Get-Date) - $ImageTransferSessionStartTime
											$ElapsedTime_Minutes = ([Math]::Round($ElapsedTime.TotalMinutes,2))
											#$PercentComplete = (($BytesTotal / $ImageSize) * 100)
											$PercentComplete = (($BytesTotal / $ReportedFileLength) * 100)
											$ETA_Seconds = ([Math]::Round( ((($ElapsedTime.TotalSeconds * 100)/$PercentComplete) - $ElapsedTime.TotalSeconds),2))
											$ETA_Minutes = $ETA_Seconds/60
											$DownloadedMB = $(($BytesTotal/([MATH]::Pow(1024,2))))
											#$ImageSizeMB = $(($ImageSize/([MATH]::Pow(1024,2))))
											$ImageSizeMB = $(($ReportedFileLength/([MATH]::Pow(1024,2))))
											$AverageTransferRate = ([Math]::Round(($DownloadedMB/$ElapsedTime.TotalSeconds),2))
											Write-Progress -Id 1 -Activity "Downloading [$($oDisk.Name)] in $($ChunkMB) Chunks, `$StartRange, `$EndRange: $($StartRange) - $($EndRange), PercentComplete: $(([Math]::Round($PercentComplete,2)))" -Status "Downloaded $($DownloadedMB) MB, of $($ImageSizeMB) MB in $($ElapsedTime_Minutes) Minutes, at $($AverageTransferRate) MB/s" -PercentComplete $PercentComplete -SecondsRemaining $ETA_Seconds

											Write-Verbose "$($MyInvocation.MyCommand) Close ResponseStream and Return.Result"
											# Close streams and response
											Try{
												$ResponseStream.Close()
												#$Response.Dispose()
												$Return.Result.Dispose()
											}Catch{}
											$Return = $Null;
											Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
										}Else{
											Write-Warning "$($MyInvocation.MyCommand) `$Return NOT IsSuccessStatusCode"
											Write-Warning "$($MyInvocation.MyCommand) `$Return [$($Return | Select * | Out-String)]"
											Write-Warning "$($MyInvocation.MyCommand) `$Return.result [$($Return.result | Select * | Out-String)]"
											#Write-Warning "$($Response.Exception.InnerException.Message | Select * | Out-String)"
											Write-Warning "$($Return.Result.Exception.InnerException.Message | Select * | Out-String)"
											$Return = $Null;
											BREAK
										}
									}while(($BytesRead -gt 0) -AND ($BytesRead -ne $Null) -AND ($BytesRead -ne "") -AND ($BytesTotal -lt $ReportedFileLength) -AND ($EndRange -le $ReportedFileLength) -AND (!$Error[0]))
									Write-Progress -Id 1 -Activity "Downloading [$($oDisk.Name)] in $($ChunkMB) Chunks, `$StartRange, `$EndRange: $($StartRange) - $($EndRange), PercentComplete: $(([Math]::Round($PercentComplete,2)))" -Status "Downloaded $($DownloadedMB) MB, of $($ImageSizeMB) MB in $($ElapsedTime_Minutes) Minutes, at $($AverageTransferRate) MB/s" -PercentComplete $PercentComplete -SecondsRemaining $ETA_Seconds -Completed
									Write-Host -Fore Cyan "Downloaded $($BytesTotal) of $($ImageSize) bytes"
									Write-Host -Fore Cyan "`tSource reported size $($ReportedFileLength) bytes"
									#$oDisk | Select Name, provisioned_size, actual_size, total_size
									IF($BytesTotal -eq $ReportedFileLength){Write-Host -Fore Green "Download completed successfully."}ElseIF($BytesTotal -eq $ImageSize){Write-Host -Fore Green "Download completed successfully."}Else{Write-Host -Fore RED -BACK BLACK "Download failed."}
								}Else{
									$ImageTransferUrl = [Uri]$ImageTransferSessionUri
									IF($PSBoundParameters['UseProxyUrl'].IsPresent -eq $True){
										Write-Warning "oVirt Reported File Length less than 1 byte, can not download."
									}Else{
										Write-Warning "oVirt Reported File Length less than 1 byte, can not download, If KVM host [$($ImageTransferUrl.Host)] is Unreachable on port  [$($ImageTransferUrl.Port)], using the -UseProxyUrl parameter may help."
									}
								}
							#}Catch{
							#	Write-Error "Error downloading file: $_"
							#}Finally{
								Write-Verbose "$($MyInvocation.MyCommand) Close file stream"
								# Close file stream if open
								IF($FileStream -ne $Null){$FileStream.Close()}

								Write-Verbose "$($MyInvocation.MyCommand) Dispose `$HttpClient"
								# Dispose of HttpClient
								IF($HttpClient -ne $Null){$HttpClient.Dispose()}
							#}
							IF(($BytesTotal -ne $ImageSize) -AND $(IF($ReportedFileLength -ne $Null){($BytesTotal -lt $ReportedFileLength)})){
								IF(Test-Path -Path $ImageFilePath){
									Write-Verbose "$($MyInvocation.MyCommand) `Deleting [$($ImageFilePath)]"
									Remove-Item -Path $ImageFilePath -EA SilentlyContinue -Confirm:0
								}
							}
							IF(Test-Path -Path $ImageFilePath){
								DO{Sleep 5; $oImageTransferStatusCheck = Get-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id; Write-Verbose "$($MyInvocation.MyCommand): `$oImageTransferStatusCheck: $($oImageTransferStatusCheck | Out-String)"}While(($oImageTransferStatusCheck.transferred -lt (Get-ChildItem $ImageFilePath).Length) -AND ($oImageTransferStatusCheck.phase -eq "transferring"))
								IF($oImageTransferStatusCheck.transferred -ge (Get-ChildItem $ImageFilePath).Length){
									Write-Host "Finalizing Transfer"
									$Finalize = Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id -Status finalize
									IF($Finalize){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
								}ElseIF($oImageTransferStatusCheck.transferred -lt (Get-ChildItem $ImageFilePath).Length){
									Write-Host "Cancelling Transfer"
									$Cancel = Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id -Status cancel
									IF($Cancel){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
								}
							}Else{
								Write-Host "Cancelling Transfer"
								$Cancel = Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id -Status cancel
								IF($Cancel){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
							}
							$oImageTransferStatus = Get-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id
							$ImageTransferSessionEndTime = Get-Date
							IF(Test-Path -Path $ImageFilePath -EA SilentlyContinue){$DownloadedFile = Get-ChildItem -Path $ImageFilePath -EA SilentlyContinue}ElseIF(Test-Path -Path $($ImageFolderPath +"\"+ $oDisk.Name +".$($oDisk.storage_type)")){$DownloadedFile = Get-ChildItem -Path $($ImageFolderPath +"\"+ $oDisk.Name +".$($oDisk.storage_type)")}Else{$($ImageFolderPath +"\"+ $oDisk.Name +".$($oDisk.storage_type)")}
						}Else{
							$SavedProgressPreference = $ProgressPreference
							$ProgressPreference = 'SilentlyContinue'
							Try{$DownloadFileResponse = Invoke-RestMethod -OutFile $($ImageFolderPath +"\"+ $ImageTransferSession.image.id +".$($oDisk.storage_type)") -Uri $ImageTransferSessionUri -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $($ImageFolderPath +"\"+ $ImageTransferSession.image.id +".$($oDisk.storage_type)") -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
							IF($DownloadFileResponse){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
							$ProgressPreference = $SavedProgressPreference
							IF(Test-Path -Path $($ImageFolderPath +"\"+ $ImageTransferSession.image.id +".$($oDisk.storage_type)")){$DownloadedFile = Get-ChildItem -Path $($ImageFolderPath +"\"+ $ImageTransferSession.image.id +".$($oDisk.storage_type)")}Else{$DownloadedFile = $($ImageFolderPath +"\"+ $ImageTransferSession.image.id +".$($oDisk.storage_type)")}
						}
					}
				}Else{Write-Warning "'ImageFolderPath' [$($PSBoundParameters['ImageFolderPath'])] Not Found"}
			}Else{Write-Warning "No 'ImageFolderPath' Provided to Save File"}
		}
	}
	End{
		[PSCustomObject]@{
			oDisk = $oDisk
			ImageTransferSession = $ImageTransferSession
			ImageTransferSessionUri = $ImageTransferSessionUri
			ImageFolderPath = $ImageFolderPath
			DownloadedFile = $DownloadedFile
			Finalize = $Finalize
			Cancel = $Cancel
			oImageTransferStatus = $oImageTransferStatus
			ImageTransferSessionStartTime = $ImageTransferSessionStartTime
			ImageTransferSessionEndTime = $ImageTransferSessionEndTime
			ElapsedTime = $ElapsedTime
			ElapsedTime_Minutes = $ElapsedTime_Minutes
			PercentComplete = $PercentComplete
			ImageSize = $ImageSize
			WrittenFileSize = $DownloadedFile.Length
			ReportedFileLength = $ReportedFileLength
			DownloadedBytes = $BytesTotal
			DownloadedMB = $DownloadedMB
			ChunkSize = $ChunkSize
			ChunkMB = $ChunkMB
			AverageTransferMBSec = $AverageTransferRate
			AutomaticDecompression = $HttpClientHandler.AutomaticDecompression
		}
	}
}

Function Import-oDiskImage{
	<#
		.SYNOPSIS
			This function imports an oDisk Image, on an oVirt Server system to a new storage domain.
		.DESCRIPTION
			This function imports an oDisk Image, on an oVirt Server system to a new storage domain.
			Returns the job response from the oVirt Server.
		.PARAMETER oDiskAction
			Valid options "UseExisting", "CreateNew", "AsGlanceImageTemplate"
			"AsGlanceImageTemplate" is NOT available in this version of this function
			If AsGlanceImageTemplate is used, then the image will be imported as a template, otherwise it will be imported as a disk.
			Glance is storage in OpenStack
			
			If "UseExisting" is used, the following input parameters are Required/Used
				Required
					oDisk using Name, Id, or Uid
					ImageFilePath
			If "CreateNew" is used, the following parameters are Required/Optional
				Required
					oDiskName
					ImageFilePath
					oStorageDomain, oStorageDomainId, or oStorageDomainUid
					ProvisionedSize (auto calculated if not provided)
				Optional
					DiskType
					Format
					Alias
					Active
					Backup
					BackupMode
					Shareable
					Sparse
					WipeAfterDelete
			If "AsGlanceImageTemplate" is used, the following parameters are Required/Used
				Required
					oImageName
					ImageFilePath
					oCluster, oClusterId, or oClusterUid
		.PARAMETER Name
			The Name of the EXISTING oDisk
			Can use Wildcard '*'
		.PARAMETER Id
			The Id of the EXISTING oDisk
		.PARAMETER Uid
			The Uid of the EXISTING oDisk
		.PARAMETER oDiskName
			The Name for the NEW oDisk, to create for the oDisk Image
		.PARAMETER oImageName
			The Name for the NEW oDisk Image when "AsGlanceImageTemplate" is used to storage an an oImage template
		.PARAMETER ImageFilePath
			The file path to retreive the oDisk Image File to upload
		.PARAMETER oStorageDomain
			The Name of the oStorageDomain for the NEW oDisk
			Can use Wildcard '*'
		.PARAMETER oStorageDomainId
			The Id of the oStorageDomain for the NEW oDisk
		.PARAMETER oStorageDomainUid
			The Uid of the oStorageDomain for the NEW oDisk
		.PARAMETER oCluster
			The Name of the oCluster for the NEW oDisk Image
			Can use Wildcard '*'
		.PARAMETER oClusterDomainId
			The Id of the oCluster for the NEW oDisk Image
		.PARAMETER oClusterUid
			The Uid of the oCluster for the NEW oDisk Image
		.PARAMETER DiskType
			There are three types of disks that can be added - disk image, direct LUN and Managed Block disk. Cinder integration has been replaced by Managed Block Storage.
			Valid options "Image", "LUN", "ManagedBlock"
				DiskImage(Image) - Most common, a disk file on the Storage Domain file system, if oHost is not provided, remains floating
					FloatingDiskImage - Same as DiskImage, except no oHost assigned, therefore only a DB object entry
				DirectLUN(LUN) - A block device used as local disk, if oHost is not provided, remains floating
					FloatingDirectLUN - Same as DirectLUN, except no oHost assigned, therefore only a DB object entry
				ManagedBlock - A disk on a Managed Block Storage Domain
			When creating a new floating image Disk, the API requires the storage_domain, provisioned_size and format attributes.
			Note that block storage domains (i.e., storage domains with the storage type of iSCSI or FCP) don’t support the combination of the raw format with sparse=true, so sparse=false must be stated explicitly.
		.PARAMETER ProvisionedSize
			The virtual size of the disk, in bytes
				If not provided size will be retrieved from the ImageFilePath Length
		.PARAMETER Format
			The underlying storage format
			Valid options "cow", "raw"
				cow - The Copy On Write format allows snapshots, with a small performance overhead.
				raw - The raw format does not allow snapshots, but offers improved performance.
			Note that block storage domains (i.e., storage domains with the storage type of iSCSI or FCP) don’t support the combination of the raw format with sparse=true, so sparse=false must be stated explicitly
		.PARAMETER Alias
			Alias for the oDisk
		.PARAMETER Active
			Indicates if the disk is visible to the virtual machine.
		.PARAMETER Backup
			The backup behavior supported by the disk
			Valid options "none", "incremental"
		.PARAMETER BackupMode
			The backup type that was taken for the disk (full/incremental)
			Valid options "full", "incremental"
		.PARAMETER Shareable
			Indicates if the disk can be attached to multiple virtual machines
		.PARAMETER Sparse
			Indicates if the physical storage for the disk should not be preallocated
		.PARAMETER WipeAfterDelete
			Indicates if the disk’s blocks will be read back as zeros after it is deleted:
				- On block storage, the disk will be zeroed and only then deleted.
		.PARAMETER ChunkSize
			32-bit integer setting for the Size of the chunks of the image file to be uploaded
			Default is 64MB as a conservative value, recommended is 1024MB for performance if memory is sufficient
			-ChunkSize 1024MB
			-ChunkSize 1073741824
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Import-oDiskImage -oVirtServerName $oVirtServerName -Name "MyoDisk" -ImageFilePath "C:\temp\MyoDisk"
				Import an oDisk Image File
		.EXAMPLE
			PS> $NewIsoTransfer = Import-oDiskImage -oVirtServerName $oVirtServerName -oDiskName "abc_test.iso" -ImageFilePath "C:\MyPath\abc_test.iso" -oDiskAction CreateNew -DiskType Image -oStorageDomain "MyStorageDomainName"
				Import an ISO File
				NOTE: Source Files with an name extension of ".iso", will automatically have the following paramarters set/overridden:
					"ContentType"="iso"
					-Format "raw"
					-DiskType "image"
		.INPUTS
			[System.String]
			[oDisk]
			[oStorageDomain]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/31/2024
			Version 1.0b	6/18/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/image_transfer
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/image_transfer
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/image_transfers
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/image/methods/import
			https://ovirt.github.io/ovirt-imageio/images.html
			Get-oDisk
			New-oDisk
			Get-oImageTransfer
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'AsGlanceImageTemplate')]
	Param(
		#Choice Use Existing oDisk or Create New oDisk
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet("UseExisting", "CreateNew", "AsGlanceImageTemplate")]
			[ValidateSet("UseExisting", "CreateNew")]
			[System.String]$oDiskAction,
		
		#Existing oDisk
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="UseExisting")]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="UseExisting")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="UseExisting")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		
		#Local Path to retrieve the Image Transfer File
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$ImageFilePath,
		
		#FOR oDisk Image Template, "AsGlanceImageTemplate"
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="AsGlanceImageTemplate")]
			#[System.String]$oImageName,
		
		#FOR NEW oDisk
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[System.String]$oDiskName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidateScript({($_).GetType().Name -match 'oStorageDomain|String'})]$oStorageDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oStorageDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oStorageDomainUid,
		
		#"AsGlanceImageTemplate"
		#[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="AsGlanceImageTemplate")]
			#[ValidateScript({($_).GetType().Name -match 'oCluster|String'})]$oCluster,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="AsGlanceImageTemplate")]
			#[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			#[System.String]$oClusterId,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="AsGlanceImageTemplate")]
			#[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			#[System.String]$oClusterUid,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			#[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			#[System.String]$oHostId,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			#[System.String]$oHostUid,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.String]$Comment,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.String]$Description,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			#[ValidateSet("DiskImage", "FloatingDiskImage", "DirectLUN", "FloatingDirectLUN", "ManagedBlock")]
			#[ValidateSet("image", "lun", "managed_block_storage")]
			[ValidateSet("Image", "LUN", "ManagedBlock")]
			[System.String]$DiskType,
		#Disabling this input, using ProvisionedSize to override
		#[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			#[ValidateRange(1,([INT64]::MaxValue))]
			#[System.INT64]$InitialSize,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[ValidateRange(1,([INT64]::MaxValue))]
			[System.INT64]$ProvisionedSize,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[ValidateSet("cow", "raw")]
			[System.String]$Format,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[System.String]$Alias,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[BOOLEAN]$Active,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[ValidateSet("none", "incremental")] #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_backup_mode
			[System.String]$Backup,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[ValidateSet("full", "incremental")] #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_backup_mode
			[System.String]$BackupMode,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[BOOLEAN]$Shareable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="CreateNew")]
			[BOOLEAN]$WipeAfterDelete,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet("RestMethod")]
			#[System.String]$Uploader,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,([INT32]::MaxValue))]
			[System.INT32]$ChunkSize,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		
		<#
		Location of/for the Image File
		Upload Image
			Choice Use Existing oDisk
			Create New oDisk
			Create an image transfer process
			Loop to Monitor Progress
			Finalize the image transfer process
		#>
		
		$ImageTransferSpecs = [PSCustomObject]@{}
		IF(!($PSBoundParameters.ContainsKey("ImageFilePath"))){
			$PSBoundParameters['ImageFilePath'] = Get-oFilePath -Title "Pick an Image File to Upload" -SpecialFolder MyComputer
		}
		Write-Verbose "$($MyInvocation.MyCommand) `$ImageFilePath: [$($ImageFilePath | Out-String)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['ImageFilePath']: [$($PSBoundParameters['ImageFilePath'] | Out-String)]"
		$ImageFileInfo = [System.IO.FileInfo]$ImageFilePath
		$oDisk = $NULL
		IF($PSBoundParameters['oDiskAction'] -eq "UseExisting"){
			IF($PSBoundParameters.ContainsKey("Name")){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDisk = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDisk]}{
						Write-Verbose "$($MyInvocation.MyCommand) Name is [oDisk]"
						$oDisk = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oDisk"}{
						Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDisk]"
						$oDisk = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters.ContainsKey("Id")){
				IF($PSBoundParameters['Id']){
					IF($PSBoundParameters['oVirtServerName']){
						$oDisk = Get-oDisk -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDisk = Get-oDisk -Id $PSBoundParameters['Id'] -EA SilentlyContinue
					}
					IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
			}ElseIF($PSBoundParameters.ContainsKey("Uid")){
				IF($PSBoundParameters['Uid']){
					$UidUrl = [Uri]$Uid
					$oDisk = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
					IF($oDisk){$oDisk | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
			}
		}ElseIF($PSBoundParameters['oDiskAction'] -eq "CreateNew"){
			IF($PSBoundParameters.ContainsKey("oStorageDomain")){
				SWITCH($PSBoundParameters['oStorageDomain']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oStorageDomain = Get-oStorageDomain -Name $PSBoundParameters['oStorageDomain'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oStorageDomain = Get-oStorageDomain -Name $PSBoundParameters['oStorageDomain'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oStorageDomain){$oStorageDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oStorageDomain = Get-oStorageDomain -Name $PSBoundParameters['oStorageDomain'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oStorageDomain = Get-oStorageDomain -Name $PSBoundParameters['oStorageDomain'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oStorageDomain){$oStorageDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oStorageDomain]}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is [oStorageDomain]"
						$oStorageDomain = $PSBoundParameters['oStorageDomain']
					}
					{$_.GetType().Name -eq "oStorageDomain"}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain GetType equals [oStorageDomain]"
						$oStorageDomain = $PSBoundParameters['oStorageDomain']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters.ContainsKey("oStorageDomainId")){
				IF($PSBoundParameters['oVirtServerName']){
					$oStorageDomain = Get-oStorageDomain -Id $PSBoundParameters['oStorageDomainId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oStorageDomain = Get-oStorageDomain -Id $PSBoundParameters['oStorageDomainId'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
				}
				IF($oStorageDomain){$oStorageDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters.ContainsKey("oStorageDomainUid")){
				$UidUrl = [Uri]$oStorageDomainUid
				$oStorageDomain = Get-oStorageDomain -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oStorageDomain){$oStorageDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			
			#Build New oDisk Spec & forward to New-oDisk, need @Params created
			$NewoDiskParameters = New-Object HashTable
			IF($PSBoundParameters.ContainsKey("oDiskName")){
				$NewoDiskParameters.Add("Name",$PSBoundParameters['oDiskName'])
				IF((($PSBoundParameters['oDiskName']).Substring($($oDiskName.Length -4)) -eq ".iso") -OR ($ImageFileInfo.Extension -eq ".iso")){
					$NewoDiskParameters.Add("ContentType","iso")
					$PSBoundParameters['Format'] = "raw"
					$PSBoundParameters['DiskType'] = "Image"
				}
			}ElseIF($PSCmdlet.ParameterSetName -eq "CreateNew"){
				$NewoDiskParameters.Add("Name",$ImageFileInfo.Name)
				IF($ImageFileInfo.Extension -eq ".iso"){
					$NewoDiskParameters.Add("ContentType","iso")
					$PSBoundParameters['Format'] = "raw"
					$PSBoundParameters['DiskType'] = "Image"
				}
			}
			
			IF($PSBoundParameters.ContainsKey("DiskType")){$NewoDiskParameters.Add("DiskType",$PSBoundParameters['DiskType'])}Else{$NewoDiskParameters.Add("DiskType","Image")}
			IF(!($PSBoundParameters.ContainsKey("ProvisionedSize"))){$PSBoundParameters['ProvisionedSize'] = $ImageFileInfo.Length}
			#IF($PSBoundParameters.ContainsKey("InitialSize")){$NewoDiskParameters.Add("InitialSize",$PSBoundParameters['InitialSize'])}
			IF($PSBoundParameters.ContainsKey("ProvisionedSize")){$NewoDiskParameters.Add("InitialSize",$PSBoundParameters['ProvisionedSize'])}
			IF($PSBoundParameters.ContainsKey("ProvisionedSize")){$NewoDiskParameters.Add("ProvisionedSize",$PSBoundParameters['ProvisionedSize'])}
			IF($PSBoundParameters.ContainsKey("Format")){$NewoDiskParameters.Add("Format",$PSBoundParameters['Format'])}
			IF($PSBoundParameters.ContainsKey("Alias")){$NewoDiskParameters.Add("Alias",$PSBoundParameters['Alias'])}
			IF($PSBoundParameters.ContainsKey("Active")){$NewoDiskParameters.Add("Active",$PSBoundParameters['Active'])}
			IF($PSBoundParameters.ContainsKey("Backup")){$NewoDiskParameters.Add("Backup",$PSBoundParameters['Backup'])}
			IF($PSBoundParameters.ContainsKey("BackupMode")){$NewoDiskParameters.Add("BackupMode",$PSBoundParameters['BackupMode'])}
			IF($PSBoundParameters.ContainsKey("Shareable")){$NewoDiskParameters.Add("Shareable",$PSBoundParameters['Shareable'])}
			IF($PSBoundParameters.ContainsKey("WipeAfterDelete")){$NewoDiskParameters.Add("WipeAfterDelete",$PSBoundParameters['WipeAfterDelete'])}
			IF($PSBoundParameters.ContainsKey("oVirtServerName")){$NewoDiskParameters.Add("oVirtServerName",$PSBoundParameters['oVirtServerName'])}ElseIF($oVirtServerName){$NewoDiskParameters.Add("oVirtServerName",$oVirtServerName)}
			IF($oStorageDomain){$NewoDiskParameters.Add("oStorageDomain",$oStorageDomain.Name)}
			Write-Verbose "$($MyInvocation.MyCommand) `$NewoDiskParameters: $($NewoDiskParameters | Out-String)"
			$oDisk = New-oDisk @NewoDiskParameters
			#Wait for deployement of oDisk
			IF($oDisk.status -ne "ok"){
				Write-Host -NoNewLine -Fore Cyan "Waiting for Deployment of oDisk [$($oDisk.Name)]"
				$WaitTimer = 60
				$NewoDiskCreationStartTime = Get-Date
				Do{Write-Host -NoNewLine -Fore DarkGray "."; Start-Sleep 1; $oDiskCheck = Get-oDisk -Id $oDisk.Id -oVirtServerName $oDisk.oVirtServer}Until(($oDiskCheck.status -eq "ok") -OR ((Get-Date) -GT $NewoDiskCreationStartTime.AddSeconds($WaitTimer)))
				IF($oDiskCheck.status -eq "ok"){
					$oDisk = $oDiskCheck
					Write-Host -Fore Green "Success"
				}Else{
					Write-Host -Fore Red "Failed or Timed Out waiting [$($WaitTimer)] seconds with oDisk Status of [$($oDiskCheck.status)]"
				}
			}
		}ElseIF($PSBoundParameters['oDiskAction'] -eq "AsGlanceImageTemplate"){
			IF($PSBoundParameters.ContainsKey("oCluster")){
				SWITCH($PSBoundParameters['oCluster']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oCluster = Get-oCluster -Name $PSBoundParameters['oCluster'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oCluster = Get-oCluster -Name $PSBoundParameters['oCluster'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oCluster){$oCluster | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oCluster = Get-oCluster -Name $PSBoundParameters['oCluster'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oCluster = Get-oCluster -Name $PSBoundParameters['oCluster'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oCluster){$oCluster | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oCluster]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is [oCluster]"
						$oCluster = $PSBoundParameters['oCluster']
					}
					{$_.GetType().Name -eq "oCluster"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals [oCluster]"
						$oCluster = $PSBoundParameters['oCluster']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters.ContainsKey("oClusterId")){
				IF($PSBoundParameters['oVirtServerName']){
					$oCluster = Get-oCluster -Id $PSBoundParameters['oClusterId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oCluster = Get-oCluster -Id $PSBoundParameters['oClusterId'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
				}
				IF($oCluster){$oCluster | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters.ContainsKey("oClusterUid")){
				$UidUrl = [Uri]$oClusterUid
				$oCluster = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oCluster){$oCluster | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		IF($oDisk){
			$oVirtServerName = $oDisk.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'disk' -Value $([PSCustomObject]@{'id'=$oDisk.Id})
			$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'direction' -Value "upload"
		}ElseIF($PSBoundParameters['oDiskAction'] -eq "AsGlanceImageTemplate"){
			IF($oCluster){$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'cluster' -Value $([PSCustomObject]@{'name'=$oCluster.Name})}
			IF($PSBoundParameters.ContainsKey("oImageName")){$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'template' -Value $($PSBoundParameters['oImageName'])}
			$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'import_as_template' -Value "true"
			$ImageTransferSpecs | Add-Member -MemberType NoteProperty -Name 'direction' -Value "upload"
		}
		IF(($oDisk) -OR ($PSBoundParameters['oDiskAction'] -eq "AsGlanceImageTemplate")){
			$Uri = $BaseURL + "/ovirt-engine/api/imagetransfers"
			$Method = "POST"
			$JsonBody = $ImageTransferSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json"
			Write-Verbose "$($JsonBody | Out-String)"
	
			$ImageTransferSession = $Null
			$ImageTransferSessionStartTime = Get-Date
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true"}
			#Write-Verbose "$($MyInvocation.MyCommand) Creating Image Transfer Session"
			Write-Host -NoNewLine -Fore Cyan "Creating Image Transfer Session"; Write-Host -NoNewLine -Fore DarkGray "..."
			Try{$ImageTransferSession = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
			IF($ImageTransferSession){
				#$ImageTransferSession.phase
				Write-Host -Fore Green "Success"
				Write-Host -Fore Cyan "`tImageTransferSession Id: $($ImageTransferSession)"
				$ImageTransferStates = @("cancelled","cancelled_system","cancelled_user","finalizing_cleanup","finalizing_failure","finalizing_success","finished_cleanup","finished_failure","finished_success","initializing","paused_system","paused_user","resuming","transferring","unknown")
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				IF($ImageTransferSession.phase -ne "transferring"){
					#Check for Prepping States
					Write-Host -NoNewLine -Fore Cyan "Waiting for Image Transfer Session Status [$($ImageTransferSession.phase)]"
					IF(@("initializing","resuming") -Contains $ImageTransferSession.phase){
						#Loop and wait for ready or failure/cancel
						Do{Write-Host -NoNewLine -Fore DarkGray "."; Start-Sleep 1; $oImageTransfer = Get-oImageTransfer -Id $ImageTransferSession.Id -oVirtServerName $oVirtServerName; IF($oImageTransfer){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}}Until(($oImageTransfer.phase -eq "transferring") -OR ((($ImageTransferSessionStartTime).AddSeconds($ImageTransferSession.inactivity_timeout)) -lt (Get-Date)))
						IF($oImageTransfer.phase -eq "transferring"){
							Write-Host -Fore Green "Success"
						}Else{
							Write-Host -Fore Red "Failed or Timed Out waiting [$($ImageTransferSession.inactivity_timeout)] seconds with oImageTransfer Phase of [$($oImageTransfer.phase)]"
						}
					}
					#Check for Failure/Cancel States
					IF(($ImageTransferSession.phase -ne "transferring") -AND ($oImageTransfer.phase -ne "transferring")){
						IF($oImageTransfer){
							Write-Warning "Image Transfer Session Failed State [$($oImageTransfer.phase)]"; BREAK
						}Else{
							Write-Warning "Image Transfer Session Failed State [$($ImageTransferSession.phase)]"; BREAK
						}
					}
				}
				IF(($ImageTransferSession.phase -eq "transferring") -OR ($oImageTransfer.phase -eq "transferring")){
					#Execute Transfer Action
					Write-Host -Fore Cyan "Beginning Image Transfer"
					$Method = "PUT"
					Write-Verbose "$($MyInvocation.MyCommand): `$Uri: $($Uri | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand): `$Method: $($Method | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand): `$ImageFilePath: $($PSBoundParameters['ImageFilePath'] | Out-String)"
					#IF($PSBoundParameters['Uploader'] -eq "RestMethod"){
					#https://learn.microsoft.com/en-us/dotnet/api/system.io.filestream.read?view=net-8.0
					#https://ovirt.github.io/ovirt-imageio/images.html
					
					#Invoke-RestMethod is very slow due to built-in Progress indicator enabled by default, Disable it
					$SavedProgressPreference = $ProgressPreference
					$ProgressPreference = 'SilentlyContinue'
					
					#PS Max Mem
					#(Get-Item WSMan:\localhost\Shell\MaxMemoryPerShellMB -EA SilentlyContinue).Value/[MATH]::Pow(1024,3)
					
					#Find Mem on this window
					$ThisPSWindowProcess = $Null
					IF(!($ThisPSWindowProcess)){$ThisPSWindowProcess = Get-Process -Id $PID -EA SilentlyContinue}
					IF(!($ThisPSWindowProcess)){$ThisPSWindowProcess = ([System.Diagnostics.Process]::GetCurrentProcess())}
					IF(!($ThisPSWindowProcess)){$ThisPSWindowProcess = Get-Process -Id ([System.Diagnostics.Process]::GetCurrentProcess()).Id -EA SilentlyContinue}
					IF(!($ThisPSWindowProcess)){
						$SavedWindowTitle = $Host.UI.RawUI.WindowTitle
						$WindowTitleGuid = [GUID]::NewGuid().Guid
						$Host.UI.RawUI.WindowTitle = $WindowTitleGuid
						$ThisPSWindowProcess = Get-Process -ProcessName powershell -EA SilentlyContinue | ?{$_.MainWindowTitle -eq $WindowTitleGuid}
						$Host.UI.RawUI.WindowTitle = $SavedWindowTitle
					}
					
					#Check OS Type
					IF(([IntPtr]::Size * 8) -eq 32){$WorkingSet = $ThisPSWindowProcess.WorkingSet}ElseIF(([IntPtr]::Size * 8) -eq 64){$WorkingSet = $ThisPSWindowProcess.WorkingSet64}
					
					#Set Read Chunk Size based on user input and/or Default & guard rails
					#Set Read Chunk Size based on user input and/or Default & guard rails
					$DefaultBlockSize = 64MB
					$DefaultBlockSize = [math]::pow(2,26) #64MiB
					$DefaultBlockSize = 67108864
					$MemFreeSpaceReservation = 64MB
					$MemFreeSpaceReservation = 67108864
					IF($PSBoundParameters['ChunkSize']){
						IF($PSBoundParameters['ChunkSize'] -le ((Get-Item WSMan:\localhost\Shell\MaxMemoryPerShellMB -EA SilentlyContinue).Value)){
							$BlockSize = $PSBoundParameters['ChunkSize']
						}Else{
							$BlockSize = $DefaultBlockSize
						}
					}Else{
						#Check Admin Status
						# IF((New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)){Enable-PSRemoting -SkipNetworkProfileCheck -Force}
						#Enable-PSRemoting : Access is denied. To run this cmdlet, start Windows PowerShell with the "Run as administrator" option
						
						#"Stopped","Running"
						IF((Get-Service -Name WinRM).Status -eq "Running"){$MaxMemoryPerShellMB = ((Get-Item WSMan:\localhost\Shell\MaxMemoryPerShellMB -EA SilentlyContinue).Value)}Else{$MaxMemoryPerShellMB = $Null}
						IF($MaxMemoryPerShellMB){
							$AvailableMemThisWindow = ((($MaxMemoryPerShellMB) - $WorkingSet) - $MemFreeSpaceReservation)
							#Is less than File Stream max read size
							IF($AvailableMemThisWindow -le [INT32]::MaxValue){
								IF($AvailableMemThisWindow -ge $DefaultBlockSize){
									$BlockSize = $AvailableMemThisWindow
								}Else{
									$BlockSize = $DefaultBlockSize
								}
							}Else{
								$BlockSize = $DefaultBlockSize
							}
						}Else{$BlockSize = $DefaultBlockSize}
					}
					$TransferChunkSize = $BlockSize
					$FileStream = [System.IO.File]::OpenRead($ImageFilePath)
					$Buffer = New-Object byte[] $BlockSize
					$numBytesRead = 0
					#(Get-ChildItem -Path $ImageFilePath).Length
					$numBytesToRead = [INT64]$ImageFileInfo.Length
					#Write-Output "$([char]27)[2J"
					$oDiskCheck = Get-oDisk -oVirtServerName $oVirtServerName -Id $oDisk.Id
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
					Write-Host "`$oDisk Provisioned Size Bytes: $(($oDiskCheck).provisioned_size)"
					Write-Host "`$oDisk Initial Size Bytes: $(($oDiskCheck).initial_size)"
					Write-Host "`$oDisk Total Size Bytes: $(($oDiskCheck).total_size)"
					Write-Host "Get-ChildItem File Size Bytes: $((Get-ChildItem -Path $ImageFilePath).Length)"
					Write-Host "File Size Bytes: $([INT64](($ImageFileInfo).Length))"
					Write-Host "Transfer Chunk Size MB: $($BlockSize/[MATH]::Pow(1024,2))"
					#get current cursor positions, to write updates in place
					$X = $Host.UI.RawUI.CursorPosition.X
					$Y = $Host.UI.RawUI.CursorPosition.Y
					$ChunkTimes = [System.Collections.ArrayList]@()
					$oImageTransferStatusInFlight = $Null
					While($true){
						$ChunkStartTime = Get-Date
						IF($numBytesRead -ge $ImageFileInfo.Length){ Break }
						[INT32]$ReadBlock = $FileStream.Read($Buffer, 0, $BlockSize)
						[void]$FileStream.Flush()
						IF($ReadBlock -le 0){ Break }
						$numBytesRead += $ReadBlock
						$numBytesToRead -= $ReadBlock
						#IF(($ImageFileInfo.Length - $numBytesRead) -lt $BlockSize){$BlockSize = ($ImageFileInfo.Length - $numBytesRead)}
						#$Headers = @{"Accept" = "application/json";"ContentType" = "application/octet-stream";"Content-Range" = "bytes $($numBytesRead - $ReadBlock)-$($numBytesRead + $ReadBlock)/*";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true";"Content-Length" = "$($ReadBlock)"}
						$Headers = @{"Accept" = "application/json";"ContentType" = "application/octet-stream";"Content-Range" = "bytes $($numBytesRead - $ReadBlock)-$($numBytesRead)/*";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true";"Content-Length" = "$($ReadBlock)"}
						Write-Verbose "$($MyInvocation.MyCommand): `$Headers: $($Headers | Out-String)"
						$Body = [System.IO.MemoryStream]::new($Buffer, 0, $ReadBlock)
						$FormattedWebError = $Null
						Try{$Nada = Invoke-RestMethod -Uri "$($ImageTransferSession.proxy_url)?flush=y" -Headers $Headers -Body $Body -Method PUT -ContentType "application/octet-stream" -EV WebError; IF($Nada){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $PSBoundParameters['ImageFilePath'] -Uri $ImageTransferSession.proxy_url); Write-Error $FormattedWebError}
						$PercentComplete = $(($numBytesRead*100)/$ImageFileInfo.Length)
						$SecondsRemaining = $(  ((((Get-Date) - $ImageTransferSessionStartTime).TotalSeconds * 100)/$PercentComplete) - (((Get-Date) - $ImageTransferSessionStartTime).TotalSeconds) )
						$ChunkUploadSeconds = (((Get-Date) - $ChunkStartTime).TotalSeconds)
						$ChunkTimes.Add($ChunkUploadSeconds) | Out-Null
						$AverageTimePerChunk = ($ChunkTimes | Measure-Object -Average).Average
						#set the cursor coordinates back
						$Host.UI.RawUI.CursorPosition = New-Object System.Management.Automation.Host.Coordinates $X,$Y
						Write-Host -Fore Cyan -NoNewLine "`$PercentComplete: ["; Write-Host -Back BLACK -NoNewLine "$([Math]::Round($PercentComplete,2))"; Write-Host -Fore Cyan -NoNewLine "] "; Write-Host -Fore Cyan -NoNewLine "`$ReadPosition: ["; Write-Host -NoNewLine "$($numBytesRead)"; Write-Host -Fore Cyan -NoNewLine "], of ["; Write-Host -NoNewLine "$($ImageFileInfo.Length)"; Write-Host -Fore Cyan -NoNewLine "], Average Seconds Per Chunk Upload [";Write-Host -NoNewLine "$([Math]::Round($AverageTimePerChunk,3))"; Write-Host -Fore Cyan -NoNewLine "] Seconds Remaining [";Write-Host -Back BLACK -NoNewLine "$([Math]::Round($SecondsRemaining))"; Write-Host -Fore Cyan -NoNewLine "]"
						IF(!($oImageTransferStatusInFlight)){$oImageTransferStatusInFlight = Get-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id; IF($oImageTransferStatusInFlight){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}}
					}
					IF($FileStream){$FileStream.close()}
					Write-Host ""
					$ProgressPreference = $SavedProgressPreference
					DO{Sleep 5; $oImageTransferStatusCheck = Get-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id; Write-Verbose "$($MyInvocation.MyCommand): `$oImageTransferStatusCheck: $($oImageTransferStatusCheck | Out-String)"; IF($oImageTransferStatusCheck){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}}While(($oImageTransferStatusCheck.transferred -lt (Get-ChildItem $ImageFilePath).Length) -AND ($oImageTransferStatusCheck.phase -eq "transferring"))
					IF($oImageTransferStatusCheck.transferred -ge (Get-ChildItem $ImageFilePath).Length){
						Write-Host "Finalizing Transfer"
						$Finalize = Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id -Status finalize
						IF($Finalize){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}ElseIF($oImageTransferStatusCheck.transferred -lt (Get-ChildItem $ImageFilePath).Length){
						Write-Host "Cancelling Transfer"
						$Cancel = Set-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id -Status cancel
						IF($Cancel){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}
					$oImageTransferStatus = Get-oImageTransferStatus -oVirtServerName $oVirtServerName -Id $ImageTransferSession.Id
					IF($oImageTransferStatus){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					#}
					$ImageTransferSessionEndTime = Get-Date
					
					[PSCustomObject]@{
						ImageTransferSession = $ImageTransferSession
						oImageTransferStatus = $oImageTransferStatus
						#oImageTransferStatusCheck = $oImageTransferStatusCheck
						#oImageTransferStatusInFlight = $oImageTransferStatusInFlight
						ImageFilePath = $ImageFilePath
						ImageTransferSessionStartTime = $ImageTransferSessionStartTime
						ImageTransferSessionEndTime = $ImageTransferSessionEndTime
						Duration = $($ImageTransferSessionEndTime - $ImageTransferSessionStartTime)
						Finalize = $Finalize
						Cancel = $Cancel
						FormattedWebError = $FormattedWebError
						AverageTimePerChunk = $AverageTimePerChunk
						TransferChunkSize = $TransferChunkSize
					}
				}
			}Else{[GC]::Collect(); Write-Host -Fore Red "Failed or Timed Out Creating Image Transfer Session"}		
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Export-oVM{
	<#
		.SYNOPSIS
			This function exports an the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
		.DESCRIPTION
			This function exports an the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
			Since version 4.2 of the engine it is also possible to export a virtual machine as a virtual appliance (OVA)
			Must provide oStorageDomain for an export OR oHost for and OVA Export
			If neither is provided, but oHostFolder & OVAFileName are provided, parent oHost will be selected for OVA export
		.PARAMETER Name
			The Name of the VM
		.PARAMETER oHost
			The Name of the oHost object to export the oVM
		.PARAMETER oHostId
			The Id of the oHost to export the oVM
		.PARAMETER oHostUid
			The Uid of the oHost to export the oVM
		.PARAMETER oHostFolder
			The folder path on the local file system of the oHost to create an OVA export
			Default is "/home/ovirt"
		.PARAMETER OVAFileName
			The file name to create an OVA export on the local file system of the oHost 
			Default is "<oVMName>.ova"
		.PARAMETER oStorageDomain
			The Name of the oStorageDomain object to export the oVM
		.PARAMETER oStorageDomainId
			The Id of the oStorageDomain to export the oVM
		.PARAMETER oStorageDomainUid
			The Uid of the oStorageDomain to export the oVM
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system to place the new oVM
		.PARAMETER DiscardSnapshots
			Use the discard_snapshots parameter when the virtual machine should be exported with all of its snapshots collapsed.
		.PARAMETER Exclusive
			Use the exclusive parameter when the virtual machine should be exported even if another copy of it already exists in the export domain (override).
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.EXAMPLE
			PS> Export-oVM -oVirtServerName $oVirtServerName -Name "oVMName" -oStorageDomain "oStorageDomainName" -DiscardSnapshots -Exclusive
				Exports the oVM(s) provided to the oStorageDomain
		.EXAMPLE
			PS> Export-oVM -oVirtServerName $oVirtServerName -Name "oVMName" -oHost "oHostName" -DiscardSnapshots -Exclusive
				Exports the oVM(s) provided to the oStorageDomain
		.INPUTS
			[System.String]
			[oVM]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVM]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/export
		.LINK
			Get-Help		
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			#[System.String]$oVM,
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$oHostFolder,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$OVAFileName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oStorageDomain|String'})]$oStorageDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oStorageDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oStorageDomainUid,
		[SWITCH]$DiscardSnapshots, #$discard_snapshots
		[SWITCH]$Exclusive,
		[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		#Can only use 1 of $oHost, $oHostId, $oHostUid, $oStorageDomain, $oStorageDomainId, $oStorageDomainUid
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oHost'] Type: [$(($PSBoundParameters['oHost']).GetType().Name)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"
		$oVMOBjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oVMOBjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
