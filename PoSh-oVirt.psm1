			ForEach($Item in ($PSBoundParameters['oHostId'])){
				$HostArray.Add(([PSCustomObject]@{id = $Item})) | Out-Null
			}
			$VMSpecshosts = ([PSCustomObject]@{host=$HostArray})
			$VMSpecsPlacementPolicy = [PSCustomObject]@{hosts = $VMSpecshosts}
		}
		
		IF($PSBoundParameters['MigrationMode']){
