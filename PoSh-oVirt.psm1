		#>
		<#
			#https://www.ovirt.org/develop/api/networkingapi.html
			#$Uri = $BaseURL + "$(($oHostObjects.actions.link | ?{$_.rel -eq 'setupnetworks'}).href)"
			#So need to see if $oNetworkObjects is populated to use it
			
			Create bond and configure networks
			Configuration prior to the request:

			   eth0 ---- network aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
			   eth1 ---- network bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb
			Desired configuration after the request:

			   eth0 ---|             |-- network aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
					   +--- bond0 ---+
			   eth1 ---|             |-- network bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb
			POST to /api/hosts/{host:id}/setupnetworks

			<action>
			   <bonds>
				 <host_nic>
				   <name>bond0<name>
				   <link_aggregation>
					 <options>
					   <option>
						 <name>module</name>
						 <value>bonding</value>
					   </option>
					   <option>
						 <name>mode</name>
						 <value>1</value>
						 <type>Active-Backup</type>
					   </option>
					   <option>
						 <name>miimon</name>
						 <value>100</value>
					   </option>
					 </options>
					 <slaves>
					   <host_nic>
						 <name>eth0<name>
					   </host_nic>
					   <host_nic>
						 <name>eth1<name>
					   </host_nic>
					 </slaves>
				   </link_aggregation>
				 </host_nic>
			   </bonds>
			   <network_attachments>
				 <network_attachment>
				   <network id="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"/>
				   <host_nic>
					 <name>bond0<name>
				   </host_nic>
				 </network_attachment>
				 <network_attachment>
				   <network id="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"/>
				   <host_nic>
					 <name>bond0<name>
				   </host_nic>
				 </network_attachment>
			   </network_attachments>
			</action>
		
		#>
				
		# $oHostNicSpecs = [PSCustomObject]@{name = $($Name)}
		$oHostNicSpecs = [PSCustomObject]@{name = $($PSBoundParameters['Name'])}
		$oHostNicOptionsSpecs = [PSCustomObject]@{}
		IF($PSBoundParameters['BondingMode'] -ne "Custom"){
			SWITCH($PSBoundParameters['BondingMode']){
				{$_ -eq "(Mode 0) Round-robin"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Round-robin";"value"="0"},@{"name"="miimon"; "value"="100"})})}
				{$_ -eq "(Mode 1) Active-Backup"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Active-Backup";"value"="1"},@{"name"="miimon"; "value"="100"})})}
				{$_ -eq "(Mode 2) Load balance (balance-xor)"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Load balance (balance-xor)";"value"="2"},@{"name"="miimon"; "value"="100"})})}
				{$_ -eq "(Mode 3) Broadcast"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Broadcast";"value"="3"},@{"name"="miimon"; "value"="100"})})}
				{$_ -eq "(Mode 4) Dynamic link aggregation (802.3ad)"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Dynamic link aggregation (802.3ad)"; "value"="4"},@{"name"="xmit_hash_policy"; "value"="2"})})}
				{$_ -eq "(Mode 5) Adaptive transmit load balancing (balance-tlb)"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Adaptive transmit load balancing (balance-tlb)"; "value"="5"})})}
				{$_ -eq "(Mode 6) Adaptive load balancing (balance-alb)"}{$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $([PSCustomObject]@{option = @(@{"name"="mode";"type"="Adaptive load balancing (balance-alb)"; "value"="6"})})}
			}
		}Else{
			IF($PSBoundParameters.ContainsKey('CustomMode')){
				$CustomModeOptionsArray = @()
				Foreach($Key in (($CustomMode).Keys)){
					$CustomModeOptionsArray += @{"name" = $Key; "value" = "$($CustomMode.$Key)"}
				}
				$oHostNicOptionSpec = [PSCustomObject]@{"option"=$CustomModeOptionsArray}
				$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'options' -Value $oHostNicOptionSpec
			}
		}
		$host_nic = @()
		ForEach($oHostNicObject in $oHostNicObjects){
			#Verify $oHostNicObjects are on $oHostObjects
			IF(!($oHostNicObject | ?{($_.host.id -eq $oHostObjects.id) -AND ($_.oVirtServer -eq $oHostObjects.oVirtServer)})){
				Write-Warning "$($MyInvocation.MyCommand): oHostNicObject host id [$($oHostNicObject.id)] Not Found on oHost [$($oHostObjects.id)], quitting..."; BREAK
			}
			$host_nic += $([PSCustomObject]@{"id"=$($oHostNicObject.id)})
			#$host_nic += $([PSCustomObject]@{"name"=$($oHostNicObject.Name)})
		}
		$oHostNicOptionsSpecs | Add-Member -MemberType NoteProperty -Name 'slaves' -Value $([PSCustomObject]@{"host_nic"=$host_nic})
		
		IF($oHostNicOptionsSpecs.psobject.Properties.GetEnumerator().MoveNext()){
			$oHostNicSpecs | Add-Member -MemberType NoteProperty -Name 'bonding' -Value $oHostNicOptionsSpecs
		}
		
		IF($oHostNicSpecs.psobject.Properties.GetEnumerator().MoveNext()){
			$ModifiedBondSpecs = [PSCustomObject]@{"host_nic" = @($oHostNicSpecs)}
			$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'modified_bonds' -Value $ModifiedBondSpecs
		}
		IF(($PSBoundParameters['CommitOnSuccess']).IsPresent -eq $True){$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'commit_on_success' -Value $True}
		IF(($PSBoundParameters['CheckConnectivity']).IsPresent -eq $True){$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'check_connectivity' -Value $True}
		IF(($PSBoundParameters['RunAsync']).IsPresent -eq $True){
			$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value "true"
		}Else{
			$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value "false"
		}
		IF(($PSBoundParameters['ConnectivityTimeout'])){$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'connectivity_timeout' -Value $($PSBoundParameters['ConnectivityTimeout'])}

		
		#Put stuff here for modified_labels
		IF($oNetworkLabelObjects){
			
#Verify oNetworkLabel, is child of an oHostNic or oNetwork
	#(Get-oUri -RESTUri $oHostNicObject.link.where({$_.rel -eq "networklabels"}).href).network_label
		# $oHostNicObjects | Get-oNetworkLabel
	#(Get-oUri -RESTUri $oNetworkObjects.link.where({$_.rel -eq "networklabels"}).href).network_label
		# $oNetworkObjects | Get-oNetworkLabel
			
			$ModifiedLabelsSpecs = [PSCustomObject]@{"network_label"=$([PSCustomObject]@{"name"=$oNetworkLabelObjects.Name})}
			IF($ModifiedLabelsSpecs){
				IF($ModifiedLabelsSpecs.psobject.Properties.GetEnumerator().MoveNext()){
					$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'modified_labels' -Value $ModifiedLabelsSpecs
				}
			}
		}
			
		#Put stuff here for modified_network_attachments
		IF($oNetworkObjects.Name){
			#Verify that Network is in the same datacenter as the $oHostNicObjects (use $oHostObjects already verified same DC)
				#$oHostObjects.cluster.data_center.id
				#$oNetworkObjects.data_center.Id
			IF(!($oNetworkObjects | ?{($_.data_center.id -eq $oHostObjects.cluster.data_center.id) -AND ($_.oVirtServer -eq $oHostObjects.oVirtServer)})){
				Write-Warning "$($MyInvocation.MyCommand): oNetwork DataCenter Id [$($oNetworkObjects.data_center.Id)] Not the same as oHost DataCenter Id [$($oHostObjects.cluster.data_center.id)], quitting..."; BREAK
			}
			
			$oNetworkAttachmentSpecs = [PSCustomObject]@{}
			#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $([PSCustomObject]@{name = $($oNetworkObjects.Name)})
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value @($(@([PSCustomObject]@{name = $($oNetworkObjects.name)})))
			$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $(@([PSCustomObject]@{id = $($oNetworkObjects.id)}))
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value @($(@([PSCustomObject]@{id = $($oNetworkObjects.id)})))
			$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'host_nic' -Value $([PSCustomObject]@{"name"=$($PSBoundParameters['Name'])})
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'host_nic' -Value @($([PSCustomObject]@{"name"=$($PSBoundParameters['Name'])}))
			$ip_address_assignmentSpecs = [PSCustomObject]@{}
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/boot_protocol
			IF($PSBoundParameters.ContainsKey('AssignmentMethod')){	$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'assignment_method' -Value $($PSBoundParameters['AssignmentMethod']) }
			#IF($PSBoundParameters.ContainsKey('AssignmentMethod')){	$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'assignment_method' -Value @($($PSBoundParameters['AssignmentMethod']) })
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
			IF(($PSBoundParameters.ContainsKey('IPAddress')) -OR ($PSBoundParameters.ContainsKey('Gateway')) -OR ($PSBoundParameters.ContainsKey('Netmask')) -OR ($PSBoundParameters.ContainsKey('IPVersion'))){
				$IPSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('IPAddress')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['IPAddress']) }
				IF($PSBoundParameters.ContainsKey('Gateway')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'gateway' -Value $($PSBoundParameters['Gateway']) }
				IF($PSBoundParameters.ContainsKey('Netmask')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'netmask' -Value $($PSBoundParameters['Netmask']) }
				IF($PSBoundParameters.ContainsKey('IPVersion')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'version' -Value $($PSBoundParameters['IPVersion']) }
				IF($IPSpecs.psobject.Properties.GetEnumerator().MoveNext()){
					Write-Host -Fore Cyan "`$IPSpecs.psobject.Properties.GetEnumerator().MoveNext(): [$($IPSpecs.psobject.Properties.GetEnumerator().MoveNext())]"
					$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip' -Value $IPSpecs
				}
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip_address_assignment
			IF($ip_address_assignmentSpecs.psobject.Properties.GetEnumerator().MoveNext()){
				Write-Host -Fore Cyan "`$ip_address_assignmentSpecs.psobject.Properties.GetEnumerator().MoveNext(): [$($ip_address_assignmentSpecs.psobject.Properties.GetEnumerator().MoveNext())]"
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = $ip_address_assignmentSpecs})
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value @($([PSCustomObject]@{ip_address_assignment = $ip_address_assignmentSpecs}))
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value @($([PSCustomObject]@{ip_address_assignment = $ip_address_assignmentSpecs}))
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value @($([PSCustomObject]@{ip_address_assignment = @($ip_address_assignmentSpecs)}))
				$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = @($ip_address_assignmentSpecs)})
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/dns_resolver_configuration
			IF($PSBoundParameters.ContainsKey('DNSServers')){
				$name_serversSpecs = [PSCustomObject]@{}
				$name_serverArray = [System.Collections.ArrayList]@()
				ForEach($Item in $($PSBoundParameters['DNSServers'])){ $name_serverArray.Add( $(@{"name_server"=$Item}) ) | Out-Null }
				IF($name_serverArray.Count -gt 0){
					Write-Host -Fore Cyan "`$name_serverArray.Count -gt 0: [$($name_serverArray.Count)]"
					$name_serversSpecs | Add-Member -MemberType NoteProperty -Name 'name_servers' -Value $name_serverArray
				}
				IF($name_serversSpecs.psobject.Properties.GetEnumerator().MoveNext()){
					Write-Host -Fore Cyan "`$name_serversSpecs.psobject.Properties.GetEnumerator().MoveNext(): [$($name_serversSpecs.psobject.Properties.GetEnumerator().MoveNext())]"
					$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $name_serversSpecs
				}
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
			IF($PSBoundParameters.ContainsKey('Properties')){
				$PropertiesSpec = [PSCustomObject]@{}
				$PropertiesArray = [System.Collections.ArrayList]@()
				ForEach($Item in $(($PSBoundParameters['Properties']).GetEnumerator())){$PropertiesArray.Add( $([PSCustomObject]@{"property"=$([PSCustomObject]@{"name" = $Item.Name; "value" = $Item.Value})}) ) | Out-Null }
				IF($PropertiesArray.Count -gt 0){
					Write-Host -Fore Cyan "`$PropertiesArray.Count -gt 0: [$($PropertiesArray.Count)]"
					$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'properties' -Value $PropertiesArray
				}
			}
			
			IF($oNetworkAttachmentSpecs.psobject.Properties.GetEnumerator().MoveNext()){
				Write-Host -Fore Cyan "`$oNetworkAttachmentSpecs.psobject.Properties.GetEnumerator().MoveNext(): [$($oNetworkAttachmentSpecs.psobject.Properties.GetEnumerator().MoveNext())]"
				$ModifiedNetworkAttachmentsSpecs = [PSCustomObject]@{"network_attachment" = @($oNetworkAttachmentSpecs)}
				#$ModifiedNetworkAttachmentsSpecs = [PSCustomObject]@{"network_attachment" = $oNetworkAttachmentSpecs}
				#$oHostBondSpecs = [PSCustomObject]@{"network_attachment" = $oNetworkAttachmentSpecs}
				#$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'network_attachment' -Value @($oNetworkAttachmentSpecs)
				#$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'network_attachment' -Value $oNetworkAttachmentSpecs
			}
		}
		IF($ModifiedNetworkAttachmentsSpecs){
			IF($ModifiedNetworkAttachmentsSpecs.psobject.Properties.GetEnumerator().MoveNext()){
				#Un remark to use with above line $ModifiedNetworkAttachmentsSpecs = [PSCustomObject]@{"network_attachment" = $oNetworkAttachmentSpecs} instead of $oHostBondSpecs = [PSCustomObject]@{"network_attachment" = $oNetworkAttachmentSpecs}
				Write-Host -Fore Cyan "`$ModifiedNetworkAttachmentsSpecs.psobject.Properties.GetEnumerator().MoveNext(): [$($ModifiedNetworkAttachmentsSpecs.psobject.Properties.GetEnumerator().MoveNext())]"
				$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'modified_network_attachments' -Value $ModifiedNetworkAttachmentsSpecs
				#$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'modified_network_attachments' -Value @($ModifiedNetworkAttachmentsSpecs)
			}
		}
				
		#Put stuff here for synchronized_network_attachments
		#$ModifiedSyncronizedNetworkAttachmentsSpecs = [PSCustomObject]@{}
		#$oHostBondSpecs | Add-Member -MemberType NoteProperty -Name 'synchronized_network_attachments' -Value $ModifiedSyncronizedNetworkAttachmentsSpecs
		
		#POST /ovirt-engine/api/hosts/123/setupnetworks
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$BaseURL = "https://$($oHostObjects.oVirtServer)"
		$Uri = $BaseURL + "$(($oHostObjects.actions.link | ?{$_.rel -eq 'setupnetworks'}).href)"
		$Method = "POST"
		$JsonBody = $oHostBondSpecs | ConvertTo-Json -Depth 50
		$global:oHostBondSpecs = $oHostBondSpecs
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oHostBond"
		Write-Verbose "$($JsonBody | Out-String)"
		#Write-Host -Fore Green "[$($oHostBondSpecs | Out-String)]"
		#Write-Host -Fore Green "[$($JsonBody | Out-String)]"
		$UpdatedoHostBond = $Null
		TRY{$UpdatedoHostBond = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		#IF($UpdatedoHostBond){$OutPutItems.Add($UpdatedoHostBond) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		IF($UpdatedoHostBond){
			IF(($UpdatedoHostBond.status -eq "Complete") -AND ($UpdatedoHostBond.modified_bonds.host_nic | ?{$_.name -eq $PSBoundParameters['Name']})){
				$oHostBond = $Null; $oHostBond = ($oHostObjects | Get-oHostNic | Where-Object {$_.bonding.slaves.host_nic.id} | ?{$_.Name -eq $($PSBoundParameters['Name'])})
			}
			IF($oHostBond){
				$OutPutItems.Add($oHostBond) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				$OutPutItems.Add($UpdatedoHostBond) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}
		}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

