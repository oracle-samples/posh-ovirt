							$TemplateSpecsRandomGeneratorDeviceRate = [PSCustomObject]@{
								  period = $RandomGeneratorDurationMs
								  bytes = $RandomGeneratorBytesPerSec
							}
							Add-Member -NotePropertyName "rate" -NotePropertyValue $TemplateSpecsRandomGeneratorDeviceRate -inputObject $TemplateSpecsRandomGeneratorDevice
						}
					}Else{
						$TemplateSpecsRandomGeneratorDevice = [PSCustomObject]@{source = $Null}
					}
				}

				IF($PSBoundParameters.ContainsKey('IOThreadsEnabled')){$TemplateSpecsIO = [PSCustomObject]@{"threads" = $(IF($NumberIOThreads){$NumberIOThreads}Else{"1"})}}

				IF(($PSBoundParameters.ContainsKey('DisplayAllowOverRide')) -OR ($PSBoundParameters.ContainsKey('DisplayCopyPasteEnabled')) -OR ($ConsoleDisconnectAction) -OR ($DisconnectActionDelayinMinutes) -OR ($PSBoundParameters.ContainsKey('DisplayFileTransferEnabled')) -OR ($Monitors) -OR ($PSBoundParameters.ContainsKey('SmartCardEnabled')) -OR ($GraphicsProtocol) -OR ($VNCKeyboardLayout)){
					$TemplateSpecsDisplay = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('DisplayAllowOverRide')){Add-Member -NotePropertyName "allow_override" -NotePropertyValue $DisplayAllowOverRide -inputObject $TemplateSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('DisplayCopyPasteEnabled')){Add-Member -NotePropertyName "copy_paste_enabled" -NotePropertyValue $DisplayCopyPasteEnabled -inputObject $TemplateSpecsDisplay}
					IF($ConsoleDisconnectAction){Add-Member -NotePropertyName "disconnect_action" -NotePropertyValue $ConsoleDisconnectAction -inputObject $TemplateSpecsDisplay}
					IF($DisconnectActionDelayinMinutes){Add-Member -NotePropertyName "disconnect_action_delay" -NotePropertyValue $DisconnectActionDelayinMinutes -inputObject $TemplateSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('DisplayFileTransferEnabled')){Add-Member -NotePropertyName "file_transfer_enabled" -NotePropertyValue $DisplayFileTransferEnabled -inputObject $TemplateSpecsDisplay}
					IF($Monitors){Add-Member -NotePropertyName "monitors" -NotePropertyValue $Monitors -inputObject $TemplateSpecsDisplay}
					IF($PSBoundParameters.ContainsKey('SmartCardEnabled')){Add-Member -NotePropertyName "smartcard_enabled" -NotePropertyValue $SmartCardEnabled -inputObject $TemplateSpecsDisplay}
					IF($GraphicsProtocol){Add-Member -NotePropertyName "type" -NotePropertyValue $GraphicsProtocol -inputObject $TemplateSpecsDisplay}
					IF($VNCKeyboardLayout){Add-Member -NotePropertyName "keyboard_layout" -NotePropertyValue $VNCKeyboardLayout -inputObject $TemplateSpecsDisplay}
				}
				
				IF($TimeZone){
					$TemplateSpecsTimeZone = [PSCustomObject]@{
						"name" = ((($TimeZone).Split('[]') | ?{$_})[1])
					}
				}
				
				If($PSBoundParameters.ContainsKey('UsbEnabled')){
					$TemplateSpecsUsb = [PSCustomObject]@{
						"enabled" = $UsbEnabled
						"type" = "native"
					}
				}
				
				IF(($MigrationEncrypted) -OR ($MigrationParallel) -OR ($MigrationCompressed) -OR ($MigrationAutoConverge)){
					$TemplateSpecsMigration = [PSCustomObject]@{}
					IF($MigrationEncrypted){Add-Member -NotePropertyName "encrypted" -NotePropertyValue $MigrationEncrypted -inputObject $TemplateSpecsMigration}
					IF($MigrationParallel){Add-Member -NotePropertyName "parallel_migrations_policy" -NotePropertyValue $MigrationParallel -inputObject $TemplateSpecsMigration}
					IF($MigrationCompressed){Add-Member -NotePropertyName "compressed" -NotePropertyValue $MigrationCompressed -inputObject $TemplateSpecsMigration} #"inherit", need to get back to this one
					IF($MigrationAutoConverge){Add-Member -NotePropertyName "auto_converge" -NotePropertyValue $MigrationAutoConverge -inputObject $TemplateSpecsMigration} #"inherit", need to get back to this one
					#"policy" = @{id=a7aeedb2-8d66-4e51-bb22-32595027ce71} This sets a Migation Policy, from those available 
				}
				
				IF(($PSBoundParameters.ContainsKey('MemoryBallooning')) -OR ($MemoryGuaranteed) -OR ($MemoryMax) -OR ($MemoryOverCommitPercentage) -OR ($MemoryTHPEnabled)){
					$TemplateSpecsMemoryPolicy = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('MemoryBallooning')){Add-Member -NotePropertyName "ballooning" -NotePropertyValue $MemoryBallooning -inputObject $TemplateSpecsMemoryPolicy}
					IF($MemoryGuaranteed){Add-Member -NotePropertyName "guaranteed" -NotePropertyValue $MemoryGuaranteed -inputObject $TemplateSpecsMemoryPolicy}
					IF($MemoryMax){Add-Member -NotePropertyName "max" -NotePropertyValue $MemoryMax -inputObject $TemplateSpecsMemoryPolicy}
					IF($MemoryOverCommitPercentage){Add-Member -NotePropertyName "over_commit" -NotePropertyValue $MemoryOverCommitPercentage -inputObject $TemplateSpecsMemoryPolicy}
					IF($PSBoundParameters.ContainsKey('MemoryTHPEnabled')){Add-Member -NotePropertyName "transparent_huge_pages" -NotePropertyValue ([PSCustomObject]@{enabled = $MemoryTHPEnabled}) -inputObject $TemplateSpecsMemoryPolicy}
				}

				IF($PSBoundParameters.ContainsKey('HAEnabled')){
					$TemplateSpecsHA = [PSCustomObject]@{"enabled" = $HAEnabled}
					SWITCH($HAPriority){
						{$_ -eq "Low"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 1 -inputObject $TemplateSpecsHA}
						{$_ -eq "Medium"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 50 -inputObject $TemplateSpecsHA}
						{$_ -eq "High"}{Add-Member -NotePropertyName "priority" -NotePropertyValue 100 -inputObject $TemplateSpecsHA}
					}
				}
				
				IF($CPUShares){
					SWITCH($CPUShares){
						{$_ -eq 'disabled'}{$cpu_shares = 0}
						{$_ -eq 'low'}{$cpu_shares = 512}
						{$_ -eq 'medium'}{$cpu_shares = 1024}
						{$_ -eq 'high'}{$cpu_shares = 2048}
						{$_ -eq 'custom'}{IF($CPUSharesInt){$cpu_shares = $CPUSharesInt}Else{$cpu_shares = 0}}
					}
				}
				
				IF($CpuCoresPerSocket -OR $CpuSockets -OR $CpuThreads){
					$TemplateSpecsCpuTopology = [PSCustomObject]@{}
					IF($CpuCoresPerSocket){Add-Member -NotePropertyName "cores" -NotePropertyValue $CpuCoresPerSocket -inputObject $TemplateSpecsCpuTopology}
					IF($CpuSockets){Add-Member -NotePropertyName "sockets" -NotePropertyValue $CpuSockets -inputObject $TemplateSpecsCpuTopology}
					IF($CpuThreads){Add-Member -NotePropertyName "threads" -NotePropertyValue $CpuThreads -inputObject $TemplateSpecsCpuTopology}
				}

				# (gou /ovirt-engine/api/operatingsystems).operating_system|Select -ExpandProperty architecture|Sort -u
				IF($CpuType -OR $TemplateSpecsCpuTopology -OR $VMType){
					$TemplateSpecsCpu = [PSCustomObject]@{}
					#"topology" = $TemplateSpecsCpuTopology
					#"architecture" = $CpuType
					#"mode"="host_passthrough" #Only if VM is Pinned to host
						#$oVM.cpu.mode = "host_passthrough"
					IF($TemplateSpecsCpuTopology){Add-Member -NotePropertyName "topology" -NotePropertyValue $TemplateSpecsCpuTopology -inputObject $TemplateSpecsCpu}
					IF($CpuType){Add-Member -NotePropertyName "architecture" -NotePropertyValue $CpuType -inputObject $TemplateSpecsCpu}
					IF(($VMType -eq "high_performance") -AND ($MigrationMode -eq 'pinned')){
						#Disabled migration
						IF($PSBoundParameters['PassThroughHostCPU'] -eq $True){
							Add-Member -NotePropertyName "mode" -NotePropertyValue "host_passthrough" -inputObject $TemplateSpecsCpu
						}Else{
							Add-Member -NotePropertyName "mode" -NotePropertyValue "" -inputObject $TemplateSpecsCpu
						}
					}Else{
						Add-Member -NotePropertyName "mode" -NotePropertyValue "" -inputObject $TemplateSpecsCpu
					}
				}

				IF(($CpuProfile) -or ($CpuProfileId)){
