Function Get-oCpuUnit{
	<#
		.SYNOPSIS
			This function retrieves the oCpuUnit(s) for an oHost on an oVirt Server system.
			PipedObject should be type(s) oHost.
		.DESCRIPTION
			This function retrieves the oCpuUnit(s) for an oHost on a oVirt Server system.
			Returns a set of oCpuUnit(s) for an oHost that correspond to the filter criteria provided by the function parameters.
			This function accepts piped object types: oHost
		.PARAMETER Syncopate
			Switch to Syncopate (truncate/abridge) returned data set
		.EXAMPLE
			PS> Get-oHost -oVirtServerName $oVirtServerName | Get-oCpuUnit
				Returns the oCpuUnit(s) on oHost(s)
		.EXAMPLE
			$oCpuUnits = Get-oHost | Get-oCpuUnit
		.EXAMPLE
			$oCpuUnits = $oHost | Get-oCpuUnit
		.EXAMPLE
			$oCpuUnits = $oHost | Get-oCpuUnit | Where-Object {$_.vms}
			Returns only Cpus with Pinned VMs
		.EXAMPLE
			$oCpuUnits = $oHost | Get-oCpuUnit | Where-Object {$_.vms}
			ForEach($VM in ($oCpuUnits.vms.vm | Sort -u id)){
				[PSCustomObject]@{
					VM = $VM.Name
					cpu_pinning_policy = $VM.cpu_pinning_policy
					cpu_id = ($oCpuUnits | ?{$_.vms.vm.id -eq $VM.Id}).cpu_id -join ','
				}
			}
		.INPUTS
			[oHost]
		.OUTPUTS
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		9/2/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#Generic Input to facilitate Piping between Functions
		[Parameter(Mandatory, ValueFromPipeline, ValueFromPipelineByPropertyName, ParameterSetName="Solo", DontShow)]$PipedObject,
		
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#Secondary Only Object, receives: oHost
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Process"
		<#
		$oVxObjectName = "oCpuUnit"
		$oVxObjectName = "$((($MyInvocation.MyCommand) -Split('-'))[1])"
		
		IF($PSBoundParameters | ?{!$_.PipedObject}){$ParametersToSend = $PSBoundParameters}Else{$ParametersToSend = @{}}
		$ParametersToSend.Add("oVxObjectName",$oVxObjectName)
		IF($PSBoundParameters['PipedObject']){$ParametersToSend.Add("ParentUid",$PSBoundParameters['PipedObject'].Uid);$ParametersToSend.Add("oVirtServerName",$PSBoundParameters['PipedObject'].oVirtServer)}
		Write-Verbose "$($MyInvocation.MyCommand): `$ParametersToSend : $($ParametersToSend | Out-String)"
		Get-oVirtObject @ParametersToSend
		#>
		
		IF($PSBoundParameters['PipedObject']){
			(Get-oUri -RESTUri (($PSBoundParameters['PipedObject']).Link | ?{$_.rel -eq "cpuunits"}).href -oVirtServerName ($PSBoundParameters['PipedObject']).oVirtServer -Method GET).host_cpu_unit | Sort {[int]($_.socket_id -replace '(\d+).*', '$1')}, {[int]($_.cpu_id -replace '(\d+).*', '$1')} | Select socket_id, core_id, cpu_id, vms
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

