						#I'm concerned this might return many oVNicProfiles with the same names	
						#$AvailableoVNicProfiles = ((Get-oUri -RESTUri "/ovirt-engine/api/vnicprofiles?search=$($oVNicProfile)" -oVirtServerName $oVirtServerName).vnic_profile | ?{$_.Name -eq $oVNicProfile}) #Faster
