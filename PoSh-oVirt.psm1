#XML/JSON conversions
Function Convert-PSCustomObjectToXMLString{
	<#
		.SYNOPSIS
			This function converts a PSCustomObject To and XMLString
		.DESCRIPTION
			This function converts a PSCustomObject To and XMLString
		.PARAMETER PSCustomObject
		.PARAMETER RootName
		.PARAMETER RecursionDepth
			Default is 20
		.EXAMPLE
			PS> Convert-PSCustomObjectToXMLString -PSCustomObject $PSCustomObject -RootName "RootName" -RecursionDepth = 25
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCustomObject]
			[INT]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/14/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,Position=0)]
			[System.Management.Automation.PSObject]$PSCustomObject,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$RootName,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT]$RecursionDepth = 20
	)
	<#
		[byte][char]'a'
		[char]97
	#>
	$CurrentRecursionDepth = @(Get-PSCallStack).count
	IF($CurrentRecursionDepth -gt $RecursionDepth){BREAK}
	#Write-Host -fore cyan "RecursionDepth: $($CurrentRecursionDepth)"
	IF(($RootName) -AND ($CurrentRecursionDepth -eq 2)){"<$($RootName)>"}
	ForEach($Item in ($PSCustomObject.psobject.Members|?{$_.MemberType -Match "Property"}|?{$_.value -ne $Null})){
		IF($Item.TypeNameofValue -eq "System.Management.Automation.PSCustomObject"){
			#"$(1..$($CurrentRecursionDepth) | %{"$([char]32)"})<$($Item.Name)>"
			"<$($Item.Name)>"
			Convert-PSCustomObjectToXMLString -PSCustomObject $PSCustomObject."$($Item.Name)" -RecursionDepth $RecursionDepth
			#"$(1..$($CurrentRecursionDepth) | %{"$([char]32)"})</$($Item.Name)>"
			"</$($Item.Name)>"
		}Else{
			#"$(1..$($CurrentRecursionDepth) | %{"$([char]32)"})<$($Item.Name)>$($Item.Value)</$($Item.Name)>"
			"<$($Item.Name)>$($Item.Value)</$($Item.Name)>"
		}
	}
	IF(($RootName) -AND ($CurrentRecursionDepth -eq 2)){"</$($RootName)>"}
}

Function Convert-RestResponseTooVirtObject{
	<#
		.SYNOPSIS
			This function converts a new REST API oVirt Object from an oVirt system into the correct Class Object
		.DESCRIPTION
			This function converts a new REST API oVirt Object from an oVirt system into the correct Class Object
		.PARAMETER InputObject
		.PARAMETER ObjectType
		.EXAMPLE
			PS> Convert-RestResponseTooVirtObject -InputObject $oVxObjects -ObjectType "oCluster" -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCustomObject]
		.OUTPUTS
			[oVObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/14/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding()]
	Param(
		#InputObject
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,Position=0)]
			[Alias('IO')]
			#[System.Array[]]$InputObject,
			[System.Management.Automation.PSObject]$InputObject,
		#ObjectType
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("oAffinityGroup","oAffinityLabel","oBackup","oBalance","oBookmark","oCdRom","oCertificate","oCheckPoint","oCluster","oClusterFeature","oClusterLevel","oComputeResource","oCpuProfile","oDataCenter","oDevice","oDiscoveredHost","oDiskAttachment","oDisk","oDiskProfile","oDiskSnapshot","oDomain","oEnabledFeature","oEvent","oExternalHostProvider","oFenceAgent","oFile","oFilter","oGlusterBrick","oGlusterHook","oGlusterVolume","oGraphicsConsole","oExternalNetworkProvider","oExternalNetworkProviderConfiguration","oGroup","oHook","oHost","oVMHostDevice","oHostGroup","oHostLabel","oHostNic","oHostNumaNode","oIcon","oImage","oInstanceType","oiScsiBond","oJob","oLinkLayerDiscoveryProtocolElement","oMacPool","oManagementNetwork","oNetwork","oNetworkAttachment","oNetworkFilter","oNetworkFilterParameter","oNetworkLabel","oNic","oOpenStackImageProvider","oOpenStackNetworkProvider","oOperatingSystem","oOption","oPermission","oPermit","oQoS","oQuota","oQuotaClusterLimit","oRole","oSchedulingPolicy","oSchedulingPolicyUnit","oSnapShot","oStatistic","oStep","oStorageDomain","oStorageConnection","oStorageServerConnection","oStorageConnectionExtension","oTag","oTemplate","oUnmanagedNetwork","oUser","oVirt","oVirtualFunctionAllowedLabel","oVirtualFunctionAllowedNetwork","oVM","oVMApplication","oVmLabel","oVmNic","oVMNumaNode","oVmPool","oVnicProfile","oVolumeType","oWatchDog","oWeight")]
			[Alias('OT')]
			[System.String]$ObjectType,
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		$oVxObject = $PSBoundParameters['InputObject']
		$TypeName = $PSBoundParameters['ObjectType']
		$Port = "443"
		$oVxOutPutObject = New-Object -TypeName $TypeName
		Write-Verbose "$($MyInvocation.MyCommand) `$ObjectType: [$($TypeName)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$oVxObject Type: [$(($oVxObject).GetType().Name)]"
		Write-Verbose "Get-$($oVxObjectName): oVxOutPutObject [$((($oVxOutPutObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name) -join ', '))]"
		$oVxObject | %{$_ | Add-Member -MemberType NoteProperty -Name oVirtServer -Value $oVirtServerName -Force}
		#$oVxObject | %{$_ | Add-Member -MemberType NoteProperty -Name Uid -Value "https://$($oVirtServerName):$($Port)$($_.href)"}
		IF($TypeName -eq "oVirt"){
			$oVxObject | %{$_ | Add-Member -MemberType NoteProperty -Name Uid -Value "https://$($oVirtServerName):$($Port)/ovirt-engine/api"}
		}Else{
			$oVxObject | %{$_ | Add-Member -MemberType NoteProperty -Name Uid -Value "https://$($oVirtServerName):$($Port)$($_.href)"}
		}
		Write-Verbose "Get-$($oVxObjectName): oVxObject [$((($oVxObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name) -join ', '))]"
		$oVxObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name | %{$oVxOutPutObject.$_ =  $oVxObject.$_}
		Write-Verbose "$($MyInvocation.MyCommand) `$oVxOutPutObject Type: [$(($oVxOutPutObject).GetType().Name)]"
		$oVxOutPutObject
	}
	End{}
}

#Helper Function, if web requests need to be retrieved as XML (This module uses JSON as preferred method)
Function Convert-XMLtoPSObject{
	<#
		.SYNOPSIS
			This function converts a XML to a PSObject
		.DESCRIPTION
			This function converts a XML to a PSObject
		.PARAMETER XML
	#>
	Param(
		$XML
	)
	$Return = New-Object -TypeName PSCustomObject
	ForEach($Property in ($XML | Get-Member -MemberType Property | Where-Object {$_.MemberType -EQ "Property"})){
		IF ($Property.Definition -Match "^\bstring\b.*$"){
			$Return | Add-Member -MemberType NoteProperty -Name $($Property.Name) -Value $($XML.($Property.Name))
		}ElseIf($Property.Definition -Match "^\System.Xml.XmlElement\b.*$"){
			$Return | Add-Member -MemberType NoteProperty -Name $($Property.Name) -Value $(Convert-XMLtoPSObject -XML $($XML.($Property.Name)))
		}ElseIf($Property.Definition -Match "^\System.Object\b.*$"){
			$PropertyArray = [System.Collections.ArrayList]@()
			ForEach($Item in $($XML.($Property.Name))){
				$PropertyArray.Add(($Item | Select -Property ($Item | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name))) | Out-Null
			}
			$Return | Add-Member -MemberType NoteProperty -Name $($Property.Name) -Value $PropertyArray
		}Else{
			Write-Host -Fore Yellow "`tUnrecognized Type: $($_.Name)='$($_.Definition)'"
		}
	}
	$Return
}

Function Get-oVirtObject{
	<#
		.SYNOPSIS
