					Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxObject [$($oVxObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name)]"
					Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxObject [$($oVxObject | Select * | Out-String)]"
					$oVxObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name | %{$oVxOutPutObject.$_ =  $oVxObject.$_}
					$oVxOutPutObjects.Add($oVxOutPutObject) | Out-Null
				 }
				 IF($oVxOutPutObjects.Count -eq 1){$oVxOutPutObjects = $oVxOutPutObjects[0]}
			}
			Write-Verbose "$($MyInvocation.MyCommand): PipedObject [$($PipedObject | Out-String)]"
			Return $oVxOutPutObjects | Sort Name
		}Else{
			$oVirtConnectionsToProcess = $Null
			$ProvidedConnectionParams = $Null; $ProvidedConnectionParams = ($PSBoundParameters.GetEnumerator() | ?{($_.Key -eq "oVirtServerName")}).Value | %{ @{"oVirtServerName"=$_}}
			Write-Verbose "$($MyInvocation.MyCommand): ProvidedConnectionParams: [$($ProvidedConnectionParams | Out-String)]"
			IF($ProvidedConnectionParams){$oVirtConnectionsToProcess = Resolve-oVirtConnection @ProvidedConnectionParams -ErrorAction SilentlyContinue}Else{$oVirtConnectionsToProcess = Resolve-oVirtConnection -ErrorAction SilentlyContinue}
			Write-Verbose "$($MyInvocation.MyCommand): oVirtConnectionsToProcess: [$($oVirtConnectionsToProcess | Out-String)]"
			
			#Loop Through $oVirtConnectionsToProcess in the Process section
			IF($oVirtConnectionsToProcess){
				$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
				ForEach($oVirtConnection in $oVirtConnectionsToProcess){
					$oVirtServerName = $oVirtConnection.oVirtServerName
					IF($PSBoundParameters['ParentUid']){					
						IF($($PSBoundParameters['ParentUid']).Host -ne $oVirtServerName){CONTINUE}
						$URI = "$(($PSBoundParameters['ParentUid']).OriginalString)/$($WebObjectPluralName)"
					}Else{
						$URI = "https://$($oVirtServerName)/ovirt-engine/api/$($WebObjectPluralName)"
					}
					
					#Need to ReRun Resolve-oVirtConnection just prior to the lookup, to minimize oVirtConnections timing out while previous servers process
					Resolve-oVirtConnection -oVirtServerName $oVirtConnection.Name -ErrorAction SilentlyContinue | Out-Null
					#Can Return via XML or JSON
					#$ReturnDataType = "xml"
					#$ReturnDataType = "json"
					#$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtToken.AccessToken)"; "All-Content"="true"}
					IF(($Syncopate).IsPresent -eq $True){
						$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtConnection.AccessToken)"}
					}Else{
						$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtConnection.AccessToken)"; "All-Content"="true"}
					}
					Write-Verbose "$($MyInvocation.MyCommand): Base URI [$($URI)]"
					Write-Verbose "$($MyInvocation.MyCommand): Headers [$($Headers | Out-String)]"
					
					IF($oVxName -OR $oVxId){
						Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Name or Id provided, running 'Process-oVxName' sub function"
						Function Process-oVxName{
							Param(
								$oName,
								$oID
							)
							Write-Verbose "Process-oVxName: Running"
