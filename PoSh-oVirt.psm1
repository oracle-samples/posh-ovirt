#Needs work to pre-filter better
<#
SR 3-37721612141 : oVirt REST API, how to return events by Date/Time Range
	Enhancement request : 36952396
	https://bug.oraclecorp.com/pls/bug/webbug_print.show?c_rptno=36952396
		/ovirt-engine/api/events?search=time%3E%3D2024-12-10T17%3A02%3A18.612Z%26time%3C%3D2024-12-13T17%3A02%3A18.612Z <-FAILS
#>
Function Get-oEvent{
	<#
		.SYNOPSIS
			This function retrieves the Event on an oVirt Server system.
		.DESCRIPTION
			This function retrieves the Event on a oVirt Server system.
			Returns a set of Event that correspond to the filter criteria provided by the function parameters.
			
			The order of the returned list of events is always garanteed. If the sortby clause is included in the search parameter, 
			then the events will be ordered according to that clause. If the sortby clause isn't included, then the events will be 
			sorted by the numeric value of the id attribute, starting with the highest value. This, combined with the max parameter, 
			simplifies obtaining the most recent event.
			
			GET /ovirt-engine/api/events?max=1
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/events/methods/list/parameters/from
			GET /ovirt-engine/api/events?from=123
			GET /ovirt-engine/api/events?search=severity%3Dnormal
			Below example paginates event resources. The URL-encoded request is:
				GET /ovirt-engine/api/events?search=sortby%20time%20asc%20page%201
			Increase the page value to view the next page of results.
				GET /ovirt-engine/api/events?search=sortby%20time%20asc%20page%202
				#[System.Web.HttpUtility]::UrlEncode('&')
			GET /ovirt-engine/api/vms?search=page%201&max=10
			GET /ovirt-engine/api/vms?search=name%3D=myvm&case_sensitive=true
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#_search_syntax
			The search parameters use the same syntax as the oVirt query language:
				(criteria) [sortby (element) asc|desc]
			GET /ovirt-engine/api/vms/123?follow=disk_attachments,nics
				
		.PARAMETER SearchText
			The Search Text to filter oEvent(s)
			Can use Wildcard '*'
				I.e. MyNI*
		.PARAMETER SearchField
			The Field(s) to apply the 'SearchText'
		.PARAMETER CaseSensitive
			Switch to search Case Sensitive oEvent name(s)
			By default queries are not case sensitive
		.PARAMETER Id
			The Id(s) of Event(s)
		.PARAMETER CorrelationId
			The Id of a Correlating Event
		.PARAMETER AfterUTC
			UTC DateTime to retrieve events occuring after and filter out events occuring before
			Be careful not to over filter if using with 'Time' and/or 'BeforeUTC'
		.PARAMETER BeforeUTC
			UTC DateTime to retrieve events occuring before and filter out events occuring after
			Be careful not to over filter if using with 'Time' and/or 'AfterUTC'
		.PARAMETER CustomQueryString
			Custom Search string to replace all other input params
			Use the UI Events Search window, enter a single space to populate suggestions for syntax to use here
			Examples:
				"?search=time%20>%20Monday%20and%20<Wednesday"
				"?search=Vms.on_host%20=%20myhostname"
				"?search=Clusters = LS5VDA01"
				"?search=Clusters.name = LS5VDA01"
		.PARAMETER Pagination
			Returns the specific page of items when a large set would typically be Returned
			Increase the page value to retrieve the next page
			
			The page clause can be used in conjunction with other clauses inside the search parameter.
			For example, the following request will return the second page of virtual machines, but sorting by name:
				/ovirt-engine/api/vms?search=sortby%20name%20page%202&max=10
			The API is stateless; it is not possible to retain a state between different requests since all requests are independent 
				from each other. As a result, if a status change occurs between your requests, then the page results may be inconsistent.
			For example, if you request a specific page from a list of virtual machines, and virtual machines are created or removed 
				before you request the next page, then your results may be missing some of them, or contain duplicates.
		.PARAMETER MaxEvents
			Use the max parameter to limit the number of objects returned.
			The request will only return the number of oEvent(s), regardless of how many are available in the system
			Sets the maximum number of events to return. If not specified all the events are returned.
		.PARAMETER From
			Indicates the event index after which events should be returned.
			The indexes of events are strictly increasing, so when this parameter is used only the events with greater indexes will 
			be returned.
			This parameter is optional, and if not specified then the first event returned will be most recently generated.
		.PARAMETER Severity
			The event severity level
			Valid options "alert","error","normal","warning"
				Alert severity. Used to specify a condition that requires an immediate attention.
				Error severity. Used to specify that there is an error that needs to be examined.
				Normal severity. Used for information events.
				Warning severity. Used to warn something might be wrong.
		.PARAMETER SortBy
			Sort Returned oEvents by Field
			Valid options "time","code","comment","custom_data","custom_id","data_center","description","host","storage_domain","template","time","user","vm"
		.PARAMETER SortOrder
			Sort Order, used with above "sortBy" Parameter
			Valid options "asc","desc"
		.PARAMETER Time
			One or more preformatted Time filter parameters can be used together to get the most recent oEvents occuring within the last 7 days
			Valid Options '> today','> yesterday','> Monday','> Tuesday','> Wednesday','> Thursday','> Friday','> Saturday','> Sunday','= today','= yesterday','= Monday','= Tuesday','= Wednesday','= Thursday','= Friday','= Saturday','= Sunday','< today','< yesterday','< Monday','< Tuesday','< Wednesday','< Thursday','< Friday','< Saturday','< Sunday'
			I.e. -Time '> Monday' '< Wednesday'
				Would only include the oEvents between the most recent Monday and Wednesday
			Note: today and yesterday may be required instead of the current day names
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
			If not provided the first oVirtServerName in the oVirtConnections Dictionary will be used
		.EXAMPLE
			PS> Get-oEvent -oVirtServerName $oVirtServerName
			Gets ALL oEvents, may take a while (and I mean a loooong while, might even time on anything more than a small installation)
		.EXAMPLE
			PS> Get-oEvent -oVirtServerName $oVirtServerName -Severity "warning"
				Returns the oEvent(s) of Severity level "warning"
		.EXAMPLE
			PS> Get-oEvent -oVirtServerName $oVirtServerName -Id $oEventId
			Retrieves a specific oEvent by Id
		.EXAMPLE
			PS> Get-oEvent -oVirtServerName $oVirtServerName -SearchText "cluster001" -SearchField "cluster"
			Gets oEvents where the cluster name equals "cluster001"
		.EXAMPLE
			PS> Get-oEvent -oVirtServerName $oVirtServerName -SearchText "cluster001" -SearchField "cluster","message"
			Gets oEvents where the cluster name or the description (message) field equals "cluster001"
		.EXAMPLE
			PS> $oEvents = Get-oEvent -oVirtServerName $oVirtServerName -MaxEvents 1 -SearchText "*MySamAccountName*" -SearchField message
			Searches the description (message) field matches MySamAccountName, using asterisks to denote wild card matches 
		.EXAMPLE
			PS> Get-oEvent -Time '> Monday', '< yesterday'
			Gets oEvents where the date is more recent than Monday and prior to yesterday
			Be careful not to over filter if using with 'AfterUTC' and/or 'BeforeUTC'
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oEvent]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/22/2024
			Version 1.0b	8/15/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/event
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/event
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#Search Text
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[Alias('ST')]
			[System.String]$SearchText,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidateSet("cluster","code","comment","custom_data","custom_id","data_center","message","host.name","id","model","name","storage_domain","template","time","user","version","vm.name")]
			[Alias('SF')]
			[System.String[]]$SearchField,
		#Switch to search Case Sensitive oEvent name(s)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
			[Alias('CS')]
			[SWITCH]$CaseSensitive,
	
		#oEventId
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('I')]
			[System.String]$Id,
		
		#oEventId
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set04")]
			[Alias('CI')]
			[System.String]$CorrelationId, #correlation_id
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.DateTime]$AfterUTC,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.DateTime]$BeforeUTC,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set05")]
			[Alias('Q')]
			[System.String]$CustomQueryString,
		
		#Pagination
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#_pagination
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT32]$Pagination,
		
		#The Maximum number of events to return
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT64]$MaxEvents,
		
		#Event ID to search from
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT64]$From,
		
		#Search By Severity  GET /ovirt-engine/api/events?search=severity%3Dnormal
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet('alert','error','normal','warning')]
			[System.String]$Severity,
		
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("time","code","comment","custom_data","custom_id","data_center","description","host","storage_domain","template","time","user","vm")]
			[Alias('SB')]
			[System.String]$SortBy,
			
		#(criteria) [sortby (element) asc|desc]
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("asc","desc")]
			[Alias('SO')]
			[System.String]$SortOrder,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet('> today','> yesterday','> Monday','> Tuesday','> Wednesday','> Thursday','> Friday','> Saturday','> Sunday','= today','= yesterday','= Monday','= Tuesday','= Wednesday','= Thursday','= Friday','= Saturday','= Sunday','< today','< yesterday','< Monday','< Tuesday','< Wednesday','< Thursday','< Friday','< Saturday','< Sunday')]
			[System.String[]]$Time,
				
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
		#Generic Input to facilitate Piping between Functions
		[Parameter(ValueFromPipeline, ValueFromPipelineByPropertyName, ParameterSetName="Solo", DontShow)]$PipedObject
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Process"
		$oVxObjectName = "oEvent"
		$oVxObjectName = "$((($MyInvocation.MyCommand) -Split('-'))[1])"
		
		IF($oVxObjectName){
			$WebObjectPluralName = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).WebObjectPluralName
			$WebObjectSingularName = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).WebObjectSingularName
			$TypeName = $oVxObjectName
			$PipedObjectTypesAccepted = ($oVxObjectLookupArray | ?{$_.oVxObjectName -eq $oVxObjectName}).ParentObjectTypesAllowed
		}

		$OutPutItems = [System.Collections.ArrayList]@()
		$BaseURL = "https://$($oVirtServerName)"
		Write-Verbose "$($MyInvocation.MyCommand): Base URI [$($BaseURL)]"
		$Uri = $BaseURL + "/ovirt-engine/api/events"
		
		#/ovirt-engine/api/events;from={event_id}?search={query} events/search
		#The search parameters use the same syntax as the oVirt query language:
		#(criteria) [sortby (element) asc|desc]
		#The sortby clause is optional and only needed when ordering results.
		#events
			#severity > normal sortby time
			#Returns a list of all events with severity higher than normal and sorted by the the value of their time attribute.
		#events
			#severity > normal sortby time desc
			#Returns a list of all events with severity higher than normal and sorted by the the value of their time attribute in descending order.
		#The value of the search parameter must be URL-encoded to translate reserved characters, such as operators and spaces. For example, the equal sign should be encoded as %3D:
			#GET /ovirt-engine/api/vms?search=name%3Dmyvm
		#The asterisk can be used as part of a value, to indicate that any string matches, including the emtpy string.
			#/ovirt-engine/api/vms?search=name%3Dmyvm*
		#It IS supposed to be possibile to use stand concatinated query strings
			#/ovirt-engine/api/vms?search=sortby%20name%20page%202&max=10
		#$Uri = $BaseURL + "/ovirt-engine/api/events"
		$QueryString = $Null
		IF($PSBoundParameters['SearchField']){
			IF($PSBoundParameters['SearchText']){
				ForEach($Item in $PSBoundParameters['SearchField']){
					IF($QueryString){$QueryString = $QueryString + "&"}
					$QueryString = $QueryString + "$($Item)%3D$($($PSBoundParameters['SearchText']))"
				}
			}
			IF(($PSBoundParameters['CaseSensitive']).IsPresent -eq $True){
				IF($QueryString){$QueryString = $QueryString + "&case_sensitive=true"}
			}
		}
		
		IF($PSBoundParameters['CorrelationId']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			$QueryString = $QueryString + "Correlation_id%3D$($CorrelationId)"
		}
		IF($PSBoundParameters['Id']){
			$Uri = $Uri + "/$($Id)"
		}
		
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#_pagination
		#/ovirt-engine/api/vms?search=page%201&max=10
		#The search parameter is URL-encoded, the actual value of the search parameter, before encoding, is page 1, so this is actually requesting the first page.
		#Increase the page value to retrieve the next page:
		#/ovirt-engine/api/vms?search=page%202&max=10
		#The page clause can be used in conjunction with other clauses inside the search parameter. For example, the following request will return the second page of virtual machines, but sorting by name:
		#/ovirt-engine/api/vms?search=sortby%20name%20page%202&max=10
		#The API is stateless; it is not possible to retain a state between different requests since all requests are independent from each other. As a result, if a status change occurs between your requests, then the page results may be inconsistent.
		#For example, if you request a specific page from a list of virtual machines, and virtual machines are created or removed before you request the next page, then your results may be missing some of them, or contain duplicates.
		IF($PSBoundParameters['Pagination']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			$QueryString = $QueryString + "page%20$($Pagination)"
		}
		
		#/ovirt-engine/api/events?from=123
		IF($PSBoundParameters['From']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			$QueryString = $QueryString + "from%3D$($From)"
		}
		
		#/ovirt-engine/api/events?search=severity%3Dnormal
		IF($PSBoundParameters['Severity']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			$QueryString = $QueryString + "severity%3D$($Severity)"
		}
		
		IF($PSBoundParameters['Time']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			ForEach($Item in $($PSBoundParameters['Time'])){
				IF((([ARRAY]::IndexOf($($PSBoundParameters['Time']),$Item)) -eq 0) -AND (($PSBoundParameters['Time']).count -eq 1)){
					$QueryString = $QueryString + "time%20$($Item)"
				}ElseIF(([ARRAY]::IndexOf($($PSBoundParameters['Time']),$Item)) -lt (($PSBoundParameters['Time']).count - 1)){
					$QueryString = $QueryString + "time%20$($Item)%20and%20"
				}Else{
					$QueryString = $QueryString + "time%20$($Item)"
				}
			}
		}
		
		#sortby time asc page 1
		#/ovirt-engine/api/events?search=sortby%20time%20asc%20page%201
		IF($PSBoundParameters['SortBy']){
			IF($PSBoundParameters['SortOrder']){
				IF($QueryString){$QueryString = $QueryString + "&"}
				$QueryString = $QueryString + "sortby%20$($SortBy)%20$($SortOrder)"
			}
		}
		#/ovirt-engine/api/events?max=1
		IF($PSBoundParameters['MaxEvents']){
			IF($QueryString){$QueryString = $QueryString + "&"}
			$QueryString = $QueryString + "max=$($MaxEvents)"
		}
		
		IF($PSBoundParameters['PipedObject']){}
		IF($QueryString){
			IF((!($PSBoundParameters['SearchField'])) -AND ($PSBoundParameters['SearchText'])){
				$Uri = $Uri + "?search=" + "$($SearchText)" + $QueryString
			}Else{
				IF( (($PSBoundParameters['SortBy']) -AND ($PSBoundParameters['SortOrder'])) -OR ($PSBoundParameters['From']) -OR ($PSBoundParameters['Severity']) -OR (($PSBoundParameters['SearchField']) -AND ($PSBoundParameters['SearchText']))){
					$Uri = $Uri + "?search=" + $QueryString
				}Else{
					$Uri = $Uri + "?" + $QueryString
				}
			}
		}Else{
			IF((!($PSBoundParameters['SearchField'])) -AND ($PSBoundParameters['SearchText'])){
				$Uri = $Uri + "?search=" + "$($SearchText)"
			}
		}
		IF($PSBoundParameters['CustomQueryString']){
			$Uri = $BaseURL + "/ovirt-engine/api/events" + $PSBoundParameters['CustomQueryString']
		}
		$Method = "GET"
		#Send to Server
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token))"; "All-Content"="true"}
		Write-Verbose "$($MyInvocation.MyCommand): Headers [$($Headers | Out-String)]"
		Write-Verbose "$($MyInvocation.MyCommand): URI [$($URI)]"
		Write-Debug "$($MyInvocation.MyCommand): URI [$($URI)]"
		TRY{$ReTrievedoEvent = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($ReTrievedoEvent){
			$global:ReTrievedoEvent = $ReTrievedoEvent
			Write-Verbose "$($MyInvocation.MyCommand): Retrieved oEvent(s)"
			IF($ReTrievedoEvent.Event){
				$oVxObjects = $ReTrievedoEvent.Event
			}Else{
				$oVxObjects = $ReTrievedoEvent
			}
			IF($PSBoundParameters['AfterUTC']){
				$EpochTime = $(Convert-ToEpochTime $PSBoundParameters['AfterUTC'])
				$oVxObjects = $oVxObjects | ?{$_.time -gt $EpochTime}
			}
			IF($PSBoundParameters['BeforeUTC']){
				$EpochTime = $(Convert-ToEpochTime $PSBoundParameters['BeforeUTC'])
				$oVxObjects = $oVxObjects | ?{$_.time -lt $EpochTime}
			}
			ForEach($Item in ($oVxObjects | ?{$_.id})){
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $Item -ObjectType "oEvent" -oVirtServerName $oVirtServerName)) | Out-Null
			}
		}Else{
			Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End";IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

