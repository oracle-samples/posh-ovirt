							$AvailableISOImages = $oVMStorageDomainISOs
								
							IF((!($BootCDImageId)) -AND $BootCDImage){$BootCDImageId = ($AvailableISOImages | ?{$_.Name -eq $BootCDImage}).Id}
							IF($BootCDImageId){
								$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{id = $BootCDImageId}}
								#$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{name = $BootCDImage}} #No GO on Attach
								Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecCDROM"
								Write-Verbose "$($VMSpecCDROM | Out-String)"
								#Disabling for efficiency, might need to restore this check if too many failures
								#Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
								$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
								$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								#This is the boot settings and not active (live status)
								$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/cdroms/$($ExistingAttachedCD.Id)"
								$Method = "PUT"
								$JsonBody = $VMSpecCDROM | ConvertTo-Json -Depth 50
								#$JsonBody | ConvertFrom-Json2Xml
								#($VMSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
								Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create CDROM Attachment"
								Write-Verbose "$($JsonBody | Out-String)"
								$UpdatedCDROM = $Null; $UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError
								IF($UpdatedCDROM){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
							}Else{Write-Warning "CDROM Image [$($BootCDImage)] not found"}
						}
					}ElseIF($AttachCD -eq 'StartDisConnected'){
						#Remove ISO from Virtual CDROM
						#Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
						$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						$Method = "PUT"
						#This is the boot settings and not active (live status)
						$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/cdroms/$($ExistingAttachedCD.Id)"
						$XMLString = '<cdrom><file id=""/></cdrom>'
						Write-Verbose "$($MyInvocation.MyCommand): Submitting XML to Remove ISO from CD"
						Write-Verbose "$($XMLSring | Out-String)"
						$UpdatedCDROM = $Null; $UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $XMLString -ContentType "application/xml" -EV WebError
						IF($UpdatedCDROM){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}

					IF($ChangeCD -eq 'Connect'){
						IF($ActiveCDImage -or $ActiveCDImageId){
							#Get ALL Available ISO files
							#$AvailableISOImages = (((Get-oUri -RESTUri /ovirt-engine/api/storagedomains -oVirtServerName $oVirtServerName).storage_domain.link | ?{$_.rel -eq "disks"}).href | %{Get-oUri -RESTUri $_ -oVirtServerName $oVirtServerName}).disk | ?{$_.content_type -eq "iso"}
							#Do I need to only get ISOs from storage Domains in same cluster(or datacenter) as VM? Probably should
							$oVMCluster = (Get-oUri -RESTUri $UpdatedVM.cluster.href -oVirtServerName $oVirtServerName)
							$oVMDataCenter = (Get-oUri -RESTUri $oVMCluster.data_center.href -oVirtServerName $oVirtServerName)
							$oVMStorageDomains = (Get-oUri -RESTUri ($oVMDataCenter.link | ?{$_.rel -eq "storagedomains"}).href -oVirtServerName $oVirtServerName).storage_domain
							$oVMStorageDomainISOs = ($oVMStorageDomains.link | ?{$_.rel -eq "disks"}).href | %{(Get-oUri -RESTUri $_ -oVirtServerName $oVirtServerName).disk | ?{$_.content_type -eq "iso"}}
							#$oVMStorageDomainISOs | Select Name, ID, content_type, provisioned_size, shareable | FT
							$AvailableISOImages = $oVMStorageDomainISOs
								
							IF((!($ActiveCDImageId)) -AND $ActiveCDImage){$ActiveCDImageId = ($AvailableISOImages | ?{$_.Name -eq $ActiveCDImage}).Id}
							IF($ActiveCDImageId){
								$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{id = $ActiveCDImageId}}
								#$VMSpecCDROM = [PSCustomObject]@{file = [PSCustomObject]@{name = $ActiveCDImage}} #No GO on Attach
								Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecCDROM"
								Write-Verbose "$($VMSpecCDROM | Out-String)"
								#Disabling for efficiency, might need to restore this check if too many failures
								#Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
								$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
								$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								#This is for live CD access NOT Boot settings
								#The changes made with the current=true parameter are never persisted, so they won’t have any effect after the virtual machine is rebooted.
								$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/cdroms/$($ExistingAttachedCD.Id)?current=true"
								
								$Method = "PUT"
								$JsonBody = $VMSpecCDROM | ConvertTo-Json -Depth 50
								#$JsonBody | ConvertFrom-Json2Xml
								#($VMSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
								Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Load Active CDROM"
								Write-Verbose "$($JsonBody | Out-String)"
								$UpdatedCDROM = $Null; $UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError
								IF($UpdatedCDROM){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
							}Else{
								Write-Warning "CDROM Image [$($ActiveCDImage)] not found"
							}
						}
					}ElseIF($ChangeCD -eq 'Eject'){
						#Remove ISO from Virtual CDROM
						#Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
						$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
						$Method = "PUT"
						$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/cdroms/$($ExistingAttachedCD.Id)?current=true"
						$XMLString = '<cdrom><file id=""/></cdrom>'
						Write-Verbose "$($MyInvocation.MyCommand): Submitting XML to Eject ISO from CD"
						Write-Verbose "$($XMLSring | Out-String)"
						$UpdatedCDROM = $Null; $UpdatedCDROM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $XMLString -ContentType "application/xml" -EV WebError
						IF($UpdatedCDROM){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}

					#endregion SetVMCD

					#region SetVMWatchdog
					
					IF($WatchDogModel){
						#Does a Watchdog exist that needs modified, or a new one created?
						$ExistingWatchDog = $Null
						$ExistingWatchDog = (Get-oUri -RESTUri ($UpdatedVM.link | ?{$_.rel -eq "watchdogs"}).href -oVirtServerName $oVirtServerName).watchdog
						
						IF($WatchDogModel -ne "no_watchdog" ){
							$VMSpecsWatchDogs = [PSCustomObject]@{
								model = $WatchDogModel
								#comment = ''
								#description = ''
								#name = ''
								action = $WatchDogAction
							}
							Write-Verbose "$($MyInvocation.MyCommand): `$VMSpecsWatchDogs"
							Write-Verbose "$($VMSpecsWatchDogs | Out-String)"
							
							#Disabling for efficiency, might need to restore this check if too many failures
							#Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
							$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
							$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
							#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
							IF($ExistingWatchDog){
								#Update it
								$Method = "PUT"
								$Uri = $BaseURL + $ExistingWatchDog.href
							}Else{
								$Method = "POST"
								$Uri = $BaseURL + "/ovirt-engine/api/vms/$($UpdatedVM.Id)/watchdogs"
							}
								
							$JsonBody = $VMSpecsWatchDogs | ConvertTo-Json -Depth 50
							#$JsonBody | ConvertFrom-Json2Xml
							#($VMSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
							Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create WatchDog"
							Write-Verbose "$($JsonBody | Out-String)"
							$UpdatedWatchDog = $Null; $UpdatedWatchDog = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError
							IF($UpdatedWatchDog){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
						}Else{
							#Remove it
							$Method = "DELETE"
							$Uri = $BaseURL + $ExistingWatchDog.href
							Write-Verbose "$($MyInvocation.MyCommand): Removing WatchDog $($ExistingWatchDog | Out-String)"
							$RemovedWatchDog = $Null; $RemovedWatchDog = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -ContentType "application/json" -EV WebError
							IF($RemovedWatchDog){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
						}
					}

					#endregion SetVMWatchdog
				}
		
			}Else{
				#NotifyAndSkip
				Write-Warning "oVM [$($TargetoVM.Name)] is in state [$($TargetoVM.status)] and can not be modified presently"
			}
		}
		$UpdatedVM
	}
	End{}
}

Function Set-oVmPool{
	<#
		.SYNOPSIS
			This function updates an oVmPool, on an oVirt Server system.
		.DESCRIPTION
			This function updates an oVmPool, on a oVirt Server system.
			Update the virtual machine pool.
			Returns the job response from the oVirt Server.
			The name, description, size, prestarted_vms and max_user_vms attributes can be updated after the virtual machine pool has been created.
		.PARAMETER Name
			The Name(s) of oVmPool
			Can use Wildcard '*'
		.PARAMETER Id
			The Id of the oVmPool
		.PARAMETER Uid
			The Uid of the oVmPool
		.PARAMETER Comment
			The Text for the Comment field to set on the oVmPool
		.PARAMETER Description
			The Text for the Description field to set on the oVmPool
		.PARAMETER MaxUserVms
			The maximum number of virtual machines in the pool that could be assigned to a particular user.
		.PARAMETER PrestartedVms
			The system attempts to prestart the specified number of virtual machines from the pool.
		.PARAMETER size
			The number of virtual machines in the pool.
		.PARAMETER UseLatestTemplateVersion
			Indicates if virtual machines in the pool are updated to newer versions of the template the pool is based on.
		.PARAMETER oTemplate
			The Name of the parent oTemplate for the new oVmPool
		.PARAMETER oTemplaterId
			The Id of the parent oTemplate for the new oVmPool
		.PARAMETER oTemplateUid
			The Uid of the parent oTemplate for the new oVmPool
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oVmPool -oVirtServerName $oVirtServerName -Name "Name" -oCluster "oClusterName" -oTemplateUid $oTemplate.Uid -Comment 'blah'-Description 'blah'
				Creates a new oHost with the provided Name
		.INPUTS
			[System.String]
			[oCluster]
			[oTemplate]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVmPool]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pools
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pool/methods/update
		.LINK
			New-oVmPool
			Get-oVmPool
			Remove-oVmPool
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'OVA')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'String|oVmPool'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.Int32]$MaxUserVms,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.Int32]$PrestartedVms,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.Int32]$Size,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$UseLatestTemplateVersion,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$oTemplate,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oTemplateId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oTemplateUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		
		$oVmPoolObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVmPool is String"
						#IF($PSBoundParameters['CaseSensitive'].IsPresent -eq $True){$oURI = $oURI + "&case_sensitive=true"}
						IF($PSBoundParameters['oVirtServerName']){
							$oVmPoolObjects = Get-oVmPool -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVmPoolObjects = Get-oVmPool -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVmPoolObjects){$oVmPoolObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVmPool GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVmPoolObjects = Get-oVmPool -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVmPoolObjects = Get-oVmPool -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVmPoolObjects){$oVmPoolObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVmPool]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVmPool is [oVmPool]"
						$oVmPoolObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oVmPool"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVmPool GetType equals [oVmPool]"
						$oVmPoolObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVmPool is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVmPoolObjects = Get-oVmPool -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVmPoolObjects = Get-oVmPool -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oVmPoolObjects){$oVmPoolObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oVmPoolObjects = Get-oVmPool -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVmPoolObjects){$oVmPoolObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		$oTemplateObjects = $Null
		IF($PSBoundParameters['oTemplateUid']){
			$UidUrl = [Uri]$oTemplateUid
			$oTemplateObjects = Get-oTemplate -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			IF($oTemplateObjects){$oTemplateObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oTemplateId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oTemplateObjects = Get-oTemplate -Id $PSBoundParameters['oTemplateId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
			}Else{
				$oTemplateObjects = Get-oTemplate -Id $PSBoundParameters['oTemplateId'] -EA SilentlyContinue
			}
			IF($oTemplateObjects){$oTemplateObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oTemplate']){
			SWITCH($PSBoundParameters['oTemplate']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oTemplateObjects = Get-oTemplate -Name $PSBoundParameters['oTemplate'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oTemplateObjects = Get-oTemplate -Name $PSBoundParameters['oTemplate'] -EA SilentlyContinue
					}
					IF($oTemplateObjects){$oTemplateObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oTemplateObjects = Get-oTemplate -Name $PSBoundParameters['oTemplate'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oTemplateObjects = Get-oTemplate -Name $PSBoundParameters['oTemplate'] -EA SilentlyContinue
					}
					IF($oTemplateObjects){$oTemplateObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oTemplate]}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is [oTemplate]"
					$oTemplateObjects = $PSBoundParameters['oTemplate']
				}
				{$_.GetType().Name -eq "oTemplate"}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate GetType equals [oTemplate]"
					$oTemplateObjects = $PSBoundParameters['oTemplate']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($TargetoVmPool in $oVmPoolObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoVmPool [$($TargetoVmPool.Name)]"
			$oVirtServerName = $TargetoVmPool.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
		
			$oVmPoolSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Name')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
			IF($PSBoundParameters.ContainsKey('Comment')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('MaxUserVms')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'max_user_vms' -Value $($PSBoundParameters['MaxUserVms']) }
			IF($PSBoundParameters.ContainsKey('PrestartedVms')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'prestarted_vms' -Value $($PSBoundParameters['PrestartedVms']) }
			IF($PSBoundParameters.ContainsKey('Size')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'size' -Value $($PSBoundParameters['Size']) }
			IF($PSBoundParameters['UseLatestTemplateVersion'].IsPresent -eq $True){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'use_latest_template_version' -Value $True }
			
			IF($oTemplateObjects){
				$oTemplateObject = $oTemplateObjects | Select -First 1
				$oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'template' -Value $([PSCustomObject]@{"id"=$oTemplateObject.Id})
			}
			IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){$oVmPoolSpecs = [PSCustomObject]@{async = $True}}Else{$oVmPoolSpecs = [PSCustomObject]@{async = $False}}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/vmpools/$($TargetoVmPool.Id)"
			$Method = "PUT"
			$JsonBody = $oVmPoolSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oVmPool"
			Write-Verbose "$($MyInvocation.MyCommand): Json: [$($JsonBody | Out-String)]"
			$UpdatedoVmPool = $Null
			TRY{$UpdatedoVmPool = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoVmPool){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoVmPool -ObjectType "oVmPool" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function Set-oVNicProfile{
	<#
		.SYNOPSIS
			This function updates a oVNicProfile, on an oVirt Server system.
		.DESCRIPTION
			This function updates a oVNicProfile, on a oVirt Server system.
			Please note that there is a default network filter to each VNIC profile. For more details of how the default network filter is calculated please refer to the documentation in NetworkFilters.
			This Function is a bit particular, in that the oNetwork, oNetworkFilter, oQoS, and FailoveroVNicProfile must all reside in the same oDataCenter as the intended oVNicProfile location
		.PARAMETER Name
			The Name(s) (or Object(s)) of the existing oVNicProfile(s) to update
		.PARAMETER Id
			The Id of the existing oVNicProfile(s) to update
		.PARAMETER Uid
			The Uid of the existing oVNicProfile(s) to update
		.PARAMETER oQoS
			Can Not be Set if PassThroughMode is Enabled
			Reference to the quality of service attributes to apply to the vNIC profile.
			Quality of Service attributes regulate inbound and outbound network traffic of the NIC.
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oQoSId
			Can Not be Set if PassThroughMode is Enabled
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oQoSUid
			Can Not be Set if PassThroughMode is Enabled
			Must exist in same oDataCenter as oVNicProfile
			
		.PARAMETER PassThroughMode
			Enables passthrough to an SR-IOV-enabled host NIC.
			A vNIC profile enables a NIC to be directly connected to a virtual function (VF) of an SR-IOV-enabled host NIC, if passthrough is enabled.
			The NIC will then bypass the software network virtualization and connect directly to the VF for direct device assignment.
			Passthrough cannot be enabled if the vNIC profile is already attached to a NIC.
			If a vNIC profile has passthrough enabled, qos and port_mirroring are disabled for the vNIC profile
			
			"mode"="disabled" Implemented as a virtual device.
			"mode"="enabled" Implemented as a pass-through device.
			
			'Port Mirroring,'Qos' and 'Network Filter' are not supported on passthrough profiles.
			
		.PARAMETER Migratable
			Requires PassThroughMode Enabled

			Marks whether pass_through NIC is migratable or not.
			If pass_through.mode is set to disabled this option has no meaning, and it will be considered to be true.
			If you omit this option from a request, by default, this will be set to true.
			When migrating a virtual machine, this virtual machine will be migrated only if all pass_through NICs are flagged as migratable.
		.PARAMETER FailoveroVNicProfile
			Requires PassThroughMode Enabled
			Failover vNIC profile
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER FailoveroVNicProfileId
			Requires PassThroughMode Enabled
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER FailoveroVNicProfileUid
			Requires PassThroughMode Enabled
			Must exist in same oDataCenter as oVNicProfile
		
		.PARAMETER PortMirroringEnabled
			Can Not be Set if PassThroughMode is Enabled
			Enables port mirroring.
			Port mirroring copies layer 3 network traffic on a given logical network and host to a NIC on a virtual machine.
			This virtual machine can be used for network debugging and tuning, intrusion detection, and monitoring the behavior of other virtual machines on the same host and logical network.
			The only traffic copied is internal to one logical network on one host.
			There is no increase in traffic on the network external to the host; however a virtual machine with port mirroring enabled uses more host CPU and RAM than other virtual machines.
			Port mirroring has the following limitations:
				Hot plugging a NIC with a vNIC profile that has port mirroring enabled is not supported.
				Port mirroring cannot be altered when the vNIC profile is attached to a virtual machine.
			Given the above limitations, it is recommended that you enable port mirroring on an additional, dedicated vNIC profile.
			Enabling port mirroring reduces the privacy of other network users.

		.PARAMETER CustomProperties
			Custom properties applied to the vNIC profile.
			
		.PARAMETER oNetwork
			The Name of the oNetwork (vLAN) for the existing oVNicProfile
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oNetworkId
			The Id of the oNetwork (vLAN) for the existing oVNicProfile
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oNetworkUid
			The Uid of the oNetwork (vLAN) for the existing oVNicProfile
			Must exist in same oDataCenter as oVNicProfile
		
		.PARAMETER oNetworkFilter
			The Name of the oNetworkFilter for the existing oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Reference to the top-level network filter that applies to the NICs that use this profile.
			Network filters enhance the ability to manage the network packets traffic to and from virtual machines. 
			The network filter may either contain a reference to other filters, rules for traffic filtering, or a combination of both.
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oNetworkFilterId
			The Id of the oNetworkFilter for the existing oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Must exist in same oDataCenter as oVNicProfile
		.PARAMETER oNetworkFilterUid
			The Uid of the oNetworkFilter for the existing oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Must exist in same oDataCenter as oVNicProfile
		
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			Set-oVNicProfile -Name "Existing_oVNicProfile_Name"
		.INPUTS
			[System.String]
			[oNetwork]
			[oNetworkFilter]
			[oVNicProfile]
			[oQoS]
			[System.Collections.Hashtable]
			[BOOLEAN]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVNicProfile]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/12/2024
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vnic_profile
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vnic_profile
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vnic_profiles
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_vnic_profiles
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vnic_pass_through
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			New-oVNicProfile
			Get-oVNicProfile
			Remove-oVNicProfile
			Get-Help
	#>
	#IN UI, can't change the Datacenter nor network, once created
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oVNicProfile|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03", Position=0)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$NewName, #Remeber to skip this if more than 1 oVNicProfile is targeted
		#Not observed in output nor UI
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			#[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Description,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("disabled","enabled")]
			[System.String]$PassThroughMode,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[Boolean]$Migratable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[Boolean]$PortMirroringEnabled,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({($_).GetType().Name -match 'oVNicProfile|String'})]$FailoveroVNicProfile,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$FailoveroVNicProfileId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$FailoveroVNicProfileUid,
			
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			#[HashTable]$CustomProperties,
			[System.Collections.Hashtable]$CustomProperties,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[Boolean]$AllowAllUsersToUseThisProfile,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({($_).GetType().Name -match 'oNetwork|String'})]$oNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({($_).GetType().Name -match 'oNetworkFilter|String'})]$oNetworkFilter,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkFilterId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkFilterUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({($_).GetType().Name -match 'oQoS|String'})]$oQoS,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oQoSId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oQoSUid,
		
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			#[SWITCH]$RunAsync,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		$oVNicProfileObject = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oVNicProfile is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oVNicProfileObject = Get-oVNicProfile -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oVNicProfileObject = Get-oVNicProfile -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oVNicProfileObject){$oVNicProfileObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oVNicProfile GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oVNicProfileObject = Get-oVNicProfile -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oVNicProfileObject = Get-oVNicProfile -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oVNicProfileObject){$oVNicProfileObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oVNicProfile]}{
					Write-Verbose "$($MyInvocation.MyCommand) Name is [oVNicProfile]"
					$oVNicProfileObject = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oVNicProfile"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oVNicProfile]"
					$oVNicProfileObject = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oVNicProfile is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVNicProfileObject = Get-oVNicProfile -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVNicProfileObject = Get-oVNicProfile -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oVNicProfileObject){$oVNicProfileObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				$UidUrl = [Uri]$Uid
				$oVNicProfileObject = Get-oVNicProfile -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVNicProfileObject){$oVNicProfileObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		$oNetworkObject = $oVNicProfileObject.network
		$oNetworkObject.GetoDataCenters()
		$oDataCenterObject = $oNetworkObject.data_center
		
		$FailoveroVNicProfileObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['FailoveroVNicProfileUid']){
			$UidUrl = [Uri]$FailoveroVNicProfileUid
			$FailoveroVNicProfileObjects = Get-oUri -Uri $($PSBoundParameters['FailoveroVNicProfileUid']) -EA SilentlyContinue
			IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['FailoveroVNicProfileId']){
			IF($PSBoundParameters['oVirtServerName']){
				$FailoveroVNicProfileObjects += Get-oVNicProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Id -eq $PSBoundParameters['FailoveroVNicProfileId']} | Sort -Unique
			}Else{
				$FailoveroVNicProfileObjects += Get-oVNicProfile -EA SilentlyContinue
				$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Id -eq $PSBoundParameters['FailoveroVNicProfileId']} | Sort -Unique
			}
			IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['FailoveroVNicProfile']){
			SWITCH($PSBoundParameters['FailoveroVNicProfile']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is String"
					IF($PSBoundParameters['oVirtServerName']){
						$FailoveroVNicProfileObjects += Get-oVNicProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Name -eq $PSBoundParameters['FailoveroVNicProfile']} | Sort -Unique
					}Else{
						$FailoveroVNicProfileObjects += Get-oVNicProfile -EA SilentlyContinue
						$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Name -eq $PSBoundParameters['FailoveroVNicProfile']} | Sort -Unique
					}
					IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oVNicProfile]) -OR ($_.GetType().Name -eq "oVNicProfile")}{
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is [oVNicProfile]"
					$FailoveroVNicProfileObjects = $PSBoundParameters['FailoveroVNicProfile']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | Sort Name, ID -Unique}
		#$FailoveroVNicProfileObjects.GetRelated()
		$TMP_FailoveroVNicProfileObjects = @()
		ForEach($FailoveroVNicProfileObject in $FailoveroVNicProfileObjects){
			IF(($FailoveroVNicProfileObject.network.Id -eq $oNetworkObject.Id) -and ($FailoveroVNicProfileObject.oVirtServer -eq $oNetworkObject.oVirtServer)){$TMP_FailoveroVNicProfileObjects += $FailoveroVNicProfileObject}
		}
		IF(($TMP_FailoveroVNicProfileObjects).Count -ge 1){$FailoveroVNicProfileObjects = $TMP_FailoveroVNicProfileObjects}Else{$FailoveroVNicProfileObjects = $Null}
		IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | Sort Name, ID -Unique}

		
		$oQoSObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oQoSUid']){
			$UidUrl = [Uri]$oQoSUid
			$oQoSObjects = Get-oUri -Uri $($PSBoundParameters['oQoSUid']) -EA SilentlyContinue
		}ElseIF($PSBoundParameters['oQoSId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oQoSObjects += $oDataCenterObject | Get-oQoS -EA SilentlyContinue
				$oQoSObjects = $oQoSObjects | ?{$_.Id -eq $PSBoundParameters['oQoSId']} | Sort -Unique
			}Else{
				$oQoSObjects += $oDataCenterObject | Get-oQoS -EA SilentlyContinue
				$oQoSObjects = $oQoSObjects | ?{$_.Id -eq $PSBoundParameters['oQoSId']} | Sort -Unique
			}
		}ElseIF($PSBoundParameters['oQoS']){
			SWITCH($PSBoundParameters['oQoS']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oQoSObjects += $oDataCenterObject | Get-oQoS -EA SilentlyContinue
						$oQoSObjects = $oQoSObjects | ?{$_.Name -eq $PSBoundParameters['oQoS']} | Sort -Unique
					}Else{
						$oQoSObjects += $oDataCenterObject | Get-oQoS -EA SilentlyContinue
						$oQoSObjects = $oQoSObjects | ?{$_.Name -eq $PSBoundParameters['oQoS']} | Sort -Unique
					}
				}
				{($_ -IS [oQoS]) -OR ($_.GetType().Name -eq "oQoS")}{
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is [oQoS]"
					$oQoSObjects = $PSBoundParameters['oQoS'] | ?{($_.data_center.id -eq $oDataCenterObject.Id) -AND ($_.oVirtServer -eq $oDataCenterObject.oVirtServer)}
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oQoSObjects){$oQoSObjects = $oQoSObjects | Sort -Unique}
		$TMP_oQoSObjects = @()
		ForEach($oQoSObject in $oQoSObjects){
			$oURI = $Null; $oURI = [URI]$oQoSObject.Uid
			IF($oURI){
				$oURIDCGuid = $Null; $oURIDCGuid = ($oURI.AbsolutePath.Split('/',[System.StringSplitOptions]::RemoveEmptyEntries))[3]
				IF($oURIDCGuid){
					IF(($oURIDCGuid -eq $oDataCenterObject.Id) -and ($oURI.Host -eq $oDataCenterObject.oVirtServer)){$TMP_oQoSObjects += $oQoSObject}
				}
			}
		}
		IF(($TMP_oQoSObjects).Count -ge 1){$oQoSObjects = $TMP_oQoSObjects}Else{$oQoSObjects = $Null}
		
		$oNetworkFilterObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oNetworkFilterUid']){
			$UidUrl = [Uri]$oNetworkFilterUid
			$oNetworkFilterObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkFilterUid']) -EA SilentlyContinue
		}ElseIF($PSBoundParameters['oNetworkFilterId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkFilterObjects += Get-oNetworkFilter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oNetworkFilterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkFilterId']} | Sort -Unique
			}Else{
				$oNetworkFilterObjects += Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects += Get-oCluster -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkFilterId']} | Sort -Unique
			}
		}ElseIF($PSBoundParameters['oNetworkFilter']){
			SWITCH($PSBoundParameters['oNetworkFilter']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkFilterObjects += Get-oNetworkFilter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oNetworkFilterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Name -eq $PSBoundParameters['oNetworkFilter']} | Sort -Unique
					}Else{
						$oNetworkFilterObjects += Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects += Get-oCluster -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Name -eq $PSBoundParameters['oNetworkFilter']} | Sort -Unique
					}
				}
				{($_ -IS [oNetworkFilter]) -OR ($_.GetType().Name -eq "oNetworkFilter")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is [oNetworkFilter]"
					$oNetworkFilterObjects = $PSBoundParameters['oNetworkFilter']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oNetworkFilterObjects){$oNetworkFilterObjects = $oNetworkFilterObjects | Sort -Unique}
		IF($oNetworkFilterObjects){
			$oDataCenterObject.GetoClusters()
			$oDataCenterObjectoNetworkFilters = $Null
			$TMP_oNetworkFilterObjects = @()
			$oDataCenterObjectoNetworkFilters = $oDataCenterObject.oCluster | Get-oNetworkFilter
			IF($oDataCenterObjectoNetworkFilters){$oDataCenterObjectoNetworkFilters = $oDataCenterObjectoNetworkFilters | Sort Name, ID -Unique}
			ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
				#Need to relate to oCluster? then oDataCenterObject
				ForEach($oDataCenterObjectoNetworkFilter in $oDataCenterObjectoNetworkFilters){
					IF((($oNetworkFilterObject.Id -eq $oDataCenterObjectoNetworkFilter.Id) -and ($oNetworkFilterObject.oVirtServer -eq $oDataCenterObjectoNetworkFilter.oVirtServer)) -AND ($TMP_oNetworkFilterObjects.Id -NotContains $oNetworkFilterObject.Id)){$TMP_oNetworkFilterObjects += $oNetworkFilterObject}
				}
			}
			IF(($TMP_oNetworkFilterObjects).Count -ge 1){$oNetworkFilterObjects = $TMP_oNetworkFilterObjects}Else{$oNetworkFilterObjects = $Null}
			IF($oNetworkFilterObjects){$oNetworkFilterObjects = $oNetworkFilterObjects | Sort Name, ID -Unique}
		}

		IF($oVNicProfileObject){
			$oVNicProfileSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('NewName')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $PSBoundParameters['NewName']}
			IF($PSBoundParameters.ContainsKey('Comment')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $PSBoundParameters['Comment']}
			IF($PSBoundParameters.ContainsKey('Description')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $PSBoundParameters['Description']}
			
			$CustomPropertiesSpecs = [PSCustomObject]@{}
			$CustomPropertiesArray = [System.Collections.ArrayList]@()
			IF($PSBoundParameters.ContainsKey('CustomProperties')){
				IF($oVNicProfileSpecs.CustomProperties){
					$oVNicProfileSpecs.CustomProperties = $PSBoundParameters['CustomProperties']
				}Else{
					ForEach($Key in (($PSBoundParameters['CustomProperties']).Keys)){$CustomPropertiesArray.Add(([PSCustomObject]@{name=$Key;value=$PSBoundParameters['CustomProperties'][$Key]}))| Out-Null}
					$CustomPropertiesSpecs | Add-Member -MemberType NoteProperty -Name 'custom_property' -Value $CustomPropertiesArray
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'custom_properties' -Value $CustomPropertiesSpecs
				}
			}
			#NEED TO COMPARE SETTINGS AGAINST CURRENT PassThroughMode State and desired state
			#'Port Mirroring,'Qos' and 'Network Filter' are not supported on passthrough profiles.
			IF($PSBoundParameters.ContainsKey('PassThroughMode')){
				IF($PSBoundParameters['PassThroughMode'] -eq "enabled"){
					#pass_through      : @{mode=enabled}
					IF($oVNicProfileObject.pass_through.mode -ne "enabled"){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="enabled"})}
					IF($PSBoundParameters.ContainsKey('Migratable')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'migratable' -Value $PSBoundParameters['Migratable']}
					IF($FailoveroVNicProfileObjects){ForEach($FailoveroVNicProfileObject in $FailoveroVNicProfileObjects){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'failover' -Value $([PSCustomObject]@{"id"="$($FailoveroVNicProfileObject.Id)"})}}
				}Else{
					IF($PSBoundParameters['PassThroughMode'] -eq "disabled"){
						#pass_through      : @{mode=disabled}
						IF($oVNicProfileObject.pass_through.mode -eq "enabled"){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="disabled"})}
						IF($oQoSObjects){
							ForEach($oQoSObject in $oQoSObjects){
								$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'qos' -Value $([PSCustomObject]@{"id"="$($oQoSObject.Id)"})
							}
						}
					}
					#Can Not be Set if PassThroughMode is Enabled
					IF($PSBoundParameters.ContainsKey('PortMirroringEnabled')){
						IF($PSBoundParameters['PortMirroringEnabled'] -eq "true"){
							IF($oVNicProfileObject.pass_through.mode -ne "enabled"){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $True}
						}Else{
							$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $False
						}
					}
					
					#Can Not be Set if PassThroughMode is Enabled
					IF($oVNicProfileObject.pass_through.mode -ne "enabled"){
						IF($oNetworkFilterObjects){
							#Should Only Be 1 Object
							ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
								$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'network_filter' -Value $([PSCustomObject]@{"id"="$($oNetworkFilterObject.Id)"})
							}
						}
					}
				}
			}Else{
				IF($oVNicProfileObject.pass_through.mode -eq "disabled"){
					#pass_through      : @{mode=disabled} #Default in UI is NOT Enabled
					#$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="disabled"})
						#Can Not be Set if PassThroughMode is Enabled
						IF($oQoSObjects){
							ForEach($oQoSObject in $oQoSObjects){
								$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'qos' -Value $([PSCustomObject]@{"id"="$($oQoSObject.Id)"})
							}
						}
				}
				#Can Not be Set if PassThroughMode is Enabled
				IF($PSBoundParameters.ContainsKey('PortMirroringEnabled')){
					IF($PSBoundParameters['PortMirroringEnabled'] -eq "true"){
						IF($oVNicProfileObject.pass_through.mode -eq "disabled"){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $True}
					}Else{
						$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $False
					}
				}
				#Can Not be Set if PassThroughMode is Enabled
				IF($oVNicProfileObject.pass_through.mode -ne "enabled"){
					IF($oNetworkFilterObjects){
						#Should Only Be 1 Object
						ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
							$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'network_filter' -Value $([PSCustomObject]@{"id"="$($oNetworkFilterObject.Id)"})
						}
					}
				}
			}
			$oVirtServerName = $oVNicProfileObject.oVirtServer
			IF($oVirtServerName){
				Write-Verbose "$($MyInvocation.MyCommand): `$oVNicProfileSpecs [$($oVNicProfileSpecs | Out-String)]"
				$BaseURL = "https://$($oVirtServerName)"
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#POST /ovirt-engine/api/vnicprofiles
				$Uri = $BaseURL + "/ovirt-engine/api/vnicprofiles/$($oVNicProfileObject.Id)"
				$Method = "PUT"
				$JsonBody = $oVNicProfileSpecs | ConvertTo-Json -Depth 50
				#$JsonBody | ConvertFrom-Json2Xml
				#($oVNicProfileSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oVNicProfile to oVirt"
				Write-Verbose "$($JsonBody | Out-String)"
				Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
				$UpdatedoVNicProfile = $Null
				TRY{$UpdatedoVNicProfile = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoVNicProfile){
					$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoVNicProfile -ObjectType "oVNicProfile" -oVirtServerName $oVirtServerName)) | Out-Null
					$UpdatedoVNicProfile | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
				}
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

#endregion BASE_API_SET_Functions(PUT)

