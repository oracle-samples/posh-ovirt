					IF($UpdatedoHostObject){$OutPutItems += $UpdatedoHostObject}
				}Else{Write-Warning "oHost [$($oHostObject.name)] can't be refreshed in status [$($oHostObject.status)]"}
			}

			#Needs status of "up"
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/force_select_spm
			IF(($PSBoundParameters['SelectAsSPM']).IsPresent -eq $True){
				IF(($oHostObject.status -eq "up") -or ($oHostObject.status -eq "maintenance")){
					IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
						$oHostObjectSpecs = [PSCustomObject]@{async = $True}
