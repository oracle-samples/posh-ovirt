		IF($PSBoundParameters.ContainsKey('Name')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
		IF($PSBoundParameters.ContainsKey('Comment')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
		IF($PSBoundParameters.ContainsKey('Description')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
		IF($PSBoundParameters.ContainsKey('VmPoolType')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $($PSBoundParameters['VmPoolType']) }
		IF($PSBoundParameters.ContainsKey('MaxUserVms')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'max_user_vms' -Value $($PSBoundParameters['MaxUserVms']) }
		IF($PSBoundParameters.ContainsKey('PrestartedVms')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'prestarted_vms' -Value $($PSBoundParameters['PrestartedVms']) }
		IF($PSBoundParameters.ContainsKey('Size')){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'size' -Value $($PSBoundParameters['Size']) }
		IF($PSBoundParameters['UseLatestTemplateVersion'].IsPresent -eq $True){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'use_latest_template_version' -Value $True }
		IF($PSBoundParameters['Stateful'].IsPresent -eq $True){ $oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'stateful' -Value $True }
		
		IF($oClusterObjects){
			$oClusterObject = $oClusterObjects | Select -First 1
			$oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'cluster' -Value $([PSCustomObject]@{"id"=$oClusterObject.Id})
		}
		IF($oTemplateObjects){
			$oTemplateObject = $oTemplateObjects | Select -First 1
			$oVmPoolSpecs | Add-Member -MemberType NoteProperty -Name 'template' -Value $([PSCustomObject]@{"id"=$oTemplateObject.Id})
		}
		
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/vmpools"
		$Method = "POST"
		$JsonBody = $oVmPoolSpecs | ConvertTo-Json -Depth 50
		#$JsonBody | ConvertFrom-Json2Xml
		#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oVmPool"
		Write-Verbose "$($MyInvocation.MyCommand): Json: [$($JsonBody | Out-String)]"
		$NewoVmPool = $Null
		#TRY{$NewoVmPool = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
		TRY{$NewoVmPool = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoVmPool){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoVmPool -ObjectType "oVmPool" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function New-oVNicProfile{
	<#
		.SYNOPSIS
			This function creates a new oVNicProfile, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oVNicProfile, on a oVirt Server system.
			Please note that there is a default network filter to each VNIC profile. For more details of how the default network filter is calculated please refer to the documentation in NetworkFilters.
			This Function is a bit particular, in that the oNetwork, oNetworkFilter, oQoS, and FailoveroVNicProfile must all reside in the same oDataCenter as the intended oVNicProfile location
		.PARAMETER Name
			The Name of the new oVNicProfile
		.PARAMETER Comment
			Free text containing comments about this object.
			Documentation suggests this exists, but testing shows it is never returned as an object property, nor is a property in the UI
		.PARAMETER Description
			A human-readable description in plain text.
		
		.PARAMETER oDataCenter
			The Name of the parent oDataCenter for the new oVNicProfile(s)
		.PARAMETER oDataCenterId
			The Id of the parent oDataCenter for the new oVNicProfile(s)
		.PARAMETER oDataCenterUid
			The Uid of the parent oDataCenter for the new oVNicProfile(s)
		
		.PARAMETER oQoS
			Can Not be Set if PassThroughMode is Enabled
			Reference to the quality of service attributes to apply to the vNIC profile.
			Quality of Service attributes regulate inbound and outbound network traffic of the NIC.
			Must exist in provided oDataCenter
		.PARAMETER oQoSId
			Can Not be Set if PassThroughMode is Enabled
			Must exist in provided oDataCenter
		.PARAMETER oQoSUid
			Can Not be Set if PassThroughMode is Enabled
			Must exist in provided oDataCenter
			
		.PARAMETER PassThroughMode
			Enables passthrough to an SR-IOV-enabled host NIC.
			A vNIC profile enables a NIC to be directly connected to a virtual function (VF) of an SR-IOV-enabled host NIC, if passthrough is enabled.
			The NIC will then bypass the software network virtualization and connect directly to the VF for direct device assignment.
			Passthrough cannot be enabled if the vNIC profile is already attached to a NIC.
			If a vNIC profile has passthrough enabled, qos and port_mirroring are disabled for the vNIC profile
			
			"mode"="disabled" Implemented as a virtual device.
			"mode"="enabled" Implemented as a pass-through device.
			
			'Port Mirroring,'Qos' and 'Network Filter' are not supported on passthrough profiles.
			
		.PARAMETER Migratable
			Requires PassThroughMode Enabled

			Marks whether pass_through NIC is migratable or not.
			If pass_through.mode is set to disabled this option has no meaning, and it will be considered to be true.
			If you omit this option from a request, by default, this will be set to true.
			When migrating a virtual machine, this virtual machine will be migrated only if all pass_through NICs are flagged as migratable.
		.PARAMETER FailoveroVNicProfile
			Requires PassThroughMode Enabled
			Failover vNIC profile
			Must exist in provided oDataCenter
		.PARAMETER FailoveroVNicProfileId
			Requires PassThroughMode Enabled
			Must exist in provided oDataCenter
		.PARAMETER FailoveroVNicProfileUid
			Requires PassThroughMode Enabled
			Must exist in provided oDataCenter
		
		.PARAMETER PortMirroringEnabled
			Can Not be Set if PassThroughMode is Enabled
			Enables port mirroring.
			Port mirroring copies layer 3 network traffic on a given logical network and host to a NIC on a virtual machine.
			This virtual machine can be used for network debugging and tuning, intrusion detection, and monitoring the behavior of other virtual machines on the same host and logical network.
			The only traffic copied is internal to one logical network on one host.
			There is no increase in traffic on the network external to the host; however a virtual machine with port mirroring enabled uses more host CPU and RAM than other virtual machines.
			Port mirroring has the following limitations:
				Hot plugging a NIC with a vNIC profile that has port mirroring enabled is not supported.
				Port mirroring cannot be altered when the vNIC profile is attached to a virtual machine.
			Given the above limitations, it is recommended that you enable port mirroring on an additional, dedicated vNIC profile.
			Enabling port mirroring reduces the privacy of other network users.

		.PARAMETER CustomProperties
			Custom properties applied to the vNIC profile.
			
		.PARAMETER AllowAllUsersToUseThisProfile
			Allow all users to use this Profile
		.PARAMETER oNetwork
			The Name of the oNetwork (vLAN) for the new oVNicProfile
			Must exist in provided oDataCenter
		.PARAMETER oNetworkId
			The Id of the oNetwork (vLAN) for the new oVNicProfile
			Must exist in provided oDataCenter
		.PARAMETER oNetworkUid
			The Uid of the oNetwork (vLAN) for the new oVNicProfile
			Must exist in provided oDataCenter
		
		.PARAMETER oNetworkFilter
			The Name of the oNetworkFilter for the new oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Reference to the top-level network filter that applies to the NICs that use this profile.
			Network filters enhance the ability to manage the network packets traffic to and from virtual machines. 
			The network filter may either contain a reference to other filters, rules for traffic filtering, or a combination of both.
			Must exist in provided oDataCenter
		.PARAMETER oNetworkFilterId
			The Id of the oNetworkFilter for the new oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Must exist in provided oDataCenter
		.PARAMETER oNetworkFilterUid
			The Uid of the oNetworkFilter for the new oVNicProfile
			Can Not be Set if PassThroughMode is Enabled
			Must exist in provided oDataCenter
		
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			New-oVNicProfile -Name "New_oVNicProfile_Name"
		.INPUTS
			[System.String]
			[oNetwork]
			[oNetworkFilter]
			[oDataCenter]
			[oQoS]
			[System.Collections.Hashtable]
			[BOOLEAN]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVNicProfile]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/12/2024
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vnic_profile
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vnic_profile
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vnic_profiles
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_vnic_profiles
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vnic_pass_through
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-oVNicProfile
			Set-oVNicProfile
			Remove-oVNicProfile
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		#[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		#Not observed in output nor UI
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'oVM|String|oCluster|oDatacenter|oHost'})]$oDataCenter,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDataCenterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDataCenterUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("disabled","enabled")]
			[System.String]$PassThroughMode,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$Migratable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$PortMirroringEnabled,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oVNicProfile|String'})]$FailoveroVNicProfile,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$FailoveroVNicProfileId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$FailoveroVNicProfileUid,
			
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Collections.Hashtable]$CustomProperties,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$AllowAllUsersToUseThisProfile,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oNetwork|String'})]$oNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oNetworkFilter|String'})]$oNetworkFilter,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkFilterId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkFilterUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oQoS|String'})]$oQoS,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oQoSId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oQoSUid,
		
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[SWITCH]$RunAsync,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
	}
	Process{
		$oDataCenterObjects = $Null
		IF($PSBoundParameters['oDataCenterUid']){
			$UidUrl = [Uri]$oDataCenterUid
			$oDataCenterObjects = Get-oUri -Uri $($PSBoundParameters['oDataCenterUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oDataCenter" -oVirtServerName $oVirtServerName}
			IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oDataCenterId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oDataCenterObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				#$oDataCenterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
				$oDataCenterObjects = $oDataCenterObjects | ?{$_.Id -eq $PSBoundParameters['oDataCenterId']} | Sort -Unique
			}Else{
				$oDataCenterObjects += Get-oDataCenter -EA SilentlyContinue
				#$oDataCenterObjects += Get-oCluster -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
				$oDataCenterObjects = $oDataCenterObjects | ?{$_.Id -eq $PSBoundParameters['oDataCenterId']} | Sort -Unique
			}
			IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oDataCenter']){
			SWITCH($PSBoundParameters['oDataCenter']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDataCenterObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						#$oDataCenterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
						$oDataCenterObjects = $oDataCenterObjects | ?{$_.Name -eq $PSBoundParameters['oDataCenter']} | Sort -Unique
					}Else{
						$oDataCenterObjects += Get-oDataCenter -EA SilentlyContinue
						#$oDataCenterObjects += Get-oCluster -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
						$oDataCenterObjects = $oDataCenterObjects | ?{$_.Name -eq $PSBoundParameters['oDataCenter']} | Sort -Unique
					}
					IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oDataCenter]) -OR ($_.GetType().Name -eq "oDataCenter")}{
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is [oDataCenter]"
					$oDataCenterObjects = $PSBoundParameters['oDataCenter']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		IF($oDataCenterObjects){
			$oDataCenterObjects.GetoNetworks() | Out-Null
			#($oDataCenterObjects.oNetwork[0].Link.Where({$_.rel -eq "vnicprofiles"}).href | %{Get-oUri -RESTUri $_ -oVirtServerName $oDataCenterObjects.oVirtServer}).vnic_profile
			#Make sure FailoveroVNicProfileObjects, oNetworkObjects, oNetworkFilter, and oQoS reside in oDataCenterObjects
				# $oNetworkObjects have DataCenter Property
				# $oQoSObjects have DataCenter in href and Uid
				
				# $FailoveroVNicProfileObjects have no parent or child links
				# $oNetworkFilterObjects have no parent or child links
			#Added code to each section below to handle this
		}

		$oNetworkObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oNetworkUid']){
			$UidUrl = [Uri]$oNetworkUid
			$oNetworkObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oNetwork" -oVirtServerName $oVirtServerName}
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetworkId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}Else{
				$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetwork']){
			SWITCH($PSBoundParameters['oNetwork']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}Else{
						$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}
					IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oNetwork]) -OR ($_.GetType().Name -eq "oNetwork")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is [oNetwork]"
					$oNetworkObjects = $PSBoundParameters['oNetwork']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oNetworkObjects){$oNetworkObjects = $oNetworkObjects | Sort -Unique}
		
		$Tmp_oNetworkObjects = @()
		ForEach($oNetworkObject in $oNetworkObjects){
			ForEach($oNetwork in $oDataCenterObjects.oNetwork){
				IF(($oNetworkObject.Id -eq $oNetwork.Id) -And ($oNetworkObject.oVirtServer -eq $oNetwork.oVirtServer)){
					$Tmp_oNetworkObjects += $oNetworkObject
				}
			}
		}
		IF(($Tmp_oNetworkObjects).Count -ge 1){$oNetworkObjects = $Tmp_oNetworkObjects}Else{$oNetworkObjects = $Null}

		$oQoSObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oQoSUid']){
			$UidUrl = [Uri]$oQoSUid
			$oQoSObjects = Get-oUri -Uri $($PSBoundParameters['oQoSUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oQoS" -oVirtServerName $oVirtServerName}
			IF($oQoSObjects){$oQoSObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oQoSId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oQoSObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oQoS -EA SilentlyContinue
				$oQoSObjects = $oQoSObjects | ?{$_.Id -eq $PSBoundParameters['oQoSId']} | Sort -Unique
			}Else{
				$oQoSObjects += Get-oDataCenter -EA SilentlyContinue | Get-oQoS -EA SilentlyContinue
				$oQoSObjects = $oQoSObjects | ?{$_.Id -eq $PSBoundParameters['oQoSId']} | Sort -Unique
			}
			IF($oQoSObjects){$oQoSObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oQoS']){
			SWITCH($PSBoundParameters['oQoS']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oQoSObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oQoS -EA SilentlyContinue
						$oQoSObjects = $oQoSObjects | ?{$_.Name -eq $PSBoundParameters['oQoS']} | Sort -Unique
					}Else{
						$oQoSObjects += Get-oDataCenter -EA SilentlyContinue | Get-oQoS -EA SilentlyContinue
						$oQoSObjects = $oQoSObjects | ?{$_.Name -eq $PSBoundParameters['oQoS']} | Sort -Unique
					}
					IF($oQoSObjects){$oQoSObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oQoS]) -OR ($_.GetType().Name -eq "oQoS")}{
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is [oQoS]"
					$oQoSObjects = $PSBoundParameters['oQoS']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oQoS is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oQoSObjects){$oQoSObjects = $oQoSObjects | Sort -Unique}
		
		$TMP_oQoSObjects = @()
		ForEach($oQoSObject in $oQoSObjects){
			ForEach($oDataCenterObject in $oDataCenterObjects){
				$oURI = $Null; $oURI = [URI]$oQoSObject.Uid
				IF($oURI){
					$oURIDCGuid = $Null; $oURIDCGuid = ($oURI.AbsolutePath.Split('/',[System.StringSplitOptions]::RemoveEmptyEntries))[3]
					IF($oURIDCGuid){
						IF(($oURIDCGuid -eq $oDataCenterObject.Id) -and ($oURI.Host -eq $oDataCenterObject.oVirtServer)){$TMP_oQoSObjects += $oQoSObject}
					}
				}
			}
		}
		IF(($TMP_oQoSObjects).Count -ge 1){$oQoSObjects = $TMP_oQoSObjects}Else{$oQoSObjects = $Null}
		
		$FailoveroVNicProfileObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['FailoveroVNicProfileUid']){
			$UidUrl = [Uri]$FailoveroVNicProfileUid
			$FailoveroVNicProfileObjects = Get-oUri -Uri $($PSBoundParameters['FailoveroVNicProfileUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oVNicProfile" -oVirtServerName $oVirtServerName}
			IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['FailoveroVNicProfileId']){
			IF($PSBoundParameters['oVirtServerName']){
				$FailoveroVNicProfileObjects += Get-oVNicProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Id -eq $PSBoundParameters['FailoveroVNicProfileId']} | Sort -Unique
			}Else{
				$FailoveroVNicProfileObjects += Get-oVNicProfile -EA SilentlyContinue
				$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Id -eq $PSBoundParameters['FailoveroVNicProfileId']} | Sort -Unique
			}
			IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['FailoveroVNicProfile']){
			SWITCH($PSBoundParameters['FailoveroVNicProfile']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is String"
					IF($PSBoundParameters['oVirtServerName']){
						$FailoveroVNicProfileObjects += Get-oVNicProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						#$FailoveroVNicProfileObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oVNicProfile -EA SilentlyContinue
						$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Name -eq $PSBoundParameters['FailoveroVNicProfile']} | Sort -Unique
					}Else{
						$FailoveroVNicProfileObjects += Get-oVNicProfile -EA SilentlyContinue
						#$FailoveroVNicProfileObjects += Get-oNetwork -EA SilentlyContinue | Get-oVNicProfile -EA SilentlyContinue
						$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | ?{$_.Name -eq $PSBoundParameters['FailoveroVNicProfile']} | Sort -Unique
					}
					IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oVNicProfile]) -OR ($_.GetType().Name -eq "oVNicProfile")}{
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is [oVNicProfile]"
					$FailoveroVNicProfileObjects = $PSBoundParameters['FailoveroVNicProfile']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) FailoveroVNicProfile is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | Sort Name, ID -Unique}
		
		
		#$FailoveroVNicProfileObjects.GetRelated()
		$TMP_FailoveroVNicProfileObjects = @()
		ForEach($FailoveroVNicProfileObject in $FailoveroVNicProfileObjects){
			ForEach($oNetworkObject in $oNetworkObjects){
				IF(($FailoveroVNicProfileObject.network.Id -eq $oNetworkObject.Id) -and ($FailoveroVNicProfileObject.oVirtServer -eq $oNetworkObject.oVirtServer)){$TMP_FailoveroVNicProfileObjects += $FailoveroVNicProfileObject}
			}
		}
		IF(($TMP_FailoveroVNicProfileObjects).Count -ge 1){$FailoveroVNicProfileObjects = $TMP_FailoveroVNicProfileObjects}Else{$FailoveroVNicProfileObjects = $Null}
		IF($FailoveroVNicProfileObjects){$FailoveroVNicProfileObjects = $FailoveroVNicProfileObjects | Sort Name, ID -Unique}

		$oNetworkFilterObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oNetworkFilterUid']){
			$UidUrl = [Uri]$oNetworkFilterUid
			$oNetworkFilterObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkFilterUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oNetworkFilter" -oVirtServerName $oVirtServerName}
			IF($oNetworkFilterObjects){$oNetworkFilterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetworkFilterId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkFilterObjects += Get-oNetworkFilter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oNetworkFilterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkFilterId']} | Sort -Unique
			}Else{
				$oNetworkFilterObjects += Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects += Get-oCluster -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
				$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkFilterId']} | Sort -Unique
			}
			IF($oNetworkFilterObjects){$oNetworkFilterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetworkFilter']){
			SWITCH($PSBoundParameters['oNetworkFilter']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkFilterObjects += Get-oNetworkFilter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oNetworkFilterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Name -eq $PSBoundParameters['oNetworkFilter']} | Sort -Unique
					}Else{
						$oNetworkFilterObjects += Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects += Get-oCluster -EA SilentlyContinue | Get-oNetworkFilter -EA SilentlyContinue
						$oNetworkFilterObjects = $oNetworkFilterObjects | ?{$_.Name -eq $PSBoundParameters['oNetworkFilter']} | Sort -Unique
					}
					IF($oNetworkFilterObjects){$oNetworkFilterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oNetworkFilter]) -OR ($_.GetType().Name -eq "oNetworkFilter")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is [oNetworkFilter]"
					$oNetworkFilterObjects = $PSBoundParameters['oNetworkFilter']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetworkFilter is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oNetworkFilterObjects){$oNetworkFilterObjects = $oNetworkFilterObjects | Sort -Unique}
		
		IF($oNetworkFilterObjects){
			$oDataCenterObjects.GetoClusters() | Out-Null
			$oDataCenterObjectsoNetworkFilters = $Null
			$TMP_oNetworkFilterObjects = @()
			ForEach($oDataCenterObject in $oDataCenterObjects){
				$oDataCenterObjectsoNetworkFilters = $oDataCenterObject.oCluster | Get-oNetworkFilter
				IF($oDataCenterObjectsoNetworkFilters){$oDataCenterObjectsoNetworkFilters = $oDataCenterObjectsoNetworkFilters | Sort Name, ID -Unique}
				ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
					#Need to relate to oCluster? then oDataCenterObjects
					ForEach($oDataCenterObjectsoNetworkFilter in $oDataCenterObjectsoNetworkFilters){
						IF((($oNetworkFilterObject.Id -eq $oDataCenterObjectsoNetworkFilter.Id) -and ($oNetworkFilterObject.oVirtServer -eq $oDataCenterObjectsoNetworkFilter.oVirtServer)) -AND ($TMP_oNetworkFilterObjects.Id -NotContains $oNetworkFilterObject.Id)){$TMP_oNetworkFilterObjects += $oNetworkFilterObject}
					}
				}
				IF(($TMP_oNetworkFilterObjects).Count -ge 1){$oNetworkFilterObjects = $TMP_oNetworkFilterObjects}Else{$oNetworkFilterObjects = $Null}
				IF($oNetworkFilterObjects){$oNetworkFilterObjects = $oNetworkFilterObjects | Sort Name, ID -Unique}
			}
		}

		$oVNicProfileSpecs = [PSCustomObject]@{"name"=$PSBoundParameters['Name']}
		IF($PSBoundParameters.ContainsKey('Comment')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $PSBoundParameters['Comment']}
		IF($PSBoundParameters.ContainsKey('Description')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $PSBoundParameters['Description']}
		IF($oNetworkObjects){
			#Should Only Be 1 Object
			ForEach($oNetworkObject in $oNetworkObjects){
				$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $([PSCustomObject]@{"id"="$($oNetworkObject.Id)"})
			}
		}
		
		$CustomPropertiesSpecs = [PSCustomObject]@{}
		$CustomPropertiesArray = [System.Collections.ArrayList]@()
		IF($PSBoundParameters.ContainsKey('CustomProperties')){
			IF($oVNicProfileSpecs.CustomProperties){
				$oVNicProfileSpecs.CustomProperties = $PSBoundParameters['CustomProperties']
			}Else{
				ForEach($Key in (($PSBoundParameters['CustomProperties']).Keys)){$CustomPropertiesArray.Add(([PSCustomObject]@{name=$Key;value=$PSBoundParameters['CustomProperties'][$Key]}))| Out-Null}
				$CustomPropertiesSpecs | Add-Member -MemberType NoteProperty -Name 'custom_property' -Value $CustomPropertiesArray
				$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'custom_properties' -Value $CustomPropertiesSpecs
			}
		}
		
		#'Port Mirroring,'Qos' and 'Network Filter' are not supported on passthrough profiles.
		IF($PSBoundParameters.ContainsKey('PassThroughMode')){
			IF($PSBoundParameters['PassThroughMode'] -eq "enabled"){
				#pass_through      : @{mode=enabled}
				$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="enabled"})
				IF($PSBoundParameters.ContainsKey('Migratable')){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'migratable' -Value $PSBoundParameters['Migratable']}
				IF($FailoveroVNicProfileObjects){ForEach($FailoveroVNicProfileObject in $FailoveroVNicProfileObjects){$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'failover' -Value $([PSCustomObject]@{"id"="$($FailoveroVNicProfileObject.Id)"})}}
			}Else{
				IF($PSBoundParameters['PassThroughMode'] -eq "disabled"){
					#pass_through      : @{mode=disabled}
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="disabled"})
					IF($oQoSObjects){
						ForEach($oQoSObject in $oQoSObjects){
							$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'qos' -Value $([PSCustomObject]@{"id"="$($oQoSObject.Id)"})
						}
					}
				}
				IF($PSBoundParameters.ContainsKey('PortMirroringEnabled')){
					IF($PSBoundParameters['PortMirroringEnabled'] -eq "true"){
						$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $True
					}Else{
						$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $False
					}
				}
				IF($oNetworkFilterObjects){
					#Should Only Be 1 Object
					ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
						$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'network_filter' -Value $([PSCustomObject]@{"id"="$($oNetworkFilterObject.Id)"})
					}
				}
			}
		}Else{
			#pass_through      : @{mode=disabled} #Default in UI is NOT Enabled
			$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'pass_through' -Value $([PSCustomObject]@{"mode"="disabled"})
			IF($oQoSObjects){
				ForEach($oQoSObject in $oQoSObjects){
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'qos' -Value $([PSCustomObject]@{"id"="$($oQoSObject.Id)"})
				}
			}
			IF($PSBoundParameters.ContainsKey('PortMirroringEnabled')){
				IF($PSBoundParameters['PortMirroringEnabled'] -eq "true"){
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $True
				}Else{
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'port_mirroring' -Value $False
				}
			}
			IF($oNetworkFilterObjects){
				#Should Only Be 1 Object
				ForEach($oNetworkFilterObject in $oNetworkFilterObjects){
					$oVNicProfileSpecs | Add-Member -MemberType NoteProperty -Name 'network_filter' -Value $([PSCustomObject]@{"id"="$($oNetworkFilterObject.Id)"})
				}
			}
		}

		IF($oVirtServerName){
			Write-Verbose "$($MyInvocation.MyCommand): `$oVNicProfileSpecs [$($oVNicProfileSpecs | Out-String)]"
			$BaseURL = "https://$($oVirtServerName)"
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#POST /ovirt-engine/api/vnicprofiles
			$Uri = $BaseURL + "/ovirt-engine/api/vnicprofiles"
			$Method = "POST"
			$JsonBody = $oVNicProfileSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oVNicProfileSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oVNicProfile to oVirt"
			Write-Verbose "$($JsonBody | Out-String)"
			Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
			$NewoVNicProfile = $Null
			TRY{$NewoVNicProfile = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoVNicProfile){
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoVNicProfile -ObjectType "oVNicProfile" -oVirtServerName $oVirtServerName)) | Out-Null
				
				# $AllowAllUsersToUseThisProfile , a permissions selection secondary API call, to add the additional permission
					<#
						Allow includes this Permission
							role            group
							----            -----
							VnicProfileUser Everyone
					#>
				IF($PSBoundParameters.ContainsKey('AllowAllUsersToUseThisProfile')){
					$Nada = New-oPermission -oObjectId $NewoVNicProfile.Id -Group "Everyone" -oRole "VnicProfileUser" -AuthSource "internal-authz" -oVirtServerName $oVirtServerName
				}
				$NewoVNicProfile | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"; IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

