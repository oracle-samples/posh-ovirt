	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#Secondary Only Object, receives: oVM, oTemplate, oSnapshot
	}
	Process{
		<#
		((Get-oVM).Link.Where({$_.rel -eq "reporteddevices"}).href) | %{(Get-oUri -RESTUri $_).reported_device}
		($oVMs.Link.Where({$_.rel -eq "reporteddevices"}).href) | %{(Get-oUri -RESTUri $_).reported_device}
		(Get-oUri -RESTUri ($oVM.Link.Where({$_.rel -eq "reporteddevices"}).href)).reported_device
			ips         : @{ip=System.Object[]}
			mac         : @{address=56:6f:47:0e:00:07}
			type        : network
			vm          : @{href=/ovirt-engine/api/vms/e87596a2-6b49-4b79-9533-f39bb4b78109; id=e87596a2-6b49-4b79-9533-f39bb4b78109}
