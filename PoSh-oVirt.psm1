Function Set-oiScsiBond{
	<#
		.SYNOPSIS
			This function reconfigures an oiScsiBond, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures an oiScsiBond, on a oVirt Server system.
			Returns the job response from the oVirt Server.
			Updates an iSCSI bond.
			Updating of an iSCSI bond can be done on the name and the description attributes only
		.PARAMETER oiScsiBond
			The oiScsiBond Object or Name
		.PARAMETER oiScsiBondId
			The Id of an oiScsiBond
			Needs an oDatacenter parameter to discover it
		.PARAMETER oiScsiBondUid
			The Uid of an oiScsiBond
		.PARAMETER oDatacenter
			The Name of the parent oDatacenter for the existing oiScsiBond
			In a future release, when I can test this function, I may be able to extract the oDatacenter from the oiScsiBond object and omit the oDatacenter requirement
		.PARAMETER oDatacenterId
			The Id of the parent oDatacenter for the existing oiScsiBond
		.PARAMETER oDatacenterUid
			The Uid of the parent oDatacenter for the existing oiScsiBond
		.PARAMETER NewName
			The New Name for the existing oiScsiBond(s)
		.PARAMETER Comment
			The Text for the Comment field to set on the oiScsiBond
		.PARAMETER Description
			The Text for the Description field to set on the oiScsiBond
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oiScsiBond -oiScsiBond $oiScsiBond -NewName "NewName" -Description "Description"
				Updates an oiScsiBond with the provided Settings
		.INPUTS
			[System.String]
			[oDatacenter]
			[oiScsiBond]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oiScsiBond]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/28/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/iscsi_bond
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bond
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bonds
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bond/methods/update
			New-oiScsiBond
			Get-oiScsiBond
			Remove-oiScsiBond
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set04')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set04", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oiScsiBond'})]$oiScsiBond,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[GUID]$oiScsiBondId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set05")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oiScsiBondUid,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'oDatacenter|String'})]$oDatacenter,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDatacenterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDatacenterUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$NewName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[Switch]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
