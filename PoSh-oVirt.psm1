			#It is important to note that each time a fence agent is modified it receives a new ID in OLVM
			#I suspect any status will work
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/fence
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/agent
			IF(($PSBoundParameters['FenceAgentAction'])){
				IF(($PSBoundParameters['FenceAgentAction']) -eq "add"){
					IF(($PSBoundParameters['FenceAgentType'])){
						$oHostObjectSpecs = [PSCustomObject]@{type = $FenceAgentType}
						IF($FenceAgentOrder){Add-Member -MemberType NoteProperty -Name "order" -Value $FenceAgentOrder -InputObject $oHostObjectSpecs}
						IF($FenceAgentIPAddress){Add-Member -MemberType NoteProperty -Name "ip" -Value $FenceAgentIPAddress -InputObject $oHostObjectSpecs}
						IF($FenceAgentUserName){Add-Member -MemberType NoteProperty -Name "user" -Value $FenceAgentUserName -InputObject $oHostObjectSpecs}
						IF($FenceAgentPassword){Add-Member -MemberType NoteProperty -Name "password" -Value $FenceAgentPassword -InputObject $oHostObjectSpecs}
						IF($FenceAgentPort){Add-Member -MemberType NoteProperty -Name "port" -Value $FenceAgentPort -InputObject $oHostObjectSpecs}
						IF($FenceAgentOptions){Add-Member -MemberType NoteProperty -Name "options" -Value $FenceAgentOptions -InputObject $oHostObjectSpecs}
						$Uri = $BaseURL + ($oHostObject.link | ?{$_.rel -eq "fenceagents"}).href
						$Method = "POST"
						$JsonBody = $oHostObjectSpecs | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to update oHost Fence Agent"
