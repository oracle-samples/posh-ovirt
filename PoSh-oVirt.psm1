												IF($oName){
													Write-Host "$($oVxObjectName) [$($oName)] not found, [$($oVxError.Message)]"
												}ElseIF($oID){
													Write-Host "$($oVxObjectName)iD [$($oID)] not found, [$($oVxError.Message)]"
												}
											}
											IF($Response02b){
												#$global:Response02b_Saved_XML02 = $Response02b
												Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Raw $($oVxObjectName)s Response02b Name Query [$($Response02b | Select * | Out-String)]"
												Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$WebObjectPluralName [$($WebObjectPluralName)]"
												Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$WebObjectSingularName [$($WebObjectSingularName)]"
											}
											IF($Response02b.$WebObjectPluralName.$WebObjectSingularName){
												#$oVxObjects = ($Response02b.$WebObjectPluralName.$WebObjectSingularName | %{Convert-XMLtoPSObject -XML $_}) | ?{$_.Name -eq $oName}
												$oVxObjects = ($Response02b.$WebObjectPluralName.$WebObjectSingularName | %{Convert-XMLtoPSObject -XML $_})
											}
										}
									}Else{
										IF($oName -eq [regex]::Escape('*')){
											Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Extended Raw $($oVxObjectName)s Response02 [$($Response02.$WebObjectPluralName.$WebObjectSingularName | Select * | Out-String)]"
											$oVxObjects = $Response02
										}Else{
											IF(!$Response02.$WebObjectSingularName){
												$oURI = $URI + "?name=$($oName)"
												IF(($CaseSensitive).IsPresent -eq $True){$oURI = $oURI + "&case_sensitive=true"}
												$oVxError = $Null
												Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$oURI Retry JSON [$($oURI)]"
												Try{$Response02b = $Null; $Response02b = Invoke-RestMethod -Uri $oURI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction SilentlyContinue}Catch{}
												IF(!($Response02b)){
													IF($oName){
														Write-Host "$($oVxObjectName) [$($oName)] not found, [$($oVxError.Message)]"
													}ElseIF($oID){
														Write-Host "$($oVxObjectName)iD [$($oID)] not found, [$($oVxError.Message)]"
													}
												}
												IF($Response02b){
													#$global:Response02b_Saved_JSON02 = $Response02b
													Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Raw $($oVxObjectName)s Response02b Name Query [$($Response02b | Select * | Out-String)]"
													Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$WebObjectPluralName [$($WebObjectPluralName)]"
													Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$WebObjectSingularName [$($WebObjectSingularName)]"
												}
												IF($Response02b.$WebObjectSingularName){
