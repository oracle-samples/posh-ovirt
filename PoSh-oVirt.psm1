			[ValidateScript({If ($_ -Match "^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$") { $True } Else { Throw "$_ is not a MAC Address!" }})]
			[System.String]$CustomMacAddress,
