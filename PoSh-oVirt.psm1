Function Get-oVirt{
	<#
		.SYNOPSIS
			This function retrieves the REST API Scheme on an oVirt Server system.
		.DESCRIPTION
			This function retrieves the REST API Scheme on an oVirt Server system.
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtCredential
			The PSCredential to be used to connect to the -oVirtServerName
		.PARAMETER Syncopate
			Switch to Syncopate (truncate/abridge) returned data set
		.EXAMPLE
			PS> $oVirt = Get-oVirt -oVirtServerName $oVirtServerName -oVirtToken $oVirtToken
		.INPUTS
			[System.String]
			[oVirtToken]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/22/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
        #Credentials for oVirt Server (admin@internal is the default user on non KeyCloak authentication servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[System.Management.Automation.PSCredential]$oVirtCredential,
	
		#Options
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, DontShow)]
			[Alias('CO')]
			[SWITCH]$ShowOptions,
	
		#MigrationPoliciesSupported
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, Position=5,DontShow)]
			[Alias('MP')]
			[SWITCH]$ShowMigrationPoliciesSupported,
		
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#IF((Get-WmiObject -Class Win32_PingStatus -Filter "(Address=`'$($oVirtServerName)`') AND (timeout=1000) AND (ResolveAddressNames=TRUE)" -EA Stop).StatusCode -ne [INT]'0'){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
		#IF(!(Test-NetConnection -ComputerName $oVirtServerName -InformationLevel Quiet)){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
	}
	Process{
		$oVirtConnectionsToProcess = $Null
		$ProvidedConnectionParams = $Null; $ProvidedConnectionParams = ($PSBoundParameters.GetEnumerator() | ?{($_.Key -eq "oVirtServerName")}).Value | %{ @{"oVirtServerName"=$_}}
		Write-Verbose "$($MyInvocation.MyCommand): ProvidedConnectionParams: [$($ProvidedConnectionParams | Out-String)]"
		IF($ProvidedConnectionParams){$oVirtConnectionsToProcess = Resolve-oVirtConnection @ProvidedConnectionParams -ErrorAction SilentlyContinue}Else{$oVirtConnectionsToProcess = Resolve-oVirtConnection -ErrorAction SilentlyContinue}
		Write-Verbose "$($MyInvocation.MyCommand): oVirtConnectionsToProcess: [$($oVirtConnectionsToProcess | Out-String)]"
			
		#Loop Through $oVirtConnectionsToProcess in the Process section
		IF($oVirtConnectionsToProcess){
			$OutPutItems = [System.Collections.ArrayList]@()
			ForEach($oVirtConnection in $oVirtConnectionsToProcess){
				$oVirtServerName = $oVirtConnection.oVirtServerName
				$URI = "https://$($oVirtServerName)/ovirt-engine/api"
		
				#Can Return via XML or JSON
				$ReturnDataType = "xml"
				$ReturnDataType = "json"
				$Headers = @{"Accept" = "application/$($ReturnDataType)";"Authorization" = "Bearer $($oVirtConnection.AccessToken)"; "Prefer" = "persistent-auth"; "All-Content"="true"}
				Write-Verbose "$($MyInvocation.MyCommand): Base URI [$($URI)]"
				Write-Verbose "$($MyInvocation.MyCommand): Headers [$($Headers | Out-String)]"
				
				$oVirt = $NULL
				$Response01 = $Null; $Response01 = Invoke-RestMethod -Uri $URI -Method Get -Headers $Headers -ErrorVariable oVxError
				IF(!($Response01)){
					Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
				}Else{
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
					Write-Verbose "Raw oVirt Response: $Response01"
					IF($Response01.xml){
						$oVirt = ($Response01.api | %{Convert-XMLtoPSObject -XML $_})
					}Else{
						#$oVMs = ($Response01.vm | ConvertFrom-Json)
						$oVirt = $Response01
					}
				}
				IF((!$($ShowOptions.IsPresent -eq $True)) -AND (!$($MigrationPoliciesSupported.IsPresent -eq $True))){
					$TmpoVirt = (Convert-RestResponseTooVirtObject -InputObject $oVirt -ObjectType "oVirt" -oVirtServerName $oVirtServerName)
					$TmpoVirt.Name = $oVirtServerName
					$TmpoVirt.Id = $TmpoVirt.product_info.instance_id
					$OutPutItems.Add($TmpoVirt) | Out-Null
				}
				
				IF($ShowOptions.IsPresent -eq $True){
					$oVirt = $NULL
					$URI2 = $URI + "/options"
					$Response02 = $Null; $Response02 = Invoke-RestMethod -Uri $URI2 -Method Get -Headers $Headers -ErrorVariable oVxError
					IF(!($Response02)){
						Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
					}Else{
						Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
						Write-Verbose "Raw oVirt ShowOptions Response: $Response02"
						IF($Response02.xml){
							$oVirt = ($Response02.api | %{Convert-XMLtoPSObject -XML $_})
						}Else{
							$oVirt = $Response02
						}
					}
					IF($oVirt){
						$TmpoVirt = (Convert-RestResponseTooVirtObject -InputObject $oVirt -ObjectType "oVirt" -oVirtServerName $oVirtServerName)
						$TmpoVirt.Name = $oVirtServerName
						$TmpoVirt.Id = $TmpoVirt.product_info.instance_id
						$OutPutItems.Add($TmpoVirt) | Out-Null
					}
				}
				
				IF($MigrationPoliciesSupported.IsPresent -eq $True){
					$oVirt = $NULL
					#$URI3 = $URI + "/options/MigrationPoliciesSupported?version=4.2"
					$URI3 = $URI + "/options/MigrationPoliciesSupported"
					$Response03 = $Null; $Response03 = Invoke-RestMethod -Uri $URI3 -Method Get -Headers $Headers -ErrorVariable oVxError
					IF(!($Response03)){
						Write-Host "oVirtServer [$($oVirtServerName)] not found, [$($oVxError.Message)]"
					}Else{
						Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
						Write-Verbose "Raw oVirt MigrationPoliciesSupported Response: $Response03"
						IF($Response03.xml){
							$oVirt = ($Response03.api | %{Convert-XMLtoPSObject -XML $_})
						}Else{
							$oVirt = $Response03
						}
					}
					IF($oVirt){
						$TmpoVirt = (Convert-RestResponseTooVirtObject -InputObject $oVirt -ObjectType "oVirt" -oVirtServerName $oVirtServerName)
						$TmpoVirt.Name = $oVirtServerName
						$TmpoVirt.Id = $TmpoVirt.product_info.instance_id
						$OutPutItems.Add($TmpoVirt) | Out-Null
					}
				}
			}
			Return $OutPutItems
		}
	}
	End{$UserPassword = $NULL; $oVirtCredential = $NULL; Write-Verbose "$($MyInvocation.MyCommand): End"}
}

