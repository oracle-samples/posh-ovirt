		$VMSpecsMemoryPolicy = $Null; $VMSpecsHA = $Null; $VMSpecsCpuProfile = $Null; $VMSpecsBiosBoot_menu = $Null; $VMSpecsBios = $Null; $VMSpecsOSBootDevices = $Null; 
