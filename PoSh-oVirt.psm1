			Add-Member -NotePropertyName "affinity" -NotePropertyValue $PSBoundParameters['MigrationMode'] -inputObject $VMSpecsPlacementPolicy
		}

		IF($InstanceType){
			$InstanceTypeID = $Null; $InstanceTypeID = (Get-oUri -RESTUri "/ovirt-engine/api/instancetypes?search=$($InstanceType)" -oVirtServerName $oVirtServerName).instance_type.id #Faster
