		}
		
		IF(($PSBoundParameters.ContainsKey('MigrationEncrypted')) -OR ($PSBoundParameters.ContainsKey('MigrationParallel')) -OR ($PSBoundParameters.ContainsKey('MigrationCompressed')) -OR ($PSBoundParameters.ContainsKey('MigrationAutoConverge'))){
			$VMSpecsMigration = [PSCustomObject]@{}
			IF($MigrationEncrypted){Add-Member -NotePropertyName "encrypted" -NotePropertyValue $MigrationEncrypted -inputObject $VMSpecsMigration}
			IF($MigrationParallel){Add-Member -NotePropertyName "parallel_migrations_policy" -NotePropertyValue $MigrationParallel -inputObject $VMSpecsMigration}
			IF($MigrationCompressed){Add-Member -NotePropertyName "compressed" -NotePropertyValue $MigrationCompressed -inputObject $VMSpecsMigration} #"inherit", need to get back to this one
			IF($MigrationAutoConverge){Add-Member -NotePropertyName "auto_converge" -NotePropertyValue $MigrationAutoConverge -inputObject $VMSpecsMigration} #"inherit", need to get back to this one
			#"policy" = @{id=a7aeedb2-8d66-4e51-bb22-32595027ce71} This sets a Migation Policy, from those available 
		}
		
		IF(($PSBoundParameters.ContainsKey('MemoryBallooning')) -OR ($PSBoundParameters.ContainsKey('MemoryGuaranteed')) -OR ($PSBoundParameters.ContainsKey('MemoryMax')) -OR ($PSBoundParameters.ContainsKey('MemoryOverCommitPercentage')) -OR ($PSBoundParameters.ContainsKey('MemoryTHPEnabled'))){
			$VMSpecsMemoryPolicy = [PSCustomObject]@{}
