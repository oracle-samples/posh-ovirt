Function Set-oHostBond{
	<#
		.SYNOPSIS
			This function updates an oHostBond across physical oHostNic(s), on an oHost , on an oVirt Server system.
		.DESCRIPTION
			This function updates an oHostBond across physical oHostNic(s), on an oHost , on an oVirt Server system.
			Returns the oHostNic representing the bond
			An oHostBond is a logical bond between two (or more) physical Nics (oHostNic)
		.PARAMETER oHostBond
			The Name or oHostBond object (logical oHostNic) of the existing oHostBond to modify
		.PARAMETER oHostBondId
			The Id of the existing oHostBond to modify
		.PARAMETER oHostBondUid
			The Uid of the existing oHostBond to modify
		.PARAMETER oHostNic
			The Name(s) of the oHostNic(s) to set as slaves(s) for the existing oHostBond(s)
		.PARAMETER oHostNicId
			The Id of the oHostNic(s) to set as slaves(s) for the existing oHostBond(s)
		.PARAMETER oHostNicUid
			The Uid of the oHostNic(s) to set as slaves(s) for the existing oHostBond(s)
		.PARAMETER RemoveoHostNic
			Remove oHost Nic from oHostBond
		.PARAMETER oHost
			The Name of the parent oHost for the existing oHostBond
		.PARAMETER oHostId
			The Id of the parent oHost for the existing oHostBond
		.PARAMETER oHostUid
			The Uid of the parent oHost for the existing oHostBond
		.PARAMETER BondingMode
			Sets the Bonding Mode from defined sets, or enables Custom Bonding paramaters
			Valid options (IntelliSense Tabbing) "(Mode 1) Active-Backup","(Mode 2) Load balance (balance-xor)","(Mode 3) Broadcast","(Mode 4) Dynamic link aggregation (802.3ad)","Custom"
		.PARAMETER CustomMode
			If BondingMode set to "Custom" enabled to accept an array of hashtable (name/value pairs) based on custom settings
				I.e. @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"}
		.PARAMETER oNetwork
			The Name of the oNetwork (vLAN) for the existing oHostBond oNetworkAttachment
		.PARAMETER oNetworkId
			The Id of the oNetwork (vLAN) for the existing oHostBond oNetworkAttachment
		.PARAMETER oNetworkUid
			The Uid of the oNetwork (vLAN) for the existing oHostBond oNetworkAttachment
		.PARAMETER RemoveoNetworkLabel
			Remove oNetworkLabel from oHostBond
		.PARAMETER AssignmentMethod
			Valid options "autoconf", "dhcp", "none", "poly_dhcp_autoconf", "static"
		.PARAMETER IPAddress
			The IP Address to assign the oNetworkAttachment
		.PARAMETER Netmask
			The Subnet mask of the IPAddress in Octet format
			Intellisense available
			Valid options "255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248","255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128","255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0","255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0","255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0","255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0","255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0","240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0"
		.PARAMETER Gateway
			The IP Address of the gateway for the oNetworkAttachment
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER IPVersion version
			Valid options "v4","v6"
			Only "v4" is valid in this version of function
		.PARAMETER ip_address_assignments	
			Potential future feature accepting an array of hashtables to allocate to the IP settings of the oNetworkAttachment
				See https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
		.PARAMETER DNSServers
			This accepts an array of IPAddresses and/or FQDNs of Domain Name Servers (DNS)
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER Properties
			This accepts an array of hashtable (name/value pairs) based on custom settings found in 
				https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
		.PARAMETER oNetworkLabel
			The Name (Or oNetworkLabel object) of the oNetworkLabel for the existing oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER oNetworkLabelId
			The Id of the oNetworkLabel for the existing oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER oNetworkLabelUid
			The Uid of the oNetworkLabel for the existing oHostBond
			Represents a label which can be added to a host network interface and to a network.
			The label binds the network to the host network interface by the label id
		.PARAMETER RemoveoNetwork
			Remove oNetwork from oHostBond
		.PARAMETER ConnectivityTimeout
		.PARAMETER CheckConnectivity
		.PARAMETER CommitOnSuccess
			Specifies whether to automatically save the configuration in the oVirt Node upon completing the setup and re-establishing connectivity between the oVirt Node and oVirt Engine, and without waiting for a separate commitnetconfig request.
			To make sure that the network configuration has been saved in the host, and that it will be applied when the host is rebooted
			The default value is false, which means that the configuration will not be saved automatically.
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oHostBond -oVirtServerName $oVirtServerName -oHostBond "bond1" -oHost "oHostName" -oHostNic 'ens1f0np0', 'ens1f1np1' -BondingMode "custom" -CustomMode  @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"}
				Updates an existing oHostBond with the provided Name
		.EXAMPLE
			PS> Set-oHostBond -oVirtServerName $oVirtServerName -oHostBond $oHostBond -oHostNic $oHostNics -oHost $oHost -BondingMode Custom -CustomMode @{"mode"="4";"xmit_hash_policy"="1";"miimon"="1";"lacp_rate"="1"} -oNetworkLabel "Common_Storage" -RemoveoNetworkLabel -oNetwork "Stewart_Test_VL" -RemoveoNetwork -CommitOnSuccess -Confirm:$False
				Set oHostBond $oHostBond to use the physical nics in $oHostNics, on $oHost, Configure the Bond to use Custom Mode 4, Remove an oNetworkLabel "Common_Storage", Remove an oNetwork "Stewart_Test_VL"
		.EXAMPLE
			PS> Set-oHostBond -oVirtServerName $oVirtServerName -oHostBond $oHostBond -oHost $oHost -oNetworkLabel "Common_Storage" -oNetwork "Stewart_Test_VL" -RemoveoNetwork -CommitOnSuccess -Confirm:0
				Set oHostBond $oHostBond on $oHost, To Add oNetworkLabel "Common_Storage" and remove oNetwork "Stewart_Test_VL"
		.INPUTS
			[System.String]
			[oHost]
			[oHostNic]
			[oNetwork]
			[oNetworkLabel]
			[oNetworkAttachment]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oHostNic]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/6/2024
			Version 1.1		8/7/2024
			Version 2.1		5/17/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_nic
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host_nic
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host_nics
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/bonding
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/setup_networks
				#This method is used to change the configuration of the network interfaces of a host.
		.LINK
			Get-oHostNic
			Set-oHostBond
			Remove-oHostBond
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			[ValidateScript({$_ | %{($_).GetType().Name -match 'oHostNic|String'}})]$oHostBond,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oHostBondId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}})]
			[System.String[]]$oHostBondUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({$_ | %{($_).GetType().Name -match 'oHostNic|String'}})]$oHostNic,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oHostNicId,
