							$oRoleObjects = Get-oRole -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oRoleObjects = Get-oRole -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oRole]}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole is [oRole]"
						$oRoleObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oRole"}{
						Write-Verbose "$($MyInvocation.MyCommand) oRole GetType equals [oRole]"
						$oRoleObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oRole is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
				#Adding Out-GridView to force selection of desired oRole(s) if multiple are returned, to minimize the chance of accidental deletions
				IF(($oRoleObjects | Measure-Object).Count -gt 1){
					#$Selection = $oRoleObjects | Select Name, Id, provisioned_size, oVirtServer, Description, Uid | Out-GridView -Title "Select oRole(s) to Delete" -OutputMode Multiple
					#$oRoleObjects = $oRoleObjects | ?{$Selection.Uid -Contains $_.Uid}
					$oRoleObjects = (($oRoleObjects | Select Name, Id, provisioned_size, oVirtServer, Description, Uid | Out-GridView -Title "Select oRole(s) to Delete" -OutputMode Multiple).Uid) | %{$Uid = $_; $oRoleObjects | ?{$_.Uid -eq $Uid}}
				}
				IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oRoleObjects = Get-oRole -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oRoleObjects = Get-oRole -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oRoleObjects = Get-oRole -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($TargetoRole in $oRoleObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoRole [$($TargetoRole.Name)]"
			$oVirtServerName = $TargetoRole.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			#Section to Handle Role Properties
			#$NewName, $Description
			$PropertiesThatCanChange = @("NewName","Description")
			IF(Compare-Object $PSBoundParameters.Keys $PropertiesThatCanChange -IncludeEqual -ExcludeDifferent){
				#Compare Existing Properties of $TargetoRole to select changed input params
				$oRoleSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('NewName')){
					IF($TargetoRole.Name -ne $PSBoundParameters['NewName']){
						$oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $(($PSBoundParameters['NewName']).Trim())
					}
				}
				IF($PSBoundParameters.ContainsKey('Description')){
					IF($TargetoRole.Description -ne $PSBoundParameters['Description']){
						$oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $(($PSBoundParameters['Description']).Trim())
					}
				}
			}
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oRoleSpecs: [$($oRoleSpecs | Out-String)]"
			IF($oRoleSpecs.Count -ge 1){
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/roles/$($TargetoRole.Id)"
				$Method = "PUT"
				$JsonBody = $oRoleSpecs | ConvertTo-Json -Depth 50
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oRole"
				Write-Verbose "$($JsonBody | Out-String)"
				$UpdatedoRole = $Null
				#TRY{$UpdatedoRole = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
				TRY{$UpdatedoRole = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoRole){$UpdatedoRole | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): oRoleSpecs NOT detected"
			}
	
			#Section to Handle Permit Properties
			$oClusterLevelPermits = ((Get-oUri -oVirtServerName $oVirtServerName -RESTUri /ovirt-engine/api/clusterlevels).cluster_level | Sort -Property Id -Descending | Select -First 1).permits.permit
			IF($oClusterLevelPermits){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
			$AdministrativePermitNames = $oClusterLevelPermits | ?{$_.Administrative -eq $True} | Select -ExpandProperty Name | Sort
			$UserPermitNames = $oClusterLevelPermits | ?{$_.Administrative -ne $True} | Select -ExpandProperty Name | Sort
			$AllPermitNames = $oClusterLevelPermits | Select -ExpandProperty Name | Sort
			#Check if any Permits params entered
			Write-Verbose "$($MyInvocation.MyCommand): Compare: [$((Compare-Object $PSBoundParameters.Keys $AllPermitNames -IncludeEqual -ExcludeDifferent))]"
			Write-Verbose "$($MyInvocation.MyCommand): Compare: [$($PSBoundParameters.Keys | ?{$AllPermitNames -Contains $_})]"
			Write-Verbose "$($MyInvocation.MyCommand): Compare `$PSBoundParameters.Keys: [$($PSBoundParameters.Keys)]"
			Write-Verbose "$($MyInvocation.MyCommand): Compare `$AllPermitNames: [$($AllPermitNames)]"
			IF($PSBoundParameters.Keys | ?{$AllPermitNames -Contains $_}){
				Write-Verbose "$($MyInvocation.MyCommand): Permit changes detected"
				$Permits = [System.Collections.ArrayList]@()
				$PermitsToDisable = [System.Collections.ArrayList]@()
			
				#Compare Administrative Property of $TargetoRole to select valid input params
				#Compare Existing Properties of $TargetoRole to select changed input params
				$TargetoRoleExistingPermits = $TargetoRole | Get-oPermit
				IF($TargetoRole.Administrative -eq $True){
					Write-Verbose "$($MyInvocation.MyCommand): Admin Permit(s) action"
					#$AllPermitNames
					ForEach($PermitName in $AllPermitNames){
						#IF(($PSBoundParameters[$PermitName]).IsPresent -eq $True){$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null}
						IF($PSBoundParameters.ContainsKey($PermitName)){
							IF(($PSBoundParameters[$PermitName]) -eq "enabled"){
								IF($TargetoRoleExistingPermits.Name -NotContains $PermitName){
									Write-Verbose "$($MyInvocation.MyCommand): Adding Permit To Enable [$($PermitName) : $(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id))]"
									$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null
								}
							}ElseIF(($PSBoundParameters[$PermitName]) -eq "disabled"){
								IF($TargetoRoleExistingPermits.Name -Contains $PermitName){
									Write-Verbose "$($MyInvocation.MyCommand): Adding Permit To Disable [$($PermitName) : $(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id))]"
									$PermitsToDisable.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null
								}
							}
						}
					}
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): User Permit(s) action"
					#$UserPermitNames
					ForEach($PermitName in $UserPermitNames){
						#IF(($PSBoundParameters[$PermitName]).IsPresent -eq $True){$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null}
						IF($PSBoundParameters.ContainsKey($PermitName)){
							IF(($PSBoundParameters[$PermitName]) -eq "enabled"){
								IF($TargetoRoleExistingPermits.Name -NotContains $PermitName){
									Write-Verbose "$($MyInvocation.MyCommand): Adding Permit To Enable [$($PermitName) : $(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id))]"
									$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null
								}
							}ElseIF(($PSBoundParameters[$PermitName]) -eq "disabled"){
								IF($TargetoRoleExistingPermits.Name -Contains $PermitName){
									Write-Verbose "$($MyInvocation.MyCommand): Adding Permit To Disable [$($PermitName) : $(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id))]"
									$PermitsToDisable.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $PermitName}).id)})) | Out-Null
								}
							}
						}
					}
				}
				#Request to Enable Permits
				Write-Verbose "$($MyInvocation.MyCommand): `$Permits: [$($Permits | Out-String)]"
				IF($Permits.Count -ge 1){
					#Write-Verbose "$($MyInvocation.MyCommand): `$Permits: [$($Permits | Out-String)]"
					$oPermitSpecs = [PSCustomObject]@{}
					$oPermitsSpecs = [PSCustomObject]@{}
					$oPermitSpecs | Add-Member -MemberType NoteProperty -Name 'permit' -Value $Permits
					$oPermitsSpecs | Add-Member -MemberType NoteProperty -Name 'permits' -Value $oPermitSpecs
					Write-Verbose "$($MyInvocation.MyCommand): `$Permits: [$($Permits | Out-String)]"
					Write-Verbose "$($MyInvocation.MyCommand): `$oPermitSpecs: [$($oPermitSpecs | Out-String)]"
					Write-Verbose "$($MyInvocation.MyCommand): `$oPermitsSpecs: [$($oPermitsSpecs | Out-String)]"
				
					#Send to Server
					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$Uri = $BaseURL + "/ovirt-engine/api/roles/$($TargetoRole.Id)/permits"
					$Method = "POST"
					ForEach($Permit in $Permits){
						$JsonBody = $Permit | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oRole with new oPermit(s)"
						Write-Verbose "$($JsonBody | Out-String)"
						$NewoPermit = $Null
						#TRY{$NewoPermit = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
						TRY{$NewoPermit = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
						IF($NewoPermit){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Permits NOT detected"
				}
				
				#Request to Disable Permits
				Write-Verbose "$($MyInvocation.MyCommand): `$PermitsToDisable: [$($PermitsToDisable | Out-String)]"
				IF($PermitsToDisable.Count -ge 1){
					#Send to Server
					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$Method = "DELETE"
					$JsonBody = [PSCustomObject]@{async = $True} | ConvertTo-Json
					ForEach($PermitsToDisableId in $PermitsToDisable.id){
						$Uri = $BaseURL + "/ovirt-engine/api/roles/$($TargetoRole.Id)/permits/$($PermitsToDisableId)"
						Write-Verbose "$($MyInvocation.MyCommand): Deleting oPermit from oRole"
						$DeleteoPermit = $Null
						#TRY{$DeleteoPermit = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
						TRY{$DeleteoPermit = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
						IF($DeleteoPermit){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): PermitsToDisable NOT detected"
				}
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Permit changes NOT detected"
			}
			$OutPutItems.Add((Get-oRole -Id $TargetoRole.Id -oVirtServerName $oVirtServerName)) | Out-Null
		}
		Write-Verbose "$($MyInvocation.MyCommand): Ending"
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oStorageDomain{
	<#
		.SYNOPSIS
			This function reconfigures the provided oStorageDomain, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oStorageDomain, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oStorageDomain(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of oStorageDomain(s)
		.PARAMETER Uid
			The Uid(s) of oStorageDomain(s)
		.PARAMETER NewName
			The new Name for the oStorageDomain
		.PARAMETER Comment
			Comment field text
		.PARAMETER Description
			Description field text
		.PARAMETER BackupEnabled
		.PARAMETER CriticalSpaceActionBlockerGB
		.PARAMETER WarningLowSpaceIndicatorPercent
		.PARAMETER WipeAfterDelete
		.PARAMETER ActivationOperation
			This operation activates/deactivates an attached storage domain.
			Once the storage domain is activated it is ready for use with the data center.
			Once the storage domain is deactivated it will not be used with the data center.
			Valid options "activate", "deactivate"
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oStorageDomain -oVirtServerName $oVirtServerName -NewName "Name"
				Changes the Name of the oStorageDomain(s) to the provided NewName
		.INPUTS
			[System.String]
			[oStorageDomain]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oStorageDomain]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/21/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/storage_domains
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/storage_domains/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domains
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain/methods/activate
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain/methods/deactivate
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/attached_storage_domain/methods/remove
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/storage_server_connection
		.LINK
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oStorageDomain'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$NewName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$BackupEnabled,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[INT64]$CriticalSpaceActionBlockerGB,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateRange(1,100)][INT32]$WarningLowSpaceIndicatorPercent,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[BOOLEAN]$WipeAfterDelete,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("Activate","Deactivate")]
			[System.String]$ActivationOperation,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RunAsync,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		IF($PSBoundParameters['Name']){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"}
		$oStorageDomainObjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oStorageDomainObjects = Get-oStorageDomain -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oStorageDomainObjects = Get-oStorageDomain -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oStorageDomainObjects = Get-oStorageDomain -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oStorageDomainObjects = Get-oStorageDomain -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oStorageDomain]}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is [oStorageDomain]"
						$oStorageDomainObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oStorageDomain"}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain GetType equals [oStorageDomain]"
						$oStorageDomainObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oStorageDomainObjects = Get-oStorageDomain -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oStorageDomainObjects = Get-oStorageDomain -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oStorageDomainObjects = Get-oStorageDomain -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainObjects Names: $($oStorageDomainObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oStorageDomainObject in $oStorageDomainObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainObject [$($oStorageDomainObject | Out-String)]"
			$oVirtServerName = $oStorageDomainObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainObject Status [$($oStorageDomainObject.Status)]"
			$oStorageDomainSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('NewName')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['NewName']) }
			IF($PSBoundParameters.ContainsKey('Comment')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('BackupEnabled')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'backup' -Value $($PSBoundParameters['BackupEnabled']) }
			IF($PSBoundParameters.ContainsKey('CriticalSpaceActionBlockerGB')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'critical_space_action_blocker' -Value $($PSBoundParameters['CriticalSpaceActionBlockerGB']) }
			IF($PSBoundParameters.ContainsKey('WarningLowSpaceIndicatorPercent')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'warning_low_space_indicator' -Value $($PSBoundParameters['WarningLowSpaceIndicatorPercent']) }
			IF($PSBoundParameters.ContainsKey('WipeAfterDelete')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $($PSBoundParameters['WipeAfterDelete']) }
			IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
				$oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value $true
			}Else{
				$oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value $false
			}
			IF($PSBoundParameters.ContainsKey('ActivationOperation')){
				$ActionParameters = [PSCustomObject]@{'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})}
				IF($PSBoundParameters['ActivationOperation'] -eq "Deactivate"){
					IF($PSBoundParameters['Force'].IsPresent -eq $True){
						$ActionParameters | Add-Member -MemberType NoteProperty -Name 'force' -Value $true
					}Else{
						#$ActionParameters | Add-Member -MemberType NoteProperty -Name 'force' -Value $false
					}
					$ActivationUri = $Uri + '/deactivate'
				}Else{
					$ActivationUri = $Uri + '/activate'
				}
				$Actions = [PSCustomObject]@{'action' = $ActionParameters}
			}
			IF($PSCmdlet.ShouldProcess($UpdateMessage , "Update oStorageDomain")) {
				#Send to Server
				$Uri = $BaseURL + "/ovirt-engine/api/storagedomains/$($oStorageDomainObject.Id)"
				$JsonBody = $oStorageDomainSpecs | ConvertTo-Json -Depth 50
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to update oStorageDomain"
				Write-Verbose "$($JsonBody | Out-String)"
				$UpdatedoHostObject = $Null; $WebError = $Null
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true"}
				$Method = "PUT"
				TRY{$UpdatedoStorageDomain = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoStorageDomain){
					Write-Verbose "$($MyInvocation.MyCommand): Updated oStorageDomain"
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
					#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
					
					#$oStorageDomain.status holds the activation state	https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain_status
					#POST /ovirt-engine/api/datacenters/123/storagedomains/456/activate
					#POST /ovirt-engine/api/datacenters/123/storagedomains/456/deactivate	<action><force>true</force><action>
					#If the force parameter is true then the operation will succeed, even if the OVF update which takes place before the deactivation of the storage domain failed. If the force parameter is false and the OVF update failed, the deactivation of the storage domain will also fail.
					#async also available for deactivate
					#IF($PSBoundParameters.ContainsKey('ActivationOperation')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $($PSBoundParameters['ActivationState']) }
					IF($PSBoundParameters.ContainsKey('ActivationOperation')){
						$JsonBody = $Actions | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to update oStorageDomain ActivationOperation"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedoHostObject = $Null; $WebError = $Null
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true"}
						$Method = "POST"
						TRY{$ActivatedoStorageDomain = Invoke-RestMethod -Uri $ActivationUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $ActivationUri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
						IF($ActivatedoStorageDomain){
							IF($ActivatedoStorageDomain.status -eq "complete"){
								Write-Verbose "$($MyInvocation.MyCommand): oStorageDomain Activation State Changed to [$($PSBoundParameters['ActivationOperation'])]"
								$UpdatedoStorageDomain_Tmp = $Null; $UpdatedoStorageDomain_Tmp = (Get-oUri -RESTUri $UpdatedoStorageDomain.href -oVirtServerName $oVirtServerName -EA SilentlyContinue)
								IF($UpdatedoStorageDomain_Tmp){
									$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain_Tmp -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
								}Else{
									$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
								}
							}Else{
								#Handle Error
							}
						}Else{
							$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
						}
					}Else{
						$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
					}
					
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
					IF($PSBoundParameters.ContainsKey('ActivationOperation')){
						$JsonBody = $Actions | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to update oStorageDomain ActivationOperation"
						Write-Verbose "$($JsonBody | Out-String)"
						$UpdatedoHostObject = $Null; $WebError = $Null
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token)"; "All-Content"="true"}
						$Method = "POST"
						TRY{$ActivatedoStorageDomain = Invoke-RestMethod -Uri $ActivationUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $ActivationUri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
						IF($ActivatedoStorageDomain){
							IF($ActivatedoStorageDomain.status -eq "complete"){
								Write-Verbose "$($MyInvocation.MyCommand): oStorageDomain Activation State Changed to [$($PSBoundParameters['ActivationOperation'])]"
								$UpdatedoStorageDomain_Tmp = $Null; $UpdatedoStorageDomain_Tmp = (Get-oUri -RESTUri $UpdatedoStorageDomain.href -oVirtServerName $oVirtServerName -EA SilentlyContinue)
								IF($UpdatedoStorageDomain_Tmp){
									$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain_Tmp -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
								}Else{
									$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null
								}
							}Else{
								#Handle Error
							}
						}
					}
				}
			}	
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oTemplate{
	<#
		.SYNOPSIS
			This function modifies the configuration of an oTemplate on OLVM (oVirt) Server System
		.DESCRIPTION
			This function modifies the configuration of an oTemplate on OLVM (oVirt) Server System

		.PARAMETER Name
			The Name of the oTemplate
		.PARAMETER VMType
			Virtual machine type 'desktop' intended to be used as a desktop, implication is that a sound device will automatically be added to the virtual machine
			Virtual machine type 'server' intended to be used as a server, implication is that a sound device will NOT automatically be added to the virtual machine
			Virtual machine type 'high_performance' intended to be used as a high performance virtual machine, implication is that the virtual machine configuration 
			will automatically be set for running with the highest possible performance, and with performance metrics as close to bare metal as possible
			 
			 * Some of the recommended configuration settings for the highest possible performance
			 * cannot be set automatically; manually setting them before running the virtual machine is recommended.
			 *
			 * The following configuration changes are set automatically:
			 *
			 * - Enable headless mode.
			 * - Enable serial console.
			 * - Enable pass-through host CPU.
			 * - Enable I/O threads.
			 * - Enable I/O threads pinning and set the pinning topology.
			 * - Enable the paravirtualized random number generator PCI (virtio-rng) device.
			 * - Disable all USB devices.
			 * - Disable the soundcard device.
			 * - Disable the smartcard device.
			 * - Disable the memory balloon device.
			 * - Disable the watchdog device.
			 * - Disable migration.
			 * - Disable high availability.
			 *
			 * The following recommended configuration changes have to be set manually by the user:
			 *
			 * - Enable CPU pinning topology.
			 * - Enable non-uniform memory access (NUMA) pinning topology.
			 * - Enable and set huge pages configuration.
			 * - Disable kernel same-page merging (KSM).
		.PARAMETER InstanceType
			The Instance Type of a VM is a set of predefined sizes to use to define a new VM instead of citing them individually
			For example `medium` instance type includes 1 virtual CPU and 4 GiB of memory
			The attributes that are used for instance
			 * types and are common to virtual machine and template types are:
			 *
			 * - `console`
			 * - `cpu`
			 * - `custom_cpu_model`
			 * - `custom_emulated_machine`
			 * - `display`
			 * - `high_availability`
			 * - `io`
			 * - `memory`
			 * - `memory_policy`
			 * - `migration`
			 * - `migration_downtime`
			 * - `os`
			 * - `rng_device`
			 * - `soundcard_enabled`
			 * - `usb`
			 * - `virtio_scsi`
			 *
			 * When creating a virtual machine from both an instance type and a template, the virtual machine
			 * will inherit the hardware configurations from the instance type
			 *
			 * NOTE: An instance type inherits it's attributes from the template entity although most template
			 * attributes are not used in instance types
			Options: 'tiny', 'small', 'medium', 'large', 'xlarge', 'custom_maybe_in_the_future'
		.PARAMETER Comment
			Populates the Comment field of the oTemplate on OLVM (oVirt) Server System
		.PARAMETER Description
			Populates the Description field of the oTemplate on OLVM (oVirt) Server System
		.PARAMETER OSType
			The Operating System to be used on the VM
			IntelliSense (tab ahead) Can provide list, same list as in OLVM drop-down options
			Default is 'Oracle Linux 8.x x64 [ol_8x64]'
		.PARAMETER oHost
			The name(s) of the destination Host(s) to place the VM.
		.PARAMETER oHostId
			The Id(s) of the destination Host(s) to place the VM.
		.PARAMETER MigrationMode
			Valid options are 'migratable', 'pinned', 'user_migratable'
		.PARAMETER Memory
			The size of the granted memory in bytes, default is 
		.PARAMETER MemoryGuaranteed
			The amount of memory, in bytes, that is guaranteed to not be drained by the balloon mechanism.
			The oVirt Engine internally rounds this value down to whole MiB (1MiB = 220 bytes).
			It can be updated while the virtual machine is running since oVirt 4.2 onwards, provided memory 
			is updated in the same request as well, and the virtual machine is in state up.
		.PARAMETER MemoryMax
			Maximum virtual machine memory, in bytes.
			The user provides the value in bytes, and the oVirt Engine rounds the value down to the nearest 
			lower MiB value.
			For example, if the user enters a value of 1073741825 (1 GiB + 1 byte), then the oVirt Engine 
			will truncate that value to the nearest lower MiB boundary: in this case 1073741824 (1 GiB).
		.PARAMETER MemoryBallooning
			Enables Memory Ballooning Feature
			Memory balloon is a guest device, which may be used to re-distribute / reclaim the host memory 
			based on VM needs in a dynamic way. In this way it’s possible to create memory over commitment states.
			NOTE: Enable Memory Balloon Optimization must also be selected for the cluster to be active
		.PARAMETER MemoryOverCommitPercentage
			Set Memory OverCommit Percentage allowed
			The amount of memory page sharing allowed of the memory from the virtual machine to other virtual machines
			Note: Memory Ballooning must be enabled to allow memory overcommitment
			See: https://docs.oracle.com/en/virtualization/oracle-linux-virtualization-manager/admin/admin-gs-optimize.html#config-vm-mem-cpu
		.PARAMETER MemoryTHPEnabled,
			Transparent HugePage Support (THP) is an alternative mean of using huge pages for the backing of 
			virtual memory with huge pages that supports the automatic promotion and demotion of page sizes 
			and without the shortcomings of hugetlbfs.
		.PARAMETER FirstBootDevice
			Valid options are 'cdrom', 'hd', 'network'
			Default is 'hd'
		.PARAMETER SecondBootDevice
			Valid options are 'cdrom', 'hd', 'network', 'none'
		.PARAMETER CpuType
			Valid options are 'x86_64', 'ppc64', 's390x'
			Default is 'x86_64'
		.PARAMETER CpuSockets
			The socket configuration can be updated without rebooting the virtual machine. 
			The cores and the threads require a reboot
			Default is 1
		.PARAMETER CpuCoresPerSocket
			Default is 1
		.PARAMETER CpuThreads
			Default is 1
		.PARAMETER CPUShares
			Valid options are 'disabled', 'low', 'medium', 'high', 'custom'
			'low', 'medium', 'high'
			'low':512
			'medium':1024
			'high':2048
		.PARAMETER CPUSharesInt,
			If CPUShares is set to custom, this setting allows for specific integer
		.PARAMETER CustomCPU
			Allows override of cluster default CPU type, provides a mask to advanced CPU chipset features
			IntelliSense (tab ahead) Can provide list, same list as in OLVM drop-down options
			Valid options are 'Nehalem','Nehalem,+spec-ctrl,+ssbd','Westmere','Westmere,+pcid,+spec-ctrl,+ssbd',
			'SandyBridge','SandyBridge,+pcid,+spec-ctrl,+ssbd,+md-clear','IvyBridge','IvyBridge,+pcid,+spec-ctrl,+ssbd,+md-clear',
			'Haswell-noTSX','Haswell-noTSX,+spec-ctrl,+ssbd,+md-clear','Broadwell-noTSX','Broadwell-noTSX,+spec-ctrl,+ssbd,+md-clear',
			'Skylake-Client,-hle,-rtm,-mpx','Skylake-Client-noTSX-IBRS,+ssbd,+md-clear,-mpx','Skylake-Server,-hle,-rtm,-mpx',
			'Skylake-Server-noTSX-IBRS,+ssbd,+md-clear,-mpx','Cascadelake-Server,-hle,-rtm,-mpx','Cascadelake-Server-noTSX,-mpx',
			'Icelake-Server-noTSX,-mpx'
			
		.PARAMETER CustomEmulatedMachine
			IntelliSense (tab ahead) Can provide list, same list as in OLVM drop-down options
			Valid options are 'isapc','microvm','pc','pc-i440fx-1.4','pc-i440fx-1.5','pc-i440fx-1.6','pc-i440fx-1.7','pc-i440fx-2.0',
			'pc-i440fx-2.1','pc-i440fx-2.10','pc-i440fx-2.11','pc-i440fx-2.12','pc-i440fx-2.2','pc-i440fx-2.3','pc-i440fx-2.4',
			'pc-i440fx-2.5','pc-i440fx-2.6','pc-i440fx-2.7','pc-i440fx-2.8','pc-i440fx-2.9','pc-i440fx-3.0','pc-i440fx-3.1',
			'pc-i440fx-4.0','pc-i440fx-4.1','pc-i440fx-4.2','pc-i440fx-5.0','pc-i440fx-5.1','pc-i440fx-5.2','pc-i440fx-6.0',
			'pc-i440fx-6.1','pc-i440fx-6.2','pc-i440fx-7.0','pc-i440fx-7.1','pc-i440fx-7.2','pc-q35-2.10','pc-q35-2.11','pc-q35-2.12',
			'pc-q35-2.4','pc-q35-2.5','pc-q35-2.6','pc-q35-2.7','pc-q35-2.8','pc-q35-2.9','pc-q35-3.0','pc-q35-3.1','pc-q35-4.0',
			'pc-q35-4.01','pc-q35-4.1','pc-q35-4.2','pc-q35-5.0','pc-q35-5.1','pc-q35-5.2','pc-q35-6.0','pc-q35-6.1','pc-q35-6.2',
			'pc-q35-7.0','pc-q35-7.1','pc-q35-7.2','q35','x-remote'
		.PARAMETER CustomCompatibilityVersion
			See: https://www.ovirt.org/documentation/upgrade_guide/
		.PARAMETER CpuProfile
			The name of the CPU profile available at the cluster to assign the oVM
		.PARAMETER CpuProfileId
			The Id of the CPU profile available at the cluster to assign the oVM
		.PARAMETER NumaNodeCount
			Manually Set the Number of Virtual Numa Nodes
			See: https://www.ovirt.org/develop/release-management/features/sla/numa-and-virtual-numa.html
		.PARAMETER AttachCD
			Enables checkbox to attach a CD
				Valid options 'StartConnected', 'StartDisConnected'
		.PARAMETER BootCDImage
			The Name of the ISO file to use as a permanent boot image
		.PARAMETER BootCDImageId
			The ID of the ISO file to use as a permanent boot image
		.PARAMETER ChangeCD
			Connect or Remove an ISO file in the virtual CD tray
			This is a temporary activity to allow live connections to ISO files
				Valid options 'Connect', 'Eject'
		.PARAMETER ActiveCDImage
			The Name of the ISO file to 'insert' into the virtual CD tray
		.PARAMETER ActiveCDImageId
