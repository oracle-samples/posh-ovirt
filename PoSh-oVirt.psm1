class oVirt{
	hidden [datetimeoffset]$_timestamp = $(
        Add-Member -InputObject $this -Name Time -MemberType ScriptProperty -Value { $this._timestamp.ToUnixTimeMilliSeconds() } -SecondValue { param([int64]$value) $this._timestamp = [DateTimeOffset]::FromUnixTimeMilliseconds($value).ToLocalTime() }
        Add-Member -InputObject $this -Name DateTime -MemberType ScriptProperty -Value { $this._timestamp.DateTime } -SecondValue { param([datetime]$value) $this._timestamp = $value }
        Add-Member -InputObject $this -Name DateTimeUtc -MemberType ScriptProperty -Value { $this._timestamp.UtcDateTime } -SecondValue { param([datetime]$value) $this._timestamp = $value.ToLocalTime() }
    )
    [System.String]$Name
	[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id #00000000-0000-0000-0000-000000000000 8-4-4-4-12
	[oUser]$authenticated_user
	[oUser]$effective_user
	[System.String]$href = "/ovirt-engine/api"
	[System.Array]$link
	[System.Management.Automation.PSObject]$product_info
	[System.Management.Automation.PSObject]$special_objects
	[System.Management.Automation.PSObject]$summary
	[System.String]$Uid
	[System.String]$oVirtServer
    oVirt(){$this.Init(@{})} # Default constructor
	oVirt([hashtable]$Properties){$this.Init($Properties)} # Convenience constructor from hashtable
	oVirt([System.String]$Name,
	[System.String]$Id,
	[oUser]$authenticated_user,
	[oUser]$effective_user,
	[System.String]$href,
	[System.Array]$link,
	[System.Management.Automation.PSObject]$product_info,
	[System.Management.Automation.PSObject]$special_objects,
	[System.Management.Automation.PSObject]$summary,
	[System.Int64]$time,
	[System.String]$Uid, 
	[System.String]$oVirtServer){
        $this.Init(@{
			name = $Name;
			id = $Id;
			authenticated_user = $authenticated_user;
			effective_user = $effective_user;
			href = $href;
			link = $link;
			product_info = $product_info;
			special_objects = $special_objects;
			summary = $summary;
			time = $time;
			Uid = $Uid;
			oVirtServer = $oVirtServer
		}); 
	} # Common constructor for class properties
	hidden [void]Init([hashtable]$Properties){
		foreach($Property in $Properties.Keys){
			$this.$Property = $Properties.$Property
		}
	} # Shared initializer method
	[System.String]ToString(){
		return $(IF($this.name){$this.name}Else{$this.id})
	} # Method to return a string representation of the oObject
	[System.Array]GetAuthenticatedUser(){
		$TmpoObject = $Null; $TmpoObject = $(IF($this.authenticated_user.href){(Get-oUri -RESTUri "$($this.authenticated_user.href)" -oVirtServerName $this.oVirtServer -EA SilentlyContinue) | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oUser" -oVirtServerName $this.oVirtServer}})
		IF($TmpoObject){$this.authenticated_user = $TmpoObject}
		return $this.authenticated_user
    }
	[System.Array]GetEffectiveUser(){
		$TmpoObject = $Null; $TmpoObject = $(IF($this.effective_user.href){(Get-oUri -RESTUri "$($this.effective_user.href)" -oVirtServerName $this.oVirtServer -EA SilentlyContinue) | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oUser" -oVirtServerName $this.oVirtServer}})
		IF($TmpoObject){$this.effective_user = $TmpoObject}
		return $this.effective_user
    }
	[VOID]GetRelated(){
		$this.GetAuthenticatedUser()
		$this.GetEffectiveUser()
	}
	[VOID]UpdateData(){
		ForEach($Property in ((Get-oUri -RESTUri $this.href -oVirtServerName $this.oVirtServer -EA SilentlyContinue).psobject.Properties)){
			$this."$($Property.Name)" = $Property.Value
		}
		IF(!$this.href){
			IF($this.Id){
				$Tmp_this = $Null
				$Tmp_this = (Get-oPermission -Id $this.Id -oVirtServerName $this.oVirtServer -EA SilentlyContinue)
				IF($Tmp_this){
					IF(($Tmp_this).GetType().Name -eq "oPermission"){
						$this.href = $Tmp_this.href
						$this.Uid = $Tmp_this.Uid
					}Else{Write-Host -ForeGroundColor Yellow "Class oPermission did not return class type oPermission with UpdateData method"}
				}
			}
		}#Severity 3 SR 3-38291830731 : OLVM REST API returning inconsistent properties https://support.oracle.com/epmos/faces/SrDetail?_adf.ctrl-state=11jfu22l5k_4&srDetailRelativeDateParam=null&queryModeName=Technical&srNumber=3-38291830731&needSrDetailRefresh=true&_afrLoop=470566997810898
		$this.GetRelated()
	}
}
