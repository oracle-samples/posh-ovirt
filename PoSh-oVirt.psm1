				IF($PSBoundParameters['oVirtServerName']){
					$oRoleObjects = Get-oRole -Id $PSBoundParameters['oRoleId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oRoleObjects = Get-oRole -Id $PSBoundParameters['oRoleId'] -EA SilentlyContinue
				}
				IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oRoleUid']){
				$UidUrl = [Uri]$oRoleUid
				$oRoleObjects = Get-oRole -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		$oRoleObjects = $oRoleObjects | ?{$_} | Select -First 1
		IF($oRoleObjects){$oRoleObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oObjects Names: $($oObjects.Name)"
		Write-Verbose "$($MyInvocation.MyCommand): `$oRole Names: $($oRole.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($Item in $oObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oObject [$($Item | Out-String)]"
			$oVirtServerName = $Item.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$BaseURL [$($BaseURL | Out-String)]"
			$oObjectSpecs = [PSCustomObject]@{}
			IF($oRoleObjects){ $oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'role' -Value $(@{"name"=$oRoleObjects.name}) }
			
			#If no $AuthSource, attempt to retrieve and Out-GridView to Select
			$oDomains = Get-oDomain -oVirtServerName $oVirtServerName
			IF(($PSBoundParameters['UserPrincipalName']) -And (!($PSBoundParameters['AuthSource']))){
				$MailAddress = ([MailAddress]$UserPrincipalName)
				$PSBoundParameters['AuthSource'] = $MailAddress.Host
			}ElseIF($PSBoundParameters['AuthSource']){
				IF($oDomains.name -contains ($PSBoundParameters['AuthSource'])){
					$oDomain = $oDomains | ?{$_.name -eq ($PSBoundParameters['AuthSource'])}
				}Else{
					Write-Warning "Provided 'AuthSource' not found, available options '$($oDomains.name -join ''', ''')'"
					BREAK
				}
			}Else{
				$oDomain = $oDomains.name | Out-GridView -Title "Select an AuthSource where Group/User is found" -OutputMode Single
				$PSBoundParameters['AuthSource'] = $oDomain.Name
			}
			$oGroupObject = $Null
			IF($PSBoundParameters['oGroup']){
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oGroup'] [$($PSBoundParameters['oGroup'] | Out-String)]"
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oGroup'].GetType().Name [$(($PSBoundParameters['oGroup']).GetType().Name)]"
				IF(($PSBoundParameters['oGroup']).GetType().Name -eq "String"){
					$Temp_oGroup = $Null; $Temp_oGroup = Get-oGroup -oVirtServerName $oVirtServerName -Name $PSBoundParameters['oGroup'] -EA SilentlyContinue | ?{$_.domain.id -eq $oDomain.id}
					IF($Temp_oGroup){
						IF(($Temp_oGroup.GetType().Name -eq "oGroup")){
							$oGroupObject = $Temp_oGroup
						}Else{
							Write-Verbose "$($MyInvocation.MyCommand): oGroup `$Temp_oGroup [$($Temp_oGroup | Out-String)]"
						}
					}
				}ElseIF(($PSBoundParameters['oGroup']).GetType().Name -eq "oGroup"){
					$oGroupObject = $PSBoundParameters['oGroup']
				}
				IF(!$oGroupObject){
					$GroupLookup = (Get-oUri -oVirtServerName $oVirtServerName -RESTUri "/ovirt-engine/api/domains/$($oDomain.id)/groups?search=name%3D$([System.Web.HttpUtility]::UrlEncode($PSBoundParameters['oGroup']))" -EA SilentlyContinue).group
					Write-Verbose "$($MyInvocation.MyCommand): oGroup `$GroupLookup [$($GroupLookup | Out-String)]"
					$oGroupObject = Get-oGroup -oVirtServerName $oVirtServerName -Id $GroupLookup.Id -EA SilentlyContinue | ?{$_.domain.id -eq $oDomain.id} | ?{$_.domain_entry_id -eq $GroupLookup.Id}
				}
				#Need to add ldap group/user to olvm before assigning permission/role, so it can be referenced by id, if not already available
				IF(!$oGroupObject){
					$oGroupObject = New-oGroup -oVirtServerName $oVirtServerName -Name $PSBoundParameters['oGroup'] -oDomain $oDomain -EA SilentlyContinue
				}
				IF($oGroupObject){
					Write-Verbose "$($MyInvocation.MyCommand): `$oGroupObject [$($oGroupObject | Out-String)]"
					IF(($oGroupObject).GetType().Name -eq "oGroup"){
						$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'group' -Value $(@{"id"=$oGroupObject.id})
					}Else{
						Write-Warning "oGroup $($PSBoundParameters['oGroup']) Not Found, quitting..."; BREAK
					}
				}Else{Write-Warning "oGroup $($PSBoundParameters['oGroup']) Not Found, quitting..."; BREAK}
			}ElseIF($PSBoundParameters['oGroupId']){
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oGroupId'] [$($PSBoundParameters['oGroupId'])]"
				IF($PSBoundParameters['oVirtServerName']){
					$oGroupObject = Get-oGroup -oVirtServerName $PSBoundParameters['oVirtServerName'] -ID $PSBoundParameters['oGroupId'] -EA SilentlyContinue | ?{$_.domain.id -eq $oDomain.id}
				}Else{
					$oGroupObject = Get-oGroup -ID $PSBoundParameters['oGroupId'] -EA SilentlyContinue | ?{$_.domain.id -eq $oDomain.id}
				}
				IF($oGroupObject){
					#Write-Host -Fore Cyan "$($MyInvocation.MyCommand): oGroupId `$oGroupObject [$($oGroupObject | Out-String)]"
					Write-Verbose "$($MyInvocation.MyCommand): `$oGroupObject [$($oGroupObject | Out-String)]"
					$oGroupObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
					$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'group' -Value $(@{"id"=$oGroupObject.id})
				}Else{Write-Warning "oGroup $($PSBoundParameters['oGroup']) Not Found, quitting..."; BREAK}
			}ElseIF($PSBoundParameters['oGroupUid']){
				Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oGroupUid'] [$($PSBoundParameters['oGroupUid'])]"
				#$UidUrl = [Uri]$_
				#$oGroupObjects = Get-oGroup -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oGroupObject = (Get-oUri -Uri $PSBoundParameters['oGroupUid'] -EA SilentlyContinue | ?{$_} | ?{$_.domain.id -eq $oDomain.id} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oGroup" -oVirtServerName $oVirtServerName})
				IF($oGroupObject){
					Write-Host -Fore Cyan "$($MyInvocation.MyCommand): oGroupUid `$oGroupObject [$($oGroupObject | Out-String)]"
					Write-Verbose "$($MyInvocation.MyCommand): `$oGroupObject [$($oGroupObject | Out-String)]"
					$oGroupObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
					$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'group' -Value $(@{"id"=$oGroup.id})
				}Else{Write-Warning "oGroup $($PSBoundParameters['oGroupUid']) Not Found, quitting..."; BREAK}
			}ElseIF($PSBoundParameters['oUser']){
				#THE DOMAIN SEARCH FOR LDAP users DOES NOT WORK AS Documented, Probably only will work for local user groups presently
					#"/ovirt-engine/api/domains/456/users?search=name%3Dusername"
				$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'user' -Value $(@{"id"=$oUser.id})
			}ElseIF($PSBoundParameters['oUserId']){
				$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'user' -Value $(@{"id"=$($PSBoundParameters['oUserId'])})
			}ElseIF($PSBoundParameters['UserPrincipalName']){
				$MailAddress = ([MailAddress]$PSBoundParameters['UserPrincipalName'])
				$AD_User = $Null; $AD_User = Get-ADSI_User -SamAccountName $MailAddress.User -TargetDomain $MailAddress.Host
				IF($AD_User){
					$LDAP_User = (Get-oUri -RESTUri "/ovirt-engine/api/users?search=$([System.Web.HttpUtility]::UrlEncode($(([System.Text.Encoding]::UTF8.GetString($AD_User['userprincipalname'][0])).ToLower())))" -oVirtServerName $oVirtServerName).user
					IF($LDAP_User){
						#(Convert-RestResponseTooVirtObject -InputObject $LDAP_User -ObjectType "oUser" -oVirtServerName $oVirtServerName)
						$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'user' -Value $(@{"id"=$LDAP_User.id})
					}
				}
			}
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + $Item.link.where({$_.rel -eq "permissions"}).href
			$Method = "POST"
			$JsonBody = $oObjectSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oPermission"
			Write-Verbose "$($MyInvocation.MyCommand): `$Uri [$($Uri | Out-String)]"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoPermission = $Null
			TRY{$NewoPermission = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoPermission){
				Write-Verbose "$($MyInvocation.MyCommand): Created oPermission"
				$ThisoPermission = (Convert-RestResponseTooVirtObject -InputObject (Get-oUri -RESTUri $NewoPermission.href -oVirtServerName $oVirtServerName) -ObjectType "oPermission" -oVirtServerName $oVirtServerName)
				$OutPutItems.Add($ThisoPermission) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oRole{
	<#
		.SYNOPSIS
			This function creates a new oRole, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oRole, on a oVirt Server system.
			Returns the job response from the oVirt Server.
			
			Mutable Property:
				Denotes the ability to update or delete the role.
				Roles with mutable set to false are predefined roles
		.PARAMETER Name
