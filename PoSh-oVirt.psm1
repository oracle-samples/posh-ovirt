	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oVM]: [$($PSBoundParameters['oVM'] -IS [oVM])]"
		#Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oVM'] Type: [$(($PSBoundParameters['oVM']).GetType().Name)]"
		#Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"
		
		Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters [$($PSBoundParameters.GetEnumerator()) | Out-String]"
		IF($CpuType -AND $OSType){
			#Check for Matching Architecture and Error on mismatch
			$ArgumentList = $(
				SWITCH(($CpuType)){
					{$_ -eq 'x86_64'}{$OsTypeOptions | ?{($_ -NotMatch "ppc64") -AND ($_ -NotMatch "_s390x")}}
					{$_ -eq 'ppc64'}{$OsTypeOptions | ?{($_ -Match "_ppc64")}}
					{$_ -eq 's390x'}{$OsTypeOptions | ?{($_ -Match "_s390x")}}
					DEFAULT{$OsTypeOptions | ?{($_ -NotMatch "ppc64") -AND ($_ -NotMatch "_s390x")}}
				}
			)
			IF($ArgumentList -NotContains $OSType){
				Write-Warning "CpuType [$($CpuType)] and OSType [$($OSType)] Architecture do NOT match, use your head man, quitting...."
				BREAK
			}
		}
		
		IF($PSBoundParameters.ContainsKey('FirstBootDevice') -AND $PSBoundParameters.ContainsKey('SecondBootDevice')){
			IF($PSBoundParameters['FirstBootDevice'] -Eq $PSBoundParameters['SecondBootDevice']){
				Write-Warning "FirstBootDevice [$($PSBoundParameters['FirstBootDevice'])] and SecondBootDevice [$($PSBoundParameters['SecondBootDevice'])] Can NOT be the same, make a better choice, quitting...."
				BREAK
			}
		}
		
		$oVMOBjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oVMOBjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		IF($oVMOBjects.count -gt 1){Write-Warning "More than 1 oVM found, unique VM required, quitting..."; BREAK}
		
		#$VMType rules
		IF($PSBoundParameters['VMType'] -eq "high_performance"){
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_type/values/high_performance
				#The following configuration changes are set automatically:
					#Enable headless mode.
					#Enable serial console.
					#Enable pass-through host CPU.
					#Enable I/O threads.
					#Enable I/O threads pinning and set the pinning topology.
					#Enable the paravirtualized random number generator PCI (virtio-rng) device.
					#Disable all USB devices.
					#Disable the soundcard device.
					#Disable the smartcard device.
					#Disable the memory balloon device.
					#Disable the watchdog device.
					#Disable migration.
					#Disable high availability.
			$PSBoundParameters['HeadlessMode'] = $true #Enable headless mode.						#$oVM.display empty ()
			$PSBoundParameters['VirtIOSerialConsoleEnabled'] = $true #Enable serial console.		#$oVM.console.enabled
			$PSBoundParameters['PassThroughHostCPU'] = $true #Enable pass-through host CPU.			#This option can only be enabled when VM live migration is disabled. $oVM.cpu.mode = "host_passthrough"
			$PSBoundParameters['IOThreadsEnabled'] = $true #Enable I/O threads.						#$oVM.io.threads = 1, $False is #$oVM.io.threads = 0
