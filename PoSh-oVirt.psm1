			}Else{Write-Warning "No oHost discovered to search Bonds, quitting..."; BREAK}
		}ElseIF($PSBoundParameters['oHostBond']){
			ForEach($Item in $PSBoundParameters['oHostBond']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oHostBond is String"
						IF($oHostObjects){
							$oHostBondObjects += $ExistingoHostNicObjects | ?{$_.Name -eq $Item} | Sort -Property Name -Unique
							IF($oHostBondObjects){$oHostBondObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
						}Else{Write-Warning "No oHost discovered to search Bonds, quitting..."; BREAK}
					}
					{($_ -IS [oHostNic]) -OR ($_.GetType().Name -eq "oHostNic")}{
						Write-Verbose "$($MyInvocation.MyCommand) Name is [oHostNic]"
						$oHostBondObjects += $PSBoundParameters['oHostBond']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oHostBond is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		$oHostBondObjects = $oHostBondObjects | ?{$_.bonding} | ?{$_.ad_aggregator_id} | ?{!$_.ip.address} | ?{!$_.ipv6.address} | ?{$_.mac}
		
		$oHostNicObjects = @(); 
		IF($PSBoundParameters['oHostNicUid']){
			$oHostNicObjects = $(ForEach($URL in $PSBoundParameters['oHostNicUid']){Get-oUri -Uri $URL -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oHostNic" -oVirtServerName $oVirtServerName}})
			IF($oHostNicObjects){$oHostNicObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oHostNicId']){
			IF($oHostObjects){
				#$ExistingoHostNicObjects = $oHostObjects | Get-oHostNic -EA SilentlyContinue
				IF($ExistingoHostNicObjects){$oHostNicObjects = $ExistingoHostNicObjects | ?{$PSBoundParameters['oHostNicId'] -Contains $_.Id}}
				IF($oHostNicObjects){$oHostNicObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}Else{Write-Warning "No oHost discovered to search Nics, quitting..."; BREAK}
		}ElseIF($PSBoundParameters['oHostNic']){
			ForEach($Item in $PSBoundParameters['oHostNic']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oHostNic is String"
						IF($oHostObjects){
							#$ExistingoHostNicObjects = $oHostObjects | Get-oHostNic -EA SilentlyContinue
							IF($ExistingoHostNicObjects){$oHostNicObjects += $ExistingoHostNicObjects | ?{$_.Name -eq $Item} | Sort -Property Name -Unique}
							IF($oHostNicObjects){$oHostNicObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
						}Else{Write-Warning "No oHost discovered to search Nics, quitting..."; BREAK}
					}
					{($_ -IS [oHostNic]) -OR ($_.GetType().Name -eq "oHostNic")}{
						Write-Verbose "$($MyInvocation.MyCommand) Name is [oHostNic]"
						$oHostNicObjects += $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oHostNic is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}Else{
			#IF($oHostObjects -and $oHostBondObjects){$oHostNicObjects += $oHostObjects | Get-oHostNic | ?{$oHostBondObjects.bonding.slaves.host_nic.id -Contains $_.id}}
			IF($oHostObjects -and $oHostBondObjects){$oHostNicObjects += $ExistingoHostNicObjects | ?{$oHostBondObjects.bonding.slaves.host_nic.id -Contains $_.id}}
		}
		$oHostNicObjects = $oHostNicObjects | ?{!$_.bonding} | ?{$_.ad_aggregator_id} | ?{!$_.ip.address} | ?{!$_.ipv6.address} | ?{$_.mac}

		#ParentObjectTypesAllowed' = 'oCluster|oiScsiBond|oDataCenter|oOpenStackImageProvider'
		$oNetworkObjects = $Null
		IF($PSBoundParameters['oNetworkUid']){
