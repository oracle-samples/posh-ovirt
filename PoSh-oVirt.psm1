		IF($oDatacenterObject){
			Write-Verbose "$($MyInvocation.MyCommand): `$oDatacenterObject Names: $($oDatacenterObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDatacenterObject [$($oDatacenterObject | Out-String)]"
