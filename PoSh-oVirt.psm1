			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoNetworkAttachment = $Null
			TRY{$UpdatedoNetworkAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoNetworkAttachment){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoNetworkAttachment -ObjectType "oNetworkAttachment" -oVirtServerName $oVirtServerName)) | Out-Null}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
