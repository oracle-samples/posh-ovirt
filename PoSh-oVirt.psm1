		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		IF(!(($PSBoundParameters['oHost']) -or ($PSBoundParameters['oHostId']) -or ($PSBoundParameters['oHostUid']))){Write-Warning "oHost Required to Create oStorageDomain, quitting..."; BREAK}
		
		$oDataCenterObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oDataCenter']){
				SWITCH($PSBoundParameters['oDataCenter']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDataCenter]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['oDataCenter']
					}
					{$_.GetType().Name -eq "oDataCenter"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['oDataCenter']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oDataCenterId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['oDataCenterId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['oDataCenterId'] -EA SilentlyContinue
				}
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oDataCenterUid']){
				$UidUrl = [Uri]$oDataCenterUid
				$oDataCenterObjects = Get-oDataCenter -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		$oHostObject = $Null
		IF($PSBoundParameters['oHost']){
			SWITCH($PSBoundParameters['oHost']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
					}
					IF($oHostObject){$oHostObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oHostObject = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
					}
					IF($oHostObject){$oHostObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oHost]}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost is [oHost]"
					$oHostObject = $PSBoundParameters['oHost']
				}
				{$_.GetType().Name -eq "oHost"}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals [oHost]"
					$oHostObject = $PSBoundParameters['oHost']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSBoundParameters['oHostId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oHostObject = Get-oHost -Id $PSBoundParameters['oHostId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
			}Else{
				$oHostObject = Get-oHost -Id $PSBoundParameters['oHostId'] -EA SilentlyContinue
			}
			IF($oHostObject){$oHostObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oHostUid']){
			$UidUrl = [Uri]$oHostUid
			$oHostObject = Get-oHost -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			IF($oHostObject){$oHostObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}
		IF(!($oHostObject)){Write-Warning "No oHost Discovered matching input criteria to Create oStorageDomain, quitting..."; BREAK}

		Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObjects Names: $($oDataCenterObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		#ForEach($oDataCenterObject in $oDataCenterObjects){}
		Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObject [$($oDataCenterObject | Out-String)]"
		$oVirtServerName = $oDataCenterObjects.oVirtServer
		$BaseURL = "https://$($oVirtServerName)"
		#$oStorageDomainSpecs = [PSCustomObject]@{}
		IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
			$oStorageDomainSpecs = [PSCustomObject]@{async = $True}
		}Else{
			$oStorageDomainSpecs = [PSCustomObject]@{async = $False}
		}
		IF($PSBoundParameters.ContainsKey('Name')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
		IF($PSBoundParameters.ContainsKey('Comment')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
		IF($PSBoundParameters.ContainsKey('Description')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
		IF($PSBoundParameters.ContainsKey('StorageDomainType')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $($PSBoundParameters['StorageDomainType']) }
		IF($PSBoundParameters.ContainsKey('BackupEnabled')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'backup' -Value $($PSBoundParameters['BackupEnabled']) }
		IF($PSBoundParameters.ContainsKey('BlockSize')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'block_size' -Value $($PSBoundParameters['BlockSize']) }
		IF($PSBoundParameters.ContainsKey('DiscardAfterDelete')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'discard_after_delete' -Value $($PSBoundParameters['DiscardAfterDelete']) }
		IF($PSBoundParameters.ContainsKey('WipeAfterDelete')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $($PSBoundParameters['WipeAfterDelete']) }
		IF($PSBoundParameters.ContainsKey('CriticalSpaceActionBlockerGB')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'critical_space_action_blocker' -Value $($PSBoundParameters['CriticalSpaceActionBlockerGB']) }
		IF($PSBoundParameters.ContainsKey('WarningLowSpaceIndicatorPercent')){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'warning_low_space_indicator' -Value $($PSBoundParameters['WarningLowSpaceIndicatorPercent']) }
		IF($oHostObject){ $oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $([PSCustomObject]@{"name"=$oHostObject.Name})}
		
		$oStorageSpecs = [PSCustomObject]@{}
		IF($PSBoundParameters.ContainsKey('StorageDomainType')){
			IF(($PSBoundParameters['StorageDomainType'] -eq "data") -OR ($PSBoundParameters['StorageDomainType'] -eq "iso")){
				IF(($PSBoundParameters['StorageType'] -eq "nfs")){
					$oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $($PSBoundParameters['StorageType'])
					IF($PSBoundParameters.ContainsKey('NFSVersion')){ $oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'nfs_version' -Value $($PSBoundParameters['NFSVersion']) }
					IF($PSBoundParameters.ContainsKey('StoragePath')){ $oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'path' -Value $($PSBoundParameters['StoragePath']) }Else{Write-Warning "StoragePath Required for NFS"; BREAK}
					IF($PSBoundParameters.ContainsKey('IPStorageAddress')){ $oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['IPStorageAddress']) }Else{Write-Warning "IPStorageAddress Required for NFS"; BREAK}
				}
				
				IF($PSBoundParameters['StorageType'] -eq "iscsi"){
					$oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $($PSBoundParameters['StorageType'])
					$iSCSIStorageSpecs = [PSCustomObject]@{}
					IF($PSBoundParameters.ContainsKey('iSCSILogicalUnit')){
						ForEach($LU in $($PSBoundParameters['iSCSILogicalUnit'])){
							$iSCSIStorageSpecs | Add-Member -MemberType NoteProperty -Name 'logical_unit' -Value  $([PSCustomObject]@{"id"=$LU})
						}
						<#
						#Alternate Code entry for LUN Ids
						$iSCSILUNStorageSpecs = [PSCustomObject]@{}
						$LUNIdArray = [System.Collections.ArrayList]@()
						ForEach($LU in $PSBoundParameters['iSCSILogicalUnit']){
							$LUNIdArray.Add($LU) | Out-Null
						}
						$iSCSILUNStorageSpecs | Add-Member -MemberType NoteProperty -Name 'id' -Value $LUNIdArray
						$iSCSIStorageSpecs | Add-Member -MemberType NoteProperty -Name 'logical_unit' -Value $iSCSILUNStorageSpecs
						#>
						$oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'logical_units' -Value $iSCSIStorageSpecs
					}
				}
							
			}ElseIF($PSBoundParameters['StorageDomainType'] -eq "managed_block_storage"){
				<#
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage/attributes/driver_options
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage/attributes/driver_sensitive_options
					The options to be passed when creating a storage domain using a cinder driver.
				#>

				$StorageDriverPropertySpecs = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('SANIpAddress')){ $StorageDriverPropertySpecs | Add-Member -MemberType NoteProperty -Name 'san_ip' -Value $($PSBoundParameters['SANIpAddress']) }
				IF($PSBoundParameters.ContainsKey('SANLoginUsername')){ $StorageDriverPropertySpecs | Add-Member -MemberType NoteProperty -Name 'san_login' -Value $($PSBoundParameters['SANLoginUsername']) }
				IF($PSBoundParameters.ContainsKey('SANLoginPassword')){ $StorageDriverPropertySpecs | Add-Member -MemberType NoteProperty -Name 'san_password' -Value $($PSBoundParameters['SANLoginPassword']) }
				IF($PSBoundParameters.ContainsKey('UseMultipathForImageXfer')){ $StorageDriverPropertySpecs | Add-Member -MemberType NoteProperty -Name 'use_multipath_for_image_xfer' -Value $($PSBoundParameters['UseMultipathForImageXfer']) }
				IF($PSBoundParameters.ContainsKey('VolumeDriver')){ $StorageDriverPropertySpecs | Add-Member -MemberType NoteProperty -Name 'volume_driver' -Value $($PSBoundParameters['VolumeDriver']) }
				
				$StorageDriverSpecs = [PSCustomObject]@{"property"=$StorageDriverPropertySpecs}
				$oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'driver_options' -Value $StorageDriverSpecs
				
				IF($PSBoundParameters.ContainsKey('VolumeDriver')){
					IF($PSBoundParameters['VolumeDriver'] -Match "cinder"){
						$StorageDriverSensitiveOptionSpecs = [PSCustomObject]@{}
						IF($PSBoundParameters.ContainsKey('VolumeDriverUsername')){ $StorageDriverSensitiveOptionSpecs | Add-Member -MemberType NoteProperty -Name 'username' -Value $($PSBoundParameters['VolumeDriverUsername']) }
						IF($PSBoundParameters.ContainsKey('VolumeDriverPassword')){ $StorageDriverSensitiveOptionSpecs | Add-Member -MemberType NoteProperty -Name 'password' -Value $($PSBoundParameters['VolumeDriverPassword']) }
						IF($PSBoundParameters.ContainsKey('VolumeDriverSANIpAddress')){ $StorageDriverSensitiveOptionSpecs | Add-Member -MemberType NoteProperty -Name 'san_ip' -Value $($PSBoundParameters['VolumeDriverSANIpAddress']) }
						$StorageDriverSensitiveSpecs = [PSCustomObject]@{"property"=$StorageDriverPropertySpecs}
						$oStorageSpecs | Add-Member -MemberType NoteProperty -Name 'driver_sensitive_options' -Value $StorageDriverSensitiveSpecs
					}
				}
			}	
		}
		$oStorageDomainSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $oStorageSpecs
		
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/storagedomains"
		#IF($PSBoundParameters.ContainsKey('DeployHostedEngine')){ $Uri = $BaseURL + "/ovirt-engine/api/hosts?deploy_hosted_engine=true" }
		$Method = "POST"
		$JsonBody = $oStorageDomainSpecs | ConvertTo-Json -Depth 50
		#$JsonBody | ConvertFrom-Json2Xml
		#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oStorageDomain"
		Write-Verbose "$($JsonBody | Out-String)"
		$NewoStorageDomain = $Null
		#TRY{$NewoStorageDomain = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
		TRY{$NewoStorageDomain = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoStorageDomain){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoStorageDomain -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName)) | Out-Null}
		IF($NewoStorageDomain){
			Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			IF($oDataCenterObjects){
				<#
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#_attach_storage_domains_to_data_center
					The following example attaches the mydata storage domain to the Default data center.
					To attach the mydata storage domain
					
					POST /ovirt-engine/api/datacenters/001/storagedomains
					<storage_domain><name>mydata</name></storage_domain>
				#>
				$oDomainAttachSpecs = [PSCustomObject]@{"name"=$NewoStorageDomain.Name}
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/datacenters/$($oDataCenterObjects.Id)/storagedomains"
				$Method = "POST"
				$JsonBody = $oDomainAttachSpecs | ConvertTo-Json -Depth 50
				#$JsonBody | ConvertFrom-Json2Xml
				#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Attach oStorageDomain to oDataCenter"
				Write-Verbose "$($JsonBody | Out-String)"
				$oDataCenterJob = $Null
				TRY{$oDataCenterJob = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($oDataCenterJob){Write-Host -NoNewLine -Fore Green "Attached New oStorageDomain ["; Write-Host -NoNewLine "$($NewoStorageDomain.Name)"; Write-Host -NoNewLine -Fore Green "] to oDataCenter ["; Write-Host -NoNewLine "$($oDataCenterObjects.Name)"; Write-Host -Fore Green "]"; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Export-oTemplate{
	<#
		.SYNOPSIS
			This function exports an oTemplate from an oVirt system
		.DESCRIPTION
			Exports a template to a folder path as an OVA file, or to the data center export domain (depricated).
		.PARAMETER Name
			The Name of the oTemplate or the oTemplate object.
			Can use Wildcard '*' for name
				I.e. MyIte*
		.PARAMETER Id
			The Id(s) of the oTemplate
		.PARAMETER Uid
			The Uid(s) of the oTemplate
		.PARAMETER ExportType
			Valid Options are "OVA", "ExportDomain"
			Default is OVA
		.PARAMETER oHost
			The Name of the parent oHost for the oTemplate Export
		.PARAMETER oHostId
			The Id of the parent oHost for the oTemplate Export
		.PARAMETER oHostUid
			The Uid of the parent oHost for the oTemplate Export
		.PARAMETER Directory
			Folder to deposit the new OVA file on the KVM host
			Example "ova:///mnt/ova"
		.PARAMETER FileName
			File Name to create the new OVA file on the KVM host
			Example "ova_template.ova"
		.PARAMETER DiscardSnapshots
			Use the discard_snapshots parameter when the virtual machine should be exported with all of its snapshots collapsed.
		.PARAMETER oStorageDomain
			The Name of the oStorageDomain for the oTemplate Export
			Can use Wildcard '*'
		.PARAMETER oStorageDomainId
			The Id of the oStorageDomain for the oTemplate Export
		.PARAMETER oStorageDomainUid
			The Uid of the oStorageDomain for the oTemplate Export
		.PARAMETER Exclusive
			Indicates if the existing templates with the same name should be overwritten.
			The export action reports a failed action if a template of the same name exists in the destination domain.
			Set this parameter to true to change this behavior and overwrite any existing template.
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Export-oTemplate -Name $oTemplate -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
			[Boolean]
			[oTemplate]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oTemplate]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/19/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/template
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/export
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/template/methods/export
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain_type
		.LINK
			New-oTemplate
			Get-oTemplate
			Set-oTemplate
			Import-oTemplate
			Remove-oTemplate
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'OVA')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oTemplate'})]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("OVA","ExportDomain")]
			[System.String]$ExportType = "OVA",
		
		#Export as OVA
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[ValidateScript({($_).GetType().Name -match 'String|oHost'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[System.String]$Directory,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[System.String]$FileName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="OVA")]
			[SWITCH]$DiscardSnapshots,
		
		#Export to Export DOMAIN
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="ExportDomain")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidateScript({($_).GetType().Name -match 'oStorageDomain|String'})]$oStorageDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="ExportDomain")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oStorageDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="ExportDomain")]
			[Parameter(ParameterSetName="AsGlanceImageTemplate")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oStorageDomainUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="ExportDomain")]
			[SWITCH]$Exclusive,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="ExportDomain")]
			[SWITCH]$Force,
		
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		#$OutPutItems = [System.Collections.ArrayList]@()
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oTemplate]: [$($PSBoundParameters['oTemplate'] -IS [oTemplate])]"
		$oTemplateOBjects = $Null
		IF($PSBoundParameters['UId']){
			$UidUrl = [Uri]$Uid
			$oTemplateOBjects = Get-oTemplate -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			IF($oTemplateOBjects){$oTemplateOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['Id']){
			IF($PSBoundParameters['oVirtServerName']){
				$oTemplateOBjects = Get-oTemplate -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
			}Else{
				$oTemplateOBjects = Get-oTemplate -Id $PSBoundParameters['Id'] -EA SilentlyContinue
			}
			IF($oTemplateOBjects){$oTemplateOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['Name']){
			SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oTemplateOBjects = Get-oTemplate -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oTemplateOBjects = Get-oTemplate -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oTemplateOBjects){$oTemplateOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oTemplateOBjects = Get-oTemplate -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oTemplateOBjects = Get-oTemplate -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oTemplateOBjects){$oTemplateOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oTemplate]}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is [oTemplate]"
					$oTemplateOBjects = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oTemplate"}{
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate GetType equals [oTemplate]"
					$oTemplateOBjects = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oTemplate is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$oTemplateOBjects Names: $($oTemplateOBjects.Name)"
		
		$oHostObjects = $Null
		IF($PSBoundParameters['oHostUid']){
			$UidUrl = [Uri]$oHostUid
			$oHostObjects = Get-oHost -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oHostId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oHostObjects = Get-oHost -Id $PSBoundParameters['oHostId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
			}Else{
				$oHostObjects = Get-oHost -Id $PSBoundParameters['oHostId'] -EA SilentlyContinue
			}
			IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oHost']){
			SWITCH($PSBoundParameters['oHost']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
					}
					IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oHostObjects = Get-oHost -Name $PSBoundParameters['oHost'] -EA SilentlyContinue
					}
					IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oHost]}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost is [oHost]"
					$oHostObjects = $PSBoundParameters['oHost']
				}
				{$_.GetType().Name -eq "oHost"}{
					Write-Verbose "$($MyInvocation.MyCommand) oHost GetType equals [oHost]"
					$oHostObjects = $PSBoundParameters['oHost']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		$oStorageDomainObjects = $Null
		IF($PSBoundParameters['oStorageDomainUid']){
			$PSBoundParameters['oStorageDomainUid'] | %{
				$UidUrl = [Uri]$_
				$oStorageDomainObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oStorageDomain" -oVirtServerName $oVirtServerName})
				IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oStorageDomainId']){
			ForEach($ItemId in $PSBoundParameters['oStorageDomainId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oStorageDomainObjects += Get-oStorageDomain -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oStorageDomainObjects += Get-oStorageDomain -Id $ItemId -EA SilentlyContinue
				}
				IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oStorageDomain']){
			ForEach($Item in $PSBoundParameters['oStorageDomain']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oStorageDomainObjects += Get-oStorageDomain -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
						}Else{
							$oStorageDomainObjects += Get-oStorageDomain -Name $Item -EA SilentlyContinue
						}
						IF($oStorageDomainObjects){$oStorageDomainObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{($_ -IS [oStorageDomain]) -OR ($_.GetType().Name -eq "oStorageDomain")}{
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is [oStorageDomain]"
						$oStorageDomainObjects += $Item
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oStorageDomain is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		ForEach($TargetoTemplate in $oTemplateOBjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoTemplate [$($TargetoTemplate.Name)]"
			$oVirtServerName = $TargetoTemplate.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			IF($TargetoTemplate.status -eq "ok"){
				IF(!($PSBoundParameters['ExportType'])){$PSBoundParameters['ExportType'] = "OVA"}
				IF($ExportType -eq "OVA"){
					IF($oHostObjects){
						IF($oHostObjects.status | Sort -u | ?{$_ -eq "up"}){
							$oHostObject = $oHostObjects | ?{$_ -eq "up"} | Select -First 1
							$oTemplateExportSpecs = [PSCustomObject]@{}
							#$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name host -Value $([PSCustomObject]@{"id"=$oHostObject.Id})
							$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name host -Value $([PSCustomObject]@{"name"=$oHostObject.name})
							IF($PSBoundParameters['Directory']){
								#Is a windows or Linux Path? Maybe just look for forward slashes for Linux? "ova:///mnt/ova/ova_template.ova"
								IF($PSBoundParameters['Directory'] -Match "ova:///"){
									$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name directory -Value $($PSBoundParameters['Directory'])
								}Else{
									#Does Folder Exist On Windows Local Machine?
									IF(!(Test-Path -Path $PSBoundParameters['Directory'])){WRITE-WARNING "Invalid Directory Provided"; BREAK}
									$Access = $NULL ; $Result = $NULL
									$Guid = [System.Guid]::NewGuid()
									[VOID](Get-ChildItem -Path $PSBoundParameters['Directory'] -EA SilentlyContinue -EV Result)
									IF($Result.Count -eq 0){$Access += "Read"}
									Set-Content $PSBoundParameters['Directory']\$Guid -Value $NULL -EA SilentlyContinue -EV Result
									IF($Result.Count -eq 0){
											$Access += "Write"
											Remove-Item -Force $PSBoundParameters['Directory']\$Guid
									}
									IF($Access -eq "ReadWrite"){
										$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name directory -Value $($PSBoundParameters['Directory'])
									}Else{
										Write-Warning "Provided Directory [$($PSBoundParameters['Directory'])] is [$($Access)], but 'ReadWrite' is required."
									}
								}
							}Else{
								$PSBoundParameters['Directory'] = Get-oFolderPath -Title "Select Folder to Export Template OVA File"
								IF($PSBoundParameters['Directory']){
									$Access = $NULL ; $Result = $NULL
									$Guid = [System.Guid]::NewGuid()
									[VOID](Get-ChildItem -Path $PSBoundParameters['Directory'] -EA SilentlyContinue -EV Result)
									IF($Result.Count -eq 0){$Access += "Read"}
									Set-Content $PSBoundParameters['Directory']\$Guid -Value $NULL -EA SilentlyContinue -EV Result
									IF($Result.Count -eq 0){
											$Access += "Write"
											Remove-Item -Force $PSBoundParameters['Directory']\$Guid
									}
									IF($Access -eq "ReadWrite"){
										$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name directory -Value $($PSBoundParameters['Directory'])
									}Else{
										Write-Warning "Provided Directory [$($PSBoundParameters['Directory'])] is [$($Access)], but 'ReadWrite' is required."
									}
								}
							}
							IF($PSBoundParameters['FileName']){
								$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name filename -Value $($PSBoundParameters['FileName'])
							}Else{
								[void][Reflection.Assembly]::LoadWithPartialName('Microsoft.VisualBasic')
								$BoxTitle   = 'Enter Export Template OVA File Name:'
								$BoxMessage = "Select Name for Export Template OVA File"
								$PSBoundParameters['FileName'] = [Microsoft.VisualBasic.Interaction]::InputBox($BoxTitle, $BoxMessage)
								IF($PSBoundParameters['FileName']){
									$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name filename -Value $($PSBoundParameters['FileName'])
								}Else{
									$PSBoundParameters['FileName'] = "$($TargetoTemplate.name).ova"
									IF($PSBoundParameters['FileName']){
										$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name filename -Value $($PSBoundParameters['FileName'])
									}
								}
							}
							IF($PSBoundParameters['DiscardSnapshots'].IsPresent -eq $True){
								$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name discard_snapshots -Value $True
							}
							IF((($oTemplateExportSpecs.host.name) -or ($oTemplateExportSpecs.host.id)) -And ($oTemplateExportSpecs.directory) -AND ($oTemplateExportSpecs.filename)){
								#Send to Server
								Write-Verbose "$($MyInvocation.MyCommand): `$oTemplateExportSpecs [$($oTemplateExportSpecs | Out-String)]"
								Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
								$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
								$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
								$Uri = $BaseURL + "/ovirt-engine/api/templates/$($TargetoTemplate.ID)/export"
								$Method = "POST"
								$JsonBody = $oTemplateExportSpecs | ConvertTo-Json -Depth 50
								#$JsonBody | ConvertFrom-Json2Xml
								#($oTemplateExportSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
								Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Export oTemplate to Export Domain"
								Write-Verbose "$($JsonBody | Out-String)"
								$oTemplateExport = $Null
								TRY{$oTemplateExport = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
								$oTemplateExport
							}
						}Else{Write-Warning "There are no provided oHosts in 'up' status"}
					}Else{Write-Warning "No oHosts found matching provided input parameters."}
				}Else{
					IF($oStorageDomainObjects){
						IF($oStorageDomainObjects.type | Sort -u | ?{$_ -eq "export"}){
							$oStorageDomainObject = $oStorageDomainObjects | Select -First 1
							$oTemplateExportSpecs = [PSCustomObject]@{}
							$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name storage_domain -Value $([PSCustomObject]@{"id"=$oStorageDomainObject.Id})
							#IF($PSBoundParameters.ContainsKey('exclusive')){$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name exclusive -Value $True}
							IF($PSBoundParameters['Exclusive'].IsPresent -eq $True){$oTemplateExportSpecs | Add-Member -MemberType NoteProperty -Name exclusive -Value $True}
							
							Write-Verbose "$($MyInvocation.MyCommand): `$oTemplateExportSpecs [$($oTemplateExportSpecs | Out-String)]"
							Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
							$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
							$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
							#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
							$Uri = $BaseURL + "/ovirt-engine/api/templates/$($TargetoTemplate.ID)/export"
							$Method = "POST"
							$JsonBody = $oTemplateExportSpecs | ConvertTo-Json -Depth 50
							#$JsonBody | ConvertFrom-Json2Xml
							#($oTemplateExportSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
							Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Export oTemplate to Export Domain"
							Write-Verbose "$($JsonBody | Out-String)"
							$oTemplateExport = $Null
							TRY{$oTemplateExport = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
							$oTemplateExport
						}Else{Write-Warning "There is no Export Domain to export the Template into. Please attach an Export Domain to the Template's Data Center."}
					}Else{Write-Warning "No oStorageDomains found matching provided input parameters."}
				}
			}Else{
				#NotifyAndSkip
				Write-Warning "oTemplate [$($TargetoTemplate.Name)] is in state [$($TargetoTemplate.status)] and can not be modified presently"
			}
		}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function New-oTemplate{
	<#
		.SYNOPSIS
			This function copies an oVM to a new oTemplate, on an oVirt Server system.
		.DESCRIPTION
			his function copies an oVM to a new oTemplate, on an oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oTemplate
			Can use Wildcard '*'
		.PARAMETER Comment
			Free text containing comments about this object.
			Documentation suggests this exists, but testing shows it is never returned as an object property, nor is a property in the UI
		.PARAMETER Description
			A human-readable description in plain text.
		.PARAMETER oVM
			The Name/Object of the Source oVM for the new oTemplate(s)
		.PARAMETER oVMId
			The Id of the Source oVM for the new oTemplate(s)
		.PARAMETER oVMUid
			The Uid of the Source oVM for the new oTemplate(s)
		.PARAMETER oDataCenter
			The Name of the parent oDataCenter for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oDataCenterId
			The Id of the parent oDataCenter for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oDataCenterUid
			The Uid of the parent oDataCenter for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oCluster
			The Name of the parent oCluster for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oClusterId
			The Id of the parent oCluster for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oClusterUid
			The Uid of the parent oCluster for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oCpuProfile
			The Name of the parent oCpuProfile for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oCpuProfileId
			The Id of the parent oCpuProfile for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER oCpuProfileUid
			The Uid of the parent oCpuProfile for the new oTemplate(s)
			If Not provided will use the Source oVM's current location
		.PARAMETER CreateAsATemplateSubVersion
			Create as a Template Sub-Version
			Feature Not Completed Yet
		.PARAMETER AllowAllUsersToAccessThisTemplate
			Allow all users to access this Template
			Disabled in this version, service accounts, not copied correctly, and extar create permission, needs reviewd
		.PARAMETER CopyVMPermissions
			Copy VM permissions
			Specifies if the permissions of the virtual machine should be copied to the template.
			If this optional parameter is provided, and its value is true, then the permissions of 
			the virtual machine (only the direct ones, not the inherited ones) will be copied to the created template.
		.PARAMETER SealTemplate
			Seal Template (Linux only)
			Seals the template.
			If this optional parameter is provided and its value is true, then the template is sealed after creation.
			Sealing erases all host-specific configuration from the filesystem: SSH keys, UDEV rules, MAC addresses, 
			system ID, hostname, and so on, thus making it easier to use the template to create multiple virtual machines without manual intervention.
			Currently, sealing is supported only for Linux operating systems.
		.PARAMETER Alias
			Disk Allocation	oDisk Alias if only one oDisk is used
			Not Required, this is an override option
		.PARAMETER VirtualSizeGiB
			Disk Allocation	Virtual Size (GiB)
		.PARAMETER Format
			Disk Allocation	Format
			Valid options "cow", "raw"
		.PARAMETER Sparse
			Indicates if the physical storage for the disk should not be preallocated.
		.PARAMETER oStorageDomain
			Target <Storage Domain>
			If Not provided will use the Source oVM's current location
		.PARAMETER oStorageDomainId
			Target <Storage Domain>
			If Not provided will use the Source oVM's current location
		.PARAMETER oStorageDomainUid
			Target <Storage Domain>
			If Not provided will use the Source oVM's current location
		.PARAMETER oDiskProfile
			Not Used
		.EXAMPLE
			PS> New-oTemplate -oVirtServerName $oVirtServerName -Name "Name" -oCluster "oClusterName" -oVM 'vm.domain.com' -Comment 'blah'
				Creates a new oTemplate with the provided Name
		.INPUTS
			[System.String]
			[oCluster]
			[oCpuProfile]
			[oDataCenter]
			[oDiskProfile]
			[oStorageDomain]
			[oVM]
			[Boolean]
			[Int32]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oTemplate]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/13/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/templates
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/templates/methods/add
		.LINK
			Get-oTemplate
			Set-oTemplate
			Import-oTemplate
			Export-oTemplate
			Remove-oTemplate
			Get-Help
	#>	
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oVM|String'}})]$oVM,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oVMId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oVMUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oCluster|String'}} )]$oCluster,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oClusterId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oClusterUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oCpuProfile|String'}} )]$oCpuProfile,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oCpuProfileId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oCpuProfileUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oStorageDomain|String'}} )]$oStorageDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oStorageDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oStorageDomainUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Alias,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Int32]$VirtualSizeGiB,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet('cow', 'raw')]
			[System.String]$Format,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$Sparse,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$CreateAsATemplateSubVersion,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
		#	[SWITCH]$AllowAllUsersToAccessThisTemplate,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$CopyVMPermissions,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$SealTemplate,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		#$OutPutItems = [System.Collections.ArrayList]@()
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
		$oHostObjects = [System.Collections.ArrayList]@()
		$oVMObjects = [System.Collections.ArrayList]@()
		$oClusterObjects = [System.Collections.ArrayList]@()
		$oCpuProfileObjects = [System.Collections.ArrayList]@()
		$oStorageDomainObjects = [System.Collections.ArrayList]@()
		#$oDiskProfileObjects = [System.Collections.ArrayList]@()
	}
	Process{
		IF($PSBoundParameters['oVirtServerName']){$oVirtServerName = $PSBoundParameters['oVirtServerName']}
		
		IF($PSBoundParameters['oVMUid']){
			$PSBoundParameters['oVMUid'] | %{
				$UidUrl = [Uri]$_
				#$oVMObjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
