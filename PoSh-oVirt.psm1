#region Helper_Functions

Function IsAdmin{(New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)}

Function Convert-FromEpochTime{
	<#
		.SYNOPSIS
			Converts Epoch Time to Local Time or to UTC Time
		.DESCRIPTION
			Converts Epoch Time to Local Time or to UTC Time
		.PARAMETER EpochTimeMS
			An 64-bit integer containing the number of milliseconds since Jan 1st 1970, also known as epoch time
		.PARAMETER UTC
			A switch to return the Time in UTC
		.EXAMPLE
			PS> Convert-FromEpochTime -EpochTimeMS $EpochTimeMS
		.INPUTS
			[Int64]
		.OUTPUTS
			[System.DateTime]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/22/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding()]
	Param(
		#Epoch Time Milliseconds
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0, HelpMessage="Epoch Time Milliseconds")]
			[Alias('E')]
			[INT64]$EpochTimeMS,

		#Return in UTC
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Epoch Time Milliseconds")]
			[Alias('U')]
			[SWITCH]$UTC
	)
	Begin{$EpochBaseTime = '00:00:00 GMT, January 1, 1970'}
	Process{
		IF($UTC.IsPresent -eq $True){
			(Get-Date $EpochBaseTime).ToUniversalTime().AddMilliseconds($EpochTimeMS)
		}Else{
			IF((Get-Date).IsDaylightSavingTime()){
				(Get-Date $EpochBaseTime).ToUniversalTime().AddMilliseconds($EpochTimeMS).ToLocalTime()
			}Else{
				(Get-Date $EpochBaseTime).AddMilliseconds($EpochTimeMS)
			}
		}
	}
	End{}
}

Function Convert-ToEpochTime{
	<#
		.SYNOPSIS
			Converts DateTime in Universal Time to Epoch Time in Milliseconds
		.DESCRIPTION
			Converts DateTime to Epoch Time (A 64-bit integer containing the number of milliseconds since Jan 1st 1970)
			DateTime Ticks represent the total number of ticks in local time (not UTC) since the DateTime epoch, which is 
			midnight on January 1st in the year 1AD. (Each tick is 100 nanoseconds; there are 10,000 ticks in a millisecond.)
			It gets more complicated due to time zones (and DateTime's poor design) but that's the basics.
			An 64-bit integer containing the number of milliseconds since Jan 1st 1970, also known as epoch time
		.PARAMETER DateTime
			DateTime to Convert in Local Time
		.PARAMETER DateTimeUTC
			DateTime to Convert in UTC
		.EXAMPLE
			PS> Convert-ToEpochTime -DateTime (Get-Date "8/1/2024 12:00:00PM")
		.EXAMPLE
			PS> Convert-ToEpochTime -DateTimeUTC (Get-Date "8/1/2024 12:00:00PM").ToUniversalTime()
		.INPUTS
			[System.DateTime]
		.OUTPUTS
			[Int64]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/9/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#Epoch Time Milliseconds
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0, HelpMessage="Epoch Time Milliseconds")]
			[Alias('D')]
			[DateTime]$DateTime,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0, HelpMessage="Epoch Time Milliseconds")]
			[Alias('U')]
			[DateTime]$DateTimeUTC
	)
	Begin{$EpochBaseTime = '00:00:00 GMT, January 1, 1970'}
	Process{
		#Note Once you convert a DateTime PSObject to Universal, It can NOT be converted agin, it is recognized as UTC
		IF($PSBoundParameters['DateTime']){
			$EpochTime = Get-Date ($DateTime).ToUniversalTime() -UFormat %s
		}ElseIF($PSBoundParameters['DateTimeUTC']){
			$EpochTime = Get-Date ($DateTimeUTC) -UFormat %s
		}
		$EpochTimeMS = ([Math]::Round((([Decimal]$EpochTime)*1000)))
		$EpochTimeMS
	}
	End{}
}

#Helper Function, To Generate an OAuth Token
Function Get-oVirtToken{
	<#
		.SYNOPSIS
			Logs In to an oVirt Server and returns an Authentication Token for subsequent connections
		.DESCRIPTION
			Logs In to an oVirt Server and returns an Authentication Token for subsequent connections
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtCredential
			The PSCredential to be used to connect to the -oVirtServerName, if not already connected
			NOTE: If using LDAP the user credential should be in the form:
				"username@domain1.com@domain1.com"
				
				When using AD ldap the user name needs to be submitted in the format: SamAccountName@ADForrest@ADDomain
		.EXAMPLE
			PS> $oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName 
		.EXAMPLE
			PS> $oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential (Get-Credential -UserName 'admin@internal' -Message "Enter Password for $($oVirtServerName)")
		.EXAMPLE
			PS> $oVirtToken = Get-oVirtToken -oVirtServerName $oVirtServerName -oVirtCredential (Get-Credential -UserName 'admin@localhost' -Message "Enter Password for $($oVirtServerName)")
				NOTE: Not likely to use 'admin@localhost', included example for user domain reference
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCredential]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVirtToken]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/22/2024
			Version 1.1		6/23/2025 Updated for PS Core Compatibility
			Version 1.2		8/14/2025 Updated TokenTypicalTimeOutMinutes handling
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01', SupportsShouldProcess, ConfirmImpact = 'High')] #Needs -Confirm:$true
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0, HelpMessage="oVirtServerName (Name or IP)")]
			#[ValidateScript({Try{((Get-WmiObject -Class Win32_PingStatus -Filter "(Address=$($_) AND (timeout='1000') AND (ResolveAddressNames=TRUE)").StatusCode -eq 0)}Catch [System.Management.Automation.ItemNotFoundException]{Throw [System.Management.Automation.ItemNotFoundException] "${_} Does Not Ping"} })]
			#PS6 + [ValidateScript({((Get-WmiObject -Class Win32_PingStatus -Filter "(Address=$($_) AND (timeout='1000') AND (ResolveAddressNames=TRUE)").StatusCode -eq 0)}, ErrorMessage="${_} Does Not Ping")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
		#Credentials for oVirt Server (admin@internal is the default user on non KeyCloak authentication servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[System.Management.Automation.PSCredential]$oVirtCredential,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,DontShow)]
			[INT32]$TokenTimeOutMinutes
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
	}
	Process{
		#So far in testing I have run over 20 hours, with regular repeat connections every few minutes, NOT using "Prefer" = "persistent-auth", and up to 30 minutes tested in between checks
		#Typical time out with no activity is 30 minutes
		#Activity keeps the Token valid up to the Token "exp" time (or the calculated for display time   (Show-oVirtConnection | Where{$_.Name -eq $PSBoundParameters['oVirtServerName']}).Expires  )
		#$TokenTypicalTimeOutMinutes is set by default to 30 Minutes below, but can be overridden by input parameter -TokenTimeOutMinutes
		#Discovered this is saved in /etc/ovirt-engine/engine-config	UserSessionTimeOutInterval
			# engine-config -g UserSessionTimeOutInterval
				# Picked up JAVA_TOOL_OPTIONS: -Dcom.redhat.fips=false
				# UserSessionTimeOutInterval: 30 version: general
			# engine-config -s UserSessionTimeOutInterval=30
			# so probably saved in the DB
			# probably a balance of performance impact by too many idle sessions vs too many new token requests
			# 
			# cat /etc/ovirt-engine/engine-config/engine-config.properties | grep -i UserSessionTimeOutInterval
				# UserSessionTimeOutInterval.type=Integer
				# UserSessionTimeOutInterval.validValues=-1,1..100000
				# UserSessionTimeOutInterval.description=Timeout interval in minutes, after which inactive user sessions expire. A negative value indicates that sessions never expire.
			#engine-config -s UserSessionTimeOutInterval=30; systemctl restart ovirt-engine
			#I tested and can verify that "UserSessionTimeOutInterval" does control the session idle timeout for both the web UI and API.
			#Which is different from the Token expiration date
			#The session idle timeout OVERRIDES the token expiration date
			#https://bug.oraclecorp.com/pls/bug/webbug_print.show?c_rptno=36282784
		$TokenTypicalTimeOutMinutes = 30
		IF($PSBoundParameters['TokenTimeOutMinutes']){$TokenTypicalTimeOutMinutes = $PSBoundParameters['TokenTimeOutMinutes']; Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes Provided"}Else{Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes NOT Provided"}
		#IF((Get-WmiObject -Class Win32_PingStatus -Filter "(Address=`'$($oVirtServerName)`') AND (timeout=1000) AND (ResolveAddressNames=TRUE)" -EA Stop).StatusCode -ne [INT]'0'){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
		#Check Online
		$OnlineStatus = $Null
		Try{$OnlineStatus = [System.Net.Sockets.TcpClient]::new().ConnectAsync("$($oVirtServerName)", 80).Wait(3000)}Catch{}
		IF($OnlineStatus -ne $True){
			Try{$OnlineStatus = [System.Net.Sockets.TcpClient]::new().ConnectAsync("$($oVirtServerName)", 443).Wait(3000)}Catch{}
		}
		IF($OnlineStatus -ne $True){
			IF(Get-Command -Name Test-Connection -EA SilentlyContinue){
				$OnlineStatus = (Test-Connection -ComputerName $oVirtServerName -Quiet -EA SilentlyContinue)
			}
		}
		IF($OnlineStatus -ne $True){
			#Normally I would pu this first, but reliability tests have shown this to hang under GUI use
			IF(Get-Command -Name Test-NetConnection -EA SilentlyContinue){
				$OnlineStatus = (Test-NetConnection -ComputerName $oVirtServerName -InformationLevel Quiet -EA SilentlyContinue)
			}
		}
		#IF(!(Test-NetConnection -ComputerName $oVirtServerName -InformationLevel Quiet)){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
		IF($OnlineStatus -ne $True){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Respond or Ping"}
		#Try{[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $True }}Catch{}
		[System.Net.ServicePointManager]::ServerCertificateValidationCallback = $Null
		$UserName = $oVirtCredential.GetNetworkCredential().UserName
			Write-Verbose "$($MyInvocation.MyCommand): User Name: $UserName"
		$UserPassword = $oVirtCredential.GetNetworkCredential().Password
		#$UserPassword = Convert-StringToUTF8 -String $UserPassword
			#Write-Verbose "$($MyInvocation.MyCommand): User Password: $UserPassword"
		$UserDomain = $oVirtCredential.GetNetworkCredential().Domain
			Write-Verbose "$($MyInvocation.MyCommand): User Domain: $UserDomain"
		IF($UserDomain.Length -eq 0){
			#Check if using LDAP style UserName SamAccountName@ADDomain
			IF($UserName -Match "^\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*$"){
				$UserName = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[0]
				$UserDomain = ($oVirtCredential.GetNetworkCredential().UserName).Split('@')[1].Split('.')[0]
				#$oVirtCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList "$($UserDomain)\$($UserName)", (ConvertTo-SecureString -String ($oVirtCredential.GetNetworkCredential().Password) -AsPlainText -Force)
				$oVirtCredential = New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList "$($UserDomain)\$($UserName)", (ConvertTo-SecureString -String ($UserPassword) -AsPlainText -Force)
			}Else{
				Write-Warning "User Credential REQUIRES a domain configured on the oVirt server, quitting connection..."; BREAK
			}
		}
		$AuthenticationBody = "grant_type=password&scope=ovirt-app-api&username=$([uri]::EscapeUriString($UserName))%40$([uri]::EscapeUriString($UserDomain))&password=$([uri]::EscapeUriString($UserPassword))"
		Write-Verbose "$($MyInvocation.MyCommand): AuthenticationBody: $AuthenticationBody"
		$AuthenticationHeaders = @{"Accept" = "application/json"}
		Write-Verbose "$($MyInvocation.MyCommand): AuthenticationHeaders: $($AuthenticationHeaders | Out-String)"
		#Does this Extend the life of a token like it does a cookie?
		#$AuthenticationHeaders = @{"Accept" = "application/json"; "Prefer" = "persistent-auth"}
		
		$URI = "https://$($oVirtServerName)/ovirt-engine/sso/oauth/token"
		Write-Verbose "$($MyInvocation.MyCommand): oVirt Server Authentication URI: $URI"
		$ConnectionError = $Null
		IF(Get-Command -Name Invoke-RestMethod -EA SilentlyContinue){
			$ConnectionTime = Get-Date
			Try{
				IF($PSVersionTable.PSEdition -eq "Core"){
					$AuthenticationResponse = Invoke-RestMethod -Uri $URI -Method Post -body $AuthenticationBody -Headers $AuthenticationHeaders -ContentType 'application/x-www-form-urlencoded' -ErrorVariable ConnectionError -SkipCertificateCheck
				}Else{
					$AuthenticationResponse = Invoke-RestMethod -Uri $URI -Method Post -body $AuthenticationBody -Headers $AuthenticationHeaders -ContentType 'application/x-www-form-urlencoded' -ErrorVariable ConnectionError
				}
			}Catch{
				Write-Verbose "$($MyInvocation.MyCommand): oVirt Server Invoke-RestMethod Authentication Failed"
				$FormattedWebError = Format-WebError -WebError $ConnectionError -Uri $URI -Body $AuthenticationBody
				$Global:FormattedWebError = $FormattedWebError
				Write-Verbose "$($MyInvocation.MyCommand): Check `$Global:FormattedWebError"
				IF($FormattedWebError.WebError.Message -Match "Cannot authenticate user"){
					Write-Warning "$($FormattedWebError.WebError.Message.Trim('{}').Split(',') | Out-String)"
				}Else{
					Write-Warning "`$FormattedWebError: $($FormattedWebError | Select * | Out-String)"
					Write-Warning "`$FormattedWebError.ResponseBody : $($FormattedWebError.ResponseBody | Select * | Out-String)"
					Write-Warning "$($Error[0].Exception.Message | Out-String)"
					$LastCommandExecuted = $Null; $LastCommandExecuted = $ConnectionError.InvocationInfo.Line
					#Write-Warning "ConnectionError.ErrorRecord: [$($ConnectionError.ErrorRecord | Select *)]"
					Write-Warning "ConnectionError.ErrorRecord.Exception.Message: [$($ConnectionError.ErrorRecord.Exception.Message)]"
					Write-Warning "ConnectionError.ErrorRecord.Exception.Status: [$($ConnectionError.ErrorRecord.Exception.Status)]"
					Write-Warning "ConnectionError.ErrorRecord.Exception.InnerException.Message: [$($ConnectionError.ErrorRecord.Exception.InnerException.Message)]"
				}
			}
			IF((!($AuthenticationResponse)) -AND (($ConnectionError.ErrorRecord.Exception.Message -eq "The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel.") -OR ($ConnectionError.ErrorRecord.Exception.Status -eq "TrustFailure") -OR ($ConnectionError.ErrorRecord.Exception.InnerException.Message -eq "The remote certificate is invalid according to the validation procedure."))){
				#The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel.
				$LastCommandExecuted = $Null; $LastCommandExecuted = $ConnectionError.InvocationInfo.Line
				Set-SSLTLS
				Do{$ImportCertificateAnswer = Read-Host "Attempt to Import the Web Certificate for oVirt Engine on $($oVirtServerName): [Y/N]"}While(@("Y","N") -NotContains $ImportCertificateAnswer)
				IF($ImportCertificateAnswer -eq "Y"){
					$CertResults = Import-oVirtCertificate -oVirtServerName $oVirtServerName
					IF($LastCommandExecuted){Invoke-Expression -Command $LastCommandExecuted}
				}
			}
			IF($AuthenticationResponse){
				Write-Verbose "$($MyInvocation.MyCommand): Raw Authentication Response 01: $AuthenticationResponse"
				$AuthenticationToken = $AuthenticationResponse.access_token
				$TokenMeta = $AuthenticationResponse
			}
		}ElseIF(Get-Command -Name Invoke-WebRequest -EA SilentlyContinue){
			$ConnectionTime = Get-Date
			Try{
				IF($PSVersionTable.PSEdition -eq "Core"){
					$AuthenticationResponse = Invoke-WebRequest -Uri $URI -Method Post -body $AuthenticationBody -Headers $AuthenticationHeaders -ContentType 'application/x-www-form-urlencoded' -ErrorVariable ConnectionError -SkipCertificateCheck
				}Else{
					$AuthenticationResponse = Invoke-WebRequest -Uri $URI -Method Post -body $AuthenticationBody -Headers $AuthenticationHeaders -ContentType 'application/x-www-form-urlencoded' -ErrorVariable ConnectionError
				}
			}Catch{
				Write-Verbose "$($MyInvocation.MyCommand): oVirt Server Invoke-WebRequest Authentication Failed"
				$FormattedWebError = Format-WebError -WebError $ConnectionError -Uri $URI -Body $AuthenticationBody
				IF($FormattedWebError.WebError.Message -Match "Cannot authenticate user"){
					Write-Warning "$($FormattedWebError.WebError.Message.Trim('{}').Split(',') | Out-String)"
				}Else{
					Write-Warning "$($Error[0].Exception.Message | Out-String)"
					Write-Warning "`$FormattedWebError: $($FormattedWebError | Select * | Out-String)"
					Write-Warning "`$FormattedWebError.ResponseBody : $($FormattedWebError.ResponseBody | Select * | Out-String)"
					
					Write-Warning "$($Error[0].Exception.Message | Out-String)"
					Write-Warning "ConnectionError.ErrorRecord.Exception.Message: [$($ConnectionError.ErrorRecord.Exception.Message)]"
					Write-Warning "ConnectionError.ErrorRecord.Exception.Status: [$($ConnectionError.ErrorRecord.Exception.Status)]"
					Write-Warning "ConnectionError.ErrorRecord.Exception.InnerException.Message: [$($ConnectionError.ErrorRecord.Exception.InnerException.Message)]"
				}
			}
			IF((!($AuthenticationResponse)) -AND (($ConnectionError.ErrorRecord.Exception.Message -eq "The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel.") -OR ($ConnectionError.ErrorRecord.Exception.Status -eq "TrustFailure") -OR ($ConnectionError.ErrorRecord.Exception.InnerException.Message -eq "The remote certificate is invalid according to the validation procedure."))){
				#The underlying connection was closed: Could not establish trust relationship for the SSL/TLS secure channel.
				$LastCommandExecuted = $Null; $LastCommandExecuted = $ConnectionError.InvocationInfo.Line
				Set-SSLTLS
				Do{$ImportCertificateAnswer = Read-Host "Attempt to Import the Web Certificate for oVirt Engine on $($oVirtServerName): [Y/N]"}While(@("Y","N") -NotContains $ImportCertificateAnswer)
				IF($ImportCertificateAnswer -eq "Y"){
					$CertResults = Import-oVirtCertificate -oVirtServerName $oVirtServerName
					IF($LastCommandExecuted){Invoke-Expression -Command $LastCommandExecuted}
				}
			}
			IF($AuthenticationResponse){
				Write-Verbose "$($MyInvocation.MyCommand): Raw Authentication Response 02: $($AuthenticationResponse | FL | Out-String)"
				IF(Get-Command -Name ConvertFrom-Json -EA SilentlyContinue){
					$AuthenticationToken = ($AuthenticationResponse.Content | ConvertFrom-Json).access_token
				}Else{
					$AuthenticationToken = ((($AuthenticationResponse.Content) -split '"')[3])
				}
				$TokenMeta = $AuthenticationResponse.Content | ConvertFrom-Json
				Write-Verbose "$($MyInvocation.MyCommand): Authentication Token: $AuthenticationToken"
			}
		}	
		IF($AuthenticationToken){
			Write-Verbose "$($MyInvocation.MyCommand): AuthenticationToken: $($AuthenticationToken | FL | Out-String)"
			#Return $AuthenticationToken
			$oVirtToken = [oVirtToken]::new()
			$oVirtToken.AccessToken = $AuthenticationToken
				$oVirtToken.Expires = $(IF($TokenMeta.exp -ge 253402300799999){(Convert-FromEpochTime -EpochTimeMS 253402300799999)}Else{(Convert-FromEpochTime -EpochTimeMS $TokenMeta.exp)})
				$oVirtToken.ExpiresUTC = $(IF($TokenMeta.exp -ge 253402300799999){(Convert-FromEpochTime -EpochTimeMS 253402300799999 -UTC)}Else{(Convert-FromEpochTime -EpochTimeMS $TokenMeta.exp -UTC)})
				$oVirtToken.oVirtServerName = $oVirtServerName
				$oVirtToken.ExtensionData = $TokenMeta
				$oVirtToken.oVirtCredential = $oVirtCredential
				$oVirtToken.ConnectionTime = $ConnectionTime
				$oVirtToken.TokenConnectionExpires = ((Get-Date $ConnectionTime).AddMinutes($TokenTypicalTimeOutMinutes))
				$oVirtToken.TokenTypicalTimeOutMinutes = $TokenTypicalTimeOutMinutes
				Write-Verbose "$($MyInvocation.MyCommand): oVirtToken: $($oVirtToken | FL | Out-String)"
			Return $oVirtToken
		}
	}
	End{$UserPassword = $NULL; $oVirtCredential = $NULL;Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Get-oUri{
	<#
		.SYNOPSIS
			Tests an oVirt Server Uri and returns the web response
		.DESCRIPTION
			Tests an oVirt Server Uri and returns the web response
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER RESTUri
			Requires an oVirt-Engine REST API Uri (WITHOUT the https://hostname segment)
			Can be used with the -oVirtServerName, if already connected (and active)
			otherwise it uses the first connection stored in $global:oVirtConnections
		.PARAMETER Uri
			Requires a full oVirt-Engine REST API Uri (with the https://hostname segment)
		.PARAMETER Method
			The REST API Method type. Valid options are 'GET', 'POST', 'PUT', 'DELETE'
			The default is 'GET'
		.PARAMETER Body
			The REST API Body
		.PARAMETER Syncopate
			Switch to Syncopate (truncate/abridge) returned data set
		.EXAMPLE
			PS> $Response = Get-oUri -Uri https://OLVM001.domain.com/ovirt-engine/api/vms/334e7363-16eb-4c1d-bf76-3ec4c8454f5b
		.EXAMPLE
			PS> $Response = Get-oUri -RESTUri /ovirt-engine/api/clusters
		.EXAMPLE
			PS> $Response = Get-oUri -oVirtServerName $oVirtServerName -RESTUri /ovirt-engine/api/clusters
		.EXAMPLE
			PS> $Response = Get-oUri -oVirtServerName $oVirtServerName -Method GET -RESTUri /ovirt-engine/api/clusters
		.INPUTS
			[System.String]
			[System.Management.Automation.PSCredential]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVirtToken]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		3/6/2024
			Version 1.0b	8/28/2024, added Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			Version 1.0c	3/10/2025, added Additional Expired Token Retry
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
		
	#>
	[CmdletBinding(DefaultParameterSetName="Set02")]
	[ALIAS("GoU")]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)][ALIAS("U")][STRING]$Uri,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0)][ALIAS("R")][STRING]$RESTUri,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, Position=1)][ALIAS("O")][STRING]$oVirtServerName,
		[Parameter(ValueFromPipelineByPropertyName=$True)][ValidateSet('GET', 'POST', 'PUT', 'DELETE')][ALIAS("M")][STRING]$Method = "GET",
		[Parameter(ValueFromPipelineByPropertyName=$True)][ALIAS("B")][STRING]$Body = "GET",
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate
		)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
	}
	Process{
		IF($oVirtConnections){
			IF((!($PSBoundParameters['oVirtServerName'])) -AND (!($PSBoundParameters['Uri']))){
				IF($oVirtConnections.oVirtServerName.count -gt 1){
					ForEach($oVirtServerName in $oVirtConnections.oVirtServerName){
						$Error.Clear()
						Get-oUri @PSBoundParameters -oVirtServerName $oVirtServerName
						IF(!($Error[0])){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
					}
				}Else{
					($PSBoundParameters['oVirtServerName'] = $oVirtConnections[0].oVirtServerName) | Out-Null
					$oVirtServerName = $PSBoundParameters['oVirtServerName']
				}
			}Else{
				$oVirtServerName = $PSBoundParameters['oVirtServerName']
			}
			
			IF($PSBoundParameters['Uri']){
				$UriObject = [Uri]$($PSBoundParameters['Uri'])
				Write-Verbose "$($MyInvocation.MyCommand): `$UriObject [$($UriObject | Out-String)]"
				Resolve-oVirtConnection -oVirtServerName $UriObject.Host | Out-Null
				$oVirtServerName = $UriObject.Host
				IF(($Syncopate).IsPresent -eq $True){
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $(($oVirtConnections | ?{$_.oVirtServerName -eq $($UriObject.Host)}).ExtensionData.access_token)"}
				}Else{
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $(($oVirtConnections | ?{$_.oVirtServerName -eq $($UriObject.Host)}).ExtensionData.access_token)"; "All-Content"="true"}
				}
			}Else{
				IF($PSBoundParameters['oVirtServerName']){
					Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters['oVirtServerName']: [$($PSBoundParameters['oVirtServerName'] | Out-String)]"
					Resolve-oVirtConnection -oVirtServerName ($PSBoundParameters['oVirtServerName']) | Out-Null
					$Uri = "https://$($PSBoundParameters['oVirtServerName'])"
					IF(($Syncopate).IsPresent -eq $True){
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $(($oVirtConnections | ?{$_.oVirtServerName -eq $($PSBoundParameters['oVirtServerName'])}).ExtensionData.access_token)"}
					}Else{
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $(($oVirtConnections | ?{$_.oVirtServerName -eq $($PSBoundParameters['oVirtServerName'])}).ExtensionData.access_token)"; "All-Content"="true"}
					}
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Resolving oVirtConnection(s)"
					#Resolve-oVirtConnection -oVirtServerName $oVirtConnections[0].oVirtServerName | Out-Null
					Resolve-oVirtConnection | Out-Null
					IF($oVirtConnections){
						Write-Verbose "$($MyInvocation.MyCommand): `$oVirtConnections[0].oVirtServerName [$($oVirtConnections[0].oVirtServerName | Out-String)]"
						$Uri = "https://$($oVirtConnections[0].oVirtServerName)"
					}
					IF(($Syncopate).IsPresent -eq $True){
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"}
					}Else{
						$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					}
				}
				IF($PSBoundParameters['RESTUri']){
					$Uri = $Uri + $($PSBoundParameters['RESTUri'])
				}
			}
			Write-Verbose "$($MyInvocation.MyCommand): `$Method [$($Method)]"
			Write-Verbose "$($MyInvocation.MyCommand): `$Uri [$($Uri)]"
			Write-Verbose "$($MyInvocation.MyCommand): `$Headers [$($Headers | Out-String)]"
			IF($PSBoundParameters['Body']){
				$JsonBody = $Body | ConvertTo-Json
				Write-Verbose "$($MyInvocation.MyCommand): `$JsonBody [$($JsonBody | Out-String)]"
				Write-Verbose "$($MyInvocation.MyCommand): RestMethod [Invoke-RestMethod -Uri $($Uri) -Headers `$Headers -Method $($Method) -Body `$JsonBody]"
				$Error.Clear()
				Try{Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Uri $Uri -Body $JsonBody); Write-Error $FormattedWebError; $FormattedWebError}
				IF(!($Error[0])){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): RestMethod [Invoke-RestMethod -Uri $($Uri) -Headers `$Headers -Method $($Method)]"
				$Error.Clear()
				Try{Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -EV WebError}Catch{
					Write-Verbose "$($MyInvocation.MyCommand): `$WebError [$($WebError | Out-String)]"; 
					$FormattedWebError = (Format-WebError -WebError $WebError -Uri $Uri); 
					Write-Error $FormattedWebError; 
					IF($FormattedWebError.Exception -Match "Errorinvalid_grant: The provided authorization grant for the auth code has expired."){
						#Check if authenication error and retry
						$UriObject2 = [Uri]$($Uri)
						Resolve-oVirtConnection -oVirtServerName $UriObject2.Host | Out-Null
						Write-Verbose "$($MyInvocation.MyCommand): Trying to correct Token and retry action"
						Try{Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -EV WebError}Catch{
							Write-Verbose "$($MyInvocation.MyCommand): `$WebError [$($WebError | Out-String)]"; 
							$FormattedWebError = (Format-WebError -WebError $WebError -Uri $Uri); 
							Write-Error $FormattedWebError; $FormattedWebError
						}
					}Else{$FormattedWebError}
					
				}
				IF(!($Error[0])){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
			}
		}Else{Write-Warning "No oVirt Connections, use 'Connect-oVirtServer' to create one or more."}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): Done"
	}
}

Function Format-WebError{
	<#
		.SYNOPSIS
			Reads Invoke-RestMethod error stream into a PSObject
		.DESCRIPTION
			Reads Invoke-RestMethod error stream into a PSObject
		.PARAMETER WebError
		.EXAMPLE
			Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		 6/4/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
	#>
	[CmdletBinding()]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]$WebError,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]$Body,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]$Uri
	)
	Write-Verbose "$($MyInvocation.MyCommand): `$PSBoundParameters [$($PSBoundParameters | Out-String)]"
	$ErrorObject = [PSCustomObject]@{
		Message = $WebError.ErrorRecord.Exception.Message
		StatusCode = $WebError.ErrorRecord.Exception.Response.StatusCode.value__
		StatusDescription = $WebError.ErrorRecord.Exception.Response.StatusDescription
		WebError = $WebError
		LastCommandExecuted = $WebError.ErrorRecord.InvocationInfo.Line
	}
	Try{$MemStream = $WebError.ErrorRecord.Exception.Response.GetResponseStream()}Catch{}
	IF($MemStream){
		$ReadStream = New-Object System.IO.StreamReader($MemStream)
		$MultiLineRead = [System.Collections.ArrayList]@()
		While($ReadStream.Peek() -ne -1){$MultiLineRead.Add(($ReadStream.ReadLine())) | Out-Null}
		$ReadStream.Dispose();
	}
	IF($MultiLineRead){
		Add-Member -MemberType NoteProperty -Name ResponseBody -Value $($MultiLineRead | ConvertFrom-Json) -InputObject $ErrorObject
		Add-Member -MemberType NoteProperty -Name RawResponseBody -Value $($MultiLineRead) -InputObject $ErrorObject
	}
	IF($PSBoundParameters.ContainsKey('Body')){ $ErrorObject | Add-Member -MemberType NoteProperty -Name 'SentBody' -Value $Body }
	IF($PSBoundParameters.ContainsKey('Uri')){ $ErrorObject | Add-Member -MemberType NoteProperty -Name 'Uri' -Value $Uri }
	#Use "Update-TypeData" to configure a default display set
	TRY{
		$ErrorObject.PSTypeNames.Insert(0,'User.Information')
		Update-TypeData -TypeName User.Information -DefaultDisplayPropertySet Message,ResponseBody,Uri -EA SilentlyContinue
	}Catch{}
	Write-Verbose "$($MyInvocation.MyCommand): `$RawResponseBody [$($ErrorObject.RawResponseBody | Out-String)]"
	Write-Verbose "$($MyInvocation.MyCommand): `$ResponseBody [$($ErrorObject.ResponseBody | FL | Out-String)]"
	Write-Verbose "$($MyInvocation.MyCommand): `$ResponseBody.Detail [$($ErrorObject.ResponseBody.Detail | Out-String)]"
	Write-Verbose "$($MyInvocation.MyCommand): `$ResponseBody.Reason [$($ErrorObject.ResponseBody.Reason | Out-String)]"
	Return $ErrorObject
}

Function Get-SSLTLS{
	[PSCustomObject]@{
		Current = $([System.Net.ServicePointManager]::SecurityProtocol -join ',')
		Available = $([enum]::GetValues('Net.SecurityProtocolType') -join ',')
		CertificatePolicy = [System.Net.ServicePointManager]::CertificatePolicy
		ServerCertificateValidationCallback = [System.Net.ServicePointManager]::ServerCertificateValidationCallback
	}
}

Function Set-SSLTLS{
	<#
		.SYNOPSIS
			Sets the PowerShell Session to accept all Web Security Protocols 'Ssl3,Tls,Tls11,Tls12,Tls13'
		.DESCRIPTION
			Sets the PowerShell Session to accept all Web Security Protocols 'Ssl3,Tls,Tls11,Tls12,Tls13'
		.PARAMETER Protocol
			Valid option 'Ssl3,Tls,Tls11,Tls12,Tls13'
		.EXAMPLE
			Set-SSLTLS -Protocol 'Ssl3,Tls12,Tls13'
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/21/2024
			Version 1.0b	6/21/2024
			Version 1.0c	6/13/2025
			Version 1.0d	6/17/2025
			Version 1.0e	6/1/2025
			Version 1.0f	9/23/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
    [CmdletBinding()]
	Param(
		[String]$Protocol,
		[Switch]$Quiet
	)
	Write-Verbose "Setting SecurityProtocol"
	# Define the list of protocols to be disabled
	$DisabledProtocols = [System.Net.SecurityProtocolType]::Tls, [System.Net.SecurityProtocolType]::Tls11, [System.Net.SecurityProtocolType]::Ssl3
	$CurrentProtocols = [System.Net.ServicePointManager]::SecurityProtocol
	IF($PSBoundParameters['Quiet'].IsPresent -ne $True){Write-Host "Current Protocol(s): $($CurrentProtocols)"}
	IF($PSBoundParameters['Protocol']){
		$AllProtocols = [System.Net.SecurityProtocolType]$PSBoundParameters['Protocol']
	}Else{
		#Currently OLVM 4.5 uses TLS12
		<#
			Lack of common protocol reports:
			WARNING: ConnectionError.ErrorRecord.Exception.Status: [ReceiveFailure]
			WARNING: ConnectionError.ErrorRecord.Exception.InnerException.Message: [The client and server cannot communicate, because they do not possess a common algorithm]
		#>
		#$AllProtocols = [System.Net.SecurityProtocolType]'Ssl3,Tls,Tls11,Tls12,Tls13'
		#$AllProtocols = ([Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls11 -bor [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13)
		$AllProtocols = ([enum]::GetValues('Net.SecurityProtocolType') | Where-Object {($_ -ge 'Tls12') -OR (($_ -Match 'ssl') | ?{$_ -ge 'Ssl3'}) })
		Write-Verbose "Currently Available SecurityProtocols: [$($AllProtocols -join ', ')]"
	}
	IF($PSBoundParameters['Quiet'].IsPresent -ne $True){Write-Host "Setting New Protocol(s): $($AllProtocols)"}
	ForEach($Protocol in $AllProtocols){Try{[System.Net.ServicePointManager]::SecurityProtocol = $Protocol}Catch{$AllProtocols = $AllProtocols | ?{$_ -ne $Protocol}}Finally{[System.Net.ServicePointManager]::SecurityProtocol = $CurrentProtocols}}
	IF($AllProtocols){
		Write-Verbose "System Available SecurityProtocols: [$($AllProtocols -join ', ')]"
		[System.Net.ServicePointManager]::SecurityProtocol = $AllProtocols
	}
	# [System.Net.ServicePointManager]::SecurityProtocol = $([System.Net.SecurityProtocolType]'Ssl3,Tls,Tls11,Tls12,Tls13')
	
	IF([System.Net.ServicePointManager]::ServerCertificateValidationCallback -Is [System.Net.Security.RemoteCertificateValidationCallback]){
		#Incorrect setting (or changes by other code to this, will cause "The underlying connection was closed: An unexpected error occurred on a receive." Errors)
		IF($PSBoundParameters['Quiet'].IsPresent -ne $True){
			Write-Host -Fore Yellow "Found Setting ServerCertificateValidationCallback: [$([System.Net.ServicePointManager]::ServerCertificateValidationCallback)]"
			Write-Host -Fore Cyan "Setting ServerCertificateValidationCallback to Null"
			[System.Net.ServicePointManager]::ServerCertificateValidationCallback = $Null
			#[System.Net.ServicePointManager]::ServerCertificateValidationCallback = {$True}
			#[Net.ServicePointManager]::ServerCertificateValidationCallback = $Null
			Write-Host "Current ServerCertificateValidationCallback Setting: [$([System.Net.ServicePointManager]::ServerCertificateValidationCallback)]"
		}Else{
			[System.Net.ServicePointManager]::ServerCertificateValidationCallback = $Null
		}
	}
	
	IF($PSVersionTable.PSEdition -eq 'Core'){
		#See this for another method https://github.com/PowerShell/PowerShell/issues/7092
		$Script:PSDefaultParameterValues = @{
			"invoke-restmethod:SkipCertificateCheck" = $true
			"invoke-webrequest:SkipCertificateCheck" = $true
		}
	}Else{
		#Converting above PS 5 Class Command to Base64String to avoid v6+ detection on Module Load
		#Convert-StringToBase64String 'class TrustAllCertsPolicy : System.Net.ICertificatePolicy{[bool] CheckValidationResult([System.Net.ServicePoint]$srvPoint,[System.Security.Cryptography.X509Certificates.X509Certificate]$certificate,[System.Net.WebRequest]$request,[int]$certificateProblem){return $true}}'
		Invoke-Expression -Command $(Convert-oBase64StringToString -Base64String '')
		[System.Net.ServicePointManager]::CertificatePolicy = New-Object -TypeName TrustAllCertsPolicy
	}
	<#
	https://learn.microsoft.com/en-us/dotnet/api/system.net.servicepointmanager.servercertificatevalidationcallback?view=net-8.0
	A RemoteCertificateValidationCallback. The default value is Null.
	#>
	IF($PSBoundParameters['Quiet'].IsPresent -ne $True){
		[PSCustomObject]@{
			Current = $([System.Net.ServicePointManager]::SecurityProtocol -join ',')
			Available = $([enum]::GetValues('Net.SecurityProtocolType') -join ',')
			CertificatePolicy = [System.Net.ServicePointManager]::CertificatePolicy
			ServerCertificateValidationCallback = [System.Net.ServicePointManager]::ServerCertificateValidationCallback
		}
	}
}

Function Test-oWebServerSSL{
	<#
		.SYNOPSIS
			Checks the Status of vCenter and ESXi host SSL Certificates
		.DESCRIPTION
			Checks the Status of vCenter and ESXi host SSL Certificates
		.PARAMETER URL
			The DNS name of the system to check
		.PARAMETER Port
			The port number of the for the SSL connection. Default is 443
		.PARAMETER Proxy
			The web proxy DNS, if needed to connect
		.PARAMETER Timeout
			The Timeout, in milliseconds, to establish a connection. Default is 15000, I.e. 15 seconds
		.PARAMETER UseUserContext
			By default, the certificate must chain up to a trusted CA, which certificate is trusted by the 
			computer (installed in Local Machine\Trusted Root CAs). If the root CA is trusted by only current 
			user — a test will fail. 
			
			You can use this switch to override the default behavior, so the test will succeed if a root CA is 
			trusted only by current user.
		.EXAMPLE
			PS> Get-oHost | Foreach { Test-oWebServerSSL -URL $_.Name | Select OriginalURi, CertificateIsValid, Issuer, @{N="Expires";E={$_.Certificate.NotAfter} }, @{N="DaysTillExpire";E={(New-TimeSpan -Start (Get-Date) -End ($_.Certificate.NotAfter)).Days} }}
				# Check for oHost Certificates
		.EXAMPLE
			PS> Test-oWebServerSSL -URL $oVirtServerName | Select OriginalURi, CertificateIsValid, Issuer, @{N="Expires";E={$_.Certificate.NotAfter} }, @{N="DaysTillExpire";E={(New-TimeSpan -Start (Get-Date) -End ($_.Certificate.NotAfter)).Days} }
				# Check for oVirt Web UI Certificate
		.EXAMPLE
			PS> Test-oWebServerSSL -URL "https://$($oVirtServerName)/ovirt-engine/api" | Select OriginalURi, CertificateIsValid, Issuer, @{N="Expires";E={$_.Certificate.NotAfter} }, @{N="DaysTillExpire";E={(New-TimeSpan -Start (Get-Date) -End ($_.Certificate.NotAfter)).Days} }
				# Check for oVirt REST API Certificate
		.INPUTS
			[System.String]
			[Int32]
		.OUTPUTS
			[Object]
			[System.String]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			This Function found at Linked URL
			Modified to fix ErrorInformation in output object
			Added help
			Version 1.1		11/16/2022
			Version 1.2		6/11/2024 Updated/Renamed for PoSh-oVirt Module
		.LINK	
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK	
			Get-Help
	#>
	[CmdletBinding()]
	Param(
		[Parameter(Mandatory = $True, ValueFromPipeline = $True, Position = 0)][string]$URL,
		[Parameter(Position = 1)][ValidateRange(1,65535)][int]$Port = 443,
		[Parameter(Position = 2)][Net.WebProxy]$Proxy,
		#Timeout 15 Seconds
		[Parameter(Position = 3)][ValidateRange(1,[Int32]::MaxValue)][Int32]$Timeout = 15000,
		#Timeout 600 Seconds, 10 Minutes
		#[Parameter(Position = 3)][Int32]$Timeout = 600000,
		[switch]$UseUserContext
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		$CertFile = $NULL
		$ImportResults = $NULL
	}
	Process{
		IF(!("PKI.Web.WebSSL" -as [Type])){
			TRY{
Add-Type @"
using System;
using System.Net;
using System.Security.Cryptography.X509Certificates;
namespace PKI {
    namespace Web {
        public class WebSSL {
            public Uri OriginalURi;
            public Uri ReturnedURi;
            public X509Certificate2 Certificate;
            //public X500DistinguishedName Issuer;
            //public X500DistinguishedName Subject;
            public string Issuer;
            public string Subject;
            public string[] SubjectAlternativeNames;
            //public bool CertificateIsValid;
            public bool CASigned;
            //public X509ChainStatus[] ErrorInformation;
            public string[] ErrorInformation;
            public HttpWebResponse Response;
        }
    }
}
"@
			}Catch{Write-Verbose "$($MyInvocation.MyCommand): Could not Add-Type 'PKI.Web.WebSSL'"}
		}Else{Write-Verbose "$($MyInvocation.MyCommand): Type 'PKI.Web.WebSSL' Already Loaded"}
		
		IF(([URI]$URL).IsAbsoluteUri){
			$ConnectString = "https://$($([URI]$URL).Host):$($([URI]$URL).port)/"
		}Else{
			$ConnectString = "https://$($url):$($port)/"
		}
		Write-Verbose "$($MyInvocation.MyCommand): ConnectString: [$($ConnectString)]"
		
		$WebRequest = $Null
		$WebRequest = [Net.WebRequest]::Create($ConnectString)
		$WebRequest.Proxy = [System.Net.WebRequest]::DefaultWebProxy
		$WebRequest.Proxy.Credentials = [System.Net.CredentialCache]::DefaultNetworkCredentials
		IF($PSBoundParameters['Proxy']){$WebRequest.Proxy = $PSBoundParameters['Proxy']}
		$WebRequest.Credentials = $Null
		$WebRequest.Timeout = $Timeout
		$WebRequest.AllowAutoRedirect = $True
		#$WebRequest.Headers.Add("UserAgent","Mozilla/4.0+")
		#[System.Net.ServicePointManager]::DefaultConnectionLimit = 1024 #Default is 2
		[Net.ServicePointManager]::ServerCertificateValidationCallback = {$true}
		$Error.Clear()
		$Response = $Null; $ResponseError = $Null
		Write-Verbose "$($MyInvocation.MyCommand): WebRequest: [$($WebRequest)]"
		# TRY {$Response = $WebRequest.GetResponse()} Catch {WRITE-WARNING $("Web Response: `r`n" + ($Error[0].Exception | Out-String))}
		TRY{$Response = $WebRequest.GetResponse()}Catch{$ResponseError = ($Error[0].Exception | Out-String)}
		
		$Output = $Null
		IF($WebRequest.ServicePoint.Certificate -ne $Null){
			Write-Verbose "$($MyInvocation.MyCommand): WebRequest.ServicePoint.Certificate: [$($WebRequest.ServicePoint.Certificate)]"
			#Write-Host "`$WebRequest.ServicePoint.Certificate: $($WebRequest.ServicePoint.Certificate)"
			$Cert = [Security.Cryptography.X509Certificates.X509Certificate2]$WebRequest.ServicePoint.Certificate.Handle
			Write-Verbose "$($MyInvocation.MyCommand): Cert: [$($Cert)]"
			TRY{$SAN = ($Cert.Extensions | Where-Object {$_.Oid.Value -eq "2.5.29.17"}).Format(0) -split ", "}Catch{$SAN = $null}
			$chain = New-Object Security.Cryptography.X509Certificates.X509Chain -ArgumentList (!$UseUserContext)
			[void]$chain.ChainPolicy.ApplicationPolicy.Add("1.3.6.1.5.5.7.3.1")
			$Status = $chain.Build($Cert)
			$Output = New-Object PKI.Web.WebSSL
			IF($Output){
				$Props = ($Output | Get-Member -MemberType Properties | Select -ExpandProperty Name)
				IF($Props -Contains "OriginalUri"){$Output.OriginalUri = $ConnectString}
				#IF($Props -Contains "ReturnedUri"){$Output.ReturnedUri = $(IF($Response){$Response.ResponseUri}ElseIF($ResponseError){$ResponseError})}
				IF($Props -Contains "ReturnedUri"){$Output.ReturnedUri = $(IF($Response){$Response.ResponseUri})}
				IF($Props -Contains "Certificate"){$Output.Certificate = $WebRequest.ServicePoint.Certificate}
				IF($Props -Contains "Issuer"){$Output.Issuer = $WebRequest.ServicePoint.Certificate.Issuer}
				IF($Props -Contains "Subject"){$Output.Subject = $WebRequest.ServicePoint.Certificate.Subject}
				IF($Props -Contains "SubjectAlternativeNames"){$Output.SubjectAlternativeNames = $SAN}
				IF($Props -Contains "CertificateIsValid"){$Output.CertificateIsValid = $Status}
				IF($Props -Contains "CASigned"){$Output.CASigned = $Status}
				IF($Props -Contains "Response"){$Output.Response = $Response}
				IF($Props -Contains "ErrorInformation"){$Output.ErrorInformation = $(IF($chain.ChainStatus){$chain.ChainStatus | ForEach-Object {$_.Status}}ElseIF($ResponseError){$ResponseError}Else{$Null})}
			}Else{Write-Warning "`$Output could not be created"}
			$chain.Reset()
			[Net.ServicePointManager]::ServerCertificateValidationCallback = $null
			$WebRequest.Abort()
		}Else{
			#Write-Error $Error[0]
			IF($ResponseError){Write-Warning "URL: [$($URL)] Failed: $($ResponseError)"}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"; IF($Output){$Output}}
}

Function Import-oVirtCertificate{
	<#
		.SYNOPSIS
			Imports a CA Certificate from an oVirtServer to the local Certificate Store
		.DESCRIPTION
			Imports a CA Certificate from an oVirtServer to the local Certificate Store
			The local CertStoreLocation is 'Cert:\CurrentUser\My'
			
			Validates Certificate not already present
			Removes competing oVirt Certificates (like self-signed if a signed cert has been installed on the oVirt REST API)
			
			Background:
			There are 2 certs per OLVM
			There is a built-in, Self-signed Root Authority, and a second cert for the apache engine
			The first is used by OLVM and KVM and should not be replaced
			The second can be replaced by an alternate cert, to mitigate the self-signed warnings if the replaced cert can be verified by installed root authority certs
			If you install the built-in OLVM cert and don't change the apache cert, it will be verified.
			This function imports both automatically, and if the apache cert can't be verified, a meaningful warning is issued		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Import-oVirtCertificate -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0b	6/11/2024
			Version 1.0c	6/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01', SupportsShouldProcess, ConfirmImpact = 'High')] #Needs -Confirm:$true
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0, HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
			[Switch]$Quiet
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		$CertFile = $NULL
		$ImportResults = $NULL
	}
	Process{
		#Location to Save Cert File Temporarilty
		IF(Test-Path -Path "$($Env:Temp)"){
			$CertFile = "$($Env:Temp)\oVirtServer_ca.crt"
		}ElseIF(Test-Path -Path "$($Env:Tmp)"){
			$CertFile = "$($Env:Tmp)\oVirtServer_ca.crt"
		}ElseIF(Test-Path -Path "$($Env:USERPROFILE)\Documents"){
			$CertFile = "$($Env:USERPROFILE)\Documents\oVirtServer_ca.crt"
		}ElseIF(Test-Path -Path "$($Env:PUBLIC)\Documents"){
			$CertFile = "$($Env:PUBLIC)\Documents\oVirtServer_ca.crt"
		}Else{
			$CertFile = "$(((Get-Location).Path).TrimEnd('\'))\oVirtServer_ca.crt"
		}
		IF($CertFile){
			Write-Verbose "$($MyInvocation.MyCommand): CertFile: [$($CertFile)]"
			IF(Test-Path -Path $CertFile){
				Remove-Item -Path $CertFile -EA SilentlyContinue -Confirm:0
				IF(!(Test-Path -Path $CertFile)){Write-Verbose "$($MyInvocation.MyCommand): Previous CertFile Import Cleaned Up, before new import."}
			}
			IF(!(Test-Path -Path $CertFile)){Write-Verbose "$($MyInvocation.MyCommand): Ready to Import new CertFile."}
			
			#Import the CERT from the OLVM server
			#From the REST API URL
			$oVirt_RestApi_CRT = Test-oWebServerSSL -URL "https://$($oVirtServerName)/ovirt-engine/api"
			#$oVirt_RestApi_CRT.ErrorInformation
			IF($oVirt_RestApi_CRT){Write-Verbose "$($MyInvocation.MyCommand): oVirt_RestApi_CRT: [$($oVirt_RestApi_CRT)]"}
			#From the oVirt Engine URL
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=ca-certificate&format=OPENSSH-PUBKEY"
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=ca-certificate&format=X509-PEM-CA"
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=ca-certificate&format=X509-PEM"
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=engine-certificate&format=OPENSSH-PUBKEY"
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=engine-certificate&format=X509-PEM-CA"
			#Invoke-RestMethod -Uri "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=engine-certificate&format=X509-PEM"
			$WebError = $Null; $CertURL = $Null
			$CertURL = "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=ca-certificate&format=X509-PEM-CA"
			Write-Verbose "$($MyInvocation.MyCommand): CertURL: [$($CertURL)]"
			Try{
				$oVirt_SelfSigned_CRT = Invoke-RestMethod -Uri $CertURL -EV WebError
			}Catch{
				Try{
					Write-Warning "FAILED to Retrieve oVirt Self-Signed Cert from [$($CertURL)], reformatting for secure Url and trying again"
					$CertURL = "https://$($oVirtServerName):443/ovirt-engine/services/pki-resource?resource=ca-certificate&format=X509-PEM-CA"
					$WebError = $Null
					$oVirt_SelfSigned_CRT = Invoke-RestMethod -Uri $CertURL -EV WebError
				}Catch{
					IF($WebError){
						$FormattedWebError = (Format-WebError -WebError $WebError -Body $Null -Uri $CertURL); Write-Error $FormattedWebError; $FormattedWebError; Break
					}Else{Write-Warning "FAILED to Retrieve oVirt Self-Signed Cert from [$($CertURL)]"}
				}
			}
			IF($oVirt_SelfSigned_CRT){
				Write-Verbose "$($MyInvocation.MyCommand): oVirt_SelfSigned_CRT: [$($oVirt_SelfSigned_CRT)]"
				$oVirt_SelfSigned_CRT_Prepped = $oVirt_SelfSigned_CRT.Replace("-----BEGIN CERTIFICATE-----", "")
				$oVirt_SelfSigned_CRT_Prepped = $oVirt_SelfSigned_CRT_Prepped.Replace("-----END CERTIFICATE-----", "")
				$oVirt_SelfSigned_CRT_Prepped = $oVirt_SelfSigned_CRT_Prepped.trim()
				IF($PSVersionTable.PSVersion.Major -lt 6){
					$CertificateData = New-Object System.Security.Cryptography.X509Certificates.X509Certificate2    
					$CertificateData.Import([Convert]::FromBase64String($oVirt_SelfSigned_CRT_Prepped))
				}ElseIF($PSVersionTable.PSVersion.Major -ge 6){
					$CertificateData = [Security.Cryptography.X509Certificates.X509Certificate2]::new([Convert]::FromBase64String($oVirt_SelfSigned_CRT_Prepped))
				}
				Write-Verbose "$($MyInvocation.MyCommand): CertificateData: [$($CertificateData)]"
				
				Function Find-SelfSignCertInStore{
					[CmdletBinding()]
					Param([Array]$Cert)
					Write-Verbose "$($MyInvocation.MyCommand): Running"
					ForEach($Certificate in $Cert){
						Write-Verbose "$($MyInvocation.MyCommand): Search `$Cert: [$($Certificate | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): Search `$Cert.Issuer: [$($Certificate.Issuer | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): Search `$Cert.Subject: [$($Certificate.Subject | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): Search `$Cert.Thumbprint: [$($Certificate.Thumbprint | Out-String)]"
						$ReturnedCert = $NULL
						Try{$ReturnedCerts = (Get-ChildItem -Path 'Cert:' -Recurse -EA SilentlyContinue | ?{$_.psobject.Properties.name -contains "Subject"} | ?{$_.Subject -eq $Certificate.Issuer}) | Sort -Unique -Property Thumbprint}Catch{}
						IF($ReturnedCerts){
							ForEach($ReturnedCert in $ReturnedCerts){
								Write-Verbose "$($MyInvocation.MyCommand): `$ReturnedCert: [$($ReturnedCert | Out-String)]"
								Write-Verbose "$($MyInvocation.MyCommand): `$ReturnedCert.Issuer: [$($ReturnedCert.Issuer | Out-String)]"
								Write-Verbose "$($MyInvocation.MyCommand): `$ReturnedCert.Subject: [$($ReturnedCert.Subject | Out-String)]"
								Write-Verbose "$($MyInvocation.MyCommand): `$ReturnedCert.Thumbprint: [$($ReturnedCert.Thumbprint | Out-String)]"
								IF($ReturnedCert.Subject -eq $ReturnedCert.Issuer){
									Write-Verbose "$($MyInvocation.MyCommand): ReturnedCert Subject matches Issuer"
									Write-Verbose "$($MyInvocation.MyCommand): End"
									Return $ReturnedCert
								}Else{
									Write-Verbose "$($MyInvocation.MyCommand): ReturnedCert Subject does NOT match Issuer, Recursing"
									Find-SelfSignCertInStore -Cert $ReturnedCert
								}
							}
						}Else{
							Write-Warning "No Root Authority certificate found for [$($Certificate.Subject)], Cert can't be trusted"
						}
					}
					Write-Verbose "$($MyInvocation.MyCommand): End"
				}
							
				$OutPutItems = [System.Collections.ArrayList]@()
				$ExistingErrorActionPreference = $ErrorActionPreference
				$ErrorActionPreference = [System.Management.Automation.ActionPreference]::SilentlyContinue
				$AllInstalledCerts = Get-ChildItem -Path 'Cert:' -Recurse -ErrorAction "SilentlyContinue" | Sort -Unique -Property Thumbprint
				$ErrorActionPreference = $ExistingErrorActionPreference
				#Check OLVM System cert "http://$($oVirtServerName)/ovirt-engine/services/pki-resource?resource=ca-certificate&format=X509-PEM-CA"
				IF($AllInstalledCerts | ?{$_ -eq $CertificateData}){
					#Certificate is already present
					Write-Verbose "$($MyInvocation.MyCommand): Built-in OLVM Certificate Already installed in local store"
					Write-Verbose "$($MyInvocation.MyCommand): `$CertificateData: [$($CertificateData | Out-String)]"
					$OutPutItems.Add(
						[PSCustomObject]@{
							"Imported" = "AlreadyPresent"
							"CertificateDecoded" = $CertificateData
							"CertificateEncoded" = $oVirt_SelfSigned_CRT
						}
					) | Out-Null
				}Else{
					#Import Certificate
					Write-Verbose "$($MyInvocation.MyCommand): Built-in OLVM Certificate Not installed in local store, attempting import"
					IF($CertificateData){
						$oVirt_SelfSigned_CRT | Set-Content -Path $CertFile
						#certmgr.msc
						#$ImportResults = Import-Certificate -FilePath $CertFile -CertStoreLocation 'Cert:\CurrentUser\Root' -Confirm:0
						$ImportResults = Import-Certificate -FilePath $CertFile -CertStoreLocation 'Cert:\CurrentUser\My'
						IF($ImportResults){$Imported = $True}Else{$Imported = $False}
						Remove-Item -Path $CertFile -EA SilentlyContinue -Confirm:$False | Out-Null
						$OutPutItems.Add(
							[PSCustomObject]@{
								"Imported" = $Imported
								"CertificateDecoded" = $ImportResults
								"CertificateEncoded" = $oVirt_SelfSigned_CRT
							}
						) | Out-Null
					}
				}
				
				#Check if Root Authority certificate
				IF($CertificateData.Issuer -eq $CertificateData.Subject){
					#Self-Signed
					#Check if Cert is valid for oVirt server name
					IF($CertificateData.Subject -NotMatch $oVirtServerName){
						#Not Root Authority certificate
						$RootCert = $Null; $RootCert = Find-SelfSignCertInStore -Cert $CertificateData
						IF($RootCert){
							#Root Authority Certificate also already installed
							#Nothing to do
							Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate already installed"
						}Else{
							#Warning
							Write-Warning "No root CA certificate found for [$($CertificateData.Subject)], Cert can't be trusted"
						}
					}Else{
						#Is Root Authority certificate
						#Dates valid?
						IF(((Get-Date) -gt $CertificateData.NotBefore) -and ((Get-Date) -lt $CertificateData.NotAfter)){
							#Nothing more to do
							Write-Verbose "$($MyInvocation.MyCommand): Self-Signed Certificate for oVirt RestApi(apache) Time is valid/current"
						}Else{
							#Warn
							Write-Warning "Root Authority certificate found but [$($CertificateData.Subject)] Time not valid, Cert can't be trusted"
						}
					}
				}Else{
					#Not Self-Signed
					#Check if there is an issuer that is present and Self-Signed
					IF($ParentCert = ($AllInstalledCerts | ?{$_.psobject.Properties.name -contains "Subject"} | ?{$_.Subject -eq $CertificateData.Issuer})){
						$RootCert = $Null; $RootCert = Find-SelfSignCertInStore -Cert $ParentCert
						IF($RootCert){
							#Root Authority Certificate also already installed
							#Nothing to do
							Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate already installed"
						}Else{
							#Warn
							Write-Warning "No root CA certificate found for [$($CertificateData.Subject)], Cert can't be trusted"
						}
					}Else{
						#Warn that Issuer Cert not found/installed and therefore $CertificateData can't be trusted
						Write-Warning "No root CA certificate found for [$($CertificateData.Subject)], Cert can't be trusted"
					}
				}
				
				
				#Check OLVM Web UI & REST API cert ""https://$($oVirtServerName)/ovirt-engine/api"
				
				IF($AllInstalledCerts | ?{$_ -eq $oVirt_RestApi_CRT.Certificate}){
					#Certificate is already present
					Write-Verbose "$($MyInvocation.MyCommand): OLVM Apache Certificate Already installed in local store"
					Write-Verbose "$($MyInvocation.MyCommand): `$oVirt_RestApi_CRT: [$($oVirt_RestApi_CRT | Out-String)]"
					$OutPutItems.Add(
						[PSCustomObject]@{
							"Imported" = "AlreadyPresent"
							"CertificateDecoded" = $oVirt_RestApi_CRT.Certificate
							"CertificateEncoded" = $oVirt_SelfSigned_CRT
						}
					) | Out-Null
				}Else{
					#Import Certificate
					Write-Verbose "$($MyInvocation.MyCommand): OLVM Apache Certificate Not installed in local store, attempting import"
					IF($oVirt_RestApi_CRT.Certificate){
						$pemFileContent = @('-----BEGIN CERTIFICATE-----',[System.Convert]::ToBase64String($oVirt_RestApi_CRT.Certificate.RawData, 'InsertLineBreaks'),'-----END CERTIFICATE-----')
						$pemFileContent | Set-Content -Path $CertFile
						#$ImportResults = Import-Certificate -FilePath $CertFile -CertStoreLocation 'Cert:\CurrentUser\Root' -Confirm:0
						$ImportResults = Import-Certificate -FilePath $CertFile -CertStoreLocation 'Cert:\CurrentUser\My' -Confirm:0
						IF($ImportResults){$Imported = $True}Else{$Imported = $False}
						Remove-Item -Path $CertFile -EA SilentlyContinue -Confirm:0 | Out-Null
						$OutPutItems.Add(
							[PSCustomObject]@{
								"Imported" = $Imported
								"CertificateDecoded" = $ImportResults
								"CertificateEncoded" = $pemFileContent
							}
						) | Out-Null
					}
				}
				
				
				#Check if Root Authority certificate
				IF($oVirt_RestApi_CRT.Certificate.Issuer -eq $oVirt_RestApi_CRT.Certificate.Subject){
					#Self-Signed
					Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate for oVirt RestApi(apache) is self-signed"
					Write-Verbose "$($MyInvocation.MyCommand): Validating Root Authority Certificate for oVirt RestApi(apache)"
					#Check if Cert is valid for oVirt server name
					IF($oVirt_RestApi_CRT.Certificate.Subject -NotMatch $oVirtServerName){
						#Not Root Authority certificate
						Write-Verbose "$($MyInvocation.MyCommand): Self-Signed Certificate for oVirt RestApi(apache) is NOT Root Authority Cert"
						$RootCert = $Null; $RootCert = Find-SelfSignCertInStore -Cert $oVirt_RestApi_CRT.Certificate
						IF($RootCert){
							#Root Authority Certificate also already installed
							#Nothing to do
							Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate for oVirt RestApi(apache) already installed"
						}Else{
							#Warning
							Write-Warning "No root CA certificate found for [$($oVirt_RestApi_CRT.Certificate.Subject)], Cert can't be trusted"
						}
					}Else{
						#Is Root Authority certificate
						Write-Verbose "$($MyInvocation.MyCommand): Self-Signed Certificate for oVirt RestApi(apache) is Root Authority Cert, Checking date validity"
						#Dates valid?
						IF(((Get-Date) -gt $oVirt_RestApi_CRT.Certificate.NotBefore) -and ((Get-Date) -lt $oVirt_RestApi_CRT.Certificate.NotAfter)){
							#Nothing more to do
							Write-Verbose "$($MyInvocation.MyCommand): Self-Signed Certificate for oVirt RestApi(apache) Time valid"
						}Else{
							#Warn
							Write-Warning "Root Authority certificate found but [$($oVirt_RestApi_CRT.Certificate.Subject)] Time not valid, Cert can't be trusted"
						}
					}
				}Else{
					#Not Self-Signed
					Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate for oVirt RestApi(apache) is NOT self-signed"
					#Check if there is an issuer that is present and Self-Signed
					IF($ParentCert = ($AllInstalledCerts | ?{$_.psobject.Properties.name -contains "Subject"} | ?{$_.Subject -eq $oVirt_RestApi_CRT.Certificate.Issuer})){
						$RootCert = $Null; $RootCert = Find-SelfSignCertInStore -Cert $ParentCert
						IF($RootCert){
							#Root Authority Certificate also already installed
							#Nothing to do
							Write-Verbose "$($MyInvocation.MyCommand): Root Authority Certificate for oVirt RestApi(apache) already installed"
						}Else{
							#Warn
							Write-Warning "No root CA certificate found for [$($oVirt_RestApi_CRT.Certificate.Subject)], Cert can't be trusted"
						}
					}Else{
						#Warn that Issuer Cert not found/installed and therefore $oVirt_RestApi_CRT.Certificate can't be trusted
						Write-Warning "No root CA certificate found for [$($oVirt_RestApi_CRT.Certificate.Subject)], Cert can't be trusted"
						Write-Verbose "$($MyInvocation.MyCommand): `$oVirt_RestApi_CRT: [$($oVirt_RestApi_CRT | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): `$oVirt_RestApi_CRT.Issuer: [$($oVirt_RestApi_CRT.Issuer | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): `$oVirt_RestApi_CRT.Subject: [$($oVirt_RestApi_CRT.Subject | Out-String)]"
						Write-Verbose "$($MyInvocation.MyCommand): `$oVirt_RestApi_CRT.Thumbprint: [$($oVirt_RestApi_CRT.Thumbprint | Out-String)]"
					}
				}
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"; IF($PSBoundParameters['Quiet'].IsPresent -ne $True){IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}}
	#End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Write-oProgressPlus{
	<#
		.SYNOPSIS
			Displays a progress bar within a PowerShell command window.
		.DESCRIPTION
			The `Write-Progress` cmdlet displays a progress bar in a PowerShell command window that depicts the status of a running command or script. You can select the indicators that the bar reflects and the text that appears above and below the progress bar.
		.PARAMETER Activity
			Specifies the first line of text in the heading above the status bar. This text describes the activity whose progress is being reported.
		.PARAMETER Status
			Specifies the second line of text in the heading above the status bar. This text describes current state of the activity.
		.PARAMETER Id
			Specifies an ID that distinguishes each progress bar from the others. Use this parameter when you are creating more than one progress bar in a single command. If the progress bars do not have different IDs, they are superimposed instead of being displayed in a series.
		.PARAMETER Completed
			Indicates whether the progress bar is visible. If this parameter is omitted, `Write-Progress` displays progress information.
		.PARAMETER CurrentOperation
			Specifies the line of text below the progress bar. This text describes the operation that is currently taking place.
		.PARAMETER ParentId
			Specifies the parent activity of the current activity. Use the value -1 if the current activity has no parent activity.
		.PARAMETER PercentComplete
			Specifies the percentage of the activity that is completed. Use the value -1 if the percentage complete is unknown or not applicable.
		.PARAMETER SecondsRemaining
			Specifies the projected number of seconds remaining until the activity is completed. Use the value -1 if the number of seconds remaining is unknown or not applicable.
		.PARAMETER SourceId
			Specifies the source of the record. You can use this in place of Id but cannot be used with other parameters like ParentId.
		.PARAMETER ForeGroundColor
			Specifies the Fore Ground Color (Text color) of the progress bar
				Valid Color Choices are ([System.ConsoleColor]).GetEnumValues()
		.PARAMETER BackGroundColor
			Specifies the Back Ground Color of the progress bar
				Valid Color Choices are ([System.ConsoleColor]).GetEnumValues()
		.EXAMPLE
			for ($i = 1; $i -le 100; $i++ )
			{
				Write-oProgressPlus -Activity "Search in Progress" -Status "$i% Complete:" -PercentComplete $i;
			}

			Display the progress of a For loop
			This command displays the progress of a For loop that counts from 1 to 100.

			The `Write-oProgressPlus` cmdlet includes a status bar heading `Activity`, a status line, and the variable `$i` (the counter in the For loop), which indicates the relative
			completeness of the task.
			
		.EXAMPLE
			for($I = 1; $I -lt 101; $I++ )
			{
				Write-oProgressPlus -Activity Updating -Status 'Progress->' -PercentComplete $I -CurrentOperation OuterLoop
				for($j = 1; $j -lt 101; $j++ )
				{
					Write-oProgressPlus -Id 1 -Activity Updating -Status 'Progress' -PercentComplete $j -CurrentOperation InnerLoop
				}
			}

			Updating
			Progress ->
			 [ooooooooooooooooooooooooooooooooooooooooooooooooooooooooooooooooooooo]
			OuterLoop
			Updating
			Progress
			 [oooooooooooooooooo                                                   ]
			InnerLoop

			Display the progress of nested For loops
			This example displays the progress of two nested For loops, each of which is represented by a progress bar.

			The `Write-oProgressPlus` command for the second progress bar includes the Id parameter that distinguishes it from the first progress bar.

			Without the Id parameter, the progress bars would be superimposed on each other instead of being displayed one below the other.
		.EXAMPLE
			# Use Get-EventLog to get the events in the System log and store them in the $Events variable.
			$Events = Get-EventLog -LogName system
			# Pipe the events to the ForEach-Object cmdlet.
			$Events | ForEach-Object -Begin {
				# In the Begin block, use Clear-Host to clear the screen.
				Clear-Host
				# Set the $i counter variable to zero.
				$i = 0
				# Set the $out variable to a empty string.
				$out = ""
			} -Process {
				# In the Process script block search the message property of each incoming object for "bios".
				if($_.message -like "*bios*")
				{
					# Append the matching message to the out variable.
					$out=$out + $_.Message
				}
				# Increment the $i counter variable which is used to create the progress bar.
				$i = $i+1
				# Use Write-oProgressPlus to output a progress bar.
				# The Activity and Status parameters create the first and second lines of the progress bar heading, respectively.
				Write-oProgressPlus -Activity "Searching Events" -Status "Progress:" -PercentComplete ($i/$Events.count*100)
			} -End {
				# Display the matching messages using the out variable.
				$out
			}

			Display the progress while searching for a string
			This command displays the progress of a command to find the string "bios" in the System event log.

			The PercentComplete parameter value is calculated by dividing the number of events that have been processed `$I` by the total number of events retrieved
			`$Events.count` and then multiplying that result by 100.
		.EXAMPLE
			foreach ( $i in 1..10 ) {
			  Write-oProgressPlus -Id 0 "Step $i"
			  foreach ( $j in 1..10 ) {
				Write-oProgressPlus -Id 1 -ParentId 0 "Step $i - Substep $j"
				foreach ( $k in 1..10 ) {
				  Write-oProgressPlus -Id 2  -ParentId 1 "Step $i - Substep $j - iteration $k"; start-sleep -m 150
				}
			  }
			}

			Step 1
				 Processing
				Step 1 - Substep 2
					 Processing
					Step 1 - Substep 2 - Iteration 3
						 Processing

			Display progress for each level of a nested process
			In this example you can use the ParentId parameter to have indented output to show parent/child relationships in the progress of each step.

		.INPUTS
			[System.String]
			[System.Int32]
		.NOTES
			See David A. Stewart <david.a.stewart@oracle.com>.
			Version 1.0		7/21/2023
		.LINK	
			See David A. Stewart <itsavant@gmail.com>.
		.LINK	
			Get-Help

	#>
	[CmdletBinding()]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0, HelpMessage="Activity Text")]
			[System.String]$Activity,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Status Text")]
			[System.String]$Status,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="ID Number")]
			[System.Int32]$Id,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Completed")]
			[SWITCH]$Completed,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Current Operation Text")]
			[System.String]$CurrentOperation,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Parent Id Number")]
			[System.Int32]$ParentId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Percent Complete (0-100)")]
			[ValidateRange(0,100)][System.Int32]$PercentComplete,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds Remaining")]
			[System.Int32]$SecondsRemaining,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Source Id Number")]
			[System.Int32]$SourceId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Text Color")]
			[System.ConsoleColor]$ForeGroundColor,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="BackGround Color")]
			[System.ConsoleColor]$BackGroundColor
	)
	Begin{
		$InitialForeGroundColor = $host.privatedata.ProgressForegroundColor
		$InitialBackGroundColor = $host.privatedata.ProgressBackgroundColor
	}
	Process{
		IF(($PSBoundParameters['ForeGroundColor']) -AND ($PSBoundParameters['BackGroundColor'])){
			IF(($PSBoundParameters['ForeGroundColor']) -EQ ($PSBoundParameters['BackGroundColor'])){
				WRITE-WARNING "Entered parameters 'ForeGroundColor' and 'BackGroundColor' should NOT be the same or progress bar text will not be visible."
			}
		}ElseIF(($PSBoundParameters['ForeGroundColor']) -OR ($PSBoundParameters['BackGroundColor'])){
			IF(($PSBoundParameters['ForeGroundColor']) -AND (!($PSBoundParameters['BackGroundColor']))){
				IF(($PSBoundParameters['ForeGroundColor']) -EQ ($InitialBackGroundColor)){
					WRITE-WARNING "Entered parameter 'ForeGroundColor' and the Default Back Ground Color should NOT be the same or progress bar text will not be visible."
				}
			}ElseIF((!($PSBoundParameters['ForeGroundColor'])) -AND ($PSBoundParameters['BackGroundColor'])){
				IF(($PSBoundParameters['BackGroundColor']) -EQ ($InitialForeGroundColor)){
					WRITE-WARNING "Entered parameter 'BackGroundColor' and the Default Fore Ground Color should NOT be the same or progress bar text will not be visible."
				}
			}
		}
		$SplatParams = [pscustomobject]@{}
		ForEach($Key in ($PSBoundParameters.Keys | Where-Object {$_ -notin @("ForeGroundColor", "BackGroundColor")})){
			$SplatParams | Add-Member -MemberType NoteProperty -Name $Key -Value $PSBoundParameters.$Key
		}
		IF($PSBoundParameters['ForeGroundColor']){$host.privatedata.ProgressForegroundColor = $PSBoundParameters['ForeGroundColor']}
		IF($PSBoundParameters['BackGroundColor']){$host.privatedata.ProgressForegroundColor = $PSBoundParameters['BackGroundColor']}
		Write-Progress @SplatParams
	}
	End{
		$host.privatedata.ProgressForegroundColor = $InitialForeGroundColor
		$host.privatedata.ProgressBackgroundColor = $InitialBackGroundColor
	}
}

Function Remove-PuttyoHostKeys{
	<#
		.SYNOPSIS
			Removes an oHost SSH key from Windows Registry for Putty
		.DESCRIPTION
			Removes an oHost SSH key from Windows Registry for Putty.
			When an oHost's SSH key changes, it needs to be removed from the Windows registry before Putty will connect to the oHost using the new SSH key
		.PARAMETER oHostName
			The Name/FQDN of the oHost to remove the SSH key
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		9/17/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[System.String]$oHostName
	)
	$PuttyHostRegKeysPath = "HKCU:\Software\SimonTatham\PuTTY\SshHostKeys"
	IF(Test-Path -Path $PuttyHostRegKeysPath){
		$PuttyHostRegKeys = Get-Item $PuttyHostRegKeysPath
		#Get-ItemProperty –Path $PuttyHostRegKeysPath
		$Key = ($PuttyHostRegKeys.Property | ?{$_ -Match $oHostName})
		IF($PSCmdlet.ShouldProcess($oNetworkLabelObject.Name , "Permanently Delete oHost SSH key [$($Key)] from Putty Registry store")) {
			Remove-ItemProperty –Path $PuttyHostRegKeysPath –Name $Key
		}
	}
}

