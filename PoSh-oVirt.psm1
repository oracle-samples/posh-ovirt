			$oVirtServerName = $TargetoVM.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/export
			#POST /ovirt-engine/api/vms/123/export
			IF(($TargetoVM.status -eq "up") -OR ($TargetoVM.status -eq "down")){
				#A VM can be Exported to a StorageDomain OR a Host file System (OVA)
				#Since version 4.2 of the engine it is also possible to export a virtual machine as a virtual appliance (OVA)

				#Get oVM parent oHost to use for OVA export if other parameters not provided
				IF((!($oHostObject)) -AND (!($oStorageDomainObject)) -AND ($PSBoundParameters['oHostFolder']) -AND ($PSBoundParameters['OVAFileName'])){
					$oHostObject = Get-oHost -Id $TargetoVM.host.id -EA SilentlyContinue -oVirtServerName $oVirtServerName
					IF($oHostObject){$oHostObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
			
				IF($oStorageDomainObject){
					#StorageDomain Export
					$VMActionStorage = [PSCustomObject]@{'name' = $oStorageDomainObject.Name}
					$VMActionParameters = [PSCustomObject]@{
						'async' = $(IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){$True}Else{$False})
						'exclusive' = $(IF($PSBoundParameters['Exclusive'].IsPresent -eq $True){$True}Else{$False})
						'discard_snapshots' = $(IF($PSBoundParameters['DiscardSnapshots'].IsPresent -eq $True){$True}Else{$False})
						'storage_domain' = $VMActionStorage
					}
				}ElseIF($oHostObject){
					#Host File System Export
					$TargetDirectory = "/home/ovirt"
					$TargetFileName = "$($TargetoVM.Name).ova"
					$VMActionStorage = [PSCustomObject]@{'name' = $oHostObject.Name}
					$VMActionParameters = [PSCustomObject]@{
						'async' = $(IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){$True}Else{$False})
						#'exclusive' = $(IF($PSBoundParameters['Exclusive'].IsPresent -eq $True){$True}Else{$False})
						#'discard_snapshots' = $(IF($PSBoundParameters['DiscardSnapshots'].IsPresent -eq $True){$True}Else{$False})
						'directory' =  $(IF($PSBoundParameters.ContainsKey('oHostFolder')){$PSBoundParameters['oHostFolder']}Else{$TargetDirectory})
						'filename' = $(IF($PSBoundParameters.ContainsKey('OVAFileName')){$PSBoundParameters['OVAFileName']}Else{$TargetFileName})
						'host' = $VMActionStorage
					}
				}
				IF($VMActionStorage){
					#Common for Both Options
					#$VMActions = [PSCustomObject]@{'action' = $VMActionParameters}
					
					#Send to Server
					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$Uri = $BaseURL + "/ovirt-engine/api/vms/$($TargetoVM.ID)/export"
					$Method = "POST"
					#$JsonBody = $VMActions | ConvertTo-Json -Depth 50
					$JsonBody = $VMActionParameters | ConvertTo-Json -Depth 50
					Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Export oVM"
					Write-Verbose "$($JsonBody | Out-String)"
					$UpdatedVM = $Null
					TRY{$UpdatedVM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedVM = $TargetoVM}
				}Else{
					#NotifyAndSkip
					Write-Warning "Insufficient Input data to create export for oVM [$($TargetoVM.Name)], Requires oStorageDomain or oHost, or oHostFolder & OVAFileName to select parent oHost"
				}
			}Else{
				#NotifyAndSkip
				Write-Warning "oVM [$($TargetoVM.Name)] is in state [$($TargetoVM.status)], migration status not met"
			}
		}
	}
	End{$UpdatedVM}
}

Function New-oVmPool{
	<#
		.SYNOPSIS
			This function creates a new oVmPool, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oVmPool, on a oVirt Server system.
			Returns the job response from the oVirt Server.
			A new pool requires the name, cluster and template attributes.
		.PARAMETER Name
			The Name(s) of oVmPool
			Can use Wildcard '*'
		.PARAMETER oCluster
			The Name of the parent oCluster for the new oVmPool
		.PARAMETER oClusterId
			The Id of the parent oCluster for the new oVmPool
		.PARAMETER oClusterUid
			The Uid of the parent oCluster for the new oVmPool
		.PARAMETER Comment
			The Text for the Comment field to set on the oVmPool
		.PARAMETER Description
			The Text for the Description field to set on the oVmPool
		.PARAMETER MaxUserVms
			The maximum number of virtual machines in the pool that could be assigned to a particular user.
		.PARAMETER PrestartedVms
			The system attempts to prestart the specified number of virtual machines from the pool.
		.PARAMETER Size
			The number of virtual machines in the pool.
		.PARAMETER Stateful
			Virtual machine pool’s stateful flag.
		.PARAMETER VmPoolType
			Valid options "automatic", "manual"
			This policy indicates that virtual machines in the pool are automcatically deallocated by the system.
			
			Automatic
				With this policy, when a virtual machine that is part of the pool and is assigned to a user is 
				shut-down, it is detached from the user, its state is restored to the pool’s default state, and 
				the virtual machine returns to pool (i.e., the virtual machine can then be assigned to another user).
			Manual
				This policy indicates that virtual machines in the pool are deallocated manually by the administrator.
				With this policy, a virtual machine that is part of the pool remains assigned to its user and preserves 
				its state on shut-down. In order to return the virtual machine back to the pool, the administrator needs 
				to deallocate it explicitly by removing the user’s permissions on that virtual machine.
		.PARAMETER UseLatestTemplateVersion
			Indicates if virtual machines in the pool are updated to newer versions of the template the pool is based on.
		.PARAMETER oTemplate
			The Name of the parent oTemplate for the new oVmPool
		.PARAMETER oTemplaterId
			The Id of the parent oTemplate for the new oVmPool
		.PARAMETER oTemplateUid
			The Uid of the parent oTemplate for the new oVmPool
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oVmPool -oVirtServerName $oVirtServerName -Name "Name" -oCluster "oClusterName" -oTemplateUid $oTemplate.Uid -Comment 'blah'-Description 'blah'
				Creates a new oHost with the provided Name
		.INPUTS
			[System.String]
			[oCluster]
			[oTemplate]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVmPool]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/vm_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pools
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_pools/methods/add
		.LINK
			Get-oVmPool
			Set-oVmPool
			Remove-oVmPool
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'OVA')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'String|oCluster'})]$oCluster,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oClusterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
