			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[System.String]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[System.String]$Value,
		#[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			#[SWITCH]$RunAsync,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[SWITCH]$Force
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		$OutPutItems = [System.Collections.ArrayList]@()
		#$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
	}
	Process{
		$oBookmarkSpecs = [PSCustomObject]@{"bookmark"=$([PSCustomObject]@{"name"=$($PSBoundParameters['Name']);"value"=$($PSBoundParameters['Value']);})}
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/bookmarks"
		$Method = "POST"
		$JsonBody = $oBookmarkSpecs | ConvertTo-Json -Depth 50
		#$JsonBody | ConvertFrom-Json2Xml
		#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oBookmark"
		Write-Verbose "$($MyInvocation.MyCommand): Json: [$($JsonBody | Out-String)]"
		$NewoBookmark = $Null
		TRY{$NewoBookmark = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoBookmark){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoBookmark -ObjectType "oBookmark" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function Stop-oVMMigration{
	<#
		.SYNOPSIS
			This function cancels an active migration task for the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
		.DESCRIPTION
			This function cancels an active migration task for the provided oVM on an OLVM (oVirt) Kernel-based Virtual Machine
		.PARAMETER Name
			The Name of the VM
		.PARAMETER Comment
			Populates the Comment field of the oVM in OLVM
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system to place the new oVM
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.EXAMPLE
			PS> Stop-oVMMigration -oVirtServerName $oVirtServerName -Name "oVMName"
				Cancels an active migration task for the oVM(s) provided
		.INPUTS
			[System.String]
			[oVM]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oVM]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/20/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/cancel_migration
		.LINK
			Get-Help		
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	[Alias('Cancel-oVMMigration')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			#[System.String]$oVM,
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oVM]: [$($PSBoundParameters['oVM'] -IS [oVM])]"
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMOBjects = Get-oVM -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
						#$oVMOBjects = (ForEach($oVM in $PSBoundParameters['Name']){Get-oVM -Id $oVM.Id -oVirtServerName $oVM.oVirtServer -EA SilentlyContinue})
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMOBjects = $PSBoundParameters['Name']
						#$oVMOBjects = (ForEach($oVM in $PSBoundParameters['Name']){Get-oVM -Id $oVM.Id -oVirtServerName $oVM.oVirtServer -EA SilentlyContinue})
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMOBjects = Get-oVM -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oVMOBjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			}
		}
		IF($oVMOBjects){$oVMOBjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		Write-Verbose "$($MyInvocation.MyCommand): `$oVMOBjects Names: $($oVMOBjects.Name)"
		ForEach($TargetoVM in $oVMOBjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoVM [$($TargetoVM.Name)]"
			$oVirtServerName = $TargetoVM.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm/methods/cancel_migration
			IF((Get-oUri -Uri $TargetoVM.Uid).Status -eq "migrating"){
				#POST /ovirt-engine/api/vms/123/cancelmigration
				#The cancel migration action does not take any action specific parameters; therefore, the request body should contain an empty action
				IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
					$VMActionParameters = [PSCustomObject]@{'async' = $True}
				}Else{
					$VMActionParameters = [PSCustomObject]@{'async' = $False}
				}
				$VMActions = [PSCustomObject]@{'action' = $VMActionParameters}
				
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/vms/$($TargetoVM.ID)"
				$Method = "POST"
				$JsonBody = $VMActions | ConvertTo-Json -Depth 50
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Cancel oVM Migration"
				Write-Verbose "$($JsonBody | Out-String)"
				$UpdatedVM = $Null
				TRY{$UpdatedVM = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedVM = $TargetoVM}
				IF($UpdatedVM){Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}			
			}Else{
				#NotifyAndSkip
				Write-Warning "oVM [$($TargetoVM.Name)] is in state [$($TargetoVM.status)], migration status not met"
			}
		}
	}
	End{$UpdatedVM}
}

