		Write-Verbose "PSBoundParameters.Keys: [$($PSBoundParameters.Keys)]"
		Write-Verbose "PSBoundParameters Key/Value: [$(foreach($boundparam in $PSBoundParameters.GetEnumerator()) {'Key={0} Value={1}' -f $boundparam.Key,$boundparam.Value})]"
		IF($PSBoundParameters.ContainsKey('oVirtServerName')){$oVirtServerNames = $PSBoundParameters['oVirtServerName']}Else{$oVirtServerNames = Show-oVirtConnection | Select -ExpandProperty oVirtServerName}
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oVirtServerName in $oVirtServerNames){
			$BaseURL = "https://$($oVirtServerName)"
		
			$oClusterLevelPermits = ((Get-oUri -oVirtServerName $oVirtServerName -RESTUri /ovirt-engine/api/clusterlevels).cluster_level | Sort -Property Id -Descending | Select -First 1).permits.permit
			$AdministrativePermitNames = $oClusterLevelPermits | ?{$_.Administrative -eq $True} | Select -ExpandProperty Name | Sort
			$UserPermitNames = $oClusterLevelPermits | ?{$_.Administrative -ne $True} | Select -ExpandProperty Name | Sort
			$AllPermitNames = $oClusterLevelPermits | Select -ExpandProperty Name | Sort
			
			$oRoleSpecs = [PSCustomObject]@{name = $(($PSBoundParameters['Name']).Trim())}
			$oPermitSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Description')){ $oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $(($PSBoundParameters['Description']).Trim()) }
			$Permits = [System.Collections.ArrayList]@()
			IF(($PSCmdlet.ParameterSetName -eq "Administrative") -OR (($PSBoundParameters['Administrative']).IsPresent -eq $True)){
				$oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'administrative' -Value $True
				ForEach($AdministrativePermitName in $AllPermitNames){
					IF(($PSBoundParameters[$AdministrativePermitName]).IsPresent -eq $True){
						IF($Permits.Id -NotContains (($oClusterLevelPermits | ?{$_.name -eq $AdministrativePermitName}).id)){
							$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $AdministrativePermitName}).id)})) | Out-Null
						}
					}
				}
			}Else{
				$oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'administrative' -Value $False
			}
			
			ForEach($UserPermitName in $UserPermitNames){
				IF($Permits.Id -NotContains (($oClusterLevelPermits | ?{$_.name -eq $UserPermitName}).id)){
					IF(($PSBoundParameters[$UserPermitName]).IsPresent -eq $True){$Permits.Add($([PSCustomObject]@{'id'=$(($oClusterLevelPermits | ?{$_.name -eq $UserPermitName}).id)})) | Out-Null}
				}
			}
			Write-Verbose "$($MyInvocation.MyCommand): `$Permits: $Permits"
			IF($Permits.Count -ge 1){
				$oPermitSpecs | Add-Member -MemberType NoteProperty -Name 'permit' -Value $Permits
				$oRoleSpecs | Add-Member -MemberType NoteProperty -Name 'permits' -Value $oPermitSpecs
			}
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/roles"
			$Method = "POST"
			$JsonBody = $oRoleSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oRole"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoRole = $Null
			TRY{$NewoRole = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoRole){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoRole -ObjectType "oRole" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oStorageDomain{
	<#
		.SYNOPSIS
			This function creates a new oStorageDomain, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oStorageDomain, on a oVirt Server system.
			Returns the new oStorageDomain from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oStorageDomain
			Can use Wildcard '*'
		.PARAMETER oDataCenter
			The Name of the parent oDataCenter for the new oStorageDomain
		.PARAMETER oDataCenterId
			The Id of the parent oDataCenter for the new oStorageDomain
		.PARAMETER oDataCenterUid
			The Uid of the parent oDataCenter for the new oStorageDomain
		.PARAMETER Comment
			The Text for the Comment field to set on the oStorageDomain
		.PARAMETER Description
			The Text for the Description field to set on the oStorageDomain
		.PARAMETER StorageDomainType
			Indicates the kind of data managed by a storage domain
			Valid options "data","export","image","iso","managed_block_storage","volume"
			
			Data domains are used to store the disks and snapshots of the virtual machines and templates in the system
			Export domains are temporary storage repositories used to copy and move virtual machines and templates between data centers and oVirt environments
			Image domain store images that can be imported into from an external system
			ISO domains store ISO files (or logical CDs) used to install and boot operating systems and applications for the virtual machines
			Managed block storage domains are created on block storage devices
			Volume domains store logical volumes that can be used as disks for virtual machines.
		.PARAMETER StorageType
			Valid options "cinder","fcp","glance","glusterfs","iscsi","localfs","managed_block_storage","nfs","posixfs"
			In this version only "nfs", "iscsi", and "managed_block_storage" are constructed, need test systems to add more, since oVirt docs don't provide examples
		.PARAMETER IPStorageAddress
			The IPv4 IP address or Fully Qualified Domain Name (FQDN) of the oStorageDomain Target
		.PARAMETER StoragePath
			The storage path to mount on an NFS server I.e. /exports/mydata
		.PARAMETER iSCSILogicalUnit
			The LUN ID on an iSCSI server I.e. "3600144f09dbd050000004eedbd340001"
		.PARAMETER oHost
			The Name of the oHost to process the new oStorageDomain
		.PARAMETER oHostId
			The Id of the oHost to process the new oStorageDomain
		.PARAMETER oHostUid
			The Uid of the oHost to process the new oStorageDomain
		.PARAMETER NFSVersion
			The Version of the NFS server Export
			Valid options "auto","v3","v4","v4_0","v4_1","v4_2"
		.PARAMETER BlockSize
			The block size to assign block type storage such as FC or iSCSI
			Default is 512 bytes
		.PARAMETER DiscardAfterDelete
			Indicates whether disks' blocks on block storage domains will be discarded right before they are deleted
 
			If true, and a disk on this storage domain has its wipe_after_delete value enabled, then when the disk is deleted:
				It is first wiped.
				Then its blocks are discarded.
				Finally it is deleted.

			Note that:
				Discard after delete will always be false for non block storage types.
				Discard after delete can be set to true only if the storage domain supports discard.
		.PARAMETER BackupEnabled
			This attribute indicates whether a data storage domain is used as backup domain or not
		.PARAMETER CriticalSpaceActionBlockerGB
			The number of GB for critical_space_action_blocker
		.PARAMETER WarningLowSpaceIndicatorPercent
			The Percent of freespace to trigger Low Space Warning Indicator
		.PARAMETER WipeAfterDelete
			Serves as the default value of wipe_after_delete for disks on this storage domain
			Newly created disks will get their wipe_after_delete value from their storage domains by default
			Note that the configuration value SANWipeAfterDelete serves as the default value of block storage domains' wipe_after_delete value
			Can be edited after the domain is created, but doing so will not change the wipe after delete property of disks that already exist
		.PARAMETER SANIpAddress
			The IP or FQDN for managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
		.PARAMETER SANLoginUsername
			The UserName to connect to managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
		.PARAMETER SANLoginPassword
			The Password to connect to managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
		.PARAMETER UseMultipathForImageXfer
			For managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
		.PARAMETER VolumeDriver
			Option to be passed when creating a storage domain using a cinder driver
		.PARAMETER VolumeDriverUsername
			The UserName to connect to managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
			Parameters containing sensitive information, to be passed when creating a storage domain using a cinder driver. These parameters are encrypted when they are saved
		.PARAMETER VolumeDriverPassword
			The Password to connect to managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
			Parameters containing sensitive information, to be passed when creating a storage domain using a cinder driver. These parameters are encrypted when they are saved
		.PARAMETER VolumeDriverSANIpAddress
			The IP or FQDN for managed_block_storage
			Option to be passed when creating a storage domain using a cinder driver
			Parameters containing sensitive information, to be passed when creating a storage domain using a cinder driver. These parameters are encrypted when they are saved
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oStorageDomain -oVirtServerName $oVirtServerName -Name "Name" -StorageDomainType "data" -StorageType "nfs" -IPStorageAddress "FQDN or IP" -StoragePath "/export/myshare" -oHost "oHostName" -oDataCenter "oDataCenterName"
				Creates a new oStorageDomain with the provided Name
		.INPUTS
			[System.String]
			[oDataCenter]
			[oHost]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oStorageDomain]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/16/2024
			Version 1.0b	7/23/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/storage_domains
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/storage_domains/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain_type
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage/attributes/driver_sensitive_options
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'String|oDataCenter'})]$oDataCenter,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDataCenterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDataCenterUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain_type
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("data","export","image","iso","managed_block_storage","volume")]
			[System.String]$StorageDomainType,
		#Probably Read-Only
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_format
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet("v1","v2","v3","v4","v5")]
			#[System.String]$StorageFormat,
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_type
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("cinder","fcp","glance","glusterfs","iscsi","localfs","managed_block_storage","nfs","posixfs")]
			[System.String]$StorageType,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$') -or ($_ -Match "(?=^.{4,253}\.?$)(^((?!-)[a-zA-Z0-9-]{1,63}(?<!-)\.)+[a-zA-Z]{2,63}\.?$)")){ $True } Else { Throw "$_ is not an IPV4 Address or an FQDN!" }})]
			[System.String]$IPStorageAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$StoragePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String[]]$iSCSILogicalUnit, #<logical_units><logical_unit id="3600144f09dbd050000004eedbd340001"/></logical_units>
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oHost|String'})]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}Else{$True}})]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT64]$BlockSize, #block_size #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain/attributes/block_size  defaults to 512 bytes
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$DiscardAfterDelete, #discard_after_delete #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain/attributes/discard_after_delete
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$BackupEnabled,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[INT64]$CriticalSpaceActionBlockerGB, #critical_space_action_blocker, #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_domain
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("auto","v3","v4","v4_0","v4_1","v4_2")]
			[System.String]$NFSVersion, #nfs_version #https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/nfs_version
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,99)]
			[INT32]$WarningLowSpaceIndicatorPercent, #warning_low_space_indicator
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
