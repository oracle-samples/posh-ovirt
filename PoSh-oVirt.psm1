				}
			}
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Names: $($oDiskObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainObject Names: $($oStorageDomainObject.Name)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskProfileId: $($oDiskProfileId)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oQuotaId: $($oQuotaId)"
			
			$OutPutItems = [System.Collections.ArrayList]@()
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject [$($oDiskObject | Out-String)]"
			Write-Verbose "$($MyInvocation.MyCommand): `$oStorageDomainObject [$($oStorageDomainObject | Out-String)]"
			#Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Status [$($oDiskObject.Status)]"

			$oDiskSpecs = [PSCustomObject]@{}
			
			IF($PSBoundParameters.ContainsKey('Filter')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'filter' -Value $True }
			#IF($PSBoundParameters.ContainsKey('RunAsync')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'async' -Value $True }
			IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
				$oDiskSpecs = [PSCustomObject]@{async = $True}
			}Else{
				$oDiskSpecs = [PSCustomObject]@{async = $False}
			}
				
			#IF($oDiskObject.storage_type -eq "image"){
				IF($PSBoundParameters.ContainsKey('oDiskProfileId')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'disk_profile' -Value $([PSCustomObject]@{'id'=$($PSBoundParameters['oDiskProfileId'])}) }
				IF($oStorageDomainObject){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domain' -Value $([PSCustomObject]@{'id'=$oStorageDomainObject.Id}) }
				IF($PSBoundParameters.ContainsKey('oQuotaId')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'quota' -Value $([PSCustomObject]@{'id'=$($PSBoundParameters['oQuotaId'])}) }
			#}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/disks/$($oDiskObject.id)/move"
			$Method = "POST"
			$JsonBody = $oDiskSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oDiskSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Move oDisk"
			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoDisk = $Null
			#TRY{$UpdatedoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0].Exception.Message)"; $OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
			TRY{$UpdatedoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoDisk){
				Write-Verbose "$($MyInvocation.MyCommand): Moved oDisk"
				#$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDisk -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
				$OutPutItems.Add($UpdatedoDisk) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
		}Else{
			$oDiskInputString = $Null
			IF($PSCmdlet.ParameterSetName -eq "Set01"){
				SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_.GetType().Name -eq "String"}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_ -IS [oDisk]}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				{$_.GetType().Name -eq "oDisk"}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				}
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
				$oDiskInputString = $PSBoundParameters['Id']
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
				$oDiskInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
			}
			IF($PSBoundParameters['oVirtServerName']){
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
			}Else{
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oDiskAttachment{
	<#
		.SYNOPSIS
			This function adds a new disk attachment, for an oDisk, to the virtual machine, on an oVirt Server system
		.DESCRIPTION
			This function adds a new disk attachment, for an oDisk, to the virtual machine, on an oVirt Server system
		.PARAMETER Name
			The Name(s) of the oDisk(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of the oDisk(s)
		.PARAMETER Uid
			The Uid of the oDisk(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVM
			The Name of the oVM to assign the oDisk, or an oVM object
			Can use Wildcard '*'
				I.e. MyVMna*
		.PARAMETER oVMId
			The Id of the oVM to assign the oDisk
		.PARAMETER oVMUid
			The Uid of the oVM to assign the oDisk
		.PARAMETER Active
			Defines whether the disk is active in the virtual machine it’s attached to
			$True or $False
		.PARAMETER Bootable
			Defines whether the disk is bootable
			$True or $False
		.PARAMETER PassDiscard
			Defines whether the virtual machine passes discard commands to the storage
			$True or $False
		.PARAMETER Interface
			The underlying storage interface of disks communication with controller
			Valid options "ide", "sata", "spapr_vscsi", "virtio", "virtio_scsi"
				ide - Legacy controller device. Works with almost all guest operating systems, so it is good for compatibility. Performance is lower than with the other alternatives.
				sata - SATA controller device.
				spapr_vscsi - Para-virtualized device supported by the IBM pSeries family of machines, using the SCSI protocol.
				virtio - Virtualization interface where just the guest’s device driver knows it is running in a virtual environment. Enables guests to get high performance disk operations.
				virtio_scsi - Para-virtualized SCSI controller device. Fast interface with the guest via direct physical storage device address, using the SCSI protocol.
		.EXAMPLE
			PS> New-oDiskAttachment -oVirtServerName $oVirtServerName -Name "MyoDisk" -oVM "oVMName" -Active $True -Bootable $True -Interface "virtio"
				Adds a new disk attachment to the virtual machine for existing oDisk "MyoDisk"
		.INPUTS
			[System.String]
			[oVM]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDiskAttachment]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/23/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disks
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/move
			Get-oDisk
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		#Needs VM & Disk
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$oVM,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oVMId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oVMUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$Active,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$Bootable,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$PassDiscard, #pass_discard
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("ide", "sata", "spapr_vscsi", "virtio", "virtio_scsi")]
			[System.String]$Interface,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		<#
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachments
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk_attachments/methods/add
			#POST /ovirt-engine/api/vms/345/diskattachments
				<disk_attachment>
					<bootable>true</bootable>
					<pass_discard>true</pass_discard>
					<interface>ide</interface>
					<active>true</active>
					<disk id="123"/>
				</disk_attachment>
				Or it can contain the complete representation of the disk, if the disk doesn’t exist yet
				But I am not planning to add that here yet, instead allowing New-oDisk to preemptively handle that work
		#>
			Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#Write-Verbose "$($MyInvocation.MyCommand) Is [oCluster]: [$($PSBoundParameters['Name'] -IS [oCluster])]"
		IF($PSBoundParameters.ContainsKey('oVM')){Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oVM'] Type: [$(($PSBoundParameters['oVM']).GetType().Name)]"}
		$oDiskObject = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oDiskObject = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
					}
					IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oDisk]}{
					Write-Verbose "$($MyInvocation.MyCommand) Name is [oDisk]"
					$oDiskObject = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oDisk"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDisk]"
					$oDiskObject = $PSBoundParameters['Name']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskObject = Get-oDisk -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				$UidUrl = [Uri]$Uid
				$oDiskObject = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskObject){$oDiskObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		IF($oDiskObject){
			$oVirtServerName = $oDiskObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$oVMObject = $Null
			IF($PSBoundParameters['oVM']){
				SWITCH($PSBoundParameters['oVM']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMObject = Get-oVM -Name $PSBoundParameters['oVM'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMObject = Get-oVM -Name $PSBoundParameters['oVM'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oVMObject){$oVMObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMObject = Get-oVM -Name $PSBoundParameters['oVM'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMObject = Get-oVM -Name $PSBoundParameters['oVM'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oVMObject){$oVMObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMObject = $PSBoundParameters['oVM']
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMObject = $PSBoundParameters['oVM']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters['oVMId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMObject = Get-oVM -Id $PSBoundParameters['oVMId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMObject = Get-oVM -Id $PSBoundParameters['oVMId'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
				}
				IF($oVMObject){$oVMObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters['oVMUid']){
				$UidUrl = [Uri]$oVMUid
				$oVMObject = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVMObject){$oVMObject | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			
			
			IF($oVMObject){
				Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject Names: $($oDiskObject.Name)"
				Write-Verbose "$($MyInvocation.MyCommand): `$oVMObject Names: $($oVMObject.Name)"
				Write-Verbose "$($MyInvocation.MyCommand): `$oDiskObject [$($oDiskObject | Out-String)]"
				Write-Verbose "$($MyInvocation.MyCommand): `$oVMObject [$($oVMObject | Out-String)]"
				$OutPutItems = [System.Collections.ArrayList]@()
				$oDiskSpecs = [PSCustomObject]@{}
				
				IF($PSBoundParameters.ContainsKey('Active')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'active' -Value $($PSBoundParameters['Active']) }
				IF($PSBoundParameters.ContainsKey('Bootable')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'bootable' -Value $($PSBoundParameters['Bootable']) }
				IF($PSBoundParameters.ContainsKey('Interface')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'interface' -Value $($PSBoundParameters['Interface']) }
				IF($PSBoundParameters.ContainsKey('PassDiscard')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'pass_discard' -Value $($PSBoundParameters['PassDiscard']) }
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'disk' -Value $([PSCustomObject]@{'id'=$oDiskObject.Id})
				
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				$Uri = $BaseURL + "/ovirt-engine/api/vms/$($oVMObject.id)/diskattachments"
				
				$Method = "POST"
				$JsonBody = $oDiskSpecs | ConvertTo-Json -Depth 50
				#$JsonBody | ConvertFrom-Json2Xml
				#($oDiskSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Attach oDisk"
				Write-Verbose "$($JsonBody | Out-String)"
				$UpdatedoDiskAttachment = $Null
				#TRY{$UpdatedoDiskAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0].Exception.Message)"; $OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
				TRY{$UpdatedoDiskAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
				IF($UpdatedoDiskAttachment){
					Write-Verbose "$($MyInvocation.MyCommand): Attached oDisk to oVM"
					$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoDiskAttachment -ObjectType "oDiskAttachment" -oVirtServerName $oVirtServerName)) | Out-Null
					#$OutPutItems.Add($UpdatedoDiskAttachment) | Out-Null
					Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				}Else{
					Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
				}
			}Else{
				$oVMInputString = $Null
				IF($PSBoundParameters['oVM']){
					SWITCH($PSBoundParameters['oVM']){
					{$_ -IS [System.String]}{$oVMInputString = $PSBoundParameters['oVM']}
					{$_.GetType().Name -eq "String"}{$oVMInputString = $PSBoundParameters['oVM']}
					{$_ -IS [oVM]}{$oVMInputString = $PSBoundParameters['oVM'].Name}
					{$_.GetType().Name -eq "oVM"}{$oVMInputString = $PSBoundParameters['oVM'].Name}
					}
				}ElseIF($PSBoundParameters['oVMId']){
					$oVMInputString = $PSBoundParameters['oVMId']
				}ElseIF($PSBoundParameters['oVMUid']){
					$oVMInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
				}
				IF($PSBoundParameters['oVirtServerName']){
					Write-Warning "Could not locate oVM by input [$($oVMInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
				}Else{
					Write-Warning "Could not locate oVM by input [$($oVMInputString)]"
				}
			}
			
		}Else{
			$oDiskInputString = $Null
			IF($PSCmdlet.ParameterSetName -eq "Set01"){
				SWITCH($PSBoundParameters['Name']){
				{$_ -IS [System.String]}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_.GetType().Name -eq "String"}{$oDiskInputString = $PSBoundParameters['Name']}
				{$_ -IS [oDisk]}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				{$_.GetType().Name -eq "oDisk"}{$oDiskInputString = $PSBoundParameters['Name'].Name}
				}
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
				$oDiskInputString = $PSBoundParameters['Id']
			}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
				$oDiskInputString = ($UidUrl.Segments[($UidUrl.Segments.count -1)])
			}
			IF($PSBoundParameters['oVirtServerName']){
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)] on [$($PSBoundParameters['oVirtServerName'])]"
			}Else{
				Write-Warning "Could not locate oDisk by input [$($oDiskInputString)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
} 

Function New-oEvent{
	<#
		.SYNOPSIS
			Adds an external event to the internal audit log.
		.DESCRIPTION
			This is intended for integration with external systems that detect or produce events relevant for 
			the administrator of the system. For example, an external monitoring tool may be able to detect 
			that a file system is full inside the guest operating system of a virtual machine.
		.PARAMETER Name
			A human-readable name in plain text.
			Testing suggests that this field gets ignored even if provided.
		.PARAMETER Comment
			Free text containing comments about this object.
			Testing suggests that this field gets ignored even if provided.
		.PARAMETER Description
			A human-readable description in plain text.
		.PARAMETER Severity
			The event severity level
			Valid options "alert","error","normal","warning"
				Alert severity. Used to specify a condition that requires an immediate attention.
				Error severity. Used to specify that there is an error that needs to be examined.
				Normal severity. Used for information events.
				Warning severity. Used to warn something might be wrong.
		.PARAMETER Origin
			Free text identifying the origin of the event.
				ovirt
				rhev
				vmware
				xen
				external
				hosted_engine
				managed_hosted_engine
				kvm
				physical_machine
				hyperv
		.PARAMETER CustomId
			Integer. A custom event identifier.
			If not rovided will attempt to return the most recent oEvent ID and increment up by 1.
				On a highly active system it is possible another event could be assigned the same ID before this 
				function can get the new oEvent created, which would result in an error
		.PARAMETER Code
			The event code.
			Event codes represent specific activity, only use if you are certain you have the correct code number.
			Testing suggests that this field gets ignored even if provided and gets auto-assigned 9801.
		.PARAMETER CorrelationId
			The event correlation identifier. Used in order to correlate several events together.
		.PARAMETER CustomData
			Free text representing custom event data.
		.PARAMETER FloodRate
			Integer. Defines the flood rate. This prevents flooding in case an event appeared more than once in the 
			defined rate. Defaults is 30 seconds.
		.PARAMETER LogOnHost
			BOOLEAN
			Specifies whether the event should also be written to the ${hypervisor.name} log. 
			If no host is specified the event description will be written to all hosts. 
			Default is false.
		.PARAMETER Time
			The event time. Testing suggests that the Time is taken from the moment of submitting the New-oEvent, and 
			providing an alternate DateTime is ignored.
		.PARAMETER oClusterId
			Reference to the cluster service. Event can be associated with a cluster.
		.PARAMETER oDataCenterId
			Reference to the data center service. Event can be associated with a data center.
		.PARAMETER oHostId
			Reference to the host service. Event can be associated with a host.
		.PARAMETER oStorageDomainId
			Reference to the storage domain service. Event can be associated with a storage domain.
		.PARAMETER oTemplateId
			Reference to the template service. Event can be associated with a template.
		.PARAMETER oUserId
			Reference to the user service. Event can be associated with a user.
		.PARAMETER oVMId
			Reference to the virtual machine service. Event can be associated with a virtual machine.
		.EXAMPLE
			PS> New-oEvent -Description "User [$(((Show-oVirtConnection | ?{$_.Name -eq $oHost.oVirtServer}).User))] Rebooting oHost [$($oHost.Name)]" -Severity "Normal" -CustomData "Method: SSH" -LogOnHost -oHostId $oHost.Id
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetworkFilterParameter]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/14/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/event
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/log_severity
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/event
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/events/methods/add
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("alert","error","normal","warning")]
			[System.String]$Severity,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Origin,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateRange(1,([math]::pow(2,16)-1))]
			[ValidateRange(1,65535)]
			[INT32]$CustomId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,65535)]
			[INT32]$Code,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$CorrelationId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$CustomData,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,65535)]
			[INT32]$FloodRate,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$LogOnHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[DateTime]$Time,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oClusterId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDataCenterId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oStorageDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oTemplateId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oUserId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oVMId,
		
		#[SWITCH]$RunAsync,
		#[SWITCH]$Force
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		#$OutPutItems = [System.Collections.ArrayList]@()
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#$ActionParametersSpecs = [PSCustomObject]@{'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})}
		$ActionParametersSpecs = [PSCustomObject]@{}
		IF($PSBoundParameters.ContainsKey('Comment')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
		IF($PSBoundParameters.ContainsKey('Description')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
		IF($PSBoundParameters.ContainsKey('Severity')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'severity' -Value $($PSBoundParameters['Severity']) }
		IF($PSBoundParameters.ContainsKey('Origin')){
			$ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'origin' -Value $($PSBoundParameters['Origin'])
		}Else{
			$ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'origin' -Value "Custom User Created Event"
		}
		IF($PSBoundParameters.ContainsKey('CustomId')){
			$ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'custom_id' -Value $($PSBoundParameters['CustomId'])
		}Else{
			#$MostRecentoEventId = (Get-oEvent -oVirtServerName $oVirtServerName -Pagination 1 -MaxEvents 1).id
			$MostRecentoEventId = (Get-oUri -RESTUri "/ovirt-engine/api/events?search=page%201&max=1").event.Id
			$ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'custom_id' -Value $(([INT]$MostRecentoEventId)+1)
		}
		IF($PSBoundParameters.ContainsKey('Code')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'code' -Value $($PSBoundParameters['Code']) }
		IF($PSBoundParameters.ContainsKey('CorrelationId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'correlation_id' -Value $($PSBoundParameters['CorrelationId']) }
		IF($PSBoundParameters.ContainsKey('CustomData')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'custom_data' -Value $($PSBoundParameters['CustomData']) }
		IF($PSBoundParameters.ContainsKey('FloodRate')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'flood_rate' -Value $($PSBoundParameters['FloodRate']) }
		IF($PSBoundParameters.ContainsKey('LogOnHost')){ IF($LogOnHost.IsPresent -eq $True){$ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'log_on_host' -Value $True} }
		IF($PSBoundParameters.ContainsKey('Time')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'time' -Value $(Get-Date ((Get-Date $PSBoundParameters['Time']).ToUniversalTime()) -Format 'yyyy-MM-ddTHH:mm:ss.ffffK') }
		IF($PSBoundParameters.ContainsKey('oClusterID')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'cluster' -Value $(@{"id"=$PSBoundParameters['oClusterID']}) }
		IF($PSBoundParameters.ContainsKey('oDataCenterId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'data_center' -Value $(@{"id"=$PSBoundParameters['oDataCenterId']}) }
		IF($PSBoundParameters.ContainsKey('oHostId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $(@{"id"=$PSBoundParameters['oHostId']}) }
		IF($PSBoundParameters.ContainsKey('oStorageDomainId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domain' -Value $(@{"id"=$PSBoundParameters['oStorageDomainId']}) }
		IF($PSBoundParameters.ContainsKey('oTemplateId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'template' -Value $(@{"id"=$PSBoundParameters['oTemplateId']}) }
		IF($PSBoundParameters.ContainsKey('oUserId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'user' -Value $(@{"id"=$PSBoundParameters['oUserId']}) }
		IF($PSBoundParameters.ContainsKey('oVMId')){ $ActionParametersSpecs | Add-Member -MemberType NoteProperty -Name 'vm' -Value $(@{"id"=$PSBoundParameters['oVMId']}) }
		
		#Send to Server
		$BaseURL = "https://$($oVirtServerName)"
		$Uri = $BaseURL + "/ovirt-engine/api/events"
		$Method = "POST"
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($((Resolve-oVirtConnection -oVirtServerName $oVirtServerName).ExtensionData.access_token))"; "All-Content"="true"}
		Write-Verbose "$($MyInvocation.MyCommand): Headers [$($Headers | Out-String)]"
		Write-Verbose "$($MyInvocation.MyCommand): URI [$($URI)]"
		$JsonBody = $ActionParametersSpecs | ConvertTo-Json -Depth 50
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oEvent"
		Write-Verbose "$($JsonBody | Out-String)"
		$NewoEvent = $Null
		TRY{$NewoEvent = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoEvent){
			Write-Verbose "$($MyInvocation.MyCommand): Created oEvent"
			$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoEvent -ObjectType "oEvent" -oVirtServerName $oVirtServerName)) | Out-Null
			Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
		}Else{
			Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
		}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function New-oGroup{
	<#
		.SYNOPSIS
			This function creates a new oGroup on an oVirt system
		.DESCRIPTION
			This function creates a new oGroup on an oVirt system
		.PARAMETER Name
			The Name(s) of the oGroup
		.PARAMETER oDomain
			The name of the oDomain containing the LDAP group, or an $oDomain object
		.PARAMETER oDomainId
			The Id of the oDomain containing the LDAP group
		.PARAMETER oDomainUid
			The Uid of the oDomain containing the LDAP group
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oGroup -oVirtServerName $oVirtServerName -Name "Name"
				Creates the provided oGroup
		.EXAMPLE
			PS> New-oGroup -oVirtServerName $oVirtServerName -Name "Name" -oDomain "internal-authz"
				Creates the provided oGroup in the oVirt local authentication system
		.EXAMPLE
			PS> New-oGroup -oVirtServerName $oVirtServerName -Name "Name" -oDomain "MyLDAPDomain"
				Creates the provided oGroup from the LDAP domain in the oVirt system
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oGroup]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/11/2024
			Version 1.0b	4/24/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/groups
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/group
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/groups/methods/add , POST /ovirt-engine/api/groups
		.LINK
			Get-oGroup
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			#[ValidateScript({($_).GetType().Name -match 'String'})]
			[ValidateScript({($_).GetType().Name -match 'String|oGroup'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'String|oDomain'})]$oDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDomainId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDomainUid,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		IF($PSBoundParameters.ContainsKey('oVirtServerName')){$oVirtServerNames = $PSBoundParameters['oVirtServerName']}Else{$oVirtServerNames = Show-oVirtConnection | Select -ExpandProperty oVirtServerName}
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oVirtServerName in $oVirtServerNames){
			$BaseURL = "https://$($oVirtServerName)"
			IF($PSBoundParameters.ContainsKey("oDomain")){
				SWITCH($PSBoundParameters['oDomain']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDomain is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDomain = Get-oDomain -Name $PSBoundParameters['oDomain'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDomain = Get-oDomain -Name $PSBoundParameters['oDomain'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oDomain){$oDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDomain GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDomain = Get-oDomain -Name $PSBoundParameters['oDomain'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDomain = Get-oDomain -Name $PSBoundParameters['oDomain'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
						}
						IF($oDomain){$oDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDomain]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDomain is [oDomain]"
						$oDomain = $PSBoundParameters['oDomain']
					}
					{$_.GetType().Name -eq "oDomain"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDomain GetType equals [oDomain]"
						$oDomain = $PSBoundParameters['oDomain']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDomain is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}ElseIF($PSBoundParameters.ContainsKey("oDomainId")){
				IF($PSBoundParameters['oVirtServerName']){
					$oDomain = Get-oDomain -Id $PSBoundParameters['oDomainId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDomain = Get-oDomain -Id $PSBoundParameters['oDomainId'] -EA SilentlyContinue -oVirtServerName $oVirtServerName
				}
				IF($oDomain){$oDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}ElseIF($PSBoundParameters.ContainsKey("oDomainUid")){
				$UidUrl = [Uri]$oDomainUid
				$oDomain = Get-oDomain -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDomain){$oDomain | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			IF(($PSBoundParameters['Name']).GetType().Name -match 'oGroup'){
				$oGroupSpec = [PSCustomObject]@{"name" = $($PSBoundParameters['Name'].name)}
			}ElseIF(($PSBoundParameters['Name']).GetType().Name -match 'String'){
				$oGroupSpec = [PSCustomObject]@{"name" = $PSBoundParameters['Name']}
			}Else{
				Write-Warning "$($MyInvocation.MyCommand): Could not determine Type for '-Name' input parameter, quitting..."; BREAK
			}
			IF($oDomain){
				#$oGroupSpec | Add-Member -MemberType NoteProperty -Name 'domain' -Value $([PSCustomObject]@{'id'=$oDomain.Id})
				$oGroupSpec | Add-Member -MemberType NoteProperty -Name 'domain' -Value $([PSCustomObject]@{'name'=$oDomain.name})
			}
			#Send to Server
			Write-Verbose "$($MyInvocation.MyCommand): `$oGroupSpec [$($oGroupSpec | Out-String)]"
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/groups"
			$Method = "POST"
			$JsonBody = $oGroupSpec | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oGroup"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoGroup = $Null
			TRY{$NewoGroup = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoGroup){
				Write-Verbose "$($MyInvocation.MyCommand): Created oGroup"
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoGroup -ObjectType "oGroup" -oVirtServerName $oVirtServerName)) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oHost{
	<#
		.SYNOPSIS
			This function creates a new oHost, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oHost, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oHost
			Can use Wildcard '*'
		.PARAMETER Address
			The IPv4 IP address or Fully Qualified Domain Name (FQDN) of the oHost
		.PARAMETER RootPassword
			The Root Password of the oHost
		.PARAMETER oCluster
			The Name of the parent oCluster for the new oHost
		.PARAMETER oClusterId
			The Id of the parent oCluster for the new oHost
		.PARAMETER oClusterUid
			The Uid of the parent oCluster for the new oHost
		.PARAMETER Comment
			The Text for the Comment field to set on the oHost
		.PARAMETER Description
			The Text for the Description field to set on the oHost
		.PARAMETER OverrideDisplayAddress
			Indicates if to override the display address per host. Relevant only for the Host.display attribute. 
			If set, the graphical console address of a virtual machine will be overridden by the host specified 
			display address. if not set, the graphical console address of a virtual machine will not be overridden.
			Boolean to Enable/Disable Override
		.PARAMETER DisplayAddress
			Display Address Text String
				The IP address of the guest to connect the graphic console client to.
		.PARAMETER DeployHostedEngine
			When set to true, this host deploys the hosted engine components. A missing value is treated as true, 
			i.e., deploy the hosted engine components.
			Omitting this parameter equals false, and the host performs no operation in the hosted engine area.
		.PARAMETER UnDeployHostedEngine
			When set to true, this host un-deploys the hosted engine components and does not function as part of the High 
			Availability cluster. A missing value is treated as true, i.e., un-deploy. 
			Omitting this parameter equals false and the host performs no operation in the hosted engine area.
		.PARAMETER ExternalNetworkProvider
			If the cluster has a default external network provider that is supported for automatic deployment, 
			the external network provider is deployed when adding the host. Only external network providers for OVN 
			are supported for the automatic deployment. To deploy an external network provider other than the one defined 
			in the clusters, overwrite the external network provider when adding hosts.
			Default is "ovirt-provider-ovn"
		.PARAMETER SSHPort
			The SSH port 1-65535, Default is 22
		.PARAMETER SPMPriority
			 Set the Storage Pool Manager (SPM) priority of this host
				Valid options "Never","Low","Normal","High"
		.PARAMETER vGPUPlacement
			The vGPU placement strategy.
			Place vGPUs on the first available physical cards, or spread them over multiple physical cards.
				Valid options "Consolidated","Separated"
		.PARAMETER ActivateHostAfterInstall
			Activate Host After Installing the latest version of VDSM and related software on the host.
			When set to 'true', this host will be activated after its installation completes. 
			When set to 'false' the host will remain in 'maintenance' status after its installation. 
			Absence of this parameter will be interpreted as 'true', since the desired default behavior 
			is activating the host after install.
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install/parameters/activate
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts/methods/add
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install
		.PARAMETER RebootHostAfterInstall
			Reboot Host After Installing the latest version of VDSM and related software on the host.
			Indicates if the host should be rebooted after successful installation. The default value is true.
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install/parameters/reboot
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts/methods/add
		.PARAMETER EnablePowerManagement
			Indicates whether power management configuration is enabled or disabled.
		.PARAMETER DisablePolicyControlOfPowerManagement
			Disable policy control of power management
			Toggles the automated power control of the host in order to save energy. 
			When set to true, the host will be automatically powered down if the cluster’s load is low, 
			and powered on again when required. This is set to true when a host is created, unless disabled by the user.
		.PARAMETER KdumpIntegration
			Toggles whether to determine if kdump is running on the host before it is shut down. 
			When set to true, the host will not shut down during a kdump process. 
			This is set to true when a host has power management enabled, unless disabled by the user.
		.PARAMETER KSMEnabled (Not working ???)
			Kernel SamePage Merging (KSM) reduces references to memory pages from multiple identical pages to a 
			single page reference. Memory Deduplication. Boolean to Enable/Disable
			
			This property might be read only, AND triggers only when enabled on the cluster AND when the oHost 
			is under memory pressure
		.PARAMETER TransparentHugePageEnabled (Not working ???)
			Transparent huge page support expands the size of memory pages beyond the standard 4 KiB limit.
			Enable and set huge pages configuration. Boolean to Enable/Disable 
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oHost -oVirtServerName $oVirtServerName -Name "Name" -oCluster "oClusterName" -Address 'host.domain.com' -RootPassword 'blah'
				Creates a new oHost with the provided Name
		.INPUTS
			[System.String]
			[oCluster]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oHost]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/14/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts/methods/add

			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Address,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$RootPassword,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[ValidateScript({($_).GetType().Name -match 'String|oCluster'})]$oCluster,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oClusterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oClusterUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$OverrideDisplayAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$DisplayAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$DeployHostedEngine,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$UnDeployHostedEngine,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$ExternalNetworkProvider,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateRange(1,([math]::pow(2,16)-1))]
			[ValidateRange(1,65535)]
			[INT32]$SSHPort,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("Never","Low","Normal","High")][System.String]$SPMPriority,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("Consolidated","Separated")][System.String]$vGPUPlacement,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$ActivateHostAfterInstall,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$RebootHostAfterInstall,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$EnablePowerManagement,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$DisablePolicyControlOfPowerManagement,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$KdumpIntegration,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$KSMEnabled,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Boolean]$TransparentHugePageEnabled,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		$oClusterObjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oCluster']){
				SWITCH($PSBoundParameters['oCluster']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['oCluster'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oCluster]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is [oCluster]"
						$oClusterObjects = $PSBoundParameters['oCluster']
					}
					{$_.GetType().Name -eq "oCluster"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals [oCluster]"
						$oClusterObjects = $PSBoundParameters['oCluster']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oClusterId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['oClusterId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['oClusterId'] -EA SilentlyContinue
				}
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oClusterUid']){
				$UidUrl = [Uri]$oClusterUid
				$oClusterObjects = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObjects Names: $($oClusterObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		$BaseURL = "https://$($oVirtServerName)"
		$oHostSpecs = [PSCustomObject]@{}
		IF($PSBoundParameters.ContainsKey('Name')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
		IF($PSBoundParameters.ContainsKey('Address')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['Address']) }
		IF($PSBoundParameters.ContainsKey('RootPassword')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'root_password' -Value $($PSBoundParameters['RootPassword']) }
		IF($PSBoundParameters.ContainsKey('ActivateHostAfterInstall')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'activate' -Value $($PSBoundParameters['ActivateHostAfterInstall']) }
		IF($oClusterObjects){
			$oHostSpecs | Add-Member -MemberType NoteProperty -Name 'cluster' -Value $([PSCustomObject]@{id = $($oClusterObjects.Id)})
		}
		#IF($PSBoundParameters.ContainsKey('DeployHostedEngine')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'deploy_hosted_engine' -Value $($PSBoundParameters['DeployHostedEngine']) }
		#To add a hosted engine host, use the optional deploy_hosted_engine parameter:
		#POST /ovirt-engine/api/hosts?deploy_hosted_engine=true
		#IF($PSBoundParameters.ContainsKey('UnDeployHostedEngine')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'undeploy_hosted_engine' -Value $($PSBoundParameters['UnDeployHostedEngine']) }
		IF($PSBoundParameters.ContainsKey('RebootHostAfterInstall')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'reboot' -Value $($PSBoundParameters['RebootHostAfterInstall']) }
		IF($PSBoundParameters.ContainsKey('ExternalNetworkProvider')){
			$TmpSpec1 = [PSCustomObject]@{name = $($PSBoundParameters['ExternalNetworkProvider'])}
			$TmpSpec2 = [PSCustomObject]@{external_network_provider = $TmpSpec1}
			$TmpSpec3 = [PSCustomObject]@{external_network_provider_configuration = $TmpSpec2}
			$oHostSpecs | Add-Member -MemberType NoteProperty -Name 'external_network_provider_configurations' -Value $TmpSpec3
		}
		IF($PSBoundParameters.ContainsKey('Comment')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
		IF($PSBoundParameters.ContainsKey('Description')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
		IF($PSBoundParameters.ContainsKey('vGPUPlacement')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'vgpu_placement' -Value $($PSBoundParameters['vGPUPlacement']) }
		IF($PSBoundParameters.ContainsKey('SSHPort')){ $oHostSpecs | Add-Member -MemberType NoteProperty -Name 'ssh' -Value [PSCustomObject]@{port = $($PSBoundParameters['SSHPort'])} }
				
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/spm
		IF($PSBoundParameters.ContainsKey('SPMPriority')){
			SWITCH(($PSBoundParameters['SPMPriority'])){
				{$_ -eq "Never"}{$SPMPriorityValue = -1}
				{$_ -eq "Low"}{$SPMPriorityValue = 2}
				{$_ -eq "Normal"}{$SPMPriorityValue = 5}
				{$_ -eq "High"}{$SPMPriorityValue = 7}
			}
			$SPMSpec = [PSCustomObject]@{priority = $SPMPriorityValue}
			Add-Member -MemberType NoteProperty -Name "spm" -Value $SPMSpec -InputObject $oHostSpecs
		}
			
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/power_management
		IF($PSBoundParameters.ContainsKey('DisablePolicyControlOfPowerManagement')){
			$PMPSpec = [PSCustomObject]@{enabled = !$DisablePolicyControlOfPowerManagement}
			Add-Member -MemberType NoteProperty -Name "automatic_pm_enabled" -Value $PMPSpec -InputObject $oHostSpecs
		}
		IF($PSBoundParameters.ContainsKey('EnablePowerManagement')){
			$EPMSpec = [PSCustomObject]@{enabled = $EnablePowerManagement}
			Add-Member -MemberType NoteProperty -Name "power_management" -Value $EPMSpec -InputObject $oHostSpecs
		}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/power_management/attributes/kdump_detection
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/kdump_status
		IF($PSBoundParameters.ContainsKey('KdumpIntegration')){
			$KDISpec = [PSCustomObject]@{enabled = $KdumpIntegration}
			Add-Member -MemberType NoteProperty -Name "kdump_detection" -Value $KDISpec -InputObject $oHostSpecs
		}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host/attributes/ksm
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ksm
		# $XMLString = "<host><ksm><enabled>true</enabled></ksm></host>"
		IF($PSBoundParameters.ContainsKey('KSMEnabled')){
			$KSMSpec = [PSCustomObject]@{enabled = $KSMEnabled}
			#<merge_across_nodes>true</merge_across_nodes>
			Add-Member -MemberType NoteProperty -Name "ksm" -Value $KSMSpec -InputObject $oHostSpecs
		}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host/attributes/transparent_huge_pages
		# $XMLString = "<host><transparent_hugepages><enabled>false</enabled></transparent_hugepages></host>"
		IF($PSBoundParameters.ContainsKey('TransparentHugePageEnabled')){
			$THPSpec = [PSCustomObject]@{enabled = $TransparentHugePageEnabled}
			Add-Member -MemberType NoteProperty -Name "transparent_hugepages" -Value $THPSpec -InputObject $oHostSpecs
		}
		#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/display/attributes/allow_override
		IF($PSBoundParameters.ContainsKey('OverrideDisplayAddress')){
			IF($OverrideDisplayAddress -eq $True){
				IF($DisplayAddress){
					$ODASpec = [PSCustomObject]@{address = $DisplayAddress}
					Add-Member -MemberType NoteProperty -Name "display" -Value $ODASpec -InputObject $oHostSpecs
				}
			}ElseIF($OverrideDisplayAddress -eq $False){
				Add-Member -MemberType NoteProperty -Name "display" -Value $Null -InputObject $oHostSpecs
			}
		}	

		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/hosts"
		IF($PSBoundParameters.ContainsKey('DeployHostedEngine')){ $Uri = $BaseURL + "/ovirt-engine/api/hosts?deploy_hosted_engine=true" }
		$Method = "POST"
		$JsonBody = $oHostSpecs | ConvertTo-Json -Depth 50
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oHost"
		Write-Verbose "$($JsonBody | Out-String)"
		$NewoHost = $Null
		TRY{$NewoHost = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoHost){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoHost -ObjectType "oHost" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oMacPool{
	<#
		.SYNOPSIS
			This function creates an oMacPool on an oVirt system
		.DESCRIPTION
			This function creates an oMacPool on an oVirt system
			Creation of a MAC address pool requires values for the name and ranges attributes.
		.PARAMETER Name
			The Name(s) or oMacPool
			Can use Wildcard '*'
				I.e. MyIte*
		.PARAMETER Description
			The Description field (text) for the oMacPool
		.PARAMETER AllowDuplicates
			Defines whether duplicate MAC addresses are permitted in the pool.  If not specified, defaults to false.
		.PARAMETER DefaultPool
			Defines whether this is the default pool. If not specified, defaults to false.
		.PARAMETER FromMacAddress
			Starting MAC address in new oMacPool
		.PARAMETER ToMacAddress
			Ending MAC address in new oMacPool
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oMacPool -Name "MyNewoMacPool" -oVirtServerName $oVirtServerName -Description "ForVDIs" -FromMacAddress "00:00:00:00:00:00" -ToMacAddress "11-11-11-11-11-11"
		.INPUTS
			[System.String]
			[Boolean]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oMacPool]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/18/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/mac_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/mac_pool
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/mac_pools
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/mac_pools/methods/add
		.LINK
			Get-oMacPool
			Set-oMacPool
			Remove-oMacPool
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$AllowDuplicates,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$DefaultPool,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})|([0-9A-Fa-f]{2}){6}$')]
			[System.String]$FromMacAddress, #from
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})|([0-9A-Fa-f]{2}){6}$')]
			[System.String]$ToMacAddress, #to
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		#$OutPutItems = [System.Collections.ArrayList]@()
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
	}
	Process{
		$oMacPoolSpecs = [PSCustomObject]@{}
		#IF($PSBoundParameters.ContainsKey('Name')){ $oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'data_center' -Value $([PSCustomObject]@{name = $($PSBoundParameters['Name'])}) }
		IF($PSBoundParameters.ContainsKey('Name')){ $oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
		IF($PSBoundParameters.ContainsKey('Description')){ $oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
		IF(($PSBoundParameters['AllowDuplicates'].IsPresent -eq $True)){$oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'allow_duplicates' -Value $True}
		IF(($PSBoundParameters['DefaultPool'].IsPresent -eq $True)){$oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'default_pool' -Value $True}
		IF(($PSBoundParameters.ContainsKey('FromMacAddress')) -OR ($PSBoundParameters.ContainsKey('ToMacAddress'))){
			$oMacPoolRangeSpec = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('FromMacAddress')){ $oMacPoolRangeSpec | Add-Member -MemberType NoteProperty -Name 'from' -Value $($PSBoundParameters['FromMacAddress']) }
			IF($PSBoundParameters.ContainsKey('ToMacAddress')){ $oMacPoolRangeSpec | Add-Member -MemberType NoteProperty -Name 'to' -Value $($PSBoundParameters['ToMacAddress']) }
			Write-Verbose "$($MyInvocation.MyCommand): `$oMacPoolRangeSpec: [$($oMacPoolRangeSpec | Out-String)]"
			IF($oMacPoolRangeSpec){$oMacPoolSpecs | Add-Member -MemberType NoteProperty -Name 'ranges' -Value $([PSCustomObject]@{'range'=([ARRAY]@($oMacPoolRangeSpec))})}
		}
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/macpools"
		$Method = "POST"
		$JsonBody = $oMacPoolSpecs | ConvertTo-Json -Depth 50
		#$JsonBody | ConvertFrom-Json2Xml
		#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oMacPool"
		Write-Verbose "$($MyInvocation.MyCommand): Json: [$($JsonBody | Out-String)]"
		$NewoMacPool = $Null
		TRY{$NewoMacPool = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoMacPool){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoMacPool -ObjectType "oMacPool" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function New-oNetwork{
	<#
		.SYNOPSIS
			This function creates a new oNetwork, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oNetwork, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oNetwork
			Can use Wildcard '*'
		.PARAMETER oDataCenter
			The Name of the parent oDataCenter for the new oNetwork(s)
		.PARAMETER oDataCenterId
			The Id of the parent oDataCenter for the new oNetwork(s)
		.PARAMETER oDataCenterUid
			The Uid of the parent oDataCenter for the new oNetwork(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER Comment
			The Text for the Comment field to set on the oNetwork
		.PARAMETER Description
			The Text for the Description field to set on the oNetwork
		.PARAMETER NetworkLabel
			Represents a label which can be added to a host network interface and to a network. The label binds the network to the host network interface by the label id.
		.PARAMETER MTU
			The MTU (maximum transmission unit) for the oNetwork
				Default is 1500
				Valid range 68 to 65536
		.PARAMETER EnableVLANtagging
			Enables/Disables VLAN tagging
		.PARAMETER vLanId
			The vLAN Id to set if VLAN tagging is enabled
		.PARAMETER EnableVMNetwork
			Enables/Disables setting the Network to be used for VM traffic
		.PARAMETER PortIsolation
			Enables/Disables blocking communication between VMs running on the same host on this network.
		.PARAMETER HostNetworkQoSId
			The Host Network QoS Id
			Default is "unlimited"
		.PARAMETER EnableDNSConfiguration
			Enables/Disables dedicated DNS configuration overriding inheritence
		.PARAMETER DNSServers
			The IP Address(es) and/or Name(s) of DNS server(s) for this network
		.PARAMETER EnableCreateOnExternalProvider
			Enables/Disables Create on External Provider
		.PARAMETER ExternalProviderId
			The Id of the External Provider if EnableCreateOnExternalProvider is True
		.PARAMETER NetworkPortSecurity
			The Network Port Security selection if EnableCreateOnExternalProvider is True
			Valid options "undefined", "enabled", "disabled"
		.PARAMETER ConnectToPhysicalNetwork
			Enables/Disables Connect To Physical Network if EnableCreateOnExternalProvider is True
		.PARAMETER DataCenterNetworkId
			The DataCenter Network Id if ConnectToPhysicalNetwork is True
		.PARAMETER CustomPhysicalNetworkProvider
			The Custom Physical Network Provider if ConnectToPhysicalNetwork is True
		.PARAMETER STP
			Enables/Disables whether the spanning tree protocol is enabled for this network
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oNetwork -oVirtServerName $oVirtServerName -Name "Name" -oDataCenter "oDataCenterName" -vLanId 2233
				Creates a new oNetwork with the provided Name
		.INPUTS
			[System.String]
			[oDataCenter]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetwork]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		6/7/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/networks
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/networks/methods/add
		.LINK
			Get-oNetwork
			Remove-oNetwork
			Set-oNetwork
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[ValidateScript({($_).GetType().Name -match 'oVM|String|oCluster|oDatacenter|oHost'})]$oDataCenter,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDataCenterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDataCenterUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(68,65536)][INT32]$MTU,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$EnableVLANtagging,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateRange(1,4095)][INT32]$vLanId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$EnableVMNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$PortIsolation,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$HostNetworkQoSId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$EnableDNSConfiguration,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String[]]$DNSServers, #$dns_resolver_configuration,
		#Test and Update this
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[BOOLEAN]$EnableCreateOnExternalProvider,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			#[System.String]$ExternalProviderId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("undefined", "enabled", "disabled")]
			[System.String]$NetworkPortSecurity,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$ConnectToPhysicalNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$DataCenterNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$CustomPhysicalNetworkProvider,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$STP,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['oDataCenter'] Type: [$(($PSBoundParameters['oDataCenter']).GetType().Name)]"
		$oDataCenterObjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oDataCenter']){
				SWITCH($PSBoundParameters['oDataCenter']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDataCenterObjects = Get-oDataCenter -Name $PSBoundParameters['oDataCenter'] -EA SilentlyContinue
						}
						IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDataCenter]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['oDataCenter']
					}
					{$_.GetType().Name -eq "oDataCenter"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter GetType equals [oDataCenter]"
						$oDataCenterObjects = $PSBoundParameters['oDataCenter']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oDataCenterId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['oDataCenterId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDataCenterObjects = Get-oDataCenter -Id $PSBoundParameters['oDataCenterId'] -EA SilentlyContinue
				}
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oDataCenterUid']){
				$UidUrl = [Uri]$oDataCenterUid
				$oDataCenterObjects = Get-oDataCenter -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObjects Names: $($oDataCenterObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oDataCenterObject in $oDataCenterObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObject [$($oDataCenterObject | Out-String)]"
			$oVirtServerName = $oDataCenterObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oDataCenterObject Status [$($oDataCenterObject.Status)]"
			$oNetworkSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Name')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['Name']) }
			IF($PSBoundParameters.ContainsKey('Comment')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			IF($PSBoundParameters.ContainsKey('MTU')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'mtu' -Value $($PSBoundParameters['MTU']) }
			IF($PSBoundParameters.ContainsKey('PortIsolation')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'port_isolation' -Value $($PSBoundParameters['PortIsolation']) }
			IF($PSBoundParameters.ContainsKey('STP')){ $oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'stp' -Value $($PSBoundParameters['STP']) }
			IF($PSBoundParameters.ContainsKey('EnableVLANtagging')){
				IF($PSBoundParameters['EnableVLANtagging'] -eq $True){
					IF($PSBoundParameters['vLanId']){$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'vlan' -Value $([PSCustomObject]@{"id"=$PSBoundParameters['vLANId']})}
				}Else{
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'vlan' -Value $Null
					#The official documentation suggests using the above to remove a vlan, it is wrong, below is correct.
					$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'vlan' -Value $([PSCustomObject]@{"id"=$null})
				}
			}
			IF($PSBoundParameters.ContainsKey('EnableDNSConfiguration')){
				IF($PSBoundParameters['EnableDNSConfiguration'] -eq $True){
					IF($PSBoundParameters['DNSServers']){
						$NameServersSpecs = [PSCustomObject]@{}
						ForEach($Item in $PSBoundParameters['DNSServers']){
							#$DNSSpecs | Add-Member -MemberType NoteProperty -Name 'vlan' -Value $([PSCustomObject]@{"name_server"=$Item})
							$DNSSpecs | Add-Member -MemberType NoteProperty -Name 'name_server' -Value $Item
						}
						$NameServersSpecs = [PSCustomObject]@{"name_servers" = $NameServersSpecs}
						$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $NameServersSpecs
					}
				}Else{
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $Null
					$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $([PSCustomObject]@{"name_servers" = $([PSCustomObject]@{"name_server" = $null})})
				}
			}
			IF($PSBoundParameters.ContainsKey('EnableVMNetwork')){
				IF($PSBoundParameters['EnableVMNetwork'] -eq $True){
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'="vm"})
					$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'=@("vm")})
				}Else{
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'="null"})
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'=""})
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $Null
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'=@("null")})
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'=@("")})
					#$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value @()
					$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'usages' -Value $([PSCustomObject]@{'usage'=$null})
					
				}
			}
			IF(($PSBoundParameters.ContainsKey('oDataCenter')) -OR ($PSBoundParameters.ContainsKey('oDataCenterId')) -OR ($PSBoundParameters.ContainsKey('oDataCenterUid'))){
				IF($PSBoundParameters.ContainsKey('oDataCenterId')){
					$oDataCenterId = $PSBoundParameters['oDataCenterId']
				}ElseIF($PSBoundParameters.ContainsKey('oDataCenter')){
					$oDataCenterId = $oDataCenterObject.Id
				}ElseIF($PSBoundParameters.ContainsKey('oDataCenter')){
					$oDataCenterId = $oDataCenterObject.Id
				}
				IF($oDataCenterId){$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'data_center' -Value $([PSCustomObject]@{'id'=$oDataCenterId})}
			}
			IF($PSBoundParameters['HostNetworkQoSId']){$oNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'qos' -Value $([PSCustomObject]@{"id"=$PSBoundParameters['HostNetworkQoSId']})}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "/ovirt-engine/api/networks"
			$Method = "POST"
			$JsonBody = $oNetworkSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oNetwork"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoNetwork = $Null
			#TRY{$NewoNetwork = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null}
			TRY{$NewoNetwork = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoNetwork){
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoNetwork -ObjectType "oNetwork" -oVirtServerName $oVirtServerName)) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}
			
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oPermission{
	<#
		.SYNOPSIS
			This function creates a new oPermission, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oPermission, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER oObject
			The parent oObject for the new oPermission(s) to be applied
			Valid options oCluster|oDataCenter|oHost|oStorageDomain|oTemplate|oVM|oVmPool
		.PARAMETER oObjectId
			The Id of the parent oObject for the new oPermission(s) to be applied
		.PARAMETER oObjectcUid
			The Uid of the parent oObject for the new oPermission(s) to be applied
		.PARAMETER UserId
			The ID of a user for the new oPermission(s) to be applied
		.PARAMETER UserPrincipalName
			The AD UserPrincipalName of an LDAP user for the new oPermission(s) to be applied
		.PARAMETER Group
			The NAME of the group of users accounts to be assigned the oRole
		.PARAMETER GroupId
			The Id of the group of users accounts to be assigned the oRole
		.PARAMETER GroupUid
			The Uid of the group of users accounts to be assigned the oRole
		.PARAMETER oRole
			The Name of the parent oRole for the new oPermission(s)
		.PARAMETER oRoleId
			The Id of the parent oRole for the new oPermission(s)
		.PARAMETER oRoleUid
			The Uid of the parent oRole for the new oPermission(s)
		.PARAMETER AuthSource
			The User/Group identitiy source. Typically this will be an oDomain name.
				Commonly, "internal-authz", or "yourdomainforest.com" for ldap
		.PARAMETER LdapCredential
			A Credential Object to lookup AD User if LDAP domain is not trusted
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oPermission -oVirtServerName $oVirtServerName -Group "GroupName" -oObject "oObjectName" -oRole $oRole -AuthSource "ADForestDomain.com"
				Creates a new oPermission with the provided Group Name, found in the AuthSource, using the oRole for Permits
		.EXAMPLE
			PS> New-oPermission -oRole Pewter_Tier -Group gOLVM_Pewter_Tier -oObject $oDataCenter -AuthSource "internal-authz"
				Creates a new oPermission with the provided Group Name, found in the AuthSource, using the oRole for Permits
