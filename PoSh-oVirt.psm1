					$Uri = $oDatacenterObjectoiScsiBond.href
				}
			}
		}
		$oiScsiBondObject = Get-oUri -Uri $Uri -EA SilentlyContinue
		IF($PSBoundParameters.ContainsKey('Comment')){ $oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'Comment' -Value $PSBoundParameters['Comment'] }
		IF($PSBoundParameters.ContainsKey('Description')){ $oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $PSBoundParameters['Description'] }
		IF($PSBoundParameters.ContainsKey('NewName')){
			IF($oiScsiBondSpecs.name){
				$oiScsiBondSpecs.name = $PSBoundParameters['NewName']
			}Else{
				$oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $PSBoundParameters['NewName']
			}
		}
		
		IF($oiScsiBondSpecs | Get-Member -MemberType Properties){
			#Send to Server
			#PUT /ovirt-engine/api/datacenters/123/iscsibonds/1234
			Write-Verbose "oiScsiBondSpecs: $($oiScsiBondSpecs | Out-String)"
			$JsonBody = $oiScsiBondSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oiScsiBondSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Method = "PUT"
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oiScsiBond"
			Write-Verbose "Headers: $($Headers | Out-String)"
			Write-Verbose "Uri: $($Uri | Out-String)"
			Write-Verbose "Method: $($Method | Out-String)"
			Write-Verbose "JSON: $($JsonBody | Out-String)"
			$UpdatedoiScsiBond = $Null
			TRY{$UpdatedoiScsiBond = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($UpdatedoiScsiBond){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoiScsiBond -ObjectType "oiScsiBond" -oVirtServerName $oVirtServerName)) | Out-Null}
		}Else{
			#NOTE: The following returned error message USUALLY means the combo of settings are also incompatible
			#The remote server returned an error: (401) Unauthorized.; StatusCode=401; StatusDescription=Unauthorized
			Write-Warning "Configuration Settings provided by user are incompatible with oiScsiBond [$($Uri)]"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"; IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oNetworkAttachment{
	<#
		.SYNOPSIS
			This function updates an oNetworkAttachment, for an oHost (oHostNic), on an oVirt Server system.
		.DESCRIPTION
			This function updates an oNetworkAttachment, for an oHost (oHostNic), on a oVirt Server system.
			Returns the job response from the oVirt Server.
			An oNetworkAttachment is a logical "glue" connecting a physical oHostNic to a defined oNetwork in the oCluster/oDataCenter it resides
		.PARAMETER Name
			The Name(s) of oNetworkAttachment
			Can use Wildcard '*'
