								#$oName = [System.Web.HttpUtility]::UrlEncode($oName)
								$oName = [URI]::EscapeDataString($oName)
								$oURI = $URI + "?search=name%3D$($oName)"
								#Not Sure if "search" or "name" is the better option, or if I need to try both, I found "search" failed for vnicprofiles, but "name" worked, however I also need to assume that "search" was working for some, or I wouldn't have built it into the code originally
									#For Some Objects, like oNetwork, "search" works, "name" FAILS
									#For Some Objects, like ovNicProfile, "search" FAILS, "name" works
									#For Some Objects, like oCluster, oDataCenter, oHost, oTemplate, oVM, Both Work
									#Might also need to see how dual base/secondary objects work
									#Added Code below to retry with "name" if "search" FAILS to retrieve data
								#$oURI = $URI + "?name=$($oName)"
								#$oURI = $URI + "?name=$($oName)" + "&search=$($oName)"
							}ElseIF($oID){
								Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Process-oVxName: Found -Id [$($oID)] provided"
								$oID = [System.Web.HttpUtility]::UrlEncode($oID)
								$oURI = $URI + "/$($oID)"
							}
							IF(($CaseSensitive).IsPresent -eq $True){$oURI = $oURI + "&case_sensitive=true"}
							$oVxError = $Null
							Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$oURI [$($oURI)]"
							Try{$Response02 = $Null; $Response02 = Invoke-RestMethod -Uri $oURI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction SilentlyContinue}Catch{}
							
							IF(!($Response02)){
								IF($oName){
									Write-Host "$($oVxObjectName) [$($oName)] not found, [$($oVxError.Message)]"
								}ElseIF($oID){
									Write-Host "$($oVxObjectName)iD [$($oID)] not found, [$($oVxError.Message)]"
								}
							}
							IF($Response02){
								#$global:Response02_Saved = $Response02
								Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Raw $($oVxObjectName)s Response02 [$($Response02 | Select * | Out-String)]"
								IF($oName){
									IF($Response02.xml){
										IF(!($Response02.$WebObjectPluralName.$WebObjectSingularName)){
											$oURI = $URI + "?name=$($oName)"
											IF(($CaseSensitive).IsPresent -eq $True){$oURI = $oURI + "&case_sensitive=true"}
											$oVxError = $Null
											Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): `$oURI Retry XML [$($oURI)]"
											Try{$Response02b = $Null; $Response02b = Invoke-RestMethod -Uri $oURI -Method Get -Headers $Headers -ErrorVariable oVxError -ErrorAction SilentlyContinue}Catch{}
