								$oVxObjects = ($Response01.$WebObjectPluralName.$WebObjectSingularName | %{Convert-XMLtoPSObject -XML $_})
							}Else{
								Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): Extended Raw $($oVxObjectName)s Response01 [$($Response01.$WebObjectSingularName | Select * | Out-String)]"
