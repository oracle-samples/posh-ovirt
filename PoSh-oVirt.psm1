						$ALLAvailableoVNicProfiles = ((Get-oUri -RESTUri "/ovirt-engine/api/vnicprofiles" -oVirtServerName $oVirtServerName).vnic_profile)
						#(GOU /ovirt-engine/api/networks).network.data_center
						#$ALLAvailableoVNicProfiles.network.href
