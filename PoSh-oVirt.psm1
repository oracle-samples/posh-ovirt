			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/data_center_status
			IF(($TargetoDataCenter.status -eq "maintenance") -OR ($TargetoDataCenter.status -eq "uninitialized")){
				IF($PSCmdlet.ShouldProcess($TargetoDataCenter.Name , "Permanently Delete oDataCenter")) {
					$VMActionParameters = [PSCustomObject]@{
						'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})
						'force' = $(IF($Force.IsPresent -eq $True){$True}Else{$False})
					}
					$VMActions = [PSCustomObject]@{
						'action' = $VMActionParameters
					}
					$JsonBody = $VMActions | ConvertTo-Json

					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections |?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$oUri = $BaseURL + '/ovirt-engine/api/datacenters/' + $TargetoDataCenter.Id
					$Method = "DELETE"
					# Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json"
					#Try{$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri}
					Try{$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
					$DeleteResponse
				}
			}Else{
				Write-Warning "oDataCenter [$($TargetoDataCenter.Name)] is in status [$($TargetoDataCenter.status)] and can not be removed presently"
			}
		}
	}
	End{}
}

Function Remove-oDisk{
	<#
		.SYNOPSIS
			This function Permanently Removes the provided oDisk(s) from an oVirt system
		.DESCRIPTION
			This function Permanently Removes the provided oDisk(s) from an oVirt system
		.PARAMETER Name
			The Name(s) of oDisk(s)
			Can use Wildcard '*'
				I.e. MyIte*
			NOTE: STRONGLY RECOMMEND USING -ID, or better UID, instead of -NAME, because Name can discover multiple oDisks with the Same Name
		.PARAMETER Id
			The Id(s) of oDisk(s)
		.PARAMETER Uid
			The Uid(s) of oDisk(s)
		.PARAMETER CaseSensitive
			Switch to search Case Sensitive oDisk name(s)
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER Force
			Indicates that the oDisk should be removed even if it is in use, almost always a bad idea
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Remove-oDisk -oVirtServerName $oVirtServerName -Name "Name"
				Permanently Removes the provided oDisk(s)
		.INPUTS
			[System.String]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDisk]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/13/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			New-oDisk
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High',DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oDisk'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		 #Switch to search Case Sensitive oDisk name(s)
		#[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", DontShow)]
			#[Alias('CS')]
			#[SWITCH]$CaseSensitive,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$RunAsync,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$Force,
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		<#
			Function Remove-oDisk{} #https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/remove
			DELETE /ovirt-engine/api/disks/123 async
		#>

		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oDisk]: [$($PSBoundParameters['oDisk'] -IS [oDisk])]"
		$oDiskObjects = $NULL
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is String"
						#IF($PSBoundParameters['CaseSensitive'].IsPresent -eq $True){$oURI = $oURI + "&case_sensitive=true"}
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskObjects = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskObjects = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDiskObjects){$oDiskObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskObjects = Get-oDisk -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskObjects = Get-oDisk -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oDiskObjects){$oDiskObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDisk]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is [oDisk]"
						$oDiskObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oDisk"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDisk GetType equals [oDisk]"
						$oDiskObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDisk is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
				#Adding Out-GridView to force selection of desired oDisk(s) if multiple are returned, to minimize the chance of accidental deletions
				IF(($oDiskObjects | Measure-Object).Count -gt 1){
					#$Selection = $oDiskObjects | Select Name, Id, provisioned_size, oVirtServer, Description, Uid | Out-GridView -Title "Select oDisk(s) to Delete" -OutputMode Multiple
					#$oDiskObjects = $oDiskObjects | ?{$Selection.Uid -Contains $_.Uid}
					$oDiskObjects = (($oDiskObjects | Select Name, Id, provisioned_size, oVirtServer, Description, Uid | Out-GridView -Title "Select oDisk(s) to Delete" -OutputMode Multiple).Uid) | %{$Uid = $_; $oDiskObjects | ?{$_.Uid -eq $Uid}}
				}
				IF($oDiskObjects){$oDiskObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskObjects = Get-oDisk -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskObjects = Get-oDisk -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oDiskObjects){$oDiskObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oDiskObjects = Get-oDisk -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskObjects){$oDiskObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		ForEach($TargetoDisk in $oDiskObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$TargetoDisk [$($TargetoDisk.Name)]"
			$oVirtServerName = $TargetoDisk.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk_status
			IF(($TargetoDisk.status -eq "ok") -OR ($TargetoDisk.status -eq "illegal")){
				IF($PSCmdlet.ShouldProcess($TargetoDisk.Name , "Permanently Delete oDisk")) {
					$VMActionParameters = [PSCustomObject]@{
						'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})
						'force' = $(IF($Force.IsPresent -eq $True){$True}Else{$False})
					}
					$VMActions = [PSCustomObject]@{
						'action' = $VMActionParameters
					}
					$JsonBody = $VMActions | ConvertTo-Json

					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections |?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					$oUri = $BaseURL + '/ovirt-engine/api/disks/' + $TargetoDisk.Id
					$Method = "DELETE"
					# Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json"
					#Try{$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri}
					Try{$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
					$DeleteResponse
				}
			}Else{
				Write-Warning "oDisk [$($TargetoDisk.Name)] is in status [$($TargetoDisk.status)] and can not be removed presently"
			}
		}
	}
	End{}
}

