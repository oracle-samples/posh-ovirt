		IF($PSBoundParameters.ContainsKey('QcowVersion')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'qcow_version' -Value $($PSBoundParameters['QcowVersion']) }
		IF($PSBoundParameters.ContainsKey('ReadOnly')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'read_only' -Value $($PSBoundParameters['ReadOnly']) }
		IF($PSBoundParameters.ContainsKey('Shareable')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'shareable' -Value $($PSBoundParameters['Shareable']) }
		IF($PSBoundParameters.ContainsKey('Sparse')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'sparse' -Value $($PSBoundParameters['Sparse']) }
		#Probably Read Only and therefore N/A
