									Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): TypeName [$($TypeName)]"
									Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxOutPutObject [$($oVxOutPutObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name)]"
									Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxOutPutObject [$($oVxOutPutObject | Select * | Out-String)]"
									Write-Verbose "Get-$($oVxObjectName):$($MyInvocation.MyCommand): oVxObject [$($oVxObject | Get-Member -MemberType Properties, NoteProperty | Select -ExpandProperty Name)]"
