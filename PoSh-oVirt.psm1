		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
			[Alias('CS')]
			[SWITCH]$CaseSensitive,
	
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate,
	
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
        #Allows requesting Downstream items, Undetermined if I want to use this REST API feature, not used presently
		[Parameter(ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,DontShow)][String[]]$Follow,
		
