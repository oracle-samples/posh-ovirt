			$PSBoundParameters['SmartCardEnabled'] = $false #Disable the smartcard device.			#$oVM.display.smartcard_enabled
			$PSBoundParameters['MemoryBallooning'] = $false #Disable the memory balloon device		#$oVM.memory_policy.ballooning
			$PSBoundParameters['WatchDogModel'] = 'no_watchdog' #Disable the watchdog device.		#DELETE ($oVM.link | ?{$_.rel -eq "watchdogs"}).href
			#$PSBoundParameters['MigrationMode'] = 'pinned' #Disable migration.						#$oVM.placement_policy.affinity = "pinned"
			$PSBoundParameters['MigrationMode'] = 'user_migratable' #Allow manual migration only.	#$oVM.placement_policy.affinity = "user_migratable"
			$PSBoundParameters['HAEnabled'] = $false #Disable high availability.					#$oVM.high_availability.enabled
