							$oVMObjects = Get-oVM -Name $PSBoundParameters['oVM'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oVMObjects = Get-oVM -Name $PSBoundParameters['oVM'] -EA SilentlyContinue
						}
						IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oVM]}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMObjects = $PSBoundParameters['oVM']
					}
					{$_.GetType().Name -eq "oVM"}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM GetType equals [oVM]"
						$oVMObjects = $PSBoundParameters['oVM']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['oVMId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMObjects = Get-oVM -Id $PSBoundParameters['oVMId'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oVMObjects = Get-oVM -Id $PSBoundParameters['oVMId'] -EA SilentlyContinue
				}
				IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['oVMUid']){
				$UidUrl = [Uri]$oVMUid
				$oVMObjects = Get-oVM -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		
		$oDiskAttachmentObjects = @()
		IF($PSBoundParameters['oDiskAttachmentUid']){
			ForEach($Item in $PSBoundParameters['oDiskAttachmentUid']){
				$UidUrl = [Uri]$Item
				$oDiskAttachmentObjects += Get-oDiskAttachment -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oDiskAttachmentObjects){$oDiskAttachmentObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oDiskAttachmentId']){
			ForEach($Item in $PSBoundParameters['oDiskAttachmentId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oDiskAttachmentObjects += Get-oDiskAttachment -Id $Item -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oDiskAttachmentObjects += Get-oDiskAttachment -Id $Item -EA SilentlyContinue
				}
				IF($oDiskAttachmentObjects){$oDiskAttachmentObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oDiskAttachment']){
			ForEach($Item in $PSBoundParameters['oDiskAttachment']){
				SWITCH($Item){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskAttachmentObjects += Get-oDiskAttachment -Name $Item -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskAttachmentObjects += Get-oDiskAttachment -Name $Item -EA SilentlyContinue
						}
						IF($oDiskAttachmentObjects){$oDiskAttachmentObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oDiskAttachmentObjects += Get-oDiskAttachment -Name $Item -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oDiskAttachmentObjects += Get-oDiskAttachment -Name $Item -EA SilentlyContinue
						}
						IF($oDiskAttachmentObjects){$oDiskAttachmentObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oDiskAttachment]}{
						Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment is [oDiskAttachment]"
						$oDiskAttachmentObjects += $PSBoundParameters['oDiskAttachment']
					}
					{$_.GetType().Name -eq "oDiskAttachment"}{
						Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment GetType equals [oDiskAttachment]"
						$oDiskAttachmentObjects += $PSBoundParameters['oDiskAttachment']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oDiskAttachment is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oVMObjects Names: $($oVMObjects.Name)"
		Write-Verbose "$($MyInvocation.MyCommand): `$oDiskAttachmentObjects Names: $($oDiskAttachmentObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oVMObject in $oVMObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oVMObject [$($oVMObject | Out-String)]"
			$oVirtServerName = $oVMObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oVMObject Status [$($oVMObject.Status)]"
			
			$oSnapshotSpecs = [PSCustomObject]@{Description = $($PSBoundParameters['Description'])}
			IF(($PSBoundParameters['DontSaveMemory']).IsPresent -eq $True){$oSnapshotSpecs | Add-Member -MemberType NoteProperty -Name 'persist_memorystate' -Value $False}

			$disk_attachments = @()
			IF($oDiskAttachmentObjects){
				$ImageId = [GUID]::NewGuid().Guid
				ForEach($oDiskAttachmentObject in $oDiskAttachmentObjects){
					$disk_attachments += [PSCustomObject]@{
						disk_attachment = [PSCustomObject]@{
							disk = @{
								"id"=$oDiskAttachmentObject.Id
								"image_id"=$ImageId
							}
						}
					}
				}
			}
			
			IF(($PSBoundParameters['DontSnapDisks']).IsPresent -ne $True){
				IF(($disk_attachments).count -ge 1){
					#$oSnapshotSpecs | Add-Member -MemberType NoteProperty -Name 'mac' -Value $(@{"address"=$PSBoundParameters['CustomMacAddress']})
					$oSnapshotSpecs | Add-Member -MemberType NoteProperty -Name 'disk_attachments' -Value $disk_attachments
				}
			}ElseIF(($PSBoundParameters['DontSnapDisks']).IsPresent -eq $True){
				$oSnapshotSpecs | Add-Member -MemberType NoteProperty -Name 'disk_attachments' -Value ""
			}
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + "$(($oVMObject.link | ?{$_.rel -eq 'snapshots'}).href)"
			$Method = "POST"
			$JsonBody = $oSnapshotSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oSnapshot"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoSnapshot = $Null
			TRY{$NewoSnapshot = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoSnapshot){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoSnapshot -ObjectType "oVmNic" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Restore-oSnapshot{
	<#
		.SYNOPSIS
			This function Restores the provided oSnapshot for an oVM on an oVirt system
			PipedObject should be type(s) oSnapshot.
		.DESCRIPTION
			This function Restores the provided oSnapshot for an oVM on an oVirt system
		.PARAMETER oSnapshot
			The oSnapshot Object
			Can use Wildcard '*'
				I.e. MyIte*
		.PARAMETER Uid
			The Uid(s) of oSnapshot(s)
		.PARAMETER disks
			This paramter not configured in this release, requires disk ID and image_id per disk, without it, all disks are included
		.PARAMETER RestoreMemory
			The Include Restoring the Memory if saved in the oSnapshot
			Boolean
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.EXAMPLE
			PS> Restore-oSnapshot -oSnapshot $oSnapshot
				Restores the provided oSnapshot
		.EXAMPLE
			PS> Restore-oSnapshot -Uid $oSnapshot.Uid
				Restores the provided oSnapshot
		.INPUTS
			[System.String]
			[oSnapshot]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oSnapshot]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		9/30/2024
			Version 1.0b	10/01/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/snapshot/methods/restore
		.LINK
			New-oSnapshot
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High',DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oSnapshot'})]$oSnapshot,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
			[System.String]$RestoreMemory,
		[SWITCH]$RunAsync
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oSnapshot]: [$($PSBoundParameters['oSnapshot'] -IS [oSnapshot])]"
		$oSnapshotObject = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oSnapshot']){
				$oSnapshotObject = $PSBoundParameters['oSnapshot']
				$oUri = $($PSBoundParameters['oSnapshot']).Uid
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				#$UidUrl = [Uri]$Uid
				$oUri = $($PSBoundParameters['Uid'])
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oSnapshotObject [$($oSnapshotObject.Description)]"
		$UidUrl = [Uri]$oUri
		$oVirtServerName = $UidUrl.Host
		
		$ActionParameters = [PSCustomObject]@{
			'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})
			'restore_memory' = $(IF($RestoreMemory.IsPresent -eq $True){$True}Else{$False})
		}
		$Actions = [PSCustomObject]@{'action' = $ActionParameters}
		$JsonBody = $Actions | ConvertTo-Json
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections |?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$oUri = $oUri + '/restore'
		$Method = "POST"
		IF($PSBoundParameters['oSnapshot']){
			IF($oSnapshotObject.Description){
				$oSnapshotObjectText = $oSnapshotObject.Description
			}Else{
				$oSnapshotObjectText = $oSnapshotObject.Id
			}
			
		}ElseIF($PSBoundParameters['Uid']){
			#$oSnapshotObjectText = (Get-oUri -Uri $oSnapshot.Uid).Description
			$oSnapshotObject = (Get-oUri -Uri $($PSBoundParameters['Uid']))
			IF($oSnapshotObject){
				IF($oSnapshotObject.Description){
					$oSnapshotObjectText = $oSnapshotObject.Description
				}Else{
					$oSnapshotObjectText = $oSnapshotObject.Id
				}
			}Else{Write-Warning "Unable to retrieve Snapshot Uri [$($PSBoundParameters['Uid'])]"}
		}
		IF($PSCmdlet.ShouldProcess($oSnapshotObjectText, "Restore oSnapshot")) {
			Try{$RestoreResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
			$RestoreResponse
		}
	}
	End{}
}

