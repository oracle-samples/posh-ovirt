			VirtOps-Module
	#>
	[CmdletBinding(DefaultParametersetName="PS1")]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,ParameterSetName="PS1")]
			#[ValidateSet("Desktop", "Programs", "MyDocuments", "Personal", "Favorites", "Startup", "Recent", "SendTo", "StartMenu", "MyMusic", "MyVideos", "DesktopDirectory", "MyComputer", "NetworkShortcuts", "Fonts", "Templates", "CommonStartMenu", "CommonPrograms", "CommonStartup", "CommonDesktopDirectory", "ApplicationData", "PrinterShortcuts", "LocalApplicationData", "InternetCache", "Cookies", "History", "CommonApplicationData", "Windows", "System", "ProgramFiles", "MyPictures", "UserProfile", "SystemX86", "ProgramFilesX86", "CommonProgramFiles", "CommonProgramFilesX86", "CommonTemplates", "CommonDocuments", "CommonAdminTools", "AdminTools", "CommonMusic", "CommonPictures", "CommonVideos", "Resources", "LocalizedResources", "CommonOemLinks", "CDBurning")]
			[ArgumentCompleter({(([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name)})]
			[ValidateScript({($(([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name)) -Contains $_})]
			[String]$SpecialFolder,
		[Parameter(Mandatory = $False, ValueFromPipeline, ValueFromPipelineByPropertyName)][String]$Title = 'Select Folder',
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,ParameterSetName="PS2")]
			[ValidateScript({Test-Path -Path $_})][String]$BasePath
	)
	#This will List all Special Folders Available
	$SpecialFolders = ([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name
	IF($PSBoundParameters['SpecialFolder']){$InitialDirectory = $PSBoundParameters['SpecialFolder']}Else{$InitialDirectory = 'MyDocuments'}
	IF($PSBoundParameters['BasePath']){$InitialDirectory = $PSBoundParameters['BasePath']}Else{$InitialDirectory = 'MyDocuments'}
	IF($InitialDirectory -NotMatch "\\"){$InitialDirectory = [Environment]::GetFolderPath($($InitialDirectory))}
	[void][System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms')
    $FolderBrowserDialog = New-Object System.Windows.Forms.FolderBrowserDialog
    IF(!$PSBoundParameters['BasePath']){$FolderBrowserDialog.RootFolder = 'MyComputer'}
	$FolderBrowserDialog.Description = $Title
    $FoundRootFolderFlag = $False
    IF($PSBoundParameters['BasePath']){
		ForEach($SpecialFolder in $SpecialFolders){
			#([Environment]::GetFolderPath($($SpecialFolder)))
			IF($PSBoundParameters['BasePath'] -Match ([Regex]::Escape((([Environment]::GetFolderPath($($SpecialFolder))).Trim())))){
				IF($FoundRootFolderFlag -eq $False){$FolderBrowserDialog.RootFolder = $SpecialFolder}
			}ElseIF((Split-Path -Path $PSBoundParameters['BasePath']) -Match ([Regex]::Escape((([Environment]::GetFolderPath($($SpecialFolder))).Trim())))){
				IF($FoundRootFolderFlag -eq $False){$FolderBrowserDialog.RootFolder = $SpecialFolder}
			}
		}
	}
	IF($PSBoundParameters['SpecialFolder']){$FolderBrowserDialog.RootFolder = $PSBoundParameters['SpecialFolder']}
    IF($PSBoundParameters['BasePath']){$FolderBrowserDialog.SelectedPath = $PSBoundParameters['BasePath']}
    IF(!($FolderBrowserDialog.RootFolder)){$FolderBrowserDialog.RootFolder = 'MyComputer'}
	[void] $FolderBrowserDialog.ShowDialog()
	#Write-Host ($FolderBrowserDialog | Select *)
    Return $FolderBrowserDialog.SelectedPath
}

Function Get-ADSI_User{
	<#
		.SYNOPSIS
			Gets Active Directory User in any domain
		.DESCRIPTION
			Gets Active Directory User in any domain
			Can use '*' in -SamAccountName
		.PARAMETER SamAccountName
			The samacountname to search
		.PARAMETER TargetDomain
			The Active Directory domain to search
		.PARAMETER CredentialUserName
			UserName with permission to do the lookup in the TargetDomain
		.PARAMETER CredentialPassword
			Password for UserName with permission to do the lookup in the TargetDomain
		.EXAMPLE
			PS> Get-ADSI_User -SamAccountName someADname -TargetDomain activedirectorydomain.com -CredentialUserName $Credential.UserName -CredentialPassword $Credential.GetNetworkCredential().Password
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/1/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'none')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, Position=0)]
			[Alias('s')]
			[String]$SamAccountName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('d')]
			[String]$TargetDomain,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('u')]
			[String]$CredentialUserName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('p')]
			[String]$CredentialPassword
	)
	IF(!($PSBoundParameters.ContainsKey('TargetDomain'))){
		IF((Get-CimInstance win32_computersystem).PartOfDomain){
			$PSBoundParameters['TargetDomain'] = [System.DirectoryServices.ActiveDirectory.Domain]::GetCurrentDomain().Name
		}
	}
	IF($PSBoundParameters.ContainsKey('TargetDomain')){
		$Searcher = ([adsisearcher]"(&(ObjectCategory=Person)(ObjectClass=User)(samaccountname=$($SamAccountName)))")
		$Searcher.SearchRoot = [ADSI]::New("LDAP://$($PSBoundParameters['TargetDomain'])", $PSBoundParameters['CredentialUserName'], $PSBoundParameters['CredentialPassword'])
		$Searcher.FindAll().Properties
	}Else{Write-Warning "No Target Domain Provided or Discovered"}
}

