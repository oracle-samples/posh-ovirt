					}
					$TemplateSpecshosts = ([PSCustomObject]@{host=$HostArray})
					$TemplateSpecsPlacementPolicy = [PSCustomObject]@{hosts = $TemplateSpecshosts}
				}ElseIF($oHostId){
					$TemplateSpecsPlacementPolicy = [PSCustomObject]@{}
					$HostArray = [System.Collections.ArrayList]@()
					ForEach($Item in ($PSBoundParameters['oHostId'])){
						$HostArray.Add(([PSCustomObject]@{id = $Item})) | Out-Null
					}
					$TemplateSpecshosts = ([PSCustomObject]@{host=$HostArray})
					$TemplateSpecsPlacementPolicy = [PSCustomObject]@{hosts = $TemplateSpecshosts}
				}
				
				IF($MigrationMode){
					IF(!($TemplateSpecsPlacementPolicy)){$TemplateSpecsPlacementPolicy = [PSCustomObject]@{}}
					IF($MigrationMode){Add-Member -NotePropertyName "affinity" -NotePropertyValue $MigrationMode -inputObject $TemplateSpecsPlacementPolicy}
				}

				IF($InstanceType){
					$InstanceTypeID = $Null; $InstanceTypeID = (Get-oUri -RESTUri "/ovirt-engine/api/instancetypes?search=$($InstanceType)" -oVirtServerName $oVirtServerName).instance_type.id #Faster
					IF($InstanceTypeID){$TemplateSpecsInstanceType = ([PSCustomObject]@{id = $InstanceTypeID})}
				}
		
				IF(($LeaseStorageDomain) -AND (!($LeaseStorageDomainId))){
					$LeaseStorageDomainId = (Get-oUri -RESTUri "/ovirt-engine/api/storagedomains?search=$($LeaseStorageDomain)" -oVirtServerName $oVirtServerName).storage_domain.Id #Faster
				}
				IF($LeaseStorageDomainId){
					$TemplateSpecsLeaseStorageDomainId = [PSCustomObject]@{id = $LeaseStorageDomainId} #works
					$TemplateSpecsLeaseStorageDomain = [PSCustomObject]@{storage_domain = $TemplateSpecsLeaseStorageDomainId}
				}

				IF($PSBoundParameters.ContainsKey('VirtIOSCSIEnabled')){
					$TemplateSpecsVirtioScsi = ([PSCustomObject]@{enabled = $VirtIOSCSIEnabled})
					IF($VirtIOSCSIMultiQueues -AND ($VirtIOSCSIEnabled -eq $True)){
						IF(($VirtIOSCSIMultiQueues -eq "automatic") -OR ($VirtIOSCSIMultiQueues -eq "custom")){
							$VirtIOSCSIMultiQueuesEnabled = $true
						}Else{
							$VirtIOSCSIMultiQueuesEnabled = $false
						}
					}
				}
				
				IF($PSBoundParameters.ContainsKey('RandomGeneratorEnabled')){
					IF($RandomGeneratorEnabled -eq $True){
						$TemplateSpecsRandomGeneratorDevice = [PSCustomObject]@{source = "urandom"}
