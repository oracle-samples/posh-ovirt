				}Catch{$UpdatedVM = $TargetoVM; $FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; Write-Verbose "$($MyInvocation.MyCommand): `$FormattedWebError: [$($FormattedWebError | Out-String)]"}
