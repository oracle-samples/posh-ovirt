			$VMSpecsDisplay = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('DisplayAllowOverRide')){Add-Member -NotePropertyName "allow_override" -NotePropertyValue $PSBoundParameters['DisplayAllowOverRide'] -inputObject $VMSpecsDisplay}
