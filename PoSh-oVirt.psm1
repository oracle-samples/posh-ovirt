#region BASE_API_SET_Functions(PUT)

Function Set-oAffinityLabel{
	<#
		.SYNOPSIS
			This function updates an oAffinityLabel on an oVirt Server system.
		.DESCRIPTION
			The affinity label can influence virtual machine scheduling. It is most frequently used to create a sub-cluster from the available hosts.
		.PARAMETER Name
			The Name of the oAffinityLabel
		.PARAMETER Description
			A human-readable description in plain text.
		.PARAMETER oHost
			The oHost(s) to add to the oAffinityLabel
			Can be a text name(s) or an [oHost] PSObject(s)
		.PARAMETER oHostId
			The oHost Id(s) to add to the oAffinityLabel
		.PARAMETER oHostUid
			The oHost Uid(s) to add to the oAffinityLabel
		.PARAMETER RemoveoHost
			Switch to REMOVE provided oHost(s) from an existing oAffinityLabel. Otherwise Adds provided oHost(s).
		.PARAMETER oVM
			The oVM(s) to add to the oAffinityLabel
			Can be a text name(s) or an [oVM] PSObject(s)
		.PARAMETER oVMId
			The oVM Id(s) to add to the oAffinityLabel
		.PARAMETER oVMUid
			The oVM Uid(s) to add to the oAffinityLabel
		.PARAMETER RemoveoVM
			Switch to REMOVE provided oVM(s) from an existing oAffinityLabel. Otherwise Adds provided oVM(s).
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			Set-oAffinityLabel -Name "My oAffinityLabel" -NewName "SomeBetterName" -oHost "HostName01" -oVMId $oVM.Id -RemoveoVM -oVirtServerName $oVirtServerName
				Changes oAffinityLabel Name, Adds an oHost and removes an oVM
		.INPUTS
			[System.String]
			[oAffinityLabel]
			[oHost]
			[oVM]
			[BOOLEAN]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oAffinityLabel]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		11/20/2024
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/affinity_label
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/affinity_labels
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_affinity_label
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_affinity_labels
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_affinity_labels/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/assigned_affinity_label/methods/remove
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			New-oAffinityLabel
			Get-oAffinityLabel
			Remove-oAffinityLabel
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High',DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			#[ValidateScript({($_).GetType().Name -match 'oVM|String|oCluster|oDatacenter|oHost'})]$Name,
			[System.String]$NewName,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'String|oAffinityLabel'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$Uid,
		 #Switch to search Case Sensitive oDomain name(s)
		#[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
		#	[Alias('CS')]
			#[SWITCH]$CaseSensitive,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oHost|String'}} )]$oHost,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oHostId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oHostUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RemoveoHost,
			
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript( {$_ | %{($_).GetType().Name -match 'oVM|String'}})]$oVM,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String[]]$oVMId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateScript( {$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}}  )]
			[System.String]$oVMUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RemoveoVM,
			
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
		#	[Boolean]$HasImplicitAffinityGroup,
		#Once you set this it is very hard to undo
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
		#	[Boolean]$ReadOnly,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		#$OutPutItems = [System.Collections.ArrayList]@()
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
		$oHostObjects = [System.Collections.ArrayList]@()
		$oVMObjects = [System.Collections.ArrayList]@()
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand): Is [oAffinityLabel]: [$($PSBoundParameters['oAffinityLabel'] -IS [oAffinityLabel])]"
		
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
		$oAffinityLabelObjects = [System.Collections.ArrayList]@()
		
		IF($PSBoundParameters['Uid']){
			Write-Verbose "$($MyInvocation.MyCommand): User Entered Uid"
			$PSBoundParameters['Uid'] | %{
				$UidUrl = [Uri]$_
				#$oAffinityLabelObjects = Get-oAffinityLabel -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oAffinityLabelObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oAffinityLabel" -oVirtServerName $oVirtServerName})
				IF($oAffinityLabelObjects){$oAffinityLabelObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['Id']){
			Write-Verbose "$($MyInvocation.MyCommand): User Entered Id"
			ForEach($ItemId in $PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oAffinityLabelObjects += Get-oAffinityLabel -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oAffinityLabelObjects += Get-oAffinityLabel -Id $ItemId -EA SilentlyContinue
				}
				IF($oAffinityLabelObjects){$oAffinityLabelObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['Name']){
			Write-Verbose "$($MyInvocation.MyCommand): User Entered Name"
			ForEach($Item in $PSBoundParameters['Name']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oAffinityLabel is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oAffinityLabelObjects += Get-oAffinityLabel -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
						}Else{
							$oAffinityLabelObjects += Get-oAffinityLabel -Name $Item -EA SilentlyContinue
						}
						IF($oAffinityLabelObjects){$oAffinityLabelObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{($_ -IS [oAffinityLabel]) -OR ($_.GetType().Name -eq "oAffinityLabel")}{
						Write-Verbose "$($MyInvocation.MyCommand) oAffinityLabel is [oAffinityLabel]"
						$oAffinityLabelObjects += $Item
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oAffinityLabel is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oAffinityLabelObjects [$($oAffinityLabelObjects.Name)]"
		
		IF($PSBoundParameters['oHostUid']){
			$PSBoundParameters['oHostUid'] | %{
				$UidUrl = [Uri]$_
				#$oHostObjects = Get-oHost -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oHostObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oHost" -oVirtServerName $oVirtServerName})
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oHostId']){
			ForEach($ItemId in $PSBoundParameters['oHostId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oHostObjects += Get-oHost -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oHostObjects += Get-oHost -Id $ItemId -EA SilentlyContinue
				}
				IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oHost']){
			ForEach($Item in $PSBoundParameters['oHost']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oHostObjects += Get-oHost -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
						}Else{
							$oHostObjects += Get-oHost -Name $Item -EA SilentlyContinue
						}
						IF($oHostObjects){$oHostObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{($_ -IS [oHost]) -OR ($_.GetType().Name -eq "oHost")}{
						Write-Verbose "$($MyInvocation.MyCommand) oHost is [oHost]"
						$oHostObjects += $Item
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oHost is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		
		IF($PSBoundParameters['oVMUid']){
			$PSBoundParameters['oVMUid'] | %{
				$UidUrl = [Uri]$_
				$oVMObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oVM" -oVirtServerName $oVirtServerName})
				IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oVMId']){
			ForEach($ItemId in $PSBoundParameters['oVMId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oVMObjects += Get-oVM -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oVMObjects += Get-oVM -Id $ItemId -EA SilentlyContinue
				}
				IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oVM']){
			ForEach($Item in $PSBoundParameters['oVM']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oVMObjects += Get-oVM -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
						}Else{
							$oVMObjects += Get-oVM -Name $Item -EA SilentlyContinue
						}
						IF($oVMObjects){$oVMObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{($_ -IS [oVM]) -OR ($_.GetType().Name -eq "oVM")}{
						Write-Verbose "$($MyInvocation.MyCommand) oVM is [oVM]"
						$oVMObjects += $Item
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oVM is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		ForEach($oAffinityLabelObject in $oAffinityLabelObjects){
			$oAffinityLabelSpec = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('NewName')){$oAffinityLabelSpec | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['NewName'])}
			IF($PSBoundParameters.ContainsKey('HasImplicitAffinityGroup')){$oAffinityLabelSpec | Add-Member -MemberType NoteProperty -Name 'has_implicit_affinity_group' -Value $($PSBoundParameters['HasImplicitAffinityGroup'])}
			IF($PSBoundParameters.ContainsKey('ReadOnly')){$oAffinityLabelSpec | Add-Member -MemberType NoteProperty -Name 'read_only' -Value $($PSBoundParameters['ReadOnly'])}
			
			Write-Verbose "$($MyInvocation.MyCommand): `$oAffinityLabelSpec [$($oAffinityLabelSpec | Out-String)]"
			$UpdatedoAffinityLabel = $Null
			#Check for changes and execute
			IF([BOOLEAN]($oAffinityLabelSpec | Get-Member -MemberType NoteProperty)){
				$oVirtServerName = $oAffinityLabelObject.oVirtServer
				$BaseURL = "https://$($oVirtServerName)"
				#Send to Server
				Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
				$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
				$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
				#POST /ovirt-engine/api/affinitylabels
				$Uri = $BaseURL + "$($oAffinityLabelObject.href)"
				$Method = "PUT"
				$JsonBody = $oAffinityLabelSpec | ConvertTo-Json -Depth 50
				#$JsonBody | ConvertFrom-Json2Xml
				#($oAffinityLabelSpec | ConvertTo-Json | ConvertFrom-Json2Xml)
				Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Update oAffinityLabel in oVirt"
				Write-Verbose "$($JsonBody | Out-String)"
				Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
				
				TRY{$UpdatedoAffinityLabel = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			}
			IF($UpdatedoAffinityLabel){
				#Update $NewoAffinityGroup Object Here
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
				$UpdatedoAffinityLabel_Tmp = (Convert-RestResponseTooVirtObject -InputObject $UpdatedoAffinityLabel -ObjectType "oAffinityLabel" -oVirtServerName $oVirtServerName)
				$UpdatedoAffinityLabel_Tmp.UpdateData()
				IF($UpdatedoAffinityLabel_Tmp){
					$OutPutItems.Add($UpdatedoAffinityLabel_Tmp) | Out-Null
				}Else{
					$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $UpdatedoAffinityLabel -ObjectType "oAffinityLabel" -oVirtServerName $oVirtServerName)) | Out-Null
				}
			}Else{
				$UpdatedoAffinityLabel = $oAffinityLabelObject
				$OutPutItems.Add($UpdatedoAffinityLabel) | Out-Null
			}
			IF($oHostObjects){
				ForEach($oHostObject in $oHostObjects){
					$oHostObjectsSpec = [PSCustomObject]@{'id'=$($oHostObject.Id)}
					#Send to Server
					Write-Verbose "$($MyInvocation.MyCommand): `$oHostObjectsSpec [$($oHostObjectsSpec | Out-String)]"
					$oVirtServerName = $oHostObject.oVirtServer
					$BaseURL = "https://$($oVirtServerName)"
					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#POST /ovirt-engine/api/affinitylabels/000-000/hosts
					IF(($PSBoundParameters['RemoveoHost']).IsPresent -NE $True){
						$Uri = $BaseURL + "$($UpdatedoAffinityLabel.link.Where({$_.rel -eq 'hosts'}).href)"
						$Method = "POST"
						$JsonBody = $oHostObjectsSpec | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oHost to oAffinityGroup"
					}Else{
						$Uri = $BaseURL + "$($UpdatedoAffinityLabel.link.Where({$_.rel -eq 'hosts'}).href)" + "/$($oHostObject.Id)"
						$Method = "DELETE"
						$ActionParameters = [PSCustomObject]@{'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})}
						$Actions = [PSCustomObject]@{'action' = $ActionParameters}
						$JsonBody = $Actions | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Remove oHost from oAffinityGroup"
					}
					#$JsonBody | ConvertFrom-Json2Xml
					#($oHostObjectsSpec | ConvertTo-Json | ConvertFrom-Json2Xml)
					Write-Verbose "$($JsonBody | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
					$PlaceHolder = $Null
					TRY{$PlaceHolder = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutErrorItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
					IF($PlaceHolder){Write-Verbose "$($PlaceHolder | Out-String)"; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}Else{Write-Verbose "$($FormattedWebError)"}
				}
			}
			
			IF($oVMObjects){
				ForEach($oVMObject in $oVMObjects){
					$oVMObjectsSpec = [PSCustomObject]@{'id'=$($oVMObject.Id)}
					#Send to Server
					Write-Verbose "$($MyInvocation.MyCommand): `$oVMObjectsSpec [$($oVMObjectsSpec | Out-String)]"
					$oVirtServerName = $oVMObject.oVirtServer
					$BaseURL = "https://$($oVirtServerName)"
					Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
					$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
					$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
					#POST /ovirt-engine/api/affinitylabels/000-000/vms
					IF(($PSBoundParameters['RemoveoVM']).IsPresent -NE $True){
						$Uri = $BaseURL + "$($UpdatedoAffinityLabel.link.Where({$_.rel -eq 'vms'}).href)"
						$Method = "POST"
						$JsonBody = $oVMObjectsSpec | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oVM to oAffinityGroup"
					}Else{
						$Uri = $BaseURL + "$($UpdatedoAffinityLabel.link.Where({$_.rel -eq 'vms'}).href)" + "/$($oVMObject.Id)"
						$Method = "DELETE"
						$ActionParameters = [PSCustomObject]@{'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})}
						$Actions = [PSCustomObject]@{'action' = $ActionParameters}
						$JsonBody = $Actions | ConvertTo-Json -Depth 50
						Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Remove oVM from oAffinityGroup"
					}
					#$JsonBody | ConvertFrom-Json2Xml
					#($oVMObjectsSpec | ConvertTo-Json | ConvertFrom-Json2Xml)
					Write-Verbose "$($JsonBody | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
					$PlaceHolder = $Null
					TRY{$PlaceHolder = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutErrorItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
					IF($PlaceHolder){Write-Verbose "$($PlaceHolder | Out-String)"; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}Else{Write-Verbose "$($FormattedWebError)"}
				}
			}
		
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Invoke-oClusterAction{
	<#
		.SYNOPSIS
			This function reconfigures the provided oCluster, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oCluster, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oCluster(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of oCluster(s)
		.PARAMETER Uid
			The Uid(s) of oCluster(s)
		.PARAMETER Action
			The action to execute on the oCluster
			Valid options "upgrade","resetemulatedmachine","refreshglusterhealstatus","syncallnetworks"
		.PARAMETER UpGradeAction
			Used when -Action "upgrade"
			
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster_upgrade_action
			Valid options "start","finish"
			
			Name	Summary
			finish	The upgrade action to be passed to finish the cluster upgrade process by marking the cluster’s upgrade_running flag to false.
			start	The upgrade action to be passed to start the cluster upgrade process by marking the cluster’s upgrade_running flag to true.
			
			Finish: The upgrade action to be passed to finish the cluster upgrade process by marking the cluster’s upgrade_running flag to false. This should be used at the end of the cluster upgrade process.
			Start: The upgrade action to be passed to start the cluster upgrade process by marking the cluster’s upgrade_running flag to true. This should used at the beginning of the cluster upgrade process.
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		
		.EXAMPLE
			PS> Set-oCluster -oVirtServerName $oVirtServerName -NewName "Name"
				Changes the Name of the oCluster(s) to the provided NewName
		.INPUTS
			[System.String]
			[oCluster]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oCluster]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/15/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/clusters
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster/methods/upgrade
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster/methods/reset_emulated_machine
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster/methods/refresh_gluster_heal_status
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/cluster/methods/sync_all_networks
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oVM|String|oCluster|oDatacenter|oHost'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("upgrade","resetemulatedmachine","refreshglusterhealstatus","syncallnetworks")]
			[System.String]$Action,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[ValidateSet("start","finish")]
			[System.String]$UpGradeAction,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
			[SWITCH]$RunAsync,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "$($MyInvocation.MyCommand) Is [oCluster]: [$($PSBoundParameters['Name'] -IS [oCluster])]"
		Write-Verbose "$($MyInvocation.MyCommand) `$PSBoundParameters['Name'] Type: [$(($PSBoundParameters['Name']).GetType().Name)]"
		$oClusterObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['Name']){
				SWITCH($PSBoundParameters['Name']){
					{$_ -IS [System.String]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_.GetType().Name -eq "String"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						}Else{
							$oClusterObjects = Get-oCluster -Name $PSBoundParameters['Name'] -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{$_ -IS [oCluster]}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is [oCluster]"
						$oClusterObjects = $PSBoundParameters['Name']
					}
					{$_.GetType().Name -eq "oCluster"}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster GetType equals [oCluster]"
						$oClusterObjects = $PSBoundParameters['Name']
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set02"){
			IF($PSBoundParameters['Id']){
				IF($PSBoundParameters['oVirtServerName']){
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['Id'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				}Else{
					$oClusterObjects = Get-oCluster -Id $PSBoundParameters['Id'] -EA SilentlyContinue
				}
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['UId']){
				$UidUrl = [Uri]$Uid
				$oClusterObjects = Get-oCluster -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}
		Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObjects Names: $($oClusterObjects.Name)"
		
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oClusterObject in $oClusterObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oClusterObject [$($oClusterObject | Out-String)]"
			$oVirtServerName = $oClusterObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			$oClusterSpecs = [PSCustomObject]@{}
			
			IF($PSBoundParameters.ContainsKey('Action')){
				$Uri = $BaseURL + $(($oClusterObject.actions.link | ?{$_.rel -eq $($PSBoundParameters['Action'])}).href)
				IF($PSBoundParameters['Action'] -eq "upgrade"){
					IF($PSBoundParameters.ContainsKey('UpGradeAction')){
						$oClusterSpecs | Add-Member -MemberType NoteProperty -Name 'upgrade_action' -Value $($PSBoundParameters['Action'])
					}
				}Else{
					IF($PSBoundParameters['RunAsync'].IsPresent -eq $True){
						$oClusterSpecs = [PSCustomObject]@{async = $True}
					}Else{
						$oClusterSpecs = [PSCustomObject]@{async = $False}
					}
				}
			}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Method = "POST"
			$JsonBody = $oClusterSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oClusterSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to execute oCluster action [$($PSBoundParameters['Action'])]"
			Write-Verbose "$($JsonBody | Out-String)"
			$UpdatedoCluster = $Null
			#TRY{$UpdatedoCluster = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$UpdatedoCluster = $oClusterObject}
			TRY{$UpdatedoCluster = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); IF($FormattedWebError){$OutPutItems.Add($FormattedWebError) | Out-Null}Else{$UpdatedoCluster = $oClusterObject; $OutPutItems.Add($UpdatedoCluster) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}; Write-Error $FormattedWebError}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Set-oCluster{
	<#
		.SYNOPSIS
			This function reconfigures the provided oCluster, on an oVirt Server system.
		.DESCRIPTION
			This function reconfigures the provided oCluster, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oCluster(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of oCluster(s)
		.PARAMETER Uid
			The Uid(s) of oCluster(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER NewName
			The New Name to assign to the oCluster
		.PARAMETER Comment
			The Text for the Comment field to set on the oCluster
		.PARAMETER Description
			The Text for the Description field to set on the oCluster
		.PARAMETER BallooningEnabled
			Enable Memory Balloon Optimization
		.PARAMETER BiosType
			Selection of Bios types
				Valid options 'I440FX Chipset with BIOS [i440fx_sea_bios]', 'Q35 Chipset with BIOS [q35_sea_bios]', 'Q35 Chipset with UEFI [q35_ovmf]', 'Q35 Chipset with UEFI SecureBoot [q35_secure_boot]'
				Default is 'Q35 Chipset with UEFI SecureBoot [q35_secure_boot]'
		.PARAMETER CpuType
			Selection of Architecture and Type of Cpus
			Valid options 'Auto Detect [undefined]','Intel Nehalem Family [x86_64]','Secure Intel Nehalem Family [x86_64]','Intel Westmere Family [x86_64]','Secure Intel Westmere Family [x86_64]','Intel SandyBridge Family [x86_64]','Secure Intel SandyBridge Family [x86_64]','Intel IvyBridge Family [x86_64]','Secure Intel IvyBridge Family [x86_64]','Intel Haswell Family [x86_64]','Secure Intel Haswell Family [x86_64]','Intel Broadwell Family [x86_64]','Secure Intel Broadwell Family [x86_64]','Intel Skylake Client Family [x86_64]','Secure Intel Skylake Client Family [x86_64]','Intel Skylake Server Family [x86_64]','Secure Intel Skylake Server Family [x86_64]','Intel Cascadelake Server Family [x86_64]','Secure Intel Cascadelake Server Family [x86_64]','Intel Icelake Server Family [x86_64]','Secure Intel Icelake Server Family [x86_64]','AMD Opteron G4 [x86_64]','AMD Opteron G5 [x86_64]','AMD EPYC [x86_64]','Secure AMD EPYC [x86_64]','IBM POWER8 [ppc64]','IBM POWER9 [ppc64]','IBM z114,z196 [s390x]','IBM zBC12,zEC12 [s390x]','IBM z13s,z13 [s390x]','IBM z14 [s390x]'
		.PARAMETER SchedulingPolicy
			The Name of the Scheduling Policy to assign to the oCluster
		.PARAMETER SchedulingPolicyId
			The Id of the Scheduling Policy to assign to the oCluster
		.PARAMETER SerialNumberPolicy
			Serial Number Policy
				Valid options "SystemDefault","host","vm","custom"
		.PARAMETER CustomSerialNumber
			Custom Serial Number
		.PARAMETER CompatibilityVersion
			The Compatibility Version to assign to the oCluster
		.PARAMETER FencingEnabled
			Enable or disable fencing on the oCluster
		.PARAMETER SkipFencingIfHostHasLiveLeaseOnSstorage
			If enabled, Skip fencing if host has live lease on storage
		.PARAMETER SkipFencingOnClusterConnectivityIssues
			If enabled, will not fence a host in case more than a configurable percentage of hosts in the cluster lost connectivity as well
		.PARAMETER SkipFencingOnClusterConnectivityIssuesThreshold
			If "SkipFencingOnClusterConnectivityIssues" enabled (above), Sets the Minimum Percentage Threshold of hosts with connectivity issues before Skipping Fencing
		.PARAMETER FIPSMode
			Enable/Disable FIPS Mode
			FIPS mode is a configuration option for systems and hardware that use Federal Information Processing Standards-compliant cryptographic algorithms and protocols
			Valid options "disabled","enabled","undefined"
		.PARAMETER FirewallType
			Firewall Type
			Valid options "firewalld","iptables"
		.PARAMETER GlusterService
			Enable/Disable Gluster Service
		.PARAMETER HAReservation
			Enable/Disable HA Reservation
		.PARAMETER KSMEnabled
			Enable/Disable KSM (Kernel Samepage Merging)
			Memory Deduplication
		.PARAMETER KSMShareMemoryPages
			Selection of which Memory Pages can be shared as part of the conservation of physical RAM
				Valid options "All_Memory","Inside_NUMA"
		.PARAMETER LogMaxMemoryUsedThresholdType
			The memory consumption threshold type for logging audit log events
			When a percentage is specified, an audit log event is logged if the memory used is above the value specified in LogMaxMemoryUsedThresholdPercent
			When an absolute value is specified, an audit log event is logged if the free memory in MB falls below the value specified in LogMaxMemoryUsedThresholdMB
				Valid options 'percentage','absolute_value_in_mb'
		.PARAMETER LogMaxMemoryUsedThresholdPercent
			The memory consumption threshold for logging audit log events as a percentage
		.PARAMETER LogMaxMemoryUsedThresholdMB
			The memory consumption threshold for logging audit log events in MB
		.PARAMETER MacPool
			The Name of the Mac Address Pool to assign to the oCluster
		.PARAMETER MacPoolId
			The Id of the Mac Address Pool to assign to the oCluster
		.PARAMETER ManagementNetwork
			The Name of the Management Network to assign to the oCluster
		.PARAMETER ManagementNetworkId
			The Id of the Management Network to assign to the oCluster
		.PARAMETER MemoryOptimization
			oCluster Memory Over Commitment Option
			None - Disable memory overcommit
			For Server Load - Allow scheduling of 150% of physical memory
			For Desktop Load - Allow scheduling of 200% of physical memory
				Valid options "None","ServerLoad","DesktopLoad"
		.PARAMETER TransparentHugepagesEnabled
			Enable/Disable Transparent Hugepages
			Transparent huge page support expands the size of memory pages beyond the standard 4 KiB limit
		.PARAMETER MigrationPolicy
			The Name of the Migration Policy to assign to the oCluster
		.PARAMETER MigrationPolicyId
			The Id of the Migration Policy to assign to the oCluster
		.PARAMETER MigrationAutoConverge
			Enable/Disable Migration AutoConverge
		.PARAMETER MigrationCompressed
			Enable/Disable Migration Compression
		.PARAMETER MigrationEncrypted
			Enable/Disable Migration Encryption
		.PARAMETER MigrationParallel
			Whether and how many parallel migrations are allowed
				Valid options "disabled","auto","auto_parallel","custom"
		.PARAMETER MigrationNumberCustomParallel
			When "MigrationParallel" is set to custom, this setting configures the maximum number of parallel migrations allowed
				Valid range 2-255
		.PARAMETER MigrationBandwidth
			Sets how the Migration Bandwidth is assigned
			auto - Takes the bandwidth from the Quality of Service if the Quality of Service is defined.
			hypervisor_default - Takes the value as configured on the hypervisor.
			custom - Custom defined bandwidth in Mbit/s.
				Vaild options "auto","hypervisor_default","custom"
		.PARAMETER MigrationBandwidthLimitMbps
			If "MigrationBandwidth" option above is set to "custom", this sets the Migration Bandwidth Limit in Mbps
		.PARAMETER ResiliencePolicy
			Sets under which error conditions the Virtual Machines will be migrated
				Valid options "MigrateVirtualMachines","MigrateOnlyHighlyAvailableVirtualMachines","DoNotMigrateVirtualMachines"
		.PARAMETER AdditionalRandomNumberGeneratorEnabled
			Additional Random Number Generator source:
			Enables/Disables checkbox "/dev/hwrng source"
		.PARAMETER ThreadsAsCores
			Enables/Disables checkbox "Count Threads As Cores" under CPU Threads
			Allows guests to use host threads as virtual CPU cores
			Controls AMD Clustered MultiThreading or Intel Hyper-Threading technology
		.PARAMETER TrustedService
			Enables/Disables Trusted Service
		.PARAMETER TunnelMigration
			Enables/Disables Tunnel Migration
		.PARAMETER VirtService
			Enables/Disables Virt Service
		.PARAMETER OverriddeSPICEProxyAddress
			Enables/Disables "Overridden SPICE proxy address" checkbox
		.PARAMETER SPICEProxyAddress
			Overridden SPICE proxy address
			Input must be <protocol>://<fqdn>:<port>
		.PARAMETER VncEncryption
			Enables/Disables Vnc Encryption
		.EXAMPLE
			PS> Set-oCluster -oVirtServerName $oVirtServerName -NewName "Name"
				Changes the Name of the oCluster(s) to the provided NewName
		.INPUTS
			[System.String]
			[oCluster]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oCluster]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/2/2024
			Version 1.0b	4/14/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/clusters/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/cluster
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
