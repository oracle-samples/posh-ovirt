		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#Generic Input to facilitate Piping between Functions
		[Parameter(Mandatory, ValueFromPipeline, ValueFromPipelineByPropertyName, ParameterSetName="Solo", DontShow)]$PipedObject,
		
		#Switch to Syncopate (truncate/abridge) returned data set
