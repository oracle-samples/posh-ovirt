Function New-oNetworkLabel{
	<#
		.SYNOPSIS
			This function creates a new oNetworkLabel, for an oHostNic or oNetwork, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oNetworkLabel, for an oHostNic or oNetwork, on a oVirt Server system.
			Returns the oNetworkLabel object from the oVirt Server.
		.PARAMETER oObject
			The parent oObject for the new oNetworkLabel(s) to be applied
			Valid options oHostNic|oNetwork
		.PARAMETER New_ID_Name
			The New ID Name (techically Id property) to be assigned the oNetworkLabel (Typically Free Text, I don't know why but It is visually like the "name" in the Web UI)
				While it could be a GUID, it is usually a human readable name
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oNetworkLabel -oVirtServerName $oVirtServerName -oObject $oHostNic
				Creates a new oNetworkLabel for the provided oObject
		.EXAMPLE
			PS> $oHostNic | New-oNetworkLabel -oVirtServerName $oVirtServerName
				Creates a new oNetworkLabel for the provided oObject
		.EXAMPLE
			PS> $oNetwork | New-oNetworkLabel -oVirtServerName $oVirtServerName
				Creates a new oNetworkLabel for the provided oObject
		.EXAMPLE
			$oNetwork = Get-oNetwork -Name LS5CGM01_VL2403
			$oNetwork | Get-oNetworkLabel | Remove-oNetworkLabel -Confirm:0
			$oNetworkLabel = $oNetwork | New-oNetworkLabel -New_ID_Name "LS5CGM01SW"
		.EXAMPLE
			$oHosts = Get-oHost -oVirtServerName $oVirtServerName
			$oHostNics = $oHosts[0] | Get-oHostNic
			$oHostNic = $oHostNics[0]
			$oHostNic | Get-oNetworkLabel
			$oHostNic | Get-oNetworkLabel | Remove-oNetworkLabel -Confirm:0
			$oHostNic | New-oNetworkLabel -New_ID_Name LS5CGM01SW
		.INPUTS
			[System.String]
			[oHostNic]
			[oNetwork]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetworkLabel]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/29/2024
			Version 1.0b	9/26/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_label
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_label
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_labels
			https://ovirt.massopen.cloud/ovirt-engine/docs/Technical_Reference/Network_Labels.html
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High')]
	[Alias("Set-oNetworkLabel")]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0)]
			[Alias('O')]
			[ValidateScript({$_ | %{(($_).GetType().Name -match 'oHostNic|oNetwork')}})]$oObject,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="The New Name (New Id)")]
			[Alias('I')]
			[System.String]$New_ID_Name,
			
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand) Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
	}
	Process{
		$OutPutItems = [System.Collections.ArrayList]@()
		$oObjects = $PSBoundParameters['oObject']
		ForEach($Item in $oObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oObject [$($Item | Out-String)]"
			$oVirtServerName = $Item.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$BaseURL [$($BaseURL | Out-String)]"
			$oObjectSpecs = [PSCustomObject]@{"id"=$PSBoundParameters['New_ID_Name']}
			IF($Item.GetType().Name -eq "oHostNic"){
				$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'host_nic' -Value $(@{"id"=$Item.Id})
			}ElseIF($Item.GetType().Name -eq "oNetwork"){
				$oObjectSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $(@{"id"=$Item.Id})
			}
			
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			$Uri = $BaseURL + $Item.link.where({$_.rel -eq "networklabels"}).href
			$Method = "POST"
			$JsonBody = $oObjectSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oNetworkLabel"
			Write-Verbose "$($MyInvocation.MyCommand): `$Uri [$($Uri | Out-String)]"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoNetworkLabel = $Null
			TRY{$NewoNetworkLabel = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoNetworkLabel){
				Write-Verbose "$($MyInvocation.MyCommand): Created oNetworkLabel"
				$ThisoNetworkLabel = (Convert-RestResponseTooVirtObject -InputObject (Get-oUri -RESTUri $NewoNetworkLabel.href -oVirtServerName $oVirtServerName) -ObjectType "oNetworkLabel" -oVirtServerName $oVirtServerName)
				$OutPutItems.Add($ThisoNetworkLabel) | Out-Null
				Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
			}Else{
				Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
			}
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function New-oSnapshot{
	<#
		.SYNOPSIS
			This function creates a new oSnapshot, for an oVM, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oSnapshot, for an oVM, on a oVirt Server system.
			
			For including only a sub-set of disks in the snapshots, add disk_attachments element to the request body. Note that disks which are not specified in disk_attachments element will not be a part of the snapshot.
			If an empty disk_attachments element is passed, the snapshot will include only the virtual machine configuration. If no disk_attachments element is passed, then all the disks will be included in the snapshot.
			
			For each disk, image_id element can be specified for setting the new active image id. This is used in order to restore a chain of images from backup. I.e. when restoring a disk with snapshots, 
			the relevant image_id should be specified for each snapshot (so the identifiers of the disk snapshots are identical to the backup).
		.PARAMETER Description
			The Description of the oSnapshot
		.PARAMETER oVM
			The Name of the parent oVM for the new oSnapshot
		.PARAMETER oVMId
			The Id of the parent oVM for the new oSnapshot
		.PARAMETER oVMUid
			The Uid of the parent oVM for the new oSnapshot
		.PARAMETER oDiskAttachment
			The Name of the oDiskAttachment for the new oSnapshot
			For including only a sub-set of disks in the snapshots. Note that disks which are not specified element will not be a part of the snapshot, Unless NO disks are specified, then all will be included.
		.PARAMETER oDiskAttachmentId
			The Id of the oDiskAttachment for the new oSnapshot
			For including only a sub-set of disks in the snapshots. Note that disks which are not specified element will not be a part of the snapshot, Unless NO disks are specified, then all will be included.
		.PARAMETER oDiskAttachmentUid
			The Uid of the oDiskAttachment for the new oSnapshot
			For including only a sub-set of disks in the snapshots. Note that disks which are not specified element will not be a part of the snapshot, Unless NO disks are specified, then all will be included.
		.PARAMETER DontSaveMemory
			When a snapshot is created the default value for the persist_memorystate attribute is true. That means that the content of the memory of the virtual machine will be included in the snapshot, 
			and it also means that the virtual machine will be paused for a longer time. That can negatively affect applications that are very sensitive to timing (NTP servers, for example).
			In those cases make sure that you set the attribute to false using -DontSaveMemory
		.PARAMETER DontSnapDisks
			This switch will omit snapshoting disks, and only include the VM configuration in the oSnapShot
			If an empty disk_attachments element is passed, the snapshot will include only the virtual machine configuration.
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oSnapshot -oVirtServerName $oVirtServerName -Description "MySnapShot" -oVM "oVMName" -oDiskAttachmentId 'oDiskAttachmentId' -DontSaveMemory
				Creates a new oSnapshot with the provided Description
		.INPUTS
			[System.String]
			[oVM]
			[oDiskAttachment]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oSnapshot]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		9/30/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/snapshots/methods/add
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$oVM,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oVMId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oVMUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateScript({($_).GetType().Name -match 'oDiskAttachment|String'})]$oDiskAttachment,
			[ValidateScript({$_ | %{(($_).GetType().Name -match 'oDiskAttachment|String')}})]$oDiskAttachment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[ValidatePattern({$_ | %{('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')}})]
			[System.String[]]$oDiskAttachmentId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({$_ | %{IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}}})]
			[System.String[]]$oDiskAttachmentUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Switch]$DontSaveMemory,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[Switch]$DontSnapDisks,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		$oVMObjects = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
