			PS> Get-oAffinityLabel -oVirtServerName $oVirtServerName -Id $oAffinityLabelId
		.EXAMPLE
			PS> Get-oAffinityLabel -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
			[oVirtToken]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oAffinityLabel]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/22/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oAffinityLabel Name
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", Position=0)]
			[Alias('N')]
			[System.String[]]$Name,
		
        #oAffinityLabel Id
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[Alias('I')]
			[System.String[]]$Id,
		
       [Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set04")]
			[Alias('U')]
			[System.String[]]$Uid,
		
        #Switch to search Case Sensitive oDomain name(s)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02", DontShow)]
			[Alias('CS')]
			[SWITCH]$CaseSensitive,
	
		#Switch to Syncopate (truncate/abridge) returned data set
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('SP')]
			[SWITCH]$Syncopate,
	
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		
        #Allows requesting Downstream items, Undetermined if I want to use this REST API feature, not used presently
		[Parameter(ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,DontShow)][String[]]$Follow,
		
		#Generic Input to facilitate Piping between Functions
		[Parameter(ValueFromPipeline, ValueFromPipelineByPropertyName, ParameterSetName="Solo", DontShow)]
			[ValidateScript({($_).GetType().Name -match 'oVM|oHost'})]
			$PipedObject,
		
		#Switch to get all oTemplate(s) first if more than one name or id provided, then filter the results for matches
		# Parameter Hidden from PowerShell Predictive IntelliSense (Tab Ahead/ Tab Completion)
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, DontShow)]
			[Alias('B')]
			[SWITCH]$BatchRetrieve
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand): Process"
		$oVxObjectName = "oAffinityLabel"
		$oVxObjectName = "$((($MyInvocation.MyCommand) -Split('-'))[1])"
		
		IF($PSBoundParameters | ?{!$_.PipedObject}){$ParametersToSend = $PSBoundParameters}Else{$ParametersToSend = @{}}
		$ParametersToSend.Add("oVxObjectName",$oVxObjectName)
		IF($PSBoundParameters['PipedObject']){
			$ParametersToSend.Add("ParentUid",$PSBoundParameters['PipedObject'].Uid)
			#Switch(($($PSBoundParameters['PipedObject'].GetType().Name))){
			#	{$_ -eq "oHost"}{$ParametersToSend.oVxObjectName = "oHostLabel"}
			#	{$_ -eq "oVM"}{$ParametersToSend.oVxObjectName = "oVmLabel"}
			#}
		}
		$PipedObjectRetlatedClassMethods = $Null; 
		IF($PSBoundParameters['PipedObject']){$PipedObjectRetlatedClassMethods = ($PSBoundParameters['PipedObject']) | Get-Member -MemberType Method -EA SilentlyContinue | Select -ExpandProperty Name | ?{$_ -Match $oVxObjectName}}
