			#$VMSpecscluster = [PSCustomObject]@{name = ((Get-oCluster -oClusterId $oClusterId -oVirtServerName $oVirtServerName).Name)}
			$VMSpecscluster = [PSCustomObject]@{name = ((Get-oUri -RESTUri "/ovirt-engine/api/clusters/$($oClusterId)" -oVirtServerName $oVirtServerName).Name)} #Faster
		}Else{
			#Write-Warning "A Cluster is required, need somewhere to place the [$(Name)] oVM container";BREAK
