	IF($PSBoundParameters.ContainsKey('TargetDomain')){
		$Searcher = ([adsisearcher]"(&(ObjectCategory=group)(ObjectClass=group)(samaccountname=$($GroupName)))")
		$Searcher.SearchRoot = [ADSI]::New("LDAP://$($PSBoundParameters['TargetDomain'])", $PSBoundParameters['CredentialUserName'], $PSBoundParameters['CredentialPassword'])
		#$Searcher.PageSize = 1
		$Searcher.FindAll().Properties
	}Else{Write-Warning "No Target Domain Provided or Discovered"}
}

Function Test-IPV4Compatibility{
	<#
		.SYNOPSIS
			This function validates the mathematical compatibility of a V4 IP Address, NetMask, GateWay
		.DESCRIPTION
			This function validates the mathematical compatibility of a V4 IP Address, NetMask, GateWay
			Returns $True if compatibile, otherwise returns an error
		.PARAMETER IPAddress
		.PARAMETER Netmask
		.PARAMETER Gateway
		.EXAMPLE
			PS> Test-IPV4Compatibility -IPAddress $IPAddress -Netmask $Netmask -Gateway $Gateway
		.EXAMPLE
			PS> Test-IPV4Compatibility -IPAddress 196.168.1.50 -Netmask 255.255.255.0 -Gateway 196.168.1.1
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
			[BOOLEAN]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/24/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding()]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$')){ $True } Else { Throw "$_ is not an IPV4 Address or an FQDN!" }})]
			[System.String]
			[System.Net.IPAddress]$IPAddress,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248","255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128","255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0","255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0","255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0","255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0","255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0","240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0")]
			[System.String]$Netmask,
		
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$')){ $True } Else { Throw "$_ is not an IPV4 Address or an FQDN!" }})]
			[System.String]
			[System.Net.IPAddress]$Gateway	
	)
	Begin{}
	Process{
		Try{$Network = ([System.Net.IPAddress](([System.Net.IPAddress]$IPAddress).Address -BAND ([System.Net.IPAddress]$Netmask).Address)).IPAddressToString}Catch{Return $_.Exception.Message}
		Try{$GatewayNetwork = ([System.Net.IPAddress](([System.Net.IPAddress]$Gateway).Address -BAND ([System.Net.IPAddress]$Netmask).Address)).IPAddressToString}Catch{Return $_.Exception.Message}
		IF($Network -NE $GatewayNetwork){Throw "IP Address [$($IPAddress)] with Netmask [$($Netmask)] Can NOT Access Gateway [$($Gateway)]"}
		Try{$NetmaskBinary = ($Netmask -Split "\." | % {[System.Convert]::ToString($_,2).PadLeft(8,"0")}) -Join ""}Catch{Return $_.Exception.Message}
		IF(($NetmaskBinary -NotMatch "(^1+)0+$") -or ($NetmaskBinary.Length -NE 32)){Throw "Invalid Netmask: [$(Netmask)]"}
		$CIDR = $Matches[1].length
		Return $True
	}
	End{}
}

Function Update-oVirtServer_LastUsedTime{
	<#
		.SYNOPSIS
			This function updated the LastUsedTime & TokenConnectionExpires properties of an oVirtConnection
		.DESCRIPTION
			This function updated the LastUsedTime & TokenConnectionExpires properties of an oVirtConnection
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
		.INPUTS
			[System.String]
		.OUTPUTS
			None
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/28/2024
			Version 1.1		8/14/2025 Updated TokenTypicalTimeOutMinutes handling
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Connect-oVirtServer
			DisConnect-oVirtServer
			Get-Help
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, Position=0, HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String[]]$oVirtServerName,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,DontShow)]
			[INT32]$TokenTimeOutMinutes
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		ForEach($Item in $PSBoundParameters['oVirtServerName']){
			#So far in testing I have run over 20 hours, with regular repeat connections every few minutes, NOT using "Prefer" = "persistent-auth", and up to 30 minutes tested in between checks
			#Typical time out with no activity is 30 minutes
			#Activity keeps the Token valid up to the Token "exp" time (or the calculated for display time   (Show-oVirtConnection | Where{$_.Name -eq $PSBoundParameters['oVirtServerName']}).Expires  )
			#$TokenTypicalTimeOutMinutes is set by default to 30 Minutes below, but can be overridden by input parameter -TokenTimeOutMinutes
			#Discovered this is saved in /etc/ovirt-engine/engine-config	UserSessionTimeOutInterval
				# engine-config -g UserSessionTimeOutInterval
					# Picked up JAVA_TOOL_OPTIONS: -Dcom.redhat.fips=false
					# UserSessionTimeOutInterval: 30 version: general
				# engine-config -s UserSessionTimeOutInterval=30
				# so probably saved in the DB
				# probably a balance of performance impact by too many idle sessions vs too many new token requests
				# 
				# cat /etc/ovirt-engine/engine-config/engine-config.properties | grep -i UserSessionTimeOutInterval
					# UserSessionTimeOutInterval.type=Integer
					# UserSessionTimeOutInterval.validValues=-1,1..100000
					# UserSessionTimeOutInterval.description=Timeout interval in minutes, after which inactive user sessions expire. A negative value indicates that sessions never expire.
			
			$LastUsedTime = $(Get-Date)
			Write-Verbose "$($MyInvocation.MyCommand): Updating 'LastUsedTime' for oVirt Connection [$($Item)] to DateTime [$($LastUsedTime)]"
			IF(($global:oVirtConnections | ?{$_.Name -eq $Item}).LastUsedTime){($global:oVirtConnections | ?{$_.Name -eq $Item}).LastUsedTime = $LastUsedTime}
			IF(($global:oVirtConnections | ?{$_.Name -eq $Item}).TokenTypicalTimeOutMinutes){
				$TokenTypicalTimeOutMinutes = ($global:oVirtConnections | ?{$_.Name -eq $Item}).TokenTypicalTimeOutMinutes
				IF($PSBoundParameters['TokenTimeOutMinutes']){$TokenTypicalTimeOutMinutes = $PSBoundParameters['TokenTimeOutMinutes']; Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes Provided"}Else{Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes NOT Provided"}
				($global:oVirtConnections | ?{$_.Name -eq $Item}).TokenTypicalTimeOutMinutes = $TokenTypicalTimeOutMinutes
			}Else{
				$TokenTypicalTimeOutMinutes = 30
				IF($PSBoundParameters['TokenTimeOutMinutes']){$TokenTypicalTimeOutMinutes = $PSBoundParameters['TokenTimeOutMinutes']; Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes Provided"}Else{Write-Verbose "$($MyInvocation.MyCommand): TokenTimeOutMinutes NOT Provided"}
			}
			IF(($global:oVirtConnections | ?{$_.Name -eq $Item}).TokenConnectionExpires){($global:oVirtConnections | ?{$_.Name -eq $Item}).TokenConnectionExpires = (($LastUsedTime).AddMinutes($TokenTypicalTimeOutMinutes))}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Test-oFolderWriteAccess{
	<#
		.SYNOPSIS
			Test Read and Write Access of a Folder
		.DESCRIPTION
			Test Read and Write Access of a Folder
				Returns Nothing for No Access
				Returns "Read" for Read access
				Returns "Write" for Write access
				Returns "ReadWrite" for Read & Write access
		.PARAMETER Path
			Path to test
		.EXAMPLE
			PS> Test-FolderWriteAccess -Path  $Env:UserProfile
		.INPUTS
			[System.String]
		.OUTPUTS
			[System.String]
		.NOTES
			See David A. Stewart <david.a.stewart@cerner.com>.
		.LINK	
			Get-Help
	#>
	[CmdletBinding()]
    Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,Position=0)]
			[System.String]$Path
	)
	IF(!(Test-Path -Path $Path)){WRITE-WARNING "Invalid Path"; BREAK}
	$Access = $NULL ; $Result = $NULL
	$Guid = [System.Guid]::NewGuid()
	[VOID](DIR $Path -EA SilentlyContinue -EV Result)
	IF($Result.Count -eq 0){
		$Access += "Read"
	}
	Set-Content $Path\$Guid -Value $NULL -EA SilentlyContinue -EV Result
	IF($Result.Count -eq 0){
		$Access += "Write"
		Remove-Item -Force $Path\$Guid
	}
	Return $Access
}

Function Convert-oBase64StringToString{
	<#
		.SYNOPSIS
			Converts a Base 64 String to a Text String
		.DESCRIPTION
			Converts a Base 64 String to a Text String
		.PARAMETER Base64String
			The String to be converted
		.PARAMETER OutPutVariableName
			The copy ouput to a Global Variabe with name provided by input parameter OutPutVariableName, Instead of outputing to screen
		.PARAMETER ToClipBoard
			The copy ouput to clipboard
		.EXAMPLE
			PS> $OutPutStringVariable = Convert-oBase64StringToString -Base64String $Base64String
			Converts the String and Captures Text String to $OutPutStringVariable
		.EXAMPLE
			PS> Convert-oBase64StringToString -Base64String $Base64String -ToClipBoard
			Converts the String and Copies to the clipboard
		.NOTES
			Encode:  Convert Text String to Byte Array, then to Base64String
			$MyString = "Some Text"
			$ByteArray = ([System.Text.UTF8Encoding]::New()).Getbytes($MyString)
			$Base64String = [Convert]::ToBase64String($ByteArray)
				OR One-Liner
			$Base64String = [Convert]::ToBase64String(([System.Text.UTF8Encoding]::New()).Getbytes($MyString))
			
			Decode:  Convert from Base64String Back to Text String
			$ByteArray = [Convert]::FromBase64String($Base64String)
			$MyString = [char[]][byte[]]$ByteArray -join ''
				OR One-Liner
			$MyString = [char[]][byte[]][Convert]::FromBase64String($Base64String) -join ''
			
			See David A. Stewart <david.a.stewart@cerner.com>.
			v1.1 12/13/2021
		.LINK
			See David A. Stewart <david.a.stewart@cerner.com>.
		.LINK	
			Convert-StringToBase64String
			Get-Help
	#>
	[CmdletBinding()]
	#[OutputType([string])]
	param (
		[parameter(Mandatory=$True, ValueFromPipeline=$True)][Alias("s")][string]$Base64String,
		[parameter(Mandatory=$False)][Alias("v")][string]$OutPutVariableName,
		[parameter(Mandatory=$False)][Alias("c")][Switch]$ToClipBoard
	)
	Begin{}
	Process{
		#Convert Base64String to Byte Array
		$ByteArray = $Null; $ByteArray = [Convert]::FromBase64String($Base64String)
		#Convert Byte Array to MyString
		$MyString = $Null; $MyString = [char[]][byte[]]$ByteArray -join ''
		
		IF($MyString){
			IF($ToClipBoard.IsPresent){Write-Host "Text String Copied to Clipboard"; $MyString | Clip}
			IF($OutPutVariableName){
				IF(Get-Variable -Name $OutPutVariableName -Scope "Global" -EA SilentlyContinue){Remove-Variable -Name $OutPutVariableName -Scope "Global" -Confirm:$False -Force  -EA SilentlyContinue | Out-Null}
				IF(!(Get-Variable -Name $OutPutVariableName -Scope "Global" -EA SilentlyContinue)){New-Variable -Name $OutPutVariableName -Value $MyString -Scope "Global" -Confirm:$False -Force}
				IF(Get-Variable -Name $OutPutVariableName -Scope "Global" -EA SilentlyContinue){Set-Variable -Name $OutPutVariableName -Value $MyString -Scope "Global" -Confirm:$False -Force}
			}Else{
				$MyString
			}
		}Else{
			Write-Warning "[$($Base64String)] Could NOT be Converted to Text String."
		}
	}
	End{}
}
