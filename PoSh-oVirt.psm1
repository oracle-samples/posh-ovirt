					$oClusterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oClusterObjects += Get-oCluster -Id $ItemId -EA SilentlyContinue
				}
				IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			#$oClusterObjects = $oClusterObjects | Sort -Unique
		}ElseIF($PSBoundParameters['oCluster']){
			ForEach($Item in $PSBoundParameters['oCluster']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oClusterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
						}Else{
							$oClusterObjects += Get-oCluster -Name $Item -EA SilentlyContinue
						}
						IF($oClusterObjects){$oClusterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
					}
					{($_ -IS [oCluster]) -OR ($_.GetType().Name -eq "oCluster")}{
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is [oCluster]"
						$oClusterObjects += $Item
					}
					DEFAULT{
						Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
						Write-Verbose "$($MyInvocation.MyCommand) oCluster is GetType: $($_.GetType() | Out-String)"
						Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
					}
				}
			}
		}
		
		IF($PSBoundParameters['oCpuProfileUid']){
			$PSBoundParameters['oCpuProfileUid'] | %{
				$UidUrl = [Uri]$_
				#$oCpuProfileObjects = Get-oCpuProfile -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oCpuProfileObjects += (Get-oUri -Uri $_ -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oCpuProfile" -oVirtServerName $oVirtServerName})
				IF($oCpuProfileObjects){$oCpuProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
		}ElseIF($PSBoundParameters['oCpuProfileId']){
			ForEach($ItemId in $PSBoundParameters['oCpuProfileId']){
				IF($PSBoundParameters['oVirtServerName']){
					$oCpuProfileObjects += Get-oCpuProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -Id $ItemId -EA SilentlyContinue
				}Else{
					$oCpuProfileObjects += Get-oCpuProfile -Id $ItemId -EA SilentlyContinue
				}
				IF($oCpuProfileObjects){$oCpuProfileObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
			}
			#$oCpuProfileObjects = $oCpuProfileObjects | Sort -Unique
		}ElseIF($PSBoundParameters['oCpuProfile']){
			ForEach($Item in $PSBoundParameters['oCpuProfile']){
				SWITCH($Item){
					{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
						Write-Verbose "$($MyInvocation.MyCommand) oCpuProfile is String"
						IF($PSBoundParameters['oVirtServerName']){
							$oCpuProfileObjects += Get-oCpuProfile -oVirtServerName $PSBoundParameters['oVirtServerName'] -Name $Item -EA SilentlyContinue
