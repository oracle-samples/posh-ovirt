Function New-oIsoFile{  
  <#
		.SYNOPSIS
			Creates a new .iso file
		.DESCRIPTION
			The New-IsoFile cmdlet creates a new .iso file containing content from chosen folders
		.PARAMETER Source
			The path, array of path strings, Get-ChildItem -Path "<path>" objects, or Get-Item -LiteralPath "<path>" of files to add to the ISO Image file
		.PARAMETER OutPath
			The full file path to place the new ISO file
			Default is "$Env:Temp\$((Get-Date).ToString('yyyy-MM-dd_HH-mm-ss.ffff')).iso"
		.PARAMETER BootFile
			The path to the boot file for the ISO
		.PARAMETER Media
			The ISO Media type to Emulate
			The Default is 'DVDPLUSRW_DUALLAYER'
			Valid options 'CDR','CDRW','DVDRAM','DVDPLUSR','DVDPLUSRW','DVDPLUSR_DUALLAYER','DVDDASHR','DVDDASHRW','DVDDASHR_DUALLAYER','DISK','DVDPLUSRW_DUALLAYER','BDR','BDRE'
		.PARAMETER Title
			The Title for the ISO Image
			Default is (Get-Date).ToString("yyyy-MM-dd_HH-mm-ss.ffff")
		.PARAMETER Force
			Use -Force parameter to overwrite if the target file already exists
		.PARAMETER FromClipboard
			The Source data is replaced with contents of the Clipboard
		.EXAMPLE
			New-IsoFile "C:\Tools","C:\Utilities"
			This command creates a .iso file in $Env:Temp folder (default location) that contains "C:\Tools" and "C:\Utilities" folders.
			The folders themselves are included at the root of the .iso image.
		.EXAMPLE
			New-IsoFile -FromClipboard -Verbose Before running this command, select and copy (Ctrl-C) files/folders in Explorer first.
		.EXAMPLE
			dir C:\WinPE | New-IsoFile -OutPath c:\temp\WinPE.iso -BootFile "${Env:ProgramFiles(x86)}\Windows Kits\10\Assessment and Deployment Kit\Deployment Tools\amd64\Oscdimg\efisys.bin" -Media DVDPLUSR -Title "WinPE"
			This command creates a bootable .iso file containing the content from c:\WinPE folder, but the folder itself isn't included.
			Boot file etfsboot.com can be found in Windows ADK.
			Refer to IMAPI_MEDIA_PHYSICAL_TYPE enumeration for possible media types: http://msdn.microsoft.com/en-us/library/windows/desktop/aa366217(v=vs.85).aspx
		.EXAMPLE
			$SourceDirectory = "Z:\ISOFiles\ISO_001"
			Get-ChildItem $SourceDirectory | New-ISOFile -OutPath D:\NewISOs\ISO_001.iso
		.INPUTS
			[System.String]
			[System.Array]
			[System.IO.DirectoryInfo]
			[System.IO.FileInfo]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
		.NOTES
			Version 1.0		03/23/2016
			Version 1.0b	10/31/2024
			Version 1.0c	11/11/2025
		.LINK
			Get-Help
	#> 
	[CmdletBinding(DefaultParameterSetName='Source')]
	Param( 
		[Parameter(Position=1,Mandatory=$true,ValueFromPipeline=$true, ParameterSetName='Source')]$Source,
		[Parameter(Position=2)]
			[System.String]$OutPath = "$env:temp\$((Get-Date).ToString('yyyy-MM-dd_HH-mm-ss.ffff')).iso",
		[ValidateScript({Test-Path -LiteralPath $_ -PathType Leaf})]
			[System.String]$BootFile = $null,
		[ValidateSet('CDR','CDRW','DVDRAM','DVDPLUSR','DVDPLUSRW','DVDPLUSR_DUALLAYER','DVDDASHR','DVDDASHRW','DVDDASHR_DUALLAYER','DISK','DVDPLUSRW_DUALLAYER','BDR','BDRE')]
			[System.String]$Media = 'DVDPLUSRW_DUALLAYER',
		[System.String]$Title = (Get-Date).ToString("yyyy-MM-dd_HH-mm-ss.ffff"),
		[Switch]$Force,
		[Parameter(ParameterSetName='Clipboard')]
			[Switch]$FromClipboard
	)
	Begin{
		($CompilerParameters = new-object System.CodeDom.Compiler.CompilerParameters).CompilerOptions = '/unsafe'
		IF(!('ISOFile' -as [type])){
			Add-Type -CompilerParameters $CompilerParameters -TypeDefinition @'
public class ISOFile
{ 
  public unsafe static void Create(string Path, object Stream, int BlockSize, int TotalBlocks)
  {
    int bytes = 0;
    byte[] buf = new byte[BlockSize];
    var ptr = (System.IntPtr)(&bytes);
    var o = System.IO.File.OpenWrite(Path);
    var i = Stream as System.Runtime.InteropServices.ComTypes.IStream;

    if (o != null) {
      while (TotalBlocks-- > 0) {
        i.Read(buf, BlockSize, ptr); o.Write(buf, 0, bytes);
      }
      o.Flush(); o.Close();
    }
  }
}
'@
		}
		IF($BootFile){
			IF('BDR','BDRE' -contains $Media){Write-Warning "Bootable image doesn't seem to work with media type $Media"}
			($Stream = New-Object -ComObject ADODB.Stream -Property @{Type=1}).Open()  # adFileTypeBinary
			$Stream.LoadFromFile((Get-Item -LiteralPath $BootFile).Fullname)
			($Boot = New-Object -ComObject IMAPI2FS.BootOptions).AssignBootImage($Stream)
		} 
		$MediaType = @('UNKNOWN','CDROM','CDR','CDRW','DVDROM','DVDRAM','DVDPLUSR','DVDPLUSRW','DVDPLUSR_DUALLAYER','DVDDASHR','DVDDASHRW','DVDDASHR_DUALLAYER','DISK','DVDPLUSRW_DUALLAYER','HDDVDROM','HDDVDR','HDDVDRAM','BDROM','BDR','BDRE')
		Write-Verbose -Message "Selected media type is [$($Media)] with value [$($MediaType.IndexOf($Media))]"
		($Image = New-Object -com IMAPI2FS.MsftFileSystemImage -Property @{VolumeName=$Title}).ChooseImageDefaultsForMediaType($MediaType.IndexOf($Media))
		IF([System.IO.Path]::IsPathRooted($OutPath)){
			# Throw an exception if the path can't be used
			# Example Z:\Accepted, ZZ:\NotAccepted
			#$ValidatedPath = ([System.IO.DirectoryInfo]$OutPath).FullName
			$ValidatedPath = ([System.IO.DirectoryInfo]$OutPath)
			IF($ValidatedPath.Extension -ne ".iso"){throw [System.ArgumentException]"Missing .iso in file name"}
			IF(!(Test-Path -LiteralPath $OutPath -IsValid)){throw [System.ArgumentException]"[$($OutPath)] is not a valid path format."}
		}Else{Throw [System.ArgumentException]"Only fully-qualified paths are accepted."}
		IF(!($Target = New-Item -Path $OutPath -ItemType File -Force:$Force -ErrorAction SilentlyContinue)){Write-Error -Message "Cannot create file [$($OutPath)]. Use -Force parameter to overwrite if the target file already exists."; Break}
	}
	Process{
		IF($FromClipboard){
			IF($PSVersionTable.PSVersion.Major -lt 5){Write-Error -Message 'The -FromClipboard parameter is only supported on PowerShell v5 or higher'; Break}
			$Source = Get-Clipboard -Format FileDropList
		}
		ForEach($Item in $Source){
			IF($Item -IsNot [System.IO.FileInfo] -and $Item -IsNot [System.IO.DirectoryInfo]){$Item = Get-Item -LiteralPath $Item}
			IF($Item){
				Write-Verbose -Message "Adding Item to the target image: [$($Item.FullName)]"
				Try{$Image.Root.AddTree($Item.FullName, $True)}Catch{Write-Error -Message ($_.Exception.Message.Trim() + ' Try a different media type.')}
			}
		} 
	}
	End{
		IF($Boot){$Image.BootImageOptions=$Boot}
		$Result = $Image.CreateResultImage()
		[ISOFile]::Create($Target.FullName,$Result.ImageStream,$Result.BlockSize,$Result.TotalBlocks)
		Write-Verbose -Message "Target image [$($Target.FullName)] has been created"
		$Target
	}
}

Function Get-oVirtLogBundle{
	<#
		.SYNOPSIS
			This function will collect system configuration and diagnostic information from an oVirt Server System
		.DESCRIPTION
			If uses SSH/SCP to run the ovirt-log-collector and pass thru options.
			Upon successful collection, will download files to the local system, and prompt to delete from the oVirt Server System
			NOTE: It is strongly recommended to add options to filter results, as data collection sizes and times can get quite
				large on oVirt Systems with many KVM Hosts and VMs.
				The options in the oVirt Engine configuration group can be used to filter log collection from one or 
				more hypervisors. If the --no-hypervisors option is specified, data is not collected from any hypervisor.
			Attempts to use PoSh-SSH Module if available, and falls back on Putty if available
			NOTE: OpenSSH is not an option because there’s no option or argument to bypass the password prompt with OpenSSH.
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtRootPassword
			The Root Password for the oVirt Server, in clear text or secure string
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER DownloadFilePath
			The Folder Path on the local system to download the log files from the oVirt Server System
			Will Prompt for Folder Path if NOT provided
		.PARAMETER PoshForce
			Do not perform any host key validation of the host when Posh-SSH is the selection
		.PARAMETER Plink
			Use plink.exe instead of Posh-SSH
		.PARAMETER SSHAutoHostKeyAcceptance
			Auto Accepts New Host Keys if not stored
		.PARAMETER SSHSessionTimeOutSeconds
			SSH Session Time out in Seconds (Default is 1800)
		.PARAMETER SSHKeepAliveIntervalSeconds
			SSH KeepAlive Interval in Seconds (Default is 10)
		.PARAMETER ConfigFilePath
			--conf-file=PATH	path to configuration file (default=/etc/ovirt-engine/logcollector.conf)
		.PARAMETER LocalTmpPath
			--local-tmp=PATH	directory to copy reports to locally. Please note that the directory must 
				be empty (if already exists) and will be removed upon completion.
				(default is randomly generated like: /tmp/logcollector-mkc0ncqh)
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER TicketNumber
			--ticket-number=TICKET	ticket number to pass with the sosreport
				NOTE: Caused an Error in testing, not recommended
		.PARAMETER LogSizeMiB
			--log-size=SIZE       maximum size of log to collect in MiB
				(NOTE: this is a limit for the output of each individual sos plugin, not a limit on a size 
					of the total output from the host)
		.PARAMETER FTP_SERVER
			--upload=FTP_SERVER		Upload the report to Red Hat
				(use exclusively if advised from a Red Hat support representative).
				NOTE: THIS IS FROM THE OLVM, NOT the PowerShell Console
		.PARAMETER Quiet
			--quiet		reduce console output (default=False)
		.PARAMETER Batch
			--batch		batch mode - do not prompt interactively (default=False)
		.PARAMETER LogFilePath
			--log-file=PATH		path to log file
				(default=/var/log/ovirt-engine/ovirt-log-collector/ovirt-log-collector-<TIMESTAMP>.log)
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER CertFilePath
			--cert-file=/etc/pki/ovirt-engine/apache-ca.pem
				The CA certificate used to validate the engine. (default=/etc/pki/ovirt-engine/apache-ca.pem)
				NOTE: THIS IS LOCAL ON THE OLVM, NOT the PowerShell Console
		.PARAMETER Insecure
			--insecure	Do not make an attempt to verify the engine.
		.PARAMETER VerboseResponse
			-v, --verbose
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console, not to be confused with PowerShell -Verbose option
		.PARAMETER OutFilePath
			--output=OUTPUT		Destination directory where the report will be stored
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER IncludeSensitiveData
			--include-sensitive-data	Avoid to obfuscate sensitive data like passwords,
				etc.The generated archive will contain data considered sensitive and its 
				content should be reviewed by the originating organization before being 
				passed to any third party.
		.PARAMETER NoHypervisors
			--no-hypervisors    skip collection from hypervisors (default=False)
				If the --no-hypervisors option is specified, data is not collected from any hypervisor.
				Will cancell any entries in the -Hosts parameter
		.PARAMETER HypervisorPerCluster
			--hypervisor-per-cluster	Collect data only from a hypervisor per cluster; choose the SPM if found in a cluster.
		.PARAMETER TimeOnly
			--time-only		Just gather time diff from specified hypervisors
		.PARAMETER User
			-u user@engine.example.com, --user=user@engine.example.com
				username to use with the REST API. This should be in UPN format.
		.PARAMETER WithKerberos
			--with-kerberos		Enable Kerberos authentication instead of the default basic authentication.
		.PARAMETER Engine
			-r engine.example.com, --engine=engine.example.com
				hostname or IP address of the oVirt Engine (default=localhost:443)
		.PARAMETER Cluster
			-c CLUSTER, --cluster=CLUSTER
				pattern, or comma separated list of patterns to filter the host list by cluster name (default=None)
		.PARAMETER DataCenter
			-d DATACENTER, --data-center=DATACENTER
				pattern, or comma separated list of patterns to filter the host list by data center name (default=None)
		.PARAMETER Hosts
			-H HOSTS_LIST, --hosts=HOSTS_LIST
				comma separated list of hostnames, hostname patterns, FQDNs, FQDN patterns, IP addresses, or IP address
				patterns from which the log collector should collect hypervisor logs (default=None)
				If -NoHypervisors is used this input will be ignored
		.PARAMETER HostSSHPort
			--ssh-port=PORT		the port to ssh and scp on
		.PARAMETER KeyFilePath
			-k KEYFILE, --key-file=KEYFILE
				the identity file (private key) to be used for accessing the hypervisors 
				(default=/etc/pki/ovirt-engine/keys/engine_id_rsa). If a identity file is not supplied the program will 
				prompt for a password. It is strongly recommended to use key based authentication with SSH because the 
				program may make multiple SSH connections resulting in multiple requests for the SSH password.
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER MaxConnections
			--max-connections=MAX_CONNECTIONS
				max concurrent connections for fetching hypervisor logs (default = 10)
		.PARAMETER NoPostgresql
			--no-postgresql     This option causes the tool to skip the postgresql collection (default=false)
				The log collector will connect to the oVirt Engine PostgreSQL database and dump the data for inclusion in 
				the log report unless --no-postgresql is specified.
		.PARAMETER pgUser
			--pg-user=postgres  PostgreSQL database user name (default=postgres)
				The PostgreSQL user ID can be specified if different from the default.
		.PARAMETER pgDBname
			--pg-dbname=engine  PostgreSQL database name (default=engine)
				The PostgreSQL database name can be specified if different from the default.
		.PARAMETER pgDBhost
			--pg-dbhost=localhost	PostgreSQL database hostname or IP address (default=localhost)
				If the PostgreSQL database is not on the localhost set pg-dbhost
		.PARAMETER pgDBport
			--pg-dbport=5432    PostgreSQL server port number (default=5432)
				If the PostgreSQL database is not on the localhost provide pg-dbport
		.PARAMETER pgSSHUser
			--pg-ssh-user=root  the SSH user that will be used to connect to the server upon which the remote 
				PostgreSQL database lives. (default=root)
				If the PostgreSQL database is not on the localhost provide pg-ssh-user
		.PARAMETER pgHostKey
			--pg-host-key=none  the identity file (private key) to be used for accessing the host upon which 
				the PostgreSQL database lives (default=not needed if using localhost)
				If the PostgreSQL database is not on the localhost optionally supply pg-host-key
		.EXAMPLE
			Get-oVirtLogBundle -oVirtServerName $oVirtServerName -NoHypervisors
		.EXAMPLE
			Get-oVirtLogBundle -oVirtServerName $oVirtServerName -DownloadFilePath "C:\<MyPath>\OLVM\LogBundles" -Hosts <KVM_Name01, KVM_Name02> -Confirm:0
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/8/2025
			Version 1.1		5/8/2025
			Version 1.2		8/15/2025 Updated Putty to v0.83
			Version 1.3		10/4/2025
		.LINK	
			https://github.com/oVirt/ovirt-log-collector/releases
			https://support.oracle.com/knowledge/Oracle%20Linux%20and%20Virtualization/2713403_1.html
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", HelpMessage="Root Password for oVirt Server.")]
			$oVirtRootPassword,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Destination directory to Download logs to locally")]
			[System.String]$DownloadFilePath,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('PF')]
			[SWITCH]$PoshForce,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Use plink.exe instead of Posh-SSH")]
			[SWITCH]$Plink,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('AA')]
			[SWITCH]$SSHAutoHostKeyAcceptance,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds")]
			[INT32]$SSHSessionTimeOutSeconds = "1800",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds")]
			[INT32]$SSHKeepAliveIntervalSeconds = "10",
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="path to configuration file (default=/etc/ovirt-engine/logcollector.conf)")]
			[System.String]$ConfigFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="directory to copy reports to locally. Please note that the directory must be empty (if already exists) and will be removed upon completion. (default is randomly generated like: /tmp/logcollector-mkc0ncqh)")]
			[System.String]$LocalTmpPath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="ticket number to pass with the sosreport")]
			[System.String]$TicketNumber,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="maximum size of log to collect in MiB (NOTE: this is a limit for the output of each individual sos plugin, not a limit on a size of the total output from the host)")]
			[System.String]$LogSizeMiB,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Upload the report to Red Hat (use exclusively if advised from a Red Hat support representative).")]
			[System.String]$FTP_SERVER,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="reduce console output (default=False)")]
			[SWITCH]$Quiet,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="batch mode - do not prompt interactively (default=False)")]
			[SWITCH]$Batch,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="path to log file (default=/var/log/ovirt-engine/ovirt-log-collector/ovirt-log-collector-<TIMESTAMP>.log)")]
			[System.String]$LogFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="The CA certificate used to validate the engine. (default=/etc/pki/ovirt-engine/apache-ca.pem)")]
			[System.String]$CertFilePath = "/etc/pki/ovirt-engine/apache-ca.pem",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Do not make an attempt to verify the engine")]
			[SWITCH]$Insecure,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Verbose Output")]
			[SWITCH]$VerboseResponse,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Destination directory where the report will be stored")]
			[System.String]$OutFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Include Sensitive Data")]
			[SWITCH]$IncludeSensitiveData,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="skip collection from hypervisors (default=False)")]
			[SWITCH]$NoHypervisors,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Collect data only from a hypervisor per cluster; choose the SPM if found in a cluster.")]
			[SWITCH]$HypervisorPerCluster,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Just gather time diff from specified hypervisors")]
			[SWITCH]$TimeOnly,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="username to use with the REST API. This should be in UPN format. (user@engine.example.com)")]
			[System.String]$User,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Enable Kerberos authentication instead of the default basic authentication.")]
			[SWITCH]$WithKerberos,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="hostname or IP address of the oVirt Engine (default=localhost:443)")]
			[System.String]$Engine,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="pattern, or comma separated list of patterns to filter the host list by cluster name (default=None)")]
			[System.String[]]$Clusters,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="pattern, or comma separated list of patterns to filter the host list by data center name (default=None)")]
			[System.String[]]$DataCenters,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="comma separated list of hostnames, hostname patterns, FQDNs, FQDN patterns, IP addresses, or IP address patterns from which the log collector should collect hypervisor logs (default=None)")]
			[System.String[]]$Hosts,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the port to ssh and scp on")]
			[System.String]$HostSSHPort,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the identity file (private key) to be used for accessing the hypervisors (default=/etc/pki/ovirt-engine/keys/engine_id_rsa)")]
			[System.String]$KeyFilePath = "/etc/pki/ovirt-engine/keys/engine_id_rsa",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="max concurrent connections for fetching hypervisor logs (default = 10)")]
			[INT32]$MaxConnections,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="This option causes the tool to skip the postgresql collection (default=false)")]
			[SWITCH]$NoPostgresql,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database user name (default=postgres)")]
			[System.String]$pgUser = "postgres",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database user name (default=postgres)")]
			[System.String]$pgDBname = "postgres",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database hostname or IP address (default=localhost)")]
			[System.String]$pgDBhost = "localhost",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL server port number (default=5432)")]
			[INT32]$pgDBport = "5432",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the SSH user that will be used to connect to the server upon which the remote PostgreSQL database lives. (default=root)")]
			[System.String]$pgSSHUser = "root",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the identity file (private key) to be used for accessing the host upon which the PostgreSQL database lives (default=not needed if using localhost)")]
			[System.String]$pgHostKey = "none"
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"}
	Process{
		$Command = "ovirt-log-collector --no-hypervisors"
		$Command = "ovirt-log-collector"
		IF($PSBoundParameters['ConfigFilePath']){$Command = $Command + " --conf-file=$($PSBoundParameters['ConfigFilePath'])"}
		IF($PSBoundParameters['LocalTmpPath']){$Command = $Command + " --local-tmp=$($PSBoundParameters['LocalTmpPath'])"}
		IF($PSBoundParameters['TicketNumber']){$Command = $Command + " --ticket-number=$($PSBoundParameters['TicketNumber'] -Replace (' ','_'))"}
		IF($PSBoundParameters['LogSizeMiB']){$Command = $Command + " --log-size=$($PSBoundParameters['LogSizeMiB'])"}
		IF($PSBoundParameters['FTP_SERVER']){$Command = $Command + " --upload=$($PSBoundParameters['FTP_SERVER'])"}
		IF(($PSBoundParameters['Quiet']).IsPresent -eq $True){$Command = $Command + " --quiet"}
		IF(($PSBoundParameters['Batch']).IsPresent -eq $True){$Command = $Command + " --batch"}
		IF($PSBoundParameters['LogFilePath']){$Command = $Command + " --log-file=$($PSBoundParameters['LogFilePath'])"}
		IF($PSBoundParameters['CertFilePath']){$Command = $Command + " --cert-file=$($PSBoundParameters['CertFilePath'])"}
		IF(($PSBoundParameters['Insecure']).IsPresent -eq $True){$Command = $Command + " --insecure"}
		IF(($PSBoundParameters['VerboseResponse']).IsPresent -eq $True){$Command = $Command + " --verbose"}
		IF($PSBoundParameters['OutFilePath']){$Command = $Command + " --output=$($PSBoundParameters['OutFilePath'])"}
		IF(($PSBoundParameters['IncludeSensitiveData']).IsPresent -eq $True){$Command = $Command + " --include-sensitive-data"}
		IF(($PSBoundParameters['NoHypervisors']).IsPresent -eq $True){$Command = $Command + " --no-hypervisors"}
		IF(($PSBoundParameters['HypervisorPerCluster']).IsPresent -eq $True){$Command = $Command + " --hypervisor-per-cluster"}
		IF(($PSBoundParameters['TimeOnly']).IsPresent -eq $True){$Command = $Command + " --time-only"}
		IF($PSBoundParameters['User']){$Command = $Command + " --user=$($PSBoundParameters['User'])"}
		IF(($PSBoundParameters['WithKerberos']).IsPresent -eq $True){$Command = $Command + " --with-kerberos"}
		IF($PSBoundParameters['Engine']){$Command = $Command + " --engine=$($PSBoundParameters['Engine'])"}
		IF($PSBoundParameters['Clusters']){$Command = $Command + " --cluster=$($PSBoundParameters['Cluster'] -join ', ')"}
		IF($PSBoundParameters['DataCenters']){$Command = $Command + " --data-center=$($PSBoundParameters['DataCenter'] -join ', ')"}
		IF(($PSBoundParameters['Hosts']) -AND (!($PSBoundParameters['NoHypervisors']))){$Command = $Command + " --hosts=$($PSBoundParameters['Hosts'] -join ', ')"}
		IF($PSBoundParameters['HostSSHPort']){$Command = $Command + " --ssh-port=$($PSBoundParameters['HostSSHPort'])"}
		IF($PSBoundParameters['KeyFilePath']){$Command = $Command + " --key-file=$($PSBoundParameters['KeyFilePath'])"}
		IF($PSBoundParameters['MaxConnections']){$Command = $Command + " --max-connections=$($PSBoundParameters['MaxConnections'])"}
		IF(($PSBoundParameters['NoPostgresql']).IsPresent -eq $True){$Command = $Command + " --no-postgresql"}
		IF($PSBoundParameters['pgUser']){$Command = $Command + " --pg-user=$($PSBoundParameters['pgUser'])"}
		IF($PSBoundParameters['pgDBname']){$Command = $Command + " --pg-dbname=$($PSBoundParameters['pgDBname'])"}
		IF($PSBoundParameters['pgDBhost']){$Command = $Command + " --pg-dbhost=$($PSBoundParameters['pgDBhost'])"}
		IF($PSBoundParameters['pgDBport']){$Command = $Command + " --pg-dbport=$($PSBoundParameters['pgDBport'])"}
		IF($PSBoundParameters['pgSSHUser']){$Command = $Command + " --pg-ssh-user=$($PSBoundParameters['pgSSHUser'])"}
		IF($PSBoundParameters['pgHostKey']){$Command = $Command + " --pg-host-key=$($PSBoundParameters['pgHostKey'])"}
		
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oVirtSSHCredential']){
				IF($($PSBoundParameters['oVirtSSHCredential']).GetNetworkCredential().password -ne ""){
					$oVirtSSHCredential = $PSBoundParameters['oVirtSSHCredential']
					IF($PSBoundParameters['oVirtServerName']){
						($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential = $oVirtSSHCredential
					}ElseIF(($oVirtConnections).count -eq 1){
						$oVirtServerName = $oVirtConnections[0].oVirtServerName
						$oVirtConnections[0].oVirtSSHCredential = $oVirtSSHCredential
					}
					IF(!($oVirtRootPassword)){$oVirtRootPassword = $oVirtSSHCredential.GetNetworkCredential().password}
				}Else{$oVirtSSHCredential = $Null}
			}
			IF(!($oVirtSSHCredential)){
				IF($PSBoundParameters['oVirtServerName']){
					$oVirtSSHCredential = ($oVirtConnections | ?{$_.Name -eq $PSBoundParameters['oVirtServerName']}).oVirtSSHCredential
					$oVirtServerName = $PSBoundParameters['oVirtServerName']
					IF(!($oVirtRootPassword)){$oVirtRootPassword = $oVirtSSHCredential.GetNetworkCredential().password}
				}ElseIF(($oVirtConnections).count -eq 1){
					$oVirtConnection = ($oVirtConnections[0])
					$oVirtSSHCredential = $oVirtConnection.oVirtSSHCredential
					$oVirtServerName = $oVirtConnection.Name
				}
			}
			
			IF(!($oVirtServerName)){Write-Warning "No oVirt Server available, quitting...";BREAK}

			IF((!($oVirtSSHCredential)) -AND ($oVirtServerName)){
				IF($PSBoundParameters.ContainsKey('oVirtRootPassword')){
					$UserName = 'root'
					SWITCH($PSBoundParameters['oVirtRootPassword']){
						{$_ -Is [System.String]}{$oVirtRootPassword = $oVirtRootPassword | ConvertTo-SecureString -AsPlainText -Force}
						{$_ -Is [System.Security.SecureString]}{$oVirtRootPassword = $PSBoundParameters['oVirtRootPassword']}
					}
					$oVirtSSHCredential = (New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList @($UserName,$oVirtRootPassword))
				}Else{
					$oVirtSSHCredential = (Get-Credential -UserName "root" -Message "Enter SSH Credential for oVirt Server [$($oVirtServerName)]")
				}
			}
		}ElseIF(($PSBoundParameters.ContainsKey('oVirtRootPassword')) -AND ($PSBoundParameters['oVirtServerName']) -AND (!($PSBoundParameters['oVirtSSHCredential']))){
			$UserName = 'root'
			SWITCH($PSBoundParameters['oVirtRootPassword']){
				{$_ -Is [System.String]}{$oVirtRootPassword = $oVirtRootPassword | ConvertTo-SecureString -AsPlainText -Force}
				{$_ -Is [System.Security.SecureString]}{$oVirtRootPassword = $PSBoundParameters['oVirtRootPassword']}
			}
			$oVirtSSHCredential = (New-Object -TypeName System.Management.Automation.PSCredential -ArgumentList @($UserName,$oVirtRootPassword))
		}
		
		IF($PSBoundParameters['DownloadFilePath']){
			IF(!(Test-Path -Path $($PSBoundParameters['DownloadFilePath']) -EA SilentlyContinue)){
				Write-Warning "DownloadFilePath: [$($PSBoundParameters['DownloadFilePath'])] does NOT Exist, try again."; BREAK
			}Else{
				#Check if path is FOLDER
				IF(!(Test-Path -Path $DownloadFilePath -PathType Container)){Write-Warning "DownloadFilePath: [$($PSBoundParameters['DownloadFilePath'])] is NOT a folder, try again."; BREAK}
				$DownloadFilePath = ($PSBoundParameters['DownloadFilePath'])
				#Could use Test-oFolderWriteAccess to validate R/W access here
				IF((Test-oFolderWriteAccess -Path ($PSBoundParameters['DownloadFilePath'])) -ne "ReadWrite"){Write-Warning "DownloadFilePath: [$($PSBoundParameters['DownloadFilePath'])] folder is NOT Read/Write , try again."; BREAK}
			}
		}Else{
			#Run Function to Pop-Up user path
			$DownloadFilePath = Get-oFolderPath -Title 'Where Do You Want to Put the Log Bundle File(s)?' -SpecialFolder "Desktop"
		}
		IF((Test-oFolderWriteAccess -Path $DownloadFilePath) -ne "ReadWrite"){Write-Warning "DownloadFilePath: [$($DownloadFilePath)] folder is NOT Read/Write , try again."; BREAK}
		
		IF(!(Get-Module Posh-SSH)){	IF(Get-Module -ListAvailable Posh-SSH){Import-Module Posh-SSH}Else{Write-Warning "PowerShell Module 'Posh-SSH' NOT Installed. It can be found here: https://www.powershellgallery.com/packages/Posh-SSH/"} }
		$FileSizes = $Null
		
		IF($oVirtSSHCredential){
			Write-Verbose "`$oVirtSSHCredential Available"
			$Output = $Null
			ForEach($Item in $oVirtServerName){
				$CmdToSSHInvoke = $Command.Clone()
				IF((Get-Module Posh-SSH -EA SilentlyContinue) -AND (!($PLINK.IsPresent -eq $True))){
					Write-Verbose "`$CmdToSSHInvoke: [$($CmdToSSHInvoke)]"
					# [INT32]$SSHSessionTimeOutSeconds = "1800"; [INT32]$SSHKeepAliveIntervalSeconds = "10"
					$Session = $NULL; $SSHError = $NULL; $ID = $NULL; 
					IF($PSBoundParameters['PoshForce'].IsPresent -eq $True){
						IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
							TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError -KeepAliveInterval $SSHKeepAliveIntervalSeconds -ConnectionTimeout $SSHSessionTimeOutSeconds}Catch{}
						}Else{
							TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError -KeepAliveInterval $SSHKeepAliveIntervalSeconds -ConnectionTimeout $SSHSessionTimeOutSeconds}Catch{}
						}
					}Else{
						IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
							TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -ErrorAction SilentlyContinue -ErrorVariable SSHError -KeepAliveInterval $SSHKeepAliveIntervalSeconds -ConnectionTimeout $SSHSessionTimeOutSeconds}Catch{}
						}Else{
							TRY{$Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -ErrorAction SilentlyContinue -ErrorVariable SSHError -KeepAliveInterval $SSHKeepAliveIntervalSeconds -ConnectionTimeout $SSHSessionTimeOutSeconds}Catch{}
						}
					}
					IF($Session){
						$ID = $Session.SessionID
					}ElseIf($SSHError.Exception.Message -Match "Permission denied"){
						Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed. ["; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow "]"
					}Else{
						Write-Host -NoNewLine -Fore Yellow "`tFirst Attempt Opening SSH via Posh-SSH Failed. "; Write-Host -NoNewLine -Fore RED "$($SSHError.Exception.Message)"; Write-Host -Fore Yellow ", Attempting a second time."
						IF($oVirtSSHCredential){
							$Session = $NULL; $SSHError = $NULL; $Session = New-SSHSession -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -AcceptKey:$True -Force -ErrorAction SilentlyContinue -ErrorVariable SSHError -KeepAliveInterval $SSHKeepAliveIntervalSeconds -ConnectionTimeout $SSHSessionTimeOutSeconds
						}
						IF($Session){
							$ID = $Session.SessionID
						}Else{
							Write-Host -NoNewLine -Fore Yellow "`tOpening SSH via Posh-SSH Failed a Second Time, even using 'Force' (Do not perform any host key validation of the host.). "; Write-Host -Fore RED "$($SSHError.Exception.Message)"
						}
					}
					IF($Session.Connected -eq $True){
						Write-Host -NoNewLine -Fore Green "`tConnected to ["; Write-Host -NoNewLine "$($Session.Host)"; Write-Host -Fore Green "] via SSH"
						IF($PSCmdlet.ShouldProcess($oVirtServerName , "Run Log Collection Command(s) via SSH on oVirt")){
							Write-Verbose "`t`$CmdToSSHInvoke: $($CmdToSSHInvoke | Out-String)"
							Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -NoNewLine -Fore Cyan "] on ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Cyan "]"
							$Return = Invoke-SSHCommand -SessionId $ID -Command $($CmdToSSHInvoke) -EnsureConnection -TimeOut $SSHSessionTimeOutSeconds -ShowStandardOutputStream -ShowErrorOutputStream -StandardOutputStreamColor Cyan -ErrorOutputStreamColor Red
							IF(($Return.ExitStatus -eq 255) -And (!$Return.Output)){
								Write-Warning "No OutPut Response, suggest retry with param -SSHAutoHostKeyAcceptance"
							}Else{
								IF($Return.Error -Match 'bash: ovirt-log-collector: command not found'){
									$Output = $Null; Write-Warning "Package 'ovirt-log-collector' does not appear to be installed on [$($oVirtServerName)]`r`n`tUse 'dnf list installed | grep ovirt-log-collector' to check, and use 'dnf install ovirt-log-collector; dnf install python3-magic' to install, no logs collected."
								}Else{
									$LogBundlePath = ($Return.Output | ?{$_ -Match "INFO: Log files have been collected and placed in"}) -Split ' ' | Select -Last 1
									$CheckSum = ($Return.Output | ?{$_ -Match "sha256"})
									$Output = $Null; $Output = $Return.Output
									
									#Now Get File Sizes
									$Return2 = Invoke-SSHCommand -SessionId $ID -Command "ls -l $($LogBundlePath)*" -EnsureConnection -TimeOut $SSHSessionTimeOutSeconds -ShowStandardOutputStream -ShowErrorOutputStream -StandardOutputStreamColor Cyan -ErrorOutputStreamColor Red
									IF(($Return.ExitStatus -eq 0) -And ($Return.Output)){
										#Check File Sizes
										$FileSizes = @()
										ForEach($Item in $Return2.Output){
											$FileSizes += [PSCustomObject]@{
												FileName = $Item.Split(' ').Where({$_})[-1]
												FileSize = $Item.Split(' ').Where({$_})[4]
											}
										}
									}
								}
							}
						}
					}ElseIF($Session){Write-Host -Fore Red "`tSSH Connect to Posh-SSH Session Failed."}
				}Else{
					#Set up plink.exe commands
					#Determine if Putty (plink.exe, specifically) is installed and avaiable in the path
					Try{[void](Invoke-Command {plink.exe}); $PlinkPath = "plink.exe"}catch{
						<#
						IF(!($PlinkPath)){
							#$PlinkPath = "D:\Utilities\Putty\v0.63 beta\putty\PLINK.EXE"
							$PlinkPath = (((Get-Location).Path).Trim('\'))+"\plink.exe"
							IF(!(Test-Path $PlinkPath)){
								$DeletePlink = $True
								#Convert-FileToBase64String -FilePath "C:\Program Files\PuTTY\plink.exe" -OutPutVariableName PlinkAsText -ToClipBoard
								$PlinkAsText = ''
								$PEBytes = [System.Convert]::FromBase64String($PlinkAsText)
								#Write to Disk (tmp location)
								[System.IO.File]::WriteAllBytes($PlinkPath,$PEBytes)
							}
						}
						#>
						Write-Warning "Plink.exe NOT Installed. It is a part of the PuTTY suite, found here: https://www.chiark.greenend.org.uk/~sgtatham/putty/latest.html"
						BREAK
					}
					IF($oVirtSSHCredential){$plinkoptions = "-v -ssh -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"}
					$RemoteCommand = "`'" + $CmdToSSHInvoke + "`'"
					Write-Verbose "`t`$RemoteCommand: $($RemoteCommand)"
					Write-Debug "`t`$RemoteCommand: [$($RemoteCommand)]"
					IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
						IF($oVirtSSHCredential){$PlinkCommand = "echo y | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand}
					}Else{
						IF($oVirtSSHCredential){$PlinkCommand = "echo n | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand}
					}
					Write-Verbose "`t`$PlinkCommand: $($PlinkCommand)"
					Write-Debug "`t`$PlinkCommand: [$($PlinkCommand)]"
					$DeletePlink = $False; $PlinkPath = $Null; $DoNoContinuePlink = $Null
					IF($PSCmdlet.ShouldProcess($oVirtServerName , "Run Log Collection Command(s) via SSH on oVirt")){
						IF($oVirtSSHCredential){
							Write-Host -NoNewLine -Fore Green "`tConnecting to ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Green "] via SSH"
							Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -NoNewLine -Fore Cyan "] on ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Cyan "]"
							#$global:RawOutput = $Null; $global:RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue 2>$null 3>$null 5>$null
							$global:RawOutput = $Null; $global:RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue -EV PlinkErrorStream 2>&1 3>$null 5>$null
							IF((!($global:RawOutput)) -OR ($PlinkErrorStream)){
								#$global:RawOutput = Invoke-Expression -command $PlinkCommand -EA SilentlyContinue -EV PlinkErrorStream 2>&1
								IF($PlinkErrorStream -Match 'bash: ovirt-log-collector: command not found'){
									Write-Warning "Package 'ovirt-log-collector' does not appear to be installed on [$($oVirtServerName)]`r`n`tUse 'dnf list installed | grep ovirt-log-collector' to check, and use 'dnf install ovirt-log-collector; dnf install python3-magic' to install, no logs collected."
								}Else{
									Write-Warning "`$PlinkErrorStream: [$($PlinkErrorStream)]"
								}
								$DoNoContinuePlink = $True
							}
							$LogBundlePath = ($global:RawOutput | ?{$_ -Match "INFO: Log files have been collected and placed in"}) -Split ' ' | Select -Last 1
							$CheckSum = ($global:RawOutput | ?{$_ -Match "sha256"})
							$Output = $Null; $Output = $global:RawOutput
							
							IF(!($DoNoContinuePlink)){
								#Now Get File Sizes
								$RemoteCommand2 = "`'" + "ls -l $($LogBundlePath)*" + "`'"
								Write-Verbose "`t`$RemoteCommand2: $($RemoteCommand2)"
								Write-Debug "`t`$RemoteCommand2: [$($RemoteCommand2)]"
								IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
									IF($oVirtSSHCredential){$PlinkCommand2 = "echo y | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand2}
								}Else{
									IF($oVirtSSHCredential){$PlinkCommand2 = "echo n | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand2}
								}
								$global:RawOutput2 = $Null; $global:RawOutput2 = Invoke-Expression -command $PlinkCommand2 -EA SilentlyContinue  2>$null 3>$null 5>$null
								IF($global:RawOutput2){
									#Check File Sizes
									$FileSizes = @()
									ForEach($Item in $global:RawOutput2){
										$FileSizes += [PSCustomObject]@{
											FileName = $Item.Split(' ').Where({$_})[-1]
											FileSize = $Item.Split(' ').Where({$_})[4]
										}
									}
								}
							}
						}
					}
				}
				
				IF($Output){
					$LogBundlePath = ($Output | ?{$_ -Match "INFO: Log files have been collected and placed in"}) -Split ' ' | Select -Last 1
					$CheckSum = ($Output | ?{$_ -Match "sha256"})
					Write-Host -NoNewLine -Fore Cyan "Log Bundle Path ["; Write-Host -NoNewLine "$($LogBundlePath)"; Write-Host -Fore Cyan "]"
					Write-Host -NoNewLine -Fore Cyan "`tCheck Sum ["; Write-Host -NoNewLine "$($CheckSum)"; Write-Host -Fore Cyan "]"
					#Retrieve Log File(s)
					IF($LogBundlePath -Match "/" -AND ".tar.xz"){
						IF(Get-Command -Module Posh-SSH -Name Get-SCPItem -ErrorAction SilentlyContinue){
							Get-SCPItem -AcceptKey -ConnectionTimeout $SSHSessionTimeOutSeconds -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -Path "$($LogBundlePath)" -PathType File -Destination $DownloadFilePath
							Get-SCPItem -AcceptKey -ConnectionTimeout $SSHSessionTimeOutSeconds -ComputerName $oVirtServerName -Credential $oVirtSSHCredential -Path "$($LogBundlePath).sha256" -PathType File -Destination $DownloadFilePath
						}ElseIF(Get-Command -Name pscp.exe -ErrorAction SilentlyContinue){
							#Determine if Putty (pscp.exe, specifically) is installed and avaiable in the path
							pscp.exe -C -pw "$($oVirtSSHCredential.GetNetworkCredential().Password)" "root@$($oVirtServerName):$($LogBundlePath)*" $DownloadFilePath
						}Else{
							Write-Warning "Neither PoSh-SSH Module nor Putty (pscp.exe) installed, can not download generated files on oVirt Server"
						}
						#Verify File Sizes
						#$DownloadFilePath
						#$FileSizes
						ForEach($Item in $FileSizes){
							$FileCheck = $Null; $FileCheck = Get-ChildItem -Path "$($DownloadFilePath)\$((Split-Path -Path $Item.FileName -Leaf))" -EA SilentlyContinue
							IF($FileCheck){
								IF([INT64]$FileCheck.Length -eq [INT64]$Item.FileSize){
									Write-Host -NoNewLine -Fore Green "Downloaded File ["; Write-Host -NoNewLine "$($DownloadFilePath)\$(Split-Path -Path $Item.FileName -Leaf)"; Write-Host -NoNewLine -Fore Green "], Size  ["; Write-Host -NoNewLine "$($FileCheck.Length)"; Write-Host -NoNewLine -Fore Green "], Verified Same as source File ["; Write-Host -NoNewLine "$($Item.FileName)"; Write-Host -Fore Green "]"
								}Else{
									Write-Host -NoNewLine -Fore Red "Downloaded File ["; Write-Host -NoNewLine "$($DownloadFilePath)\$(Split-Path -Path $Item.FileName -Leaf)"; Write-Host -NoNewLine -Fore Red "], Size  ["; Write-Host -NoNewLine "$($FileCheck.Length)"; Write-Host -Fore Red "]"; Write-Host -NoNewLine -Fore Red "`tDoes NOT Match source File ["; Write-Host -NoNewLine "$($Item.FileName)"; Write-Host -NoNewLine -Fore Red "], Size ["; Write-Host -NoNewLine "$($Item.FileSize)"; Write-Host -Fore Red "]"
								}
							}Else{Write-Warning "File Not Found [$($DownloadFilePath)\$(Split-Path -Path $Item.FileName -Leaf)]"}
						}
					}Else{Write-Warning "Generated Log Bundle path undetermined, manually verifiy generated and download manually."}
				}
				IF($FileSizes){
					#If Same ask if user wants to delete on oVirt
					$Answer = Get-UserAnswerPopUp -Message "Do you want to delete Bundle on [$($oVirtServerName)]" -Title "CleanUp" -TimeOut 300 -ButtonSet YN -IconType Question
					IF($Answer -eq 6){
						#Remove File(s)
						IF((Get-Module Posh-SSH -EA SilentlyContinue) -AND (!($PLINK.IsPresent -eq $True))){
							Write-Verbose "`t`$CmdToSSHInvoke: $($CmdToSSHInvoke | Out-String)"
							Write-Host -NoNewLine -Fore Cyan "`t`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -Fore Cyan "]"
							ForEach($Item in $FileSizes){
								$CmdToSSHInvoke = "rm -f -v $($Item.FileName)"
								$Return3 = Invoke-SSHCommand -SessionId $ID -Command $($CmdToSSHInvoke) -EnsureConnection -TimeOut $SSHSessionTimeOutSeconds -ShowStandardOutputStream -ShowErrorOutputStream -StandardOutputStreamColor Cyan -ErrorOutputStreamColor Red
								IF(($Return3.ExitStatus -eq 255) -And (!$Return3.Output)){
									Write-Warning "No OutPut Response, suggest retry with param -SSHAutoHostKeyAcceptance"
								}ElseIF($Return3.ExitStatus -eq 0){
									#$Return3.Output
								}
							}
						}Else{
							IF($oVirtSSHCredential){$plinkoptions = "-v -ssh -pw `'$($oVirtSSHCredential.GetNetworkCredential().Password)`'"}
							ForEach($Item in $FileSizes){
								$CmdToSSHInvoke = "rm -f -v $($Item.FileName)"
								Write-Host -NoNewLine -Fore Cyan "`Running Command ["; Write-Host -NoNewLine "$($CmdToSSHInvoke)"; Write-Host -NoNewLine -Fore Cyan "] on ["; Write-Host -NoNewLine "$($oVirtServerName)"; Write-Host -Fore Cyan "]"
								
								$RemoteCommand = "`'" + $CmdToSSHInvoke + "`'"
								Write-Verbose "`$RemoteCommand: $($RemoteCommand)"
								Write-Debug "`$RemoteCommand: [$($RemoteCommand)]"
								IF($SSHAutoHostKeyAcceptance.IsPresent -eq $True){
									IF($oVirtSSHCredential){$PlinkCommand = "echo y | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand}
								}Else{
									IF($oVirtSSHCredential){$PlinkCommand = "echo n | " + $PlinkPath + " " + $plinkoptions + " root@" + $oVirtServerName + " " + $RemoteCommand}
								}
								Write-Verbose "`$PlinkCommand: $($PlinkCommand)"
								Write-Debug "`$PlinkCommand: [$($PlinkCommand)]"
								Invoke-Expression -command $PlinkCommand -EA SilentlyContinue  2>$null 3>$null 5>$null
							}
						}
					}
				}
			}
			IF(($DeletePlink -eq $True) -AND ($PlinkAsText)){IF(Test-Path $PlinkPath -EA SilentlyContinue){Remove-Item $PlinkPath -Confirm:$False}}
		}Else{
			Write-Warning "No Valid or Matching oVirtConnection or oVirtSSHCredential found to make connection(s)"
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function New-oVirtLogBundleToMOS{
	<#
		.SYNOPSIS
			This function will collect system configuration and diagnostic information from an oVirt Server System
		.DESCRIPTION
			If uses SSH/SCP to run the ovirt-log-collector and pass thru options.
			NOTE: This is Not Working Function, it is still in development!!!!!
				Oracle employees, don't use a password, so the uploads are failing
		.SYNOPSIS
			This function will collect system configuration and diagnostic information from an oVirt Server System and upload to MOS
		.DESCRIPTION
			If uses SSH/SCP to run the ovirt-log-collector and pass thru options.
			Upon successful collection, will download files to the local system, OR will upload files to the "My Orale Support" (MOS) system, and prompt to delete from the oVirt Server System
			This Requires that an existing ticket is already created to attach the Support Bundle File.
			NOTE: It is strongly recommended to add options to filter results, as data collection sizes and times can get quite
				large on oVirt Systems with many KVM Hosts and VMs.
				The options in the oVirt Engine configuration group can be used to filter log collection from one or 
				more hypervisors. If the --no-hypervisors option is specified, data is not collected from any hypervisor.
			Attempts to use PoSh-SSH Module if available, and falls back on Putty if available
			NOTE: OpenSSH is not an option because there’s no option or argument to bypass the password prompt with OpenSSH.
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtRootPassword
			The Root Password for the oVirt Server, in clear text or secure string
		.PARAMETER oVirtSSHCredential
			The PSCredential to be used to connect to the -oVirtServerName via SSH
			Default user name is 'root'
			Stored in the oVirtConnection for subsequent connections to oVirt and KVMs (which use stored public/private keys with oVirt)
		.PARAMETER UploadToMOS
			Switch to attempt to send to "My Orale Support" (MOS) system
		.PARAMETER MOSTicketNumber
			MOS Ticket Number, Just the Ticket number, no 'SR' prefix
		.PARAMETER MOSUserName
			MOS User Name, typically you MOS email address
		.PARAMETER MOSUserPassword
			MOS User Password, SecureString or clear text (less secure)
		.PARAMETER MOSProxy
			MOS Proxy address to get to the internet, if required
				I.e. "https://<proxy.com:8080>"
		.PARAMETER MOSProgress
			Experimental. This attempts to display a progress indicator during file transfer from oVirt server to MOS
		.PARAMETER DownloadFilePath
			The Folder Path on the local system to download the log files from the oVirt Server System
			Will Prompt for Folder Path if NOT provided
		.PARAMETER PoshForce
			Do not perform any host key validation of the host when Posh-SSH is the selection
		.PARAMETER Plink
			Use plink.exe instead of Posh-SSH
		.PARAMETER SSHAutoHostKeyAcceptance
			Auto Accepts New Host Keys if not stored
		.PARAMETER SSHSessionTimeOutSeconds
			SSH Session Time out in Seconds (Default is 1800)
		.PARAMETER SSHKeepAliveIntervalSeconds
			SSH KeepAlive Interval in Seconds (Default is 10)
		.PARAMETER ConfigFilePath
			--conf-file=PATH	path to configuration file (default=/etc/ovirt-engine/logcollector.conf)
		.PARAMETER LocalTmpPath
			--local-tmp=PATH	directory to copy reports to locally. Please note that the directory must 
				be empty (if already exists) and will be removed upon completion.
				(default is randomly generated like: /tmp/logcollector-mkc0ncqh)
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER TicketNumber
			--ticket-number=TICKET	ticket number to pass with the sosreport
				NOTE: Caused an Error in testing, not recommended
		.PARAMETER LogSizeMiB
			--log-size=SIZE       maximum size of log to collect in MiB
				(NOTE: this is a limit for the output of each individual sos plugin, not a limit on a size 
					of the total output from the host)
		.PARAMETER FTP_SERVER
			--upload=FTP_SERVER		Upload the report to Red Hat
				(use exclusively if advised from a Red Hat support representative).
				NOTE: THIS IS FROM THE OLVM, NOT the PowerShell Console
		.PARAMETER Quiet
			--quiet		reduce console output (default=False)
		.PARAMETER Batch
			--batch		batch mode - do not prompt interactively (default=False)
		.PARAMETER LogFilePath
			--log-file=PATH		path to log file
				(default=/var/log/ovirt-engine/ovirt-log-collector/ovirt-log-collector-<TIMESTAMP>.log)
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER CertFilePath
			--cert-file=/etc/pki/ovirt-engine/apache-ca.pem
				The CA certificate used to validate the engine. (default=/etc/pki/ovirt-engine/apache-ca.pem)
				NOTE: THIS IS LOCAL ON THE OLVM, NOT the PowerShell Console
		.PARAMETER Insecure
			--insecure	Do not make an attempt to verify the engine.
		.PARAMETER VerboseResponse
			-v, --verbose
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console, not to be confused with PowerShell -Verbose option
		.PARAMETER OutFilePath
			--output=OUTPUT		Destination directory where the report will be stored
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER IncludeSensitiveData
			--include-sensitive-data	Avoid to obfuscate sensitive data like passwords,
				etc.The generated archive will contain data considered sensitive and its 
				content should be reviewed by the originating organization before being 
				passed to any third party.
		.PARAMETER NoHypervisors
			--no-hypervisors    skip collection from hypervisors (default=False)
				If the --no-hypervisors option is specified, data is not collected from any hypervisor.
				Will cancell any entries in the -Hosts parameter
		.PARAMETER HypervisorPerCluster
			--hypervisor-per-cluster	Collect data only from a hypervisor per cluster; choose the SPM if found in a cluster.
		.PARAMETER TimeOnly
			--time-only		Just gather time diff from specified hypervisors
		.PARAMETER User
			-u user@engine.example.com, --user=user@engine.example.com
				username to use with the REST API. This should be in UPN format.
		.PARAMETER WithKerberos
			--with-kerberos		Enable Kerberos authentication instead of the default basic authentication.
		.PARAMETER Engine
			-r engine.example.com, --engine=engine.example.com
				hostname or IP address of the oVirt Engine (default=localhost:443)
		.PARAMETER Cluster
			-c CLUSTER, --cluster=CLUSTER
				pattern, or comma separated list of patterns to filter the host list by cluster name (default=None)
		.PARAMETER DataCenter
			-d DATACENTER, --data-center=DATACENTER
				pattern, or comma separated list of patterns to filter the host list by data center name (default=None)
		.PARAMETER Hosts
			-H HOSTS_LIST, --hosts=HOSTS_LIST
				comma separated list of hostnames, hostname patterns, FQDNs, FQDN patterns, IP addresses, or IP address
				patterns from which the log collector should collect hypervisor logs (default=None)
				If -NoHypervisors is used this input will be ignored
		.PARAMETER HostSSHPort
			--ssh-port=PORT		the port to ssh and scp on
		.PARAMETER KeyFilePath
			-k KEYFILE, --key-file=KEYFILE
				the identity file (private key) to be used for accessing the hypervisors 
				(default=/etc/pki/ovirt-engine/keys/engine_id_rsa). If a identity file is not supplied the program will 
				prompt for a password. It is strongly recommended to use key based authentication with SSH because the 
				program may make multiple SSH connections resulting in multiple requests for the SSH password.
				NOTE: THIS IS LOCAL TO THE OLVM, NOT the PowerShell Console
		.PARAMETER MaxConnections
			--max-connections=MAX_CONNECTIONS
				max concurrent connections for fetching hypervisor logs (default = 10)
		.PARAMETER NoPostgresql
			--no-postgresql     This option causes the tool to skip the postgresql collection (default=false)
				The log collector will connect to the oVirt Engine PostgreSQL database and dump the data for inclusion in 
				the log report unless --no-postgresql is specified.
		.PARAMETER pgUser
			--pg-user=postgres  PostgreSQL database user name (default=postgres)
				The PostgreSQL user ID can be specified if different from the default.
		.PARAMETER pgDBname
			--pg-dbname=engine  PostgreSQL database name (default=engine)
				The PostgreSQL database name can be specified if different from the default.
		.PARAMETER pgDBhost
			--pg-dbhost=localhost	PostgreSQL database hostname or IP address (default=localhost)
				If the PostgreSQL database is not on the localhost set pg-dbhost
		.PARAMETER pgDBport
			--pg-dbport=5432    PostgreSQL server port number (default=5432)
				If the PostgreSQL database is not on the localhost provide pg-dbport
		.PARAMETER pgSSHUser
			--pg-ssh-user=root  the SSH user that will be used to connect to the server upon which the remote 
				PostgreSQL database lives. (default=root)
				If the PostgreSQL database is not on the localhost provide pg-ssh-user
		.PARAMETER pgHostKey
			--pg-host-key=none  the identity file (private key) to be used for accessing the host upon which 
				the PostgreSQL database lives (default=not needed if using localhost)
				If the PostgreSQL database is not on the localhost optionally supply pg-host-key
		.EXAMPLE
			New-oVirtLogBundleToMOS -oVirtServerName $oVirtServerName -NoHypervisors
		.EXAMPLE
			New-oVirtLogBundleToMOS -oVirtServerName $oVirtServerName -NoHypervisors -UploadToMOS -MOSTicketNumber 3-4xxxxxxxxx1 -MOSUserName "me@oracle.com" -MOSUserPassword "mypass" -MOSProgress
		.EXAMPLE
			New-oVirtLogBundleToMOS -oVirtServerName $oVirtServerName -DownloadFilePath "C:\<MyPath>\OLVM\LogBundles" -Hosts <KVM_Name01, KVM_Name02> -Confirm:0
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		8/20/2025
			Version 1.1		10/4/2025
		.LINK	
			https://github.com/oVirt/ovirt-log-collector/releases
			https://support.oracle.com/knowledge/Oracle%20Linux%20and%20Virtualization/2713403_1.html
			https://support.oracle.com/epmos/faces/DocumentDisplay?id=1547088.2
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", HelpMessage="Root Password for oVirt Server.")]
			$oVirtRootPassword,
		#SSH Credentials for oVirt Server (root is the default user on Linux servers)
        [Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[System.Management.Automation.PSCredential]$oVirtSSHCredential,

		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Upload Support Log To MOS")]
			[SWITCH]$UploadToMOS,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="MOS Ticket Number (No 'SR', just '3-4xxxxxxxxx1'")]
			[System.String]$MOSTicketNumber,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="MOS UserName (typically) Oracle email address")]
			[System.String]$MOSUserName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="MOS Password Text or SecureString")]
			[System.String]$MOSUserPassword,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="MOS Proxy Server Address")]
			[System.String]$MOSProxy,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Upload Support Log To MOS")]
			[SWITCH]$MOSProgress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Destination directory to Download logs to locally")]
			[System.String]$DownloadFilePath,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('PF')]
			[SWITCH]$PoshForce,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,HelpMessage="Use plink.exe instead of Posh-SSH")]
			[SWITCH]$Plink,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)]
			[Alias('AA')]
			[SWITCH]$SSHAutoHostKeyAcceptance,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds")]
			[INT32]$SSHSessionTimeOutSeconds = "1800",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Seconds")]
			[INT32]$SSHKeepAliveIntervalSeconds = "10",
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="path to configuration file (default=/etc/ovirt-engine/logcollector.conf)")]
			[System.String]$ConfigFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="directory to copy reports to locally. Please note that the directory must be empty (if already exists) and will be removed upon completion. (default is randomly generated like: /tmp/logcollector-mkc0ncqh)")]
			[System.String]$LocalTmpPath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="ticket number to pass with the sosreport")]
			[System.String]$TicketNumber,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="maximum size of log to collect in MiB (NOTE: this is a limit for the output of each individual sos plugin, not a limit on a size of the total output from the host)")]
			[System.String]$LogSizeMiB,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Upload the report to Red Hat (use exclusively if advised from a Red Hat support representative).")]
			[System.String]$FTP_SERVER,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="reduce console output (default=False)")]
			[SWITCH]$Quiet,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="batch mode - do not prompt interactively (default=False)")]
			[SWITCH]$Batch,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="path to log file (default=/var/log/ovirt-engine/ovirt-log-collector/ovirt-log-collector-<TIMESTAMP>.log)")]
			[System.String]$LogFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="The CA certificate used to validate the engine. (default=/etc/pki/ovirt-engine/apache-ca.pem)")]
			[System.String]$CertFilePath = "/etc/pki/ovirt-engine/apache-ca.pem",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Do not make an attempt to verify the engine")]
			[SWITCH]$Insecure,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Verbose Output")]
			[SWITCH]$VerboseResponse,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Destination directory where the report will be stored")]
			[System.String]$OutFilePath,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Include Sensitive Data")]
			[SWITCH]$IncludeSensitiveData,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="skip collection from hypervisors (default=False)")]
			[SWITCH]$NoHypervisors,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Collect data only from a hypervisor per cluster; choose the SPM if found in a cluster.")]
			[SWITCH]$HypervisorPerCluster,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Just gather time diff from specified hypervisors")]
			[SWITCH]$TimeOnly,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="username to use with the REST API. This should be in UPN format. (user@engine.example.com)")]
			[System.String]$User,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="Enable Kerberos authentication instead of the default basic authentication.")]
			[SWITCH]$WithKerberos,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="hostname or IP address of the oVirt Engine (default=localhost:443)")]
			[System.String]$Engine,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="pattern, or comma separated list of patterns to filter the host list by cluster name (default=None)")]
			[System.String[]]$Clusters,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="pattern, or comma separated list of patterns to filter the host list by data center name (default=None)")]
			[System.String[]]$DataCenters,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="comma separated list of hostnames, hostname patterns, FQDNs, FQDN patterns, IP addresses, or IP address patterns from which the log collector should collect hypervisor logs (default=None)")]
			[System.String[]]$Hosts,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the port to ssh and scp on")]
			[System.String]$HostSSHPort,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="the identity file (private key) to be used for accessing the hypervisors (default=/etc/pki/ovirt-engine/keys/engine_id_rsa)")]
			[System.String]$KeyFilePath = "/etc/pki/ovirt-engine/keys/engine_id_rsa",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="max concurrent connections for fetching hypervisor logs (default = 10)")]
			[INT32]$MaxConnections,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="This option causes the tool to skip the postgresql collection (default=false)")]
			[SWITCH]$NoPostgresql,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database user name (default=postgres)")]
			[System.String]$pgUser = "postgres",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database user name (default=postgres)")]
			[System.String]$pgDBname = "postgres",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, HelpMessage="PostgreSQL database hostname or IP address (default=localhost)")]
