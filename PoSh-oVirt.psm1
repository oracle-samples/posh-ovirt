						$oHostObjectSpecs = [PSCustomObject]@{async = $False}
					}
					IF($PSBoundParameters['SkipUpgradeReboot'].IsPresent -eq $True){Add-Member -MemberType NoteProperty -Name reboot -Value $false -InputObject $oHostObjectSpecs} #default is to reboot
					
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install/parameters/activate
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts/methods/add
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install
					IF($PSBoundParameters.ContainsKey('ActivateHostAfterInstall')){
						#Default is $TRUE
						IF($PSBoundParameters['ActivateHostAfterInstall'] -eq $False){Add-Member -MemberType NoteProperty -Name activate -Value $false -InputObject $oHostObjectSpecs}
					}
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/host/methods/install/parameters/reboot
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/hosts/methods/add
					IF($PSBoundParameters.ContainsKey('RebootHostAfterInstall')){
						#Default is $TRUE
						IF($PSBoundParameters['RebootHostAfterInstall'] -eq $False){Add-Member -MemberType NoteProperty -Name reboot -Value $false -InputObject $oHostObjectSpecs}
					}
					$Uri = $BaseURL + ($oHostObject.actions.link | ?{$_.rel -eq "install"}).href
					$Method = "POST"
