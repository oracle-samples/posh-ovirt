Function New-oiScsiBond{
	<#
		.SYNOPSIS
			This function creates a new oiScsiBond, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oiScsiBond, on a oVirt Server system.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of oiScsiBond
			Can use Wildcard '*'
		.PARAMETER Comment
			The Text for the Comment field to set on the oiScsiBond
		.PARAMETER Description
			The Text for the Description field to set on the oiScsiBond
		.PARAMETER oDataCenter
			The Name of the parent oDataCenter for the new oiScsiBond(s)
		.PARAMETER oDataCenterId
			The Id of the parent oDataCenter for the new oiScsiBond(s)
		.PARAMETER oDataCenterUid
			The Uid of the parent oDataCenter for the new oiScsiBond(s)
		.PARAMETER oNetwork
			The Name of the oNetwork (vLAN) for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oNetworkId
			The Id of the oNetwork (vLAN) for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oNetworkUid
			The Uid of the oNetwork (vLAN) for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oStorageConnection
			The Name of the oStorageConnection for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oStorageConnectionId
			The Id of the oStorageConnection for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oStorageConnectionUid
			The Uid of the oStorageConnection for the new oiScsiBond
			Must exist in provided oDataCenter
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> New-oiScsiBond -oVirtServerName $oVirtServerName -Name "Name" -oDataCenter "oDataCenterName"
				Creates a new oiScsiBond with the provided Name
		.INPUTS
			[System.String]
			[oDataCenter]
			[oNetwork]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oiScsiBond]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/27/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/iscsi_bond
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bond
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bonds
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/iscsi_bonds/methods/add
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_connection
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=1)]
			[ValidateScript({($_).GetType().Name -match 'oVM|String|oCluster|oDatacenter|oHost'})]$oDataCenter,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDataCenterId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oDataCenterUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Comment,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Description,
	
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oNetwork|String'})]$oNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkUid,
		
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oStorageConnection|String'})]$oStorageConnection,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')][System.String]$oStorageConnectionId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oStorageConnectionUid,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		IF($oVirtServerName){
			$BaseURL = "https://$($oVirtServerName)"
		}Else{
			$oVirtServerName = $oVirtConnections[0].oVirtServerName
			$BaseURL = "https://$($oVirtServerName)"
		}
		$OutPutItems = [System.Collections.Generic.List[PSobject]]@()
		$OutPutErrorItems = [System.Collections.ArrayList]@()
	}
	Process{
		$oDataCenterObjects = $Null
		IF($PSBoundParameters['oDataCenterUid']){
			$UidUrl = [Uri]$oDataCenterUid
			$oDataCenterObjects = Get-oUri -Uri $($PSBoundParameters['oDataCenterUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oDataCenter" -oVirtServerName $oVirtServerName}
			IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oDataCenterId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oDataCenterObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				#$oDataCenterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
				$oDataCenterObjects = $oDataCenterObjects | ?{$_.Id -eq $PSBoundParameters['oDataCenterId']} | Sort -Unique
			}Else{
				$oDataCenterObjects += Get-oDataCenter -EA SilentlyContinue
				#$oDataCenterObjects += Get-oCluster -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
				$oDataCenterObjects = $oDataCenterObjects | ?{$_.Id -eq $PSBoundParameters['oDataCenterId']} | Sort -Unique
			}
			IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oDataCenter']){
			SWITCH($PSBoundParameters['oDataCenter']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oDataCenterObjects += Get-oDataCenter -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						#$oDataCenterObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
						$oDataCenterObjects = $oDataCenterObjects | ?{$_.Name -eq $PSBoundParameters['oDataCenter']} | Sort -Unique
					}Else{
						$oDataCenterObjects += Get-oDataCenter -EA SilentlyContinue
						#$oDataCenterObjects += Get-oCluster -EA SilentlyContinue | Get-oDataCenter -EA SilentlyContinue
						$oDataCenterObjects = $oDataCenterObjects | ?{$_.Name -eq $PSBoundParameters['oDataCenter']} | Sort -Unique
					}
					IF($oDataCenterObjects){$oDataCenterObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oDataCenter]) -OR ($_.GetType().Name -eq "oDataCenter")}{
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is [oDataCenter]"
					$oDataCenterObjects = $PSBoundParameters['oDataCenter']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oDataCenter is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		$oNetworkObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oNetworkUid']){
			$UidUrl = [Uri]$oNetworkUid
			$oNetworkObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oNetwork" -oVirtServerName $oVirtServerName}
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetworkId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}Else{
				$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
				$oNetworkObjects = $oNetworkObjects | ?{$_.Id -eq $PSBoundParameters['oNetworkId']} | Sort -Unique
			}
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetwork']){
			SWITCH($PSBoundParameters['oNetwork']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkObjects += Get-oNetwork -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}Else{
						$oNetworkObjects += Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects += Get-oCluster -EA SilentlyContinue | Get-oNetwork -EA SilentlyContinue
						$oNetworkObjects = $oNetworkObjects | ?{$_.Name -eq $PSBoundParameters['oNetwork']} | Sort -Unique
					}
					IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oNetwork]) -OR ($_.GetType().Name -eq "oNetwork")}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is [oNetwork]"
					$oNetworkObjects = $PSBoundParameters['oNetwork']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oNetworkObjects){$oNetworkObjects = $oNetworkObjects | Sort -Unique}
		
		IF(($oDataCenterObjects) -AND ($oNetworkObjects)){
			$oDataCenterObjects.GetoNetworks() | Out-Null
			$Tmp_oNetworkObjects = @()
			ForEach($oNetworkObject in $oNetworkObjects){
				ForEach($oNetwork in $oDataCenterObjects.oNetwork){
					IF(($oNetworkObject.Id -eq $oNetwork.Id) -And ($oNetworkObject.oVirtServer -eq $oNetwork.oVirtServer)){
						$Tmp_oNetworkObjects += $oNetworkObject
					}
				}
			}
			IF(($Tmp_oNetworkObjects).Count -ge 1){$oNetworkObjects = $Tmp_oNetworkObjects}Else{$oNetworkObjects = $Null}
		}
		
		$oStorageConnectionObjects = $Null #Must be in provided oDataCenter
		IF($PSBoundParameters['oStorageConnectionUid']){
			$UidUrl = [Uri]$oStorageConnectionUid
			$oStorageConnectionObjects = Get-oUri -Uri $($PSBoundParameters['oStorageConnectionUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oStorageConnection" -oVirtServerName $oVirtServerName}
			IF($oStorageConnectionObjects){$oStorageConnectionObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oStorageConnectionId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oStorageConnectionObjects += Get-oStorageConnection -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
				$oStorageConnectionObjects += Get-oStorageDomain -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oStorageConnection -EA SilentlyContinue
				$oStorageConnectionObjects = $oStorageConnectionObjects | ?{$_.Id -eq $PSBoundParameters['oStorageConnectionId']} | Sort -Unique
			}Else{
				$oStorageConnectionObjects += Get-oStorageConnection -EA SilentlyContinue
				$oStorageConnectionObjects += Get-oStorageDomain -EA SilentlyContinue | Get-oStorageConnection -EA SilentlyContinue
				$oStorageConnectionObjects = $oStorageConnectionObjects | ?{$_.Id -eq $PSBoundParameters['oStorageConnectionId']} | Sort -Unique
			}
			IF($oStorageConnectionObjects){$oStorageConnectionObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oStorageConnection']){
			SWITCH($PSBoundParameters['oStorageConnection']){
				{($_ -IS [System.String]) -OR ($_.GetType().Name -eq "String")}{
					Write-Verbose "$($MyInvocation.MyCommand) oStorageConnection is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oStorageConnectionObjects += Get-oStorageConnection -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
						$oStorageConnectionObjects += Get-oStorageDomain -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue | Get-oStorageConnection -EA SilentlyContinue
						$oStorageConnectionObjects = $oStorageConnectionObjects | ?{$_.Name -eq $PSBoundParameters['oStorageConnection']} | Sort -Unique
					}Else{
						$oStorageConnectionObjects += Get-oStorageConnection -EA SilentlyContinue
						$oStorageConnectionObjects += Get-oStorageDomain -EA SilentlyContinue | Get-oStorageConnection -EA SilentlyContinue
						$oStorageConnectionObjects = $oStorageConnectionObjects | ?{$_.Name -eq $PSBoundParameters['oStorageConnection']} | Sort -Unique
					}
					IF($oStorageConnectionObjects){$oStorageConnectionObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{($_ -IS [oStorageConnection]) -OR ($_.GetType().Name -eq "oStorageConnection")}{
					Write-Verbose "$($MyInvocation.MyCommand) oStorageConnection is [oStorageConnection]"
					$oStorageConnectionObjects = $PSBoundParameters['oStorageConnection']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oStorageConnection is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		IF($oStorageConnectionObjects){$oStorageConnectionObjects = $oStorageConnectionObjects | Sort -Unique}
		
		IF(($oDataCenterObjects) -AND ($oStorageConnectionObjects)){
			$oDataCenterObjects.GetoStorageDomains() | Out-Null
			$oDataCenterObjectsoStorageConnectionObjects = $oDataCenterObjects.oStorageDomain | Get-oStorageConnection
			IF($oDataCenterObjectsoStorageConnectionObjects){$oDataCenterObjectsoStorageConnectionObjects = $oDataCenterObjectsoStorageConnectionObjects | Sort -Unique}
			$Tmp_oStorageConnectionObjects = @()
			ForEach($oStorageConnectionObject in $oStorageConnectionObjects){
				ForEach($oStorageConnection in $oDataCenterObjectsoStorageConnectionObjects){
					IF(($oStorageConnectionObject.Id -eq $oStorageConnection.Id) -And ($oStorageConnectionObject.oVirtServer -eq $oStorageConnection.oVirtServer)){
						$Tmp_oStorageConnectionObjects += $oStorageConnectionObject
					}
				}
			}
			IF(($Tmp_oStorageConnectionObjects).Count -ge 1){$oStorageConnectionObjects = $Tmp_oStorageConnectionObjects}Else{$oStorageConnectionObjects = $Null}
		}
		
		$oiScsiBondSpecs = [PSCustomObject]@{"name"=$PSBoundParameters['Name']}
		IF($PSBoundParameters.ContainsKey('Comment')){$oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $PSBoundParameters['Comment']}
		IF($PSBoundParameters.ContainsKey('Description')){$oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $PSBoundParameters['Description']}
		IF($oDataCenterObjects){
			#Should Only Be 1 Object
			$oVirtServerName = $oDataCenterObjects | Select -First 1 -ExpandProperty oVirtServer
		}
		IF($oNetworkObjects){
			#Should Only Be 1 Object
			$oiScsiBondNetworkSpecs = [PSCustomObject]@{}
			ForEach($oNetworkObject in $oNetworkObjects){
				#This might be incorrect, IDs might need to be the Array Items inside network, rather than network being an array item inside networks, I don't have a test system to check presently
				$oiScsiBondNetworkSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $([PSCustomObject]@{"id"="$($oNetworkObject.Id)"})
			}
			$oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'networks' -Value $oiScsiBondNetworkSpecs
		}
		IF($oStorageConnectionObjects){
			#Should Only Be 1 Object
			$oiScsiBondoStorageConnectionObjectSpecs = [PSCustomObject]@{}
			ForEach($oStorageConnectionObject in $oStorageConnectionObjects){
				#This might be incorrect, IDs might need to be the Array Items inside storage_connection, rather than storage_connection being an array item inside storage_connections, I don't have a test system to check presently
				$oiScsiBondoStorageConnectionObjectSpecs | Add-Member -MemberType NoteProperty -Name 'storage_connection' -Value $([PSCustomObject]@{"id"="$($oStorageConnectionObject.Id)"})
			}
			$oiScsiBondSpecs | Add-Member -MemberType NoteProperty -Name 'storage_connections' -Value $oiScsiBondoStorageConnectionObjectSpecs
		}
		IF($oVirtServerName){
			Write-Verbose "$($MyInvocation.MyCommand): `$oiScsiBondSpecs [$($oiScsiBondSpecs | Out-String)]"
			$BaseURL = "https://$($oVirtServerName)"
			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			#POST /ovirt-engine/api/datacenters/123/iscsibonds
			$Uri = $BaseURL + "/ovirt-engine/api/datacenters/$($oDataCenterObjects.Id)/iscsibonds"
			$Method = "POST"
			$JsonBody = $oiScsiBondSpecs | ConvertTo-Json -Depth 50
			#$JsonBody | ConvertFrom-Json2Xml
			#($oiScsiBondSpecs | ConvertTo-Json | ConvertFrom-Json2Xml)
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Add oVNicProfile to oVirt"
			Write-Verbose "$($JsonBody | Out-String)"
			Write-Verbose "$($MyInvocation.MyCommand): Uri: $($Uri | Out-String)"
			$NewoiScsiBond = $Null
			TRY{$NewoiScsiBond = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoiScsiBond){
				$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoiScsiBond -ObjectType "oiScsiBond" -oVirtServerName $oVirtServerName)) | Out-Null
				$NewoiScsiBond | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}
			}
		}
	}
	End{
		Write-Verbose "$($MyInvocation.MyCommand): End"
		IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}
	}
}

Function New-oNetworkAttachment{
	<#
		.SYNOPSIS
			This function creates a new oNetworkAttachment, for an oHost (oHostNic), on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oNetworkAttachment, for an oHost (oHostNic), on a oVirt Server system.
			Returns the new oNetworkAttachment from the oVirt Server.
			An oNetworkAttachment is a logical "glue" connecting a physical oHostNic (or Bond) to a defined oNetwork or oNetworkLabel in the oCluster/oDataCenter it resides
		.PARAMETER Comment
		.PARAMETER Description
		.PARAMETER oHostNic
			The oHostNic for the new oNetworkAttachment(s)
		.PARAMETER oNetwork
			The Name of the oNetwork for the new oNetworkAttachment(s)
		.PARAMETER oNetworkId
			The Id of the oNetwork for the new oNetworkAttachment(s)
		.PARAMETER oNetworkUid
			The Uid of the oNetwork for the new oNetworkAttachment(s)
		.PARAMETER oNetworkLabel
			The oNetworkLabel for the new oNetworkAttachment(s)
			IMPORTANT NOTE: an oNetworkLabel Object can contain either/both an oHostNic and/or oNetwork
				If Generated using Get-oNetwork | Get-oNetworkLabel it will have a $oNetworkLabel.network property populated
				If Generated using Get-oHost | Get-oHostNic | Get-oNetworkLabel it will have a $oNetworkLabel.host_nic property populated
		.PARAMETER AssignmentMethod
			Valid options "autoconf", "dhcp", "none", "poly_dhcp_autoconf", "static"
		.PARAMETER IPAddress
			The IP Address to assign the oNetworkAttachment
		.PARAMETER Netmask
			The Subnet mask of the IPAddress in Octet format
			Intellisense available
			Valid options "255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248","255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128","255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0","255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0","255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0","255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0","255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0","240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0"
		.PARAMETER Gateway
			The IP Address of the gateway for the oNetworkAttachment
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER IPVersion version
			Valid options "v4","v6"
			Only "v4" is valid in this version of function
		.PARAMETER ip_address_assignments	
			Potential future feature accepting an array of hashtables to allocate to the IP settings of the oNetworkAttachment
				See https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
		.PARAMETER DNSServers
			This accepts an array of IPAddresses and/or FQDNs of Domain Name Servers (DNS)
			Omitting will use oNetwork defaults, or none if not set on oNetwork
		.PARAMETER Properties
			This accepts an array of hashtable (name/value pairs) based on custom settings found in 
				https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			$oNetwork = Get-oNetwork -oVirtServerName $oVirtServerName -Id cc2038a5-4cd7-4f54-a2c0-2fc3c95cb704
			$oHostNic = Get-oHost -oVirtServerName $oVirtServerName -Name "MyHostName" | Get-oHostNic | Where{$_.Name -eq "bond0.2400"}
			$oNetworkAttachment = New-oNetworkAttachment -oVirtServerName $oVirtServerName -oNetwork $oNetwork -oHostNic $oHostNic -AssignmentMethod "dhcp"
				Creates a new oNetworkAttachment using the specified oNetwork and oHostNic, and sets it to use DHCP for IP addressing
		.EXAMPLE
			$oNetwork = Get-oNetwork -oVirtServerName $oVirtServerName -Id cc2038a5-4cd7-4f54-a2c0-2fc3c95cb704
			$oNetworkLabel = Get-oHost -oVirtServerName $oVirtServerName -Name "MyHostName" | Get-oHostNic | Where{$_.Name -eq "bond0.2400"} | Get-oNetworkLabel
			$oNetworkAttachment = New-oNetworkAttachment -oVirtServerName $oVirtServerName -oNetwork $oNetwork -oNetworkLabel $oNetworkLabel -AssignmentMethod "static" -IPAddress 192.168.1.2 -Netmask 255.255.255.0 -Gateway 192.168.1.1 -DNSServers "192.168.1.251","192.168.1.252"
				Creates a new oNetworkAttachment using the specified oNetwork and the $oNetworkLabel.host_nic, and sets it to use DHCP for IP addressing
		.EXAMPLE
			$oHostNic = Get-oHost -oVirtServerName $oVirtServerName -Name "MyHostName" | Get-oHostNic | Where{$_.Name -eq "bond0.2400"}
			$oNetworkLabel = Get-oNetwork -oVirtServerName $oVirtServerName -Id cc2038a5-4cd7-4f54-a2c0-2fc3c95cb704 | Get-oNetworkLabel
			$oNetworkAttachment = New-oNetworkAttachment -oVirtServerName $oVirtServerName -oNetworkLabel $oNetworkLabel -oHostNic $oHostNic -AssignmentMethod "dhcp"
				Creates a new oNetworkAttachment using the specified oHostNic and the $oNetworkLabel.network, and sets it to use DHCP for IP addressing
		.INPUTS
			[System.String]
			[oHostNic]
			[oNetworkLabel]
			[oNetwork]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetworkAttachment]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/25/2024
			Version 1.1		3/6/2025
			Version 1.2		5/12/2025
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_attachments
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_attachment
			Get-oNetworkAttachment
			Set-oNetworkAttachment
			Remove-oNetworkAttachment
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			#[ValidateScript({($_).GetType().Name -match 'oHostNic|String'})]$oHostNic,
			[ValidateScript({($_).GetType().Name -match 'oHostNic'})]$oHostNic,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidateScript({($_).GetType().Name -match 'oNetworkLabel'})]
			[System.String]$oNetworkLabel,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oNetwork|String'})]$oNetwork,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oNetworkId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oNetworkUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("autoconf", "dhcp", "none", "poly_dhcp_autoconf", "static")]
			[System.String]$AssignmentMethod,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$') -or ($_ -Match "(?=^.{4,253}\.?$)(^((?!-)[a-zA-Z0-9-]{1,63}(?<!-)\.)+[a-zA-Z]{2,63}\.?$)") -or ($_  -Match "^(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))$")){ $True } Else { Throw "$_ is not an IPV4 Address, IPV6 Address, or an FQDN!" }})]
			[System.String][System.String]$IPAddress,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateSet("255.255.255.255","255.255.255.254","255.255.255.252","255.255.255.248","255.255.255.240","255.255.255.224","255.255.255.192","255.255.255.128","255.255.255.0","255.255.254.0","255.255.252.0","255.255.248.0","255.255.240.0","255.255.224.0","255.255.192.0","255.255.128.0","255.255.0.0","255.254.0.0","255.252.0.0","255.248.0.0","255.240.0.0","255.224.0.0","255.192.0.0","255.128.0.0","255.0.0.0","254.0.0.0","252.0.0.0","248.0.0.0","240.0.0.0","224.0.0.0","192.0.0.0","128.0.0.0")]
			[System.String]$Netmask,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$')){ $True } Else { Throw "$_ is not an IPV4 Address or an FQDN!" }})]
			[System.String]$Gateway,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			#[ValidateSet("v4","v6")]
			[ValidateSet("v4")]
			[System.String]$IPVersion = "v4",
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(($_ -match '^(?:(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)\.){3}(?:1\d\d|2[0-5][0-5]|2[0-4]\d|0?[1-9]\d|0?0?\d)$') -or ($_ -Match "(?=^.{4,253}\.?$)(^((?!-)[a-zA-Z0-9-]{1,63}(?<!-)\.)+[a-zA-Z]{2,63}\.?$)")){ $True } Else { Throw "$_ is not an IPV4 Address or an FQDN!" }})]
			[System.String[]]$DNSServers,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.Collections.Hashtable[]]$Properties,
		#[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
		#	[System.Collections.Hashtable[]]$ip_address_assignments,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		
		#Validate IP Settings -Only test if all 3 are present
		IF(($PSBoundParameters['IPAddress']) -AND ($PSBoundParameters['Netmask']) -AND ($PSBoundParameters['Gateway'])){
			IF($Validate = Test-IPV4Compatibility -IPAddress $IPAddress -Netmask $Netmask -Gateway $Gateway){
				#Input IP settings are mathematically compatible
			}Else{Write-Warning "$($MyInvocation.MyCommand): User Provided IP Settings invalid network combination, quitting..."; BREAK}
		}
		
		$oHostNicObjects = $Null
		IF($PSBoundParameters['oHostNic']){$oHostNicObjects = $PSBoundParameters['oHostNic']}
		IF(!($oHostNicObjects -or $PSBoundParameters['oNetworkLabel'])){Write-Warning "$($MyInvocation.MyCommand): oHostNic Not Found, quitting..."; BREAK}
		IF($PSBoundParameters['oNetworkLabel']){$oNetworkLabelObjects = $PSBoundParameters['oNetworkLabel']}
		IF(!($oNetworkLabelObjects -or $oHostNicObjects)){Write-Warning "$($MyInvocation.MyCommand): Neither oHostNic or oNetworkLabel Provided/Found, quitting..."; BREAK}
		IF(($oNetworkLabelObjects) -AND (!($oHostNicObjects))){
			$oNetworkLabelObjects.GetRelated()
			$oHostNicObjects = $oNetworkLabelObjects.host_nic
		}
		IF(!($oHostNicObjects)){Write-Warning "$($MyInvocation.MyCommand): oHostNic Not Found, quitting..."; BREAK}
		
		$oNetworkObjects = $Null
		IF($PSBoundParameters['oNetworkUid']){
			$UidUrl = [Uri]$oNetworkUid
			$oNetworkObjects = Get-oNetwork -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetworkId']){
			IF($PSBoundParameters['oVirtServerName']){
				$oNetworkObjects = Get-oNetwork -Id $PSBoundParameters['oNetworkId']  -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
			}Else{
				$oNetworkObjects = Get-oNetwork -Id $PSBoundParameters['oNetworkId'] -EA SilentlyContinue
			}
			IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
		}ElseIF($PSBoundParameters['oNetwork']){
			SWITCH($PSBoundParameters['oNetwork']){
				{$_ -IS [System.String]}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkObjects = Get-oNetwork -Name $PSBoundParameters['oNetwork'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oNetworkObjects = Get-oNetwork -Name $PSBoundParameters['oNetwork'] -EA SilentlyContinue
					}
					IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_.GetType().Name -eq "String"}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork GetType equals String"
					IF($PSBoundParameters['oVirtServerName']){
						$oNetworkObjects = Get-oNetwork -Name $PSBoundParameters['oNetwork'] -oVirtServerName $PSBoundParameters['oVirtServerName'] -EA SilentlyContinue
					}Else{
						$oNetworkObjects = Get-oNetwork -Name $PSBoundParameters['oNetwork'] -EA SilentlyContinue
					}
					IF($oNetworkObjects){$oNetworkObjects | Select -Unique -ExpandProperty oVirtServer | Sort -Unique | %{Update-oVirtServer_LastUsedTime -oVirtServerName $_}}
				}
				{$_ -IS [oNetwork]}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is [oNetwork]"
					$oNetworkObjects = $PSBoundParameters['oNetwork']
				}
				{$_.GetType().Name -eq "oNetwork"}{
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork GetType equals [oNetwork]"
					$oNetworkObjects = $PSBoundParameters['oNetwork']
				}
				DEFAULT{
					Write-Verbose "$($MyInvocation.MyCommand) DEFAULT TYPE SECTION"
					Write-Verbose "$($MyInvocation.MyCommand) oNetwork is GetType: $($_.GetType() | Out-String)"
					Write-Verbose "$($MyInvocation.MyCommand) `$_: $($_ | Out-String)"
				}
			}
		}
		
		IF(!($oNetworkObjects -or $PSBoundParameters['oNetworkLabel'])){Write-Warning "$($MyInvocation.MyCommand): oNetwork Not Found, quitting..."; BREAK}
		IF(!($oNetworkLabelObjects -or $oNetworkObjects)){Write-Warning "$($MyInvocation.MyCommand): Neither oNetwork or oNetworkLabel Provided/Found, quitting..."; BREAK}
		IF(($oNetworkLabelObjects) -AND (!($oNetworkObjects))){
			$oNetworkLabelObjects.GetRelated()
			$oNetworkObjects = $oNetworkLabelObjects.network
		}
		IF(!($oNetworkObjects)){Write-Warning "$($MyInvocation.MyCommand): oNetwork Not Found, quitting..."; BREAK}
		
		Write-Verbose "$($MyInvocation.MyCommand): `$oHostNicObjects Names: $($oHostNicObjects.Name)"
		Write-Verbose "$($MyInvocation.MyCommand): `$oNetworkObjects Names: $($oNetworkObjects.Name)"
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oHostNicObject in $oHostNicObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostNicObject [$($oHostNicObject | Out-String)]"
			$oVirtServerName = $oHostNicObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			Write-Verbose "$($MyInvocation.MyCommand): `$oHostNicObject Status [$($oHostNicObject.Status)]"
			
			
			
			$oNetworkAttachmentSpecs = [PSCustomObject]@{}
			IF($PSBoundParameters.ContainsKey('Comment')){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			
			IF($oNetworkObjects){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $(@{"id"=$oNetworkObjects.id}) }
			#IF($oNetworkObjects){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'network' -Value $(@{"name"=$oNetworkObjects.name}) }
			
			IF($PSBoundParameters.ContainsKey('AssignmentMethod')){
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/boot_protocol
				$ip_address_assignmentSpecs = [PSCustomObject]@{assignment_method = $($PSBoundParameters['AssignmentMethod'])}
				$IPSpecs = [PSCustomObject]@{}
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
				IF($PSBoundParameters.ContainsKey('IPAddress')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['IPAddress']) }
				IF($PSBoundParameters.ContainsKey('Gateway')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'gateway' -Value $($PSBoundParameters['Gateway']) }
				IF($PSBoundParameters.ContainsKey('Netmask')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'netmask' -Value $($PSBoundParameters['Netmask']) }
				IF($PSBoundParameters.ContainsKey('IPVersion')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'version' -Value $($PSBoundParameters['IPVersion']) }
				IF($IPSpecs.psobject.Properties.count -ge 1){$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip' -Value $IPSpecs}
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip_address_assignment
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = $ip_address_assignmentSpecs})
				$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = @($ip_address_assignmentSpecs)})
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/dns_resolver_configuration
			IF($PSBoundParameters.ContainsKey('DNSServers')){
				$name_serversSpecs = [PSCustomObject]@{}
				$name_serverArray = [System.Collections.ArrayList]@()
				ForEach($Item in $($PSBoundParameters['DNSServers'])){ $name_serverArray.Add( $(@{"name_server"=$Item}) ) | Out-Null }
				$name_serversSpecs | Add-Member -MemberType NoteProperty -Name 'name_servers' -Value $name_serverArray
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $($PSBoundParameters['DNSServers'])
				$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $name_serversSpecs
			}
		
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
			IF($PSBoundParameters.ContainsKey('Properties')){
				IF($PSBoundParameters['Properties']){
					$PropertiesSpec = [PSCustomObject]@{}
					#$PropertiesArray = [System.Collections.ArrayList]@()
					$PropertiesArray = @()
					#ForEach($Item in $(($PSBoundParameters['Properties']).GetEnumerator())){$PropertiesArray.Add( $([PSCustomObject]@{"property"=$([PSCustomObject]@{"name" = $Item.Name; "value" = $Item.Value})}) ) | Out-Null }
					#$(($PSBoundParameters['Properties']).GetEnumerator()) | %{$PropertiesArray.Add( $([PSCustomObject]@{"property"=$_})) | Out-Null}
					$(($PSBoundParameters['Properties']).GetEnumerator()) | %{$PropertiesArray += ( $([PSCustomObject]@{"property"=$_})) }
					IF($PropertiesArray.count -gt 0){$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'properties' -Value $PropertiesArray}
				}
			}
	

			#Send to Server
			Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
			$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
			$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
			IF($oHostNicObject.bonding.slaves.host_nic){
				#Send to POST /ovirt-engine/api/hosts/123/networkattachments    <network_attachment><network id="234"/><host_nic id="456"/></network_attachment>
				IF($oHostNicObject.id){$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'host_nic' -Value $(@{"id"=$oHostNicObject.id})}
				#IF($oHostNicObject.name){$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'host_nic' -Value $(@{"name"=$oHostNicObject.name})}
				[VOID]$oHostNicObject.GetoHost()
				$Uri = $BaseURL + "$(($oHostNicObject.host.link | ?{$_.rel -eq 'networkattachments'}).href)"
				#$JsonBody = ([PSCustomObject]@{"network_attachment"=@($oNetworkAttachmentSpecs)}) | ConvertTo-Json -Depth 50
			}Else{
				#Send to POST /ovirt-engine/api/hosts/123/nics/456/networkattachments   <networkattachment><network id="234"/></networkattachment>
				$Uri = $BaseURL + "$(($oHostNicObject.link | ?{$_.rel -eq 'networkattachments'}).href)"
				#$JsonBody = $oNetworkAttachmentSpecs | ConvertTo-Json -Depth 50
			}
			$Method = "POST"
			$JsonBody = $oNetworkAttachmentSpecs | ConvertTo-Json -Depth 50
			Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oNetworkAttachment"
			Write-Verbose "$($JsonBody | Out-String)"
			$NewoNetworkAttachment = $Null
			TRY{$NewoNetworkAttachment = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
			IF($NewoNetworkAttachment){$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoNetworkAttachment -ObjectType "oNetworkAttachment" -oVirtServerName $oVirtServerName)) | Out-Null; Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName}
		}
	
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}	
}

Function New-oNetworkFilterParameter{
	<#
		.SYNOPSIS
			This function creates a new oNetworkFilterParameter, on an oVmNic, on an oVirt Server system.
		.DESCRIPTION
			This function creates a new oNetworkFilterParameter, on an oVmNic, on a oVirt Server system.
			Returns the job response from the oVirt Server.
			This function accepts piped object types: oVmNic
		.PARAMETER Name
			The Name(s) of oNetworkFilterParameter
			Can use Wildcard '*'
		.PARAMETER Value
			The Name(s) of oNetworkFilterParameter
			Can use Wildcard '*'
		.PARAMETER oVM
			The Name of the parent oVM for the new oNetworkFilterParameter(s)
		.PARAMETER oVMId
			The Id of the parent oVM for the new oNetworkFilterParameter(s)
		.PARAMETER oVMUid
			The Uid of the parent oVM for the new oNetworkFilterParameter(s)
		.PARAMETER oVmNic
			The Name of the parent oVmNic for the new oNetworkFilterParameter(s)
		.PARAMETER oVmNicId
			The Id of the parent oVmNic for the new oNetworkFilterParameter(s)
		.PARAMETER oVmNicUid
			The Uid of the parent oVmNic for the new oNetworkFilterParameter(s)
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER NetworkFilterParameters
			HashTable of Name/Value pairs of oNetworkFilterParameters, to create multiple on the target oVM
			I.e. @{"IP"="10.10.10.10"}
		.EXAMPLE
			PS> New-oNetworkFilterParameter -oVirtServerName $oVirtServerName -Name "Name" -oVM "oVMName" -oVmNic 'oVmNicId'
				Creates a new oNetworkFilterParameter with the provided Name
		.EXAMPLE
			PS> Get-oVM -oVirtServerName $oVirtServerName | Get-oVmNic | Get-oNetworkFilterParameter
				Returns the oNetworkFilterParameter(s) by on oVM(s)
		.EXAMPLE
			PS> Get-oTemplate -oVirtServerName $oVirtServerName | Get-oVmNic | Get-oNetworkFilterParameter
				Returns the oNetworkFilterParameter(s) by on oTemplate(s)
		.EXAMPLE
			PS> Get-oVM -oVirtServerName $oVirtServerName | Get-oSnapshot -oVirtServerName $oVirtServerName | Get-oVmNic | Get-oNetworkFilterParameter
				Returns the oNetworkFilterParameter(s) by on oSnapshot(s)
		.INPUTS | Get-oVmNic
			[System.String]
			[oVM]
			[oVmNic]
			[oTemplate]
			[oSnapshot]
			[HashTable]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetworkFilterParameter]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		12/2/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_filter_parameter
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/nic_network_filter_parameter
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/nic_network_filter_parameters
			https://libvirt.org/formatnwfilter.html#nwfconceptsvars
			Get-oNetworkFilterParameter
			Set-oNetworkFilterParameter
			Remove-oNetworkFilterParameter
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$Value,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01")]
			[ValidateScript({($_).GetType().Name -match 'oVM|String'})]$oVM,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oVMId,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oVMUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oVmNic|String'})]$oVmNic,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oVmNicId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$oVmNicUid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[HashTable]$NetworkFilterParameters,
		
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String]$oVirtServerName
	)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
