		IF($PSBoundParameters.ContainsKey('UsesScsiReservation')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'uses_scsi_reservation' -Value $($PSBoundParameters['UsesScsiReservation']) }
		IF($PSBoundParameters.ContainsKey('WipeAfterDelete')){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'wipe_after_delete' -Value $($PSBoundParameters['WipeAfterDelete']) }
			
		IF($PSBoundParameters.ContainsKey('DiskType')){
			IF($PSBoundParameters['DiskType'] -eq "Image"){
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_type' -Value 'image'
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domains' -Value $([PSCustomObject]@{'storage_domain'= @([PSCustomObject]@{'id'=$oStorageDomainObject.Id})})
				
				#Note that block storage domains (i.e., storage domains with the storage type of iSCSI or FCP) don’t support the combination of the raw format with sparse=true, so sparse=false must be stated explicitly.
				IF((($oDiskSpecs.storage_type -eq "iSCSI") -or ($oDiskSpecs.storage_type -eq "FCP")) -OR (($PSBoundParameters['LUN_Type'] -eq "iSCSI") -OR ($PSBoundParameters['LUN_Type'] -eq "FCP"))){
					IF($oDiskSpecs.format -eq "raw"){
						IF($oDiskSpecs.sparse){
							$oDiskSpecs.sparse = $False
						}Else{
							$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'sparse' -Value $False
						}
					}
				}
				#When creating a new floating image Disk, the API requires the storage_domain, provisioned_size and format attributes.
				#<disk><storage_domains><storage_domain id="123"/></storage_domains><name>mydisk</name><provisioned_size>1048576</provisioned_size><format>cow</format></disk>
				#Add host to FloatingDiskImage Specs
				IF($HostObject){ $oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $([PSCustomObject]@{'id'=$HostObject.Id}) }
			}ElseIF($PSBoundParameters['DiskType'] -eq "LUN"){
				#This section I have no way to test yet, so the code here is a swag
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_type' -Value 'lun'
				$oDiskLunSpecs = [PSCustomObject]@{}
				$oDiskLunLUSpecs = [PSCustomObject]@{}
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage
				$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $([PSCustomObject]@{'id'=$HostObject.Id})
				$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'logical_units' -Value $([PSCustomObject]@{'logical_unit'= $([PSCustomObject]@{'id'=$oStorageDomainObject.Id})})
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage
				IF($PSBoundParameters.ContainsKey('LUN_Comment')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['LUN_Comment']) }
				IF($PSBoundParameters.ContainsKey('LUN_Description')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['LUN_Description']) }
				IF($PSBoundParameters.ContainsKey('LUN_Driver_options')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'driver_options' -Value $($PSBoundParameters['LUN_Driver_options']) }
				IF($PSBoundParameters.ContainsKey('LUN_Driver_sensitive_options')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'driver_sensitive_options' -Value $($PSBoundParameters['LUN_Driver_sensitive_options']) }
				IF($PSBoundParameters.ContainsKey('LUN_Id')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'id' -Value $($PSBoundParameters['LUN_Id']) }
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/logical_unit
					IF($PSBoundParameters.ContainsKey('LUN_LU_Address')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['LUN_LU_Address']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_discard_max_size')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'discard_max_size' -Value $($PSBoundParameters['LUN_LU_discard_max_size']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_discard_zeroes_data')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'discard_zeroes_data' -Value $($PSBoundParameters['LUN_LU_discard_zeroes_data']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_disk_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'disk_id' -Value $($PSBoundParameters['LUN_LU_disk_id']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'id' -Value $($PSBoundParameters['LUN_LU_id']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_lun_mapping')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'lun_mapping' -Value $($PSBoundParameters['LUN_LU_lun_mapping']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_password')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'password' -Value $($PSBoundParameters['LUN_LU_password']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_paths')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'paths' -Value $($PSBoundParameters['LUN_LU_paths']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_Port')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'port' -Value $($PSBoundParameters['LUN_LU_Port']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_Portal')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'portal' -Value $($PSBoundParameters['LUN_LU_Portal']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_product_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'product_id' -Value $($PSBoundParameters['LUN_LU_product_id']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_serial')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'serial' -Value $($PSBoundParameters['LUN_LU_serial']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_size')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'size' -Value $($PSBoundParameters['LUN_LU_size']) }
					#Read-Only?
					IF($PSBoundParameters.ContainsKey('LUN_LU_status')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'status' -Value $($PSBoundParameters['LUN_LU_status']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_storage_domain_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domain_id' -Value $($PSBoundParameters['LUN_LU_storage_domain_id']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_Target')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'target' -Value $($PSBoundParameters['LUN_LU_Target']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_username')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'username' -Value $($PSBoundParameters['LUN_LU_username']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_vendor_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'vendor_id' -Value $($PSBoundParameters['LUN_LU_vendor_id']) }
					IF($PSBoundParameters.ContainsKey('LUN_LU_volume_group_id')){ $oDiskLunLUSpecs | Add-Member -MemberType NoteProperty -Name 'volume_group_id' -Value $($PSBoundParameters['LUN_LU_volume_group_id']) }
	
				IF($PSBoundParameters.ContainsKey('LUN_mount_options')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'mount_options' -Value $($PSBoundParameters['LUN_mount_options']) }
				IF($PSBoundParameters.ContainsKey('LUN_name')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'name' -Value $($PSBoundParameters['LUN_name']) }
				IF($PSBoundParameters.ContainsKey('LUN_nfs_retrans')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'nfs_retrans' -Value $($PSBoundParameters['LUN_nfs_retrans']) }
				IF($PSBoundParameters.ContainsKey('LUN_nfs_timeo')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'nfs_timeo' -Value $($PSBoundParameters['LUN_nfs_timeo']) }
				IF($PSBoundParameters.ContainsKey('LUN_nfs_version')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'nfs_version' -Value $($PSBoundParameters['LUN_nfs_version']) }
				IF($PSBoundParameters.ContainsKey('LUN_override_luns')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'override_luns' -Value $($PSBoundParameters['LUN_override_luns']) }
				IF($PSBoundParameters.ContainsKey('LUN_password')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'password' -Value $($PSBoundParameters['LUN_password']) }
				IF($PSBoundParameters.ContainsKey('LUN_path')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'path' -Value $($PSBoundParameters['LUN_path']) }
				IF($PSBoundParameters.ContainsKey('LUN_port')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'port' -Value $($PSBoundParameters['LUN_port']) }
				IF($PSBoundParameters.ContainsKey('LUN_portal')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'portal' -Value $($PSBoundParameters['LUN_portal']) }
				IF($PSBoundParameters.ContainsKey('LUN_target')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'target' -Value $($PSBoundParameters['LUN_target']) }
				IF($PSBoundParameters.ContainsKey('LUN_Type')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'type' -Value $($PSBoundParameters['LUN_Type']) }
				IF($PSBoundParameters.ContainsKey('LUN_username')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'username' -Value $($PSBoundParameters['LUN_username']) }
				IF($PSBoundParameters.ContainsKey('LUN_vfs_type')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'vfs_type' -Value $($PSBoundParameters['LUN_vfs_type']) }
				IF($PSBoundParameters.ContainsKey('LUN_volume_group')){ $oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'volume_group' -Value $($PSBoundParameters['LUN_volume_group']) }

				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/host_storage
				#Add host to FloatingDirectLUN Specs
				IF($HostObject){$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'host' -Value $([PSCustomObject]@{'id'=$HostObject.Id}) }
				$oDiskLunSpecs | Add-Member -MemberType NoteProperty -Name 'logical_units' -Value $([PSCustomObject]@{'logical_unit'=@($oDiskLunLUSpecs)})
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'lun_storage' -Value $oDiskLunSpecs
				
			}ElseIF($PSBoundParameters['DiskType'] -eq "ManagedBlock"){
				#This section I have no way to test yet, so the code here is a swag
				#<disk id="b7a4c6c5-443b-47c5-967f-6abc79675e8b"><image_id>b548366b-fb51-4b41-97be-733c887fe305</image_id><storage_domains><storage_domain id="123"/></storage_domains><name>mydisk</name><provisioned_size>1048576</provisioned_size><format>cow</format></disk>
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/storage_type
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_type' -Value 'managed_block_storage'
				$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'storage_domains' -Value $([PSCustomObject]@{'storage_domain'= @([PSCustomObject]@{'id'=$oStorageDomainObject.Id})})
				IF($PSBoundParameters.ContainsKey('oDiskId')){$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'id' -Value $($PSBoundParameters['oDiskId'])}
				IF($PSBoundParameters.ContainsKey('ImageId')){$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'image_id' -Value $($PSBoundParameters['ImageId'])}
				#Note that block storage domains (i.e., storage domains with the storage type of iSCSI or FCP) don’t support the combination of the raw format with sparse=true, so sparse=false must be stated explicitly.
				IF((($oDiskSpecs.storage_type -eq "iSCSI") -or ($oDiskSpecs.storage_type -eq "FCP")) -OR (($PSBoundParameters['LUN_Type'] -eq "iSCSI") -OR ($PSBoundParameters['LUN_Type'] -eq "FCP"))){
					IF($oDiskSpecs.format -eq "raw"){
						IF($oDiskSpecs.sparse){
							$oDiskSpecs.sparse = $False
						}Else{
							$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'sparse' -Value $False
						}
					}
				}
			}
		}
		IF($PSBoundParameters.ContainsKey('ImageId')){$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'image_id' -Value $($PSBoundParameters['ImageId'])}
		IF($PSBoundParameters.ContainsKey('interface')){$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'interface' -Value $($PSBoundParameters['interface'])}
		IF($PSBoundParameters.ContainsKey('sgio')){$oDiskSpecs | Add-Member -MemberType NoteProperty -Name 'sgio' -Value $($PSBoundParameters['sgio'])}
		
		#Send to Server
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		#$Headers = @{"Accept" = "application/xml";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Uri = $BaseURL + "/ovirt-engine/api/disks"
		$Method = "POST"
		$JsonBody = $oDiskSpecs | ConvertTo-Json -Depth 50
		Write-Verbose "$($MyInvocation.MyCommand): Submitting Json to Create oDisk"
		Write-Verbose "$($JsonBody | Out-String)"
		$NewoDisk = $Null
		#TRY{$NewoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{WRITE-WARNING "$($WebError[0].Exception.Message)"; $OutPutItems.Add((Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri)) | Out-Null}
		TRY{$NewoDisk = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); $OutPutItems.Add($FormattedWebError) | Out-Null; Write-Error $FormattedWebError}
		IF($NewoDisk){
			Write-Verbose "$($MyInvocation.MyCommand): Created oDisk"
			$OutPutItems.Add((Convert-RestResponseTooVirtObject -InputObject $NewoDisk -ObjectType "oDisk" -oVirtServerName $oVirtServerName)) | Out-Null
			Update-oVirtServer_LastUsedTime -oVirtServerName $oVirtServerName
		}Else{
			Write-Verbose "$($MyInvocation.MyCommand): Error [$($WebError | Out-String)]"
		}
	}
	End{IF($OutPutItems.Count -gt 1){$OutPutItems}ElseIF($OutPutItems.Count -eq 1){$OutPutItems[0]}}
}

Function Copy-oDisk{
	<#
		.SYNOPSIS
			This function copies an oDisk, on an oVirt Server system to a new storage domain.
		.DESCRIPTION
			This function copies an oDisk, on an oVirt Server system to a new storage domain.
			Returns the job response from the oVirt Server.
		.PARAMETER Name
			The Name(s) of the oDisk(s)
			Can use Wildcard '*'
		.PARAMETER Id
			The Id(s) of the oDisk(s)
		.PARAMETER Uid
			The Uid of the oDisk(s)
		.PARAMETER NewName
			The New Name of the oDisk
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oDiskProfile
			The Name or oDiskProfile object to assign the oDisk if the oDisk storage_type is "image"
			Disk profile for the disk in the new storage domain.
			Disk profiles are defined for storage domains, so the old disk profile will not exist in the new storage domain.
			If this parameter is not used, the first disk profile from the new storage domain to which the user has permissions will be assigned to the disk.
		.PARAMETER oDiskProfileId
			Sets the disk profile Id to assign the oDisk if the oDisk storage_type is "image"
			Disk profile for the disk in the new storage domain.
			Disk profiles are defined for storage domains, so the old disk profile will not exist in the new storage domain.
			If this parameter is not used, the first disk profile from the new storage domain to which the user has permissions will be assigned to the disk.
		.PARAMETER oQuota
			The Name or oQuota object to assign the oDisk
			Quota for the disk in the new storage domain.
			This optional parameter can be used to specify new quota for the disk, because the current quota may not be defined for the new storage domain.
			If this parameter is not used and the old quota is not defined for the new storage domain, the default (unlimited) quota will be assigned to the disk.
		.PARAMETER oQuotaId
			Sets the Quota if the oDisk storage_type is "image"
			Quota for the disk in the new storage domain.
			This optional parameter can be used to specify new quota for the disk, because the current quota may not be defined for the new storage domain.
			If this parameter is not used and the old quota is not defined for the new storage domain, the default (unlimited) quota will be assigned to the disk.
		.PARAMETER oStorageDomain
			The Name or oStorageDomain object to place the oDisk
		.PARAMETER oStorageDomainId
			The Id of the oStorageDomain to place the oDisk
		.PARAMETER oStorageDomainUid
			The Uid of the oStorageDomain to place the oDisk
		.PARAMETER RunAsync
			Execute a task asynchronously (without waiting for completion), and return a task instead of the regular output
		.EXAMPLE
			PS> Copy-oDisk -oVirtServerName $oVirtServerName -Name "MyoDisk" -oDiskProfile "oDiskProfileName" -oQuota "oQuotaName" -oStorageDomain "oStorageDomainName"
				Copies an oDisk
		.INPUTS
			[System.String]
			[oDiskProfile]
			[oQuota]
			[oStorageDomain]
			[oDisk]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oDisk]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		5/23/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disks
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/copy
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/disk/methods/move
			Get-oDisk
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDisk|String'})]$Name,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set02")]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$Id,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[System.String]$NewName,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oDiskProfile|String'})]$oDiskProfile,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidatePattern('^[0-9a-zA-Z]{8}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{4}-[0-9a-zA-Z]{12}$')]
			[System.String]$oDiskProfileId,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[BOOLEAN]$Filter,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[ValidateScript({($_).GetType().Name -match 'oQuota|String'})]$oQuota,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
