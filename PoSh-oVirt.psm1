					$oDiskObject = $PSBoundParameters['Name']
				}
				{$_.GetType().Name -eq "oDisk"}{
					Write-Verbose "$($MyInvocation.MyCommand) Name GetType equals [oDisk]"
					$oDiskObject = $PSBoundParameters['Name']
				}
				DEFAULT{
