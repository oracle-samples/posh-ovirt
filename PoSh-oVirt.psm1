			$PSBoundParameters['RandomGeneratorEnabled'] = $true #Enable the paravirtualized random number generator PCI (virtio-rng)  		#$oVM.rng_device.source
			#$PSBoundParameters['xxxxx'] = $true #Migrate only to hosts with the same TSC frequency.
			$PSBoundParameters['UsbEnabled'] = $false #Disable all USB devices.						#$oVM.usb.enabled
