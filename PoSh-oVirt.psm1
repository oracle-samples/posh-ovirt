			IF($PSBoundParameters.ContainsKey('scsi_hostdev')){$VMSpecsCustomPropertyArray += @{"name"="scsi_hostdev"; "value"=$PSBoundParameters['scsi_hostdev']}}
			Add-Member -NotePropertyName "custom_property" -NotePropertyValue $VMSpecsCustomPropertyArray -inputObject $VMSpecsCustomProperties
		}
		
		IF($oTemplate -or $oTemplateId){
			IF($oTemplateId){
				#Docs say you can provide a name or id, but passing Ids has proven problematic via JSON, so for now, I'll retreive the Name from the ID
				#$VMSpecstemplate = [PSCustomObject]@{id = $oTemplateId}
				$oTemplateObject = (Get-oUri -RESTUri "/ovirt-engine/api/templates/$($oTemplateId)" -oVirtServerName $oVirtServerName) #Faster, no need to create class objects
				$VMSpecstemplate = [PSCustomObject]@{name = (($oTemplateObject).Name)}
			}ElseIF($oTemplate){
				IF($oTemplate -Is [oTemplate]){
					$VMSpecstemplate = [PSCustomObject]@{name = $oTemplate.Name}
				}Else{
					$VMSpecstemplate = [PSCustomObject]@{name = $oTemplate}
				}
			}
		}Else{
			$VMSpecstemplate = [PSCustomObject]@{name = "Blank"}
		}
		
		#NOTE: Cluster Mandatory for a new VM container, But NOT a disk
		IF($oCluster){
