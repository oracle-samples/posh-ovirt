Function Resolve-oVirtConnection{
	<#
		.DESCRIPTION
			Helper Function
			Handle oVirtServer / oVirtConnection to replace the requirement for oVirtToken & oVirtServerName 
			in the Input Parameters
	#>
	[CmdletBinding(DefaultParameterSetName = 'Set01')]
	Param(
		#oVirtServerName
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True,  HelpMessage="oVirtServerName (Name or IP)")]
			[Alias('oVirtServer')]
			[System.String[]]$oVirtServerName
	)
	Begin{Write-Verbose "$($MyInvocation.MyCommand): Running"; [System.Net.ServicePointManager]::ServerCertificateValidationCallback = $Null}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) : PSBoundParameters: [$($PSBoundParameters | Out-String)]"
		IF($PSBoundParameters['oVirtServerName']){
			$oVirtServerNames = $PSBoundParameters['oVirtServerName']
			$oVirtConnectionsToProcess = @()
			ForEach($oVirtServerName in $oVirtServerNames){
				Write-Verbose "$($MyInvocation.MyCommand) : oVirtServerName: [$($oVirtServerName)]"
				$ExistingConnection = $Null
				#$ExistingConnection = $global:oVirtConnections | ?{$_.Name -eq $oVirtServerName}
				#Testing Replacing the Global scoped variable with a Module scope (Script)
				$ExistingConnection = $oVirtConnections | ?{$_.Name -eq $oVirtServerName}
				Write-Verbose "$($MyInvocation.MyCommand) : ExistingConnection: [$($ExistingConnection)]"
				IF($ExistingConnection){
					$oVirtConnectionsToProcess += $ExistingConnection
				}Else{
					Connect-oVirtServer -oVirtServerName $oVirtServerName -RenewConnection -NoOutPutObject -ErrorAction SilentlyContinue
					#$ExistingConnection = $global:oVirtConnections | ?{$_.Name -eq $oVirtServerName}
					#Testing Replacing the Global scoped variable with a Module scope (Script)
					$ExistingConnection = $oVirtConnections | ?{$_.Name -eq $oVirtServerName}
					IF($ExistingConnection){
						$oVirtConnectionsToProcess += $ExistingConnection
					}
				}
			}
		}Else{
			#ReTrieve all IsConnected oVirtConnections in $global:oVirtConnections
			#$oVirtConnectionsToProcess = $global:oVirtConnections
			#Testing Replacing the Global scoped variable with a Module scope (Script)
			$oVirtConnectionsToProcess = $oVirtConnections
			Write-Verbose "$($MyInvocation.MyCommand) : ExistingConnections: [$($oVirtConnectionsToProcess.Name)]"
		}
		$oVirtConnectionsToProcess_tmp = $Null
		#$oVirtConnectionsToProcess_tmp = $global:oVirtConnections | ?{$oVirtConnectionsToProcess.Name -Contains $_.Name}
		#Testing Replacing the Global scoped variable with a Module scope (Script)
		$oVirtConnectionsToProcess_tmp = $oVirtConnections | ?{$oVirtConnectionsToProcess.Name -Contains $_.Name}
		
		ForEach($oConn in $oVirtConnectionsToProcess_tmp){
			Write-Verbose "$($MyInvocation.MyCommand) : oConn.oVirtServerName: [$($oConn.oVirtServerName)]"
			Connect-oVirtServer -oVirtServerName $oConn.oVirtServerName -RenewConnection -NoOutPutObject -ErrorAction SilentlyContinue
		}
		#$oVirtConnectionsToProcess = $global:oVirtConnections | ?{$oVirtConnectionsToProcess_tmp.Name -Contains $_.Name}
		#Testing Replacing the Global scoped variable with a Module scope (Script)
		$oVirtConnectionsToProcess = $oVirtConnections | ?{$oVirtConnectionsToProcess_tmp.Name -Contains $_.Name}
		$oVirtConnectionsToProcess_tmp = $Null
	}
	End{Write-Verbose "$($MyInvocation.MyCommand) : oVirtConnectionsToProcess: [$($oVirtConnectionsToProcess | Out-String)]"; Write-Verbose "$($MyInvocation.MyCommand): End"; Return $oVirtConnectionsToProcess}
}

Function Revoke-oVirtConnection{
	<#
		.SYNOPSIS
			Expires an oVirtConnection stored in $global:oVirtConnections
		.DESCRIPTION
			Expires an oVirtConnection stored in $global:oVirtConnections
			Changes the ConnectionTime, LastUsedTime, & TokenConnectionExpires to 60 minutes ago and IsConnected to False
			Since Tokens last 30 minutes by default, this will cause them to become invalid and require a refresh
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.PARAMETER oVirtCredential
			The PSCredential to be used to connect to the -oVirtServerName, if not already connected
		.EXAMPLE
			PS> Revoke-oVirtConnection -oVirtServerName $oVirtServerName 
		.INPUTS
			[System.String]
		.OUTPUTS
			[PSCustomObject]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		2/29/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			Get-Help
	#>
	[CmdletBinding()]
	[ALIAS('ROC')]
	Param($oVirtServerName)
	Begin{
		Write-Verbose "$($MyInvocation.MyCommand): Running"
		#IF((Get-WmiObject -Class Win32_PingStatus -Filter "(Address=`'$($oVirtServerName)`') AND (timeout=1000) AND (ResolveAddressNames=TRUE)" -EA Stop).StatusCode -ne [INT]'0'){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
		#IF(!(Test-NetConnection -ComputerName $oVirtServerName -InformationLevel Quiet)){Throw [System.Management.Automation.ItemNotFoundException]"$($oVirtServerName) Does Not Ping"}
	}
	Process{
		IF($PSBoundParameters['oVirtServerName']){
			$oVirtServerNames = $PSBoundParameters['oVirtServerName']
			$oVirtConnectionsToProcess = @()
			ForEach($oVirtServerName in $oVirtServerNames){
				$ExistingConnection = $Null
				$ExistingConnection = $global:oVirtConnections | ?{$_.Name -eq $oVirtServerName}
				IF($ExistingConnection){
					#$oVirtCredential = $ExistingConnection.oVirtCredential
					$oVirtConnectionsToProcess += $ExistingConnection
				}
			}
		}Else{
			$oVirtConnectionsToProcess = $global:oVirtConnections
		}
		#Loop Through $oVirtConnectionsToProcess in the Process section
		IF($oVirtConnectionsToProcess){
			ForEach($oVirtConnection in $oVirtConnectionsToProcess){
				$oVirtServerName = $oVirtConnection.oVirtServerName
				#($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ConnectionTime = (Get-Date ($oVirtConnections | ?{$_.Name -eq $oVirtServerName}).ConnectionTime).AddMinutes(-60)
				$ConnectionTime = (Get-Date ($oVirtConnection).ConnectionTime).AddMinutes(-60)
				$TokenConnectionExpires = ($ConnectionTime).AddMinutes(60)
				($oVirtConnection).ConnectionTime = $ConnectionTime
				($oVirtConnection).LastUsedTime = (Get-Date).AddMinutes(-60)
				($oVirtConnection).TokenConnectionExpires = $TokenConnectionExpires
				($oVirtConnection).IsConnected = $False
				$oVirtConnection | Select Name, ConnectionTime, TokenConnectionExpires, InstanceId
			}
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

Function Get-oFilePath{
	<#
		.SYNOPSIS
			Opens Windows File Browser and Returns Selected file name path(s)
		.DESCRIPTION
			Opens Windows File Browser and Returns Selected file name path(s)
		.PARAMETER SpecialFolder
			Intial 'Special' Folder to open.
			Valid choices are: "Desktop", "Programs", "MyDocuments", "Personal", "Favorites", "Startup", "Recent", "SendTo", "StartMenu", "MyMusic", "MyVideos", "DesktopDirectory", "MyComputer", "NetworkShortcuts", "Fonts", "Templates", "CommonStartMenu", "CommonPrograms", "CommonStartup", "CommonDesktopDirectory", "ApplicationData", "PrinterShortcuts", "LocalApplicationData", "InternetCache", "Cookies", "History", "CommonApplicationData", "Windows", "System", "ProgramFiles", "MyPictures", "UserProfile", "SystemX86", "ProgramFilesX86", "CommonProgramFiles", "CommonProgramFilesX86", "CommonTemplates", "CommonDocuments", "CommonAdminTools", "AdminTools", "CommonMusic", "CommonPictures", "CommonVideos", "Resources", "LocalizedResources", "CommonOemLinks", "CDBurning"
			Default is "MyDocuments"
			Can NOT be Used with "Path"
		.PARAMETER Path
			Initial Path of Dialog Box
			Can NOT be Used with "SpecialFolder"
		.PARAMETER Title
			Title of Dialog Box
		.PARAMETER MultiSelect
			Switch to Enable Selecting Multiple Files
		.PARAMETER Filter
			File Name type filter
				The filter string must contain a description of the filter, followed by the vertical bar (|) 
				and the filter pattern. The strings for different filtering options must also be separated 
				by the vertical bar.
				Examples:
				'Text files (*.txt)|*.txt|All files (*.*)|*.*'
				'Image files (*.jpg, *.jpeg, *.jpe, *.jfif, *.png) | *.jpg; *.jpeg; *.jpe; *.jfif; *.png'
				'Documents (*.docx)|*.docx|SpreadSheet (*.xlsx)|*.xlsx'
				'SpreadSheet (*.csv, *.xlsx)|*.csv; *.xlsx'
		.EXAMPLE
			Get-oFilePath -SpecialFolder "Desktop" -MultiSelect -Title "Pick a file, any file or two" -Filter 'Text files (*.txt)|*.txt|All files (*.*)|*.*'
		.NOTES
			
		.LINK
			#No online help available, see David A. Stewart, david.a.stewart@cerner.com
			#To see the information on Function Options, type: "get-help about_Comment_Based_Help".
		.NOTES
			See David A. Stewart <david.a.stewart@cerner.com>.
				Version 3.0	1/13/2022
			
			The System.Windows.Forms.OpenFileDialog can hang invisibly in the background when called under MTA rather than STA .Net ApartmentState
			Three Methods should be conisdered based on use case to mitigate this situation
			1. Set the Property ShowHelp = $True
			2. Verify the Aprtment is set to STA prior to execution
				[threading.thread]::CurrentThread.GetApartmentState() -eq "STA"
				Powershell can be started explicitly in Stack
					I.e. powershell.exe -sta $MyInvocation.ScriptName
			3. Execute this Function in a named ApartmentState
				I.e. Invoke-Apartment -Apartment STA -Expression {Get-oFilePath}
	#>
	[CmdletBinding(DefaultParametersetName="PS1")]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True,ParameterSetName="PS1")]
			#[ValidateSet("Desktop", "Programs", "MyDocuments", "Personal", "Favorites", "Startup", "Recent", "SendTo", "StartMenu", "MyMusic", "MyVideos", "DesktopDirectory", "MyComputer", "NetworkShortcuts", "Fonts", "Templates", "CommonStartMenu", "CommonPrograms", "CommonStartup", "CommonDesktopDirectory", "ApplicationData", "PrinterShortcuts", "LocalApplicationData", "InternetCache", "Cookies", "History", "CommonApplicationData", "Windows", "System", "ProgramFiles", "MyPictures", "UserProfile", "SystemX86", "ProgramFilesX86", "CommonProgramFiles", "CommonProgramFilesX86", "CommonTemplates", "CommonDocuments", "CommonAdminTools", "AdminTools", "CommonMusic", "CommonPictures", "CommonVideos", "Resources", "LocalizedResources", "CommonOemLinks", "CDBurning")]
			[ArgumentCompleter({(([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name)})]
			[ValidateScript({($(([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name)) -Contains $_})]
			[String]$SpecialFolder,
		[Parameter(Mandatory = $False, ValueFromPipelineByPropertyName=$True)][String]$Title,
		[Parameter(Mandatory=$False, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True,ParameterSetName="PS2")][ValidateScript({Test-Path -Path $_ -PathType Container})][String]$Path,
		[Parameter(Mandatory=$False, ValueFromPipelineByPropertyName=$True)][String]$Filter = 'All files (*.*)|*.*',
		[Parameter(Mandatory = $False, ValueFromPipelineByPropertyName=$True)][Switch]$MultiSelect
		
	)
	#This will List all Special Folders Available
	$SpecialFolders = ([System.Environment+SpecialFolder]).GetMembers().Where({$_.MemberType -ne "Method"}).Where({$_.IsStatic}).Where({$_.FieldHandle -eq $null}).Name
	IF($PSBoundParameters['SpecialFolder']){$InitialDirectory = $PSBoundParameters['SpecialFolder']}
	ElseIF($PSBoundParameters['Path']){$InitialDirectory = $PSBoundParameters['Path']}Else{$InitialDirectory = 'MyDocuments'}
	IF($InitialDirectory -NotMatch "\\"){$InitialDirectory = [Environment]::GetFolderPath($($InitialDirectory))}
	Add-Type -AssemblyName System.Windows.Forms
	$FileBrowser = New-Object System.Windows.Forms.OpenFileDialog -Property @{ InitialDirectory = $($InitialDirectory) ; ShowHelp = $True ; SupportMultiDottedExtensions = $True ; DefaultExt = '*' ; ValidateNames = $True}
	IF($FileBrowser){
		IF($PSBoundParameters['Title']){$FileBrowser.set_Title($Title)}Else{$FileBrowser.set_Title('Select Files(s)')}
		IF($MultiSelect.IsPresent){$FileBrowser.set_Multiselect($True)}
		IF($PSBoundParameters['Filter']){$FileBrowser.set_Filter($PSBoundParameters['Filter'])}Else{$FileBrowser.set_Filter('All files (*.*)|*.*')}
		$NULL = $FileBrowser.ShowDialog()
		IF($MultiSelect.IsPresent){$FileBrowser.FileNames}Else{$FileBrowser.FileName}
		#Use These for Debugging
		#($PSBoundParameters)
		#($FileBrowser | Select *)
	}
}

