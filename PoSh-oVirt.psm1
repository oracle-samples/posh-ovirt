			Get-oDiskSnapshot
			Get-Help		
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High',DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$True, ValueFromPipeline=$True, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set01", Position=0)]
			[ValidateScript({($_).GetType().Name -match 'oDiskSnapshot'})]$oDiskSnapshot,
		[Parameter(Mandatory=$True, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True, ParameterSetName="Set03")]
			[ValidateScript({IF(([Uri]$_).AbsoluteUri -eq $Null){Throw [System.Management.Automation.ValidationMetadataException] "The input Uid: `'${_}`' is not a valid Uid"}Else{$True}})]
			[System.String]$Uid,
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$True)]
			[SWITCH]$RunAsync
	)
	Begin{
		#DELETE /disks/{disk:id}/disksnapshots/{snapshot:id}
		Write-Verbose "$($MyInvocation.MyCommand): Running"
	}
	Process{
		Write-Verbose "$($MyInvocation.MyCommand) Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		Write-Verbose "Parameter Set: [$($PSCmdlet.ParameterSetName)]"
		#Write-Verbose "$($MyInvocation.MyCommand) Is [oDiskSnapshot]: [$($PSBoundParameters['oDiskSnapshot'] -IS [oDiskSnapshot])]"
		$oDiskSnapshotObject = $Null
		IF($PSCmdlet.ParameterSetName -eq "Set01"){
			IF($PSBoundParameters['oDiskSnapshot']){
				$oDiskSnapshotObject = $PSBoundParameters['oDiskSnapshot']
				#$oUri = $oDiskSnapshotObject.Uid
				$oUri = $($PSBoundParameters['oDiskSnapshot']).Uid
			}
		}ElseIF($PSCmdlet.ParameterSetName -eq "Set03"){
			IF($PSBoundParameters['Uid']){
				#$UidUrl = [Uri]$Uid
				#$oDiskSnapshotObject = Get-oDiskSnapshot -Id ($UidUrl.Segments[($UidUrl.Segments.count -1)]) -oVirtServerName ($UidUrl.Host) -EA SilentlyContinue
				$oUri = $($PSBoundParameters['Uid'])
			}
		}
		
		#Write-Verbose "$($MyInvocation.MyCommand): `$oDiskSnapshotObject [$($oDiskSnapshotObject.Name)]"
		$UidUrl = [Uri]$oUri
		$oVirtServerName = $UidUrl.Host
		$ActionParameters = [PSCustomObject]@{'async' = $(IF($RunAsync.IsPresent -eq $True){$True}Else{$False})}
		$Actions = [PSCustomObject]@{'action' = $ActionParameters}
		$JsonBody = $Actions | ConvertTo-Json
		Resolve-oVirtConnection -oVirtServerName $oVirtServerName | Out-Null
		$Token = $(($oVirtConnections |?{$_.Name -eq $oVirtServerName}).ExtensionData.access_token)
		$Headers = @{"Accept" = "application/json";"Authorization" = "Bearer $($Token)"; "All-Content"="true"}
		$Method = "DELETE"
		IF($PSBoundParameters['oDiskSnapshot']){
			IF($oDiskSnapshotObject.Description){
				$oDiskSnapshotObjectText = $oDiskSnapshotObject.Description
			}Else{
				$oDiskSnapshotObjectText = $oDiskSnapshotObject.Id
			}
			
		}ElseIF($PSBoundParameters['Uid']){
			#$oDiskSnapshotObjectText = (Get-oUri -Uri $oDiskSnapshot.Uid).Description
			$oDiskSnapshotObject = (Get-oUri -Uri $($PSBoundParameters['Uid']))
			IF($oDiskSnapshotObject){
				IF($oDiskSnapshotObject.Description){
					$oDiskSnapshotObjectText = $oDiskSnapshotObject.Description
				}Else{
					$oDiskSnapshotObjectText = $oDiskSnapshotObject.Id
				}
			}Else{Write-Warning "Unable to retrieve Snapshot Uri [$($PSBoundParameters['Uid'])]"}
		}
		IF($PSCmdlet.ShouldProcess($oDiskSnapshotObjectText, "Permanently Delete oDiskSnapshot")){
			Try{$DeleteResponse = Invoke-RestMethod -Uri $oUri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
			$DeleteResponse
		}
	}
	End{Write-Verbose "$($MyInvocation.MyCommand): End"}
}

