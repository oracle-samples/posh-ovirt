				$oNetworkAttachmentObjects = Get-oUri -Uri $($PSBoundParameters['oNetworkAttachmentUid']) -EA SilentlyContinue | ?{$_} | %{Convert-RestResponseTooVirtObject -InputObject $_ -ObjectType "oNetworkAttachment" -oVirtServerName $oVirtServerName}
			}
		}
		
		IF(!($oNetworkAttachmentObjects)){Write-Warning "$($MyInvocation.MyCommand): oNetworkAttachment Not Found, quitting..."; BREAK}
		$OutPutItems = [System.Collections.ArrayList]@()
		ForEach($oNetworkAttachmentObject in $oNetworkAttachmentObjects){
			Write-Verbose "$($MyInvocation.MyCommand): `$oNetworkAttachmentObject [$($oNetworkAttachmentObject | Out-String)]"
			$oVirtServerName = $oNetworkAttachmentObject.oVirtServer
			$BaseURL = "https://$($oVirtServerName)"
			IF($PSBoundParameters.ContainsKey('NewName')){
				$oNetworkAttachmentSpecs = [PSCustomObject]@{name = $($PSBoundParameters['NewName'])}
			}Else{
				$oNetworkAttachmentSpecs = [PSCustomObject]@{}
			}
			
			IF($PSBoundParameters.ContainsKey('Comment')){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'comment' -Value $($PSBoundParameters['Comment']) }
			IF($PSBoundParameters.ContainsKey('Description')){ $oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'description' -Value $($PSBoundParameters['Description']) }
			
			$ip_address_assignmentSpecs = [PSCustomObject]@{}
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/boot_protocol
			IF($PSBoundParameters.ContainsKey('AssignmentMethod')){	$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'assignment_method' -Value $($PSBoundParameters['AssignmentMethod']) }
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip
			IF(($PSBoundParameters.ContainsKey('IPAddress')) -OR ($PSBoundParameters.ContainsKey('Gateway')) -OR ($PSBoundParameters.ContainsKey('Netmask')) -OR ($PSBoundParameters.ContainsKey('IPVersion'))){
				$IPSpecs = [PSCustomObject]@{}
				IF($PSBoundParameters.ContainsKey('IPAddress')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'address' -Value $($PSBoundParameters['IPAddress']) }
				IF($PSBoundParameters.ContainsKey('Gateway')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'gateway' -Value $($PSBoundParameters['Gateway']) }
				IF($PSBoundParameters.ContainsKey('Netmask')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'netmask' -Value $($PSBoundParameters['Netmask']) }
				IF($PSBoundParameters.ContainsKey('IPVersion')){ $IPSpecs | Add-Member -MemberType NoteProperty -Name 'version' -Value $($PSBoundParameters['IPVersion']) }
				$ip_address_assignmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip' -Value $IPSpecs
			}
			
			IF($ip_address_assignmentSpecs.ip){
				$ip_address_assignment_Array = [System.Collections.ArrayList]@()
				$ip_address_assignment_Array.Add($ip_address_assignmentSpecs) | Out-Null
				#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/ip_address_assignment
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = $ip_address_assignmentSpecs})
				$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'ip_address_assignments' -Value $([PSCustomObject]@{ip_address_assignment = $ip_address_assignment_Array})
			}
			
			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/dns_resolver_configuration
			IF($PSBoundParameters.ContainsKey('DNSServers')){
				$name_serversSpecs = [PSCustomObject]@{}
				$name_serverArray = [System.Collections.ArrayList]@()
				ForEach($Item in $($PSBoundParameters['DNSServers'])){ $name_serverArray.Add( $(@{"name_server"=$Item}) ) | Out-Null }
				$name_serversSpecs | Add-Member -MemberType NoteProperty -Name 'name_servers' -Value $name_serverArray
				#$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $($PSBoundParameters['DNSServers'])
				$oNetworkAttachmentSpecs | Add-Member -MemberType NoteProperty -Name 'dns_resolver_configuration' -Value $name_serversSpecs
			}

			#https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
			IF($PSBoundParameters.ContainsKey('Properties')){
