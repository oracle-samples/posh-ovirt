					#region SetVMCD

					#Attach CDROM/ISO It seems a blank CD device is created with the VM you just have to load it with an ISO
					#Currently virtual machines have exactly one CDROM device. No new devices can be added, and the existing one can’t be removed, thus there are no add or remove methods.
					#https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/vm_cdroms
					#GET /ovirt-engine/api/vms/123/cdroms
					#To change or eject the disk by changing the value of the file attribute PERMANENT
					#PUT /ovirt-engine/api/vms/123/cdroms/00000000-0000-0000-0000-000000000000

					#To change the disk that is visible to the current running virtual machine, add the current=true
