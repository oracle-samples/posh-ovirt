		.PARAMETER Properties
			This accepts an array of hashtable (name/value pairs) based on custom settings found in 
				https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment/attributes/properties
		.PARAMETER oVirtServerName
			The Name of the target oVirt Server (Oracle Linux Virualtization Manager)(OLVM) system
		.EXAMPLE
			PS> Set-oNetworkAttachment -oVirtServerName $oVirtServerName -Name "Name" -oHost "oHostName" -oHostNicId 'oHostNicId' -oNetwork 'oNetworkName' -AssignmentMethod "dhcp"
				Creates a new oNetworkAttachment with the provided Name
		.INPUTS
			[System.String]
			[oHost]
			[oHostNic]
		.OUTPUTS
			[System.String]
			[PSCustomObject]
			[oNetworkAttachment]
		.NOTES
			See David A. Stewart <itsavant@gmail.com>.
			Version 1.0		7/25/2024
		.LINK
			See David A. Stewart <david.a.stewart@Oracle.com>.
		.LINK
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#types/network_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_attachments
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_attachment
			https://ovirt.github.io/ovirt-engine-api-model/4.5/#services/network_attachment/methods/update
			New-oNetworkAttachment
			Get-oNetworkAttachment
			Remove-oNetworkAttachment
			Get-Help
	#>
	[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High', DefaultParameterSetName = 'Set01')]
	Param(
		[Parameter(Mandatory=$False, ValueFromPipeline=$False, ValueFromPipelineByPropertyName=$False)]
