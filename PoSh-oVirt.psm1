						#Try{$NewNumaNodes = $Null; $NewNumaNodes = Invoke-RestMethod -Uri $Uri -Headers $Headers -Method $Method -Body $JsonBody -ContentType "application/json" -EV WebError}Catch{$FormattedWebError = (Format-WebError -WebError $WebError -Body $JsonBody -Uri $Uri); Write-Error $FormattedWebError; $FormattedWebError}
						
						ForEach($NumaNode in $NumaNodes){
